      <!-- Achievement lists by category -->
      <div class="ach-cat-label">Победы</div>
      <div id="ach-list-win"></div>
      <div class="ach-cat-label">Исследование</div>
      <div id="ach-list-play"></div>
      <div class="ach-cat-label">Небо</div>
      <div id="ach-list-sky"></div>
      <div class="ach-cat-label">Темы</div>
      <div id="ach-list-theme"></div>
      <div class="ach-cat-label">Ранги</div>
      <div id="ach-list-rank"></div>
    </div>
  </div>

  <!-- Home screen (shown after auth / instead of #start as main menu) -->
  <div id="home-screen" style="display:none">
    <canvas id="home-bg-canvas"></canvas>
    <button id="home-settings-icon" aria-label="Настройки">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
        <path fill-rule="evenodd" d="M12,1.5 L14.68,5.53 L19.42,4.58 L18.47,9.32 L22.5,12 L18.47,14.68 L19.42,19.42 L14.68,18.47 L12,22.5 L9.32,18.47 L4.58,19.42 L5.53,14.68 L1.5,12 L5.53,9.32 L4.58,4.58 L9.32,5.53 Z M15.5,12 A3.5,3.5 0 1,0 8.5,12 A3.5,3.5 0 1,0 15.5,12 Z"/>
      </svg>
    </button>

    <div id="home-header">
      <div id="home-player-name-row">
        <div id="home-player-name">—</div>
        <span id="home-player-arrow">›</span>
      </div>
      <div id="home-rank-row">
        <span id="home-rating-pts">score: 0 ✦</span>
      </div>
      <button id="home-sky-nav-btn">
        <span class="home-sky-icon">✦</span>
        <span class="home-sky-label">Sky</span>
      </button>
    </div>

    <div id="home-center">
      <div id="home-length-picker">
        <button class="home-len-btn" data-count="7">короткая</button>
        <button class="home-len-btn" data-count="13">обычная</button>
        <button class="home-len-btn" data-count="21">длинная</button>
      </div>
    </div>

    <div id="home-bottom">
      <button id="home-play-btn">Играть</button>
    </div>
  </div>

  <!-- Start screen -->
  <div id="start">
    <h1>СОЗВЕЗДИЕ</h1>

    <!-- Step 1: game mode -->
    <div id="game-mode-step" class="start-step">
      <p>КАК ИГРАТЬ</p>
      <div class="mode-btns">
        <button class="mode-btn" id="vsAI">Играть<span class="sub">против ИИ</span></button>
        <button class="mode-btn" id="vsHuman">С другом<span class="sub">2 игрока</span></button>
      </div>
      <button id="journey-btn">Мой путь ✦</button>
    </div>

    <!-- Step 1b: game length (AI mode only) -->
    <div id="game-length-step" class="start-step">
      <p>ВЫБЕРИ ДЛИНУ ПАРТИИ</p>
      <div class="length-btns">
        <button class="length-btn" data-count="7">Короткая<span class="sub">7 точек</span></button>
        <button class="length-btn" data-count="13">Обычная<span class="sub">13 точек</span></button>
        <button class="length-btn" data-count="21">Длинная<span class="sub">21 точка</span></button>
      </div>
    </div>

    <!-- Step 2: map -->
    <div id="map-step" class="start-step">
      <p>ВЫБЕРИТЕ КАРТУ</p>
      <div class="mode-btns">
        <button class="mode-btn" data-count="7">Ковш<span class="sub">7 точек</span></button>
        <button class="mode-btn" data-count="13">Зодиак<span class="sub">13 точек</span></button>
        <button class="mode-btn" data-count="21">Галактика<span class="sub">21 точка</span></button>
      </div>
    </div>

    <!-- Step 3: names -->
    <div id="name-step" class="start-step">
      <div class="fields">
        <input id="name1" placeholder="Ваше имя" autocomplete="off">
        <input id="name2" placeholder="Имя игрока 2" autocomplete="off">
        <button id="startBtn" disabled>Начать</button>
      </div>
    </div>

    <!-- Back to game-mode-step (shown on sub-steps) -->
    <button id="start-back-btn" style="display:none; font-size:14px; color:var(--th-text2); opacity:0.6; padding:8px 0;">← Начало</button>

    <!-- Theme selector + settings -->
    <div class="start-bottom">
      <div class="start-themes">
        <button class="theme-btn" data-theme="stargazer"   title="Stargazer"></button>
        <button class="theme-btn" data-theme="minimal"     title="Minimal"></button>
        <button class="theme-btn" data-theme="suprematist" title="Suprematist"></button>
        <button class="theme-btn" data-theme="chalk"       title="Chalk"></button>
      </div>
      <label class="hints-toggle">
        <input type="checkbox" id="hints-checkbox"> Подсказки 💡
      </label>
    </div>
  </div>

  <!-- Game -->
  <div id="game">
    <div id="top-panel">
      <div class="tp-left">
        <button id="back-to-menu-btn" title="В меню">←</button>
        <div class="player-cell" id="p1-cell">
          <span class="p-name"  id="pname1">—</span>
          <span class="p-sub"   id="p1level" style="display:none"></span>
          <span id="p1-rank-stars" style="display:none"></span>
          <span class="p-score" id="score1">0</span>
        </div>
      </div>
      <div id="turn-display">Ход: —</div>
      <div class="tp-right">
        <div class="player-cell" id="p2-cell">
        <span class="p-name"  id="pname2">—</span>
        <span class="p-sub"   id="p2level"></span>
        <span id="ai-level-stars"></span>
        <span class="p-score" id="score2">0</span>
        </div>
        <button id="hints-btn" title="Подсказки">💡</button>
      </div>
      <div id="prob-bar-wrap"><div id="prob-bar-fill"></div></div>
    </div>
    <div id="canvas-area">
      <button id="ui-toggle-btn" title="Панели">···</button>
      <div id="canvas-fade-overlay"></div>
      <div id="win-flash"></div>
      <canvas id="particle-canvas"></canvas>
      <div id="duel-wrap">
        <div class="duel-panel" id="duel-left">
          <canvas id="c-duel-left"  width="900" height="700"></canvas>
          <div class="duel-label">
            <div class="duel-name" id="duel-name-left"></div>
            <div class="duel-sub"  id="duel-sub-left"></div>
          </div>
        </div>
        <div class="duel-panel" id="duel-right">
          <canvas id="c-duel-right" width="900" height="700"></canvas>
          <div class="duel-label">
            <div class="duel-name" id="duel-name-right"></div>
            <div class="duel-sub"  id="duel-sub-right"></div>
          </div>
        </div>
      </div>
      <canvas id="c" width="900" height="700"></canvas>
      <div id="error"></div>
      <div id="loss-content">
        <div id="loss-title">Проигрыш</div>
        <div id="loss-score-line"></div>
        <div id="loss-names-line"></div>
        <div id="loss-actions">
          <button id="loss-play-again-btn">Играть снова</button>
          <button id="loss-to-menu-btn">Выход</button>
        </div>
      </div>
      <div id="victory-content">
        <div id="victory-title"></div>
        <div id="victory-sub"></div>
        <div id="victory-rating"></div>
        <div id="victory-actions">
          <button id="play-again-btn">Играть снова</button>
          <button id="to-menu-btn">← В меню</button>
          <button id="change-rank-btn">Сменить ранг</button>
        </div>
      </div>
      <div id="name-constellation">
        <div id="name-const-label">Дай имя своему созвездию</div>
        <input id="name-const-input" type="text" placeholder="Название" maxlength="40">
        <div id="name-const-actions">
          <button id="name-const-save-btn">Сохранить в небо ✦</button>
          <button id="name-const-local-save-btn">Сохранить в мои созвездия</button>
          <div id="name-const-guest">Войдите чтобы сохранить</div>
          <div id="name-const-saved" style="display:none;font-size:13px;color:rgba(248,247,245,0.55);text-align:center;">Созвездие сохранено ✦</div>
          <button id="name-const-again-btn">Играть снова</button>
        </div>
      </div>
    </div>
    <div id="bottom-panel">
      <div style="display:flex;align-items:center;gap:12px;">
        <div id="rank-display"></div>
        <button id="last-move-btn">Последний ход</button>
      </div>
      <div id="theme-switcher">
        <button class="theme-btn" data-theme="stargazer"   title="Stargazer"></button>
        <button class="theme-btn" data-theme="minimal"     title="Minimal"></button>
        <button class="theme-btn" data-theme="suprematist" title="Suprematist"></button>
        <button class="theme-btn" data-theme="chalk"       title="Chalk"></button>
      </div>
    </div>
  </div>

  <!-- Journey screen ("Мой путь") -->
  <div id="journey">
    <div id="journey-topbar">
      <button id="journey-back-btn">←</button>
      <span id="journey-screen-title">Мои созвездия</span>
    </div>
    <div id="journey-grid"></div>
  </div>

  <div id="vignette-overlay"></div>
  <div id="grain-overlay"></div>

  <script src="systems/i18n.js"></script>
  <script src="systems/progression.js"></script>
  <script src="engines/star-renderer.js"></script>
  <script src="engines/line-renderer.js"></script>
  <script src="engines/themes.js"></script>
  <script src="engines/victory-renderer.js"></script>
  <script src="engines/game-engine.js"></script>
  <script src="engines/stargazer-ai.js"></script>

  <script>

    // ── Supabase ──────────────────────────────────────────────────────────────
    const SUPABASE_URL = 'https://kugqznwvdfgojofflbgi.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_c6myYVMYUvy0JreXsk0mCQ_AIzK8w4E';
    const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    // ── start screen ─────────────────────────────────────────────────────────

    const playerNames = ['', ''];
    let isAI = false;

    const n1 = document.getElementById('name1');
    const n2 = document.getElementById('name2');
    const startBtn = document.getElementById('startBtn');

    /**
     * Показывает указанный шаг стартового экрана, скрывая остальные.
     * @param {string} id — id элемента шага
     *   ('game-mode-step' | 'game-length-step' | 'map-step' | 'name-step')
     */
    function showStep(id) {
      ['game-mode-step', 'game-length-step', 'map-step', 'name-step'].forEach(s =>
        document.getElementById(s).style.display = s === id ? 'flex' : 'none'
      );
      const backBtn = document.getElementById('start-back-btn');
      if (backBtn) backBtn.style.display = id === 'game-mode-step' ? 'none' : 'block';
      const startBottom = document.querySelector('.start-bottom');
      if (startBottom) startBottom.style.display = id === 'game-mode-step' ? 'flex' : 'none';
    }

    let stargazerLevel = 1;

    // Step 1 — С другом / Со Звездочётом
    document.getElementById('vsHuman').addEventListener('click', () => {
      isAI = false;
      n2.style.display = '';
      showStep('map-step');
    });
    document.getElementById('vsAI').addEventListener('click', () => {
      isAI = true;
      n2.style.display = 'none';
      const _skipTutorial = localStorage.getItem('tutorialDone') !== null || (loadProgress().rating > 0);
      if (!_skipTutorial) {
        COUNT = 4; // tutorial: force short game
        startGame();
      } else {
        showStep('game-length-step');
      }
    });

    // Step 1b — длина партии (AI mode)
    document.querySelectorAll('.length-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        COUNT = parseInt(btn.dataset.count);
        startGame();
      });
    });

    // Step 2 — карта (human vs human)
    document.querySelectorAll('#map-step .mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        COUNT = parseInt(btn.dataset.count);
        startGame();
      });
    });

    // Step 3 — имена
    /**
     * Активирует или деактивирует кнопку «Начать» в зависимости от того,
     * заполнены ли обязательные поля имён. В режиме vs AI поле игрока 2 не требуется.
     */
    function checkReady() {
      startBtn.disabled = !(n1.value.trim() && (isAI || n2.value.trim()));
    }
    n1.addEventListener('input', checkReady);
    n2.addEventListener('input', checkReady);
    n1.addEventListener('keydown', e => {
      if (e.key !== 'Enter') return;
      isAI ? (!startBtn.disabled && startGame()) : n2.focus();
    });
    n2.addEventListener('keydown', e => e.key === 'Enter' && !startBtn.disabled && startGame());
    startBtn.addEventListener('click', startGame);

    /**
     * Инициализирует игру: сохраняет имена, генерирует точки случайно
     * (с минимальным расстоянием MIN_DIST между ними), скрывает стартовый экран
     * и отображает игровое поле.
     */
    function startGame() {
      // Останавливаем мерцание звёзд с предыдущей партии
      if (_twinkleRaf) { cancelAnimationFrame(_twinkleRaf); _twinkleRaf = null; }
      _twinkleState = null;
      if (_gameTwinkleRaf) { cancelAnimationFrame(_gameTwinkleRaf); _gameTwinkleRaf = null; }
      _gameTwinkleState = null;
      _supLayout = null;
      if (_chalkAnimRaf) { cancelAnimationFrame(_chalkAnimRaf); _chalkAnimRaf = null; }
      _chalkAnimProgress = 0;
      // Сбрасываем состояние canvas-area после duel/ended
      document.getElementById('canvas-area').classList.remove('duel', 'ended', 'lost');
      document.getElementById('victory-title').style.visibility = 'visible';
      document.getElementById('victory-sub').style.visibility   = 'visible';
      const _fo = document.getElementById('canvas-fade-overlay');
      if (_fo) _fo.style.opacity = '0';
      const _vcEl = document.getElementById('victory-content');
      if (_vcEl) { _vcEl.style.opacity = '0'; _vcEl.style.pointerEvents = 'none'; }
      const _ncEl = document.getElementById('name-constellation');
      if (_ncEl) { _ncEl.style.opacity = '0'; _ncEl.style.pointerEvents = 'none'; }
      const _gcEl = document.getElementById('c');
      if (_gcEl) _gcEl.style.transition = 'none';
      if (_gcEl) _gcEl.style.transform = '';
      requestAnimationFrame(() => { if (_gcEl) _gcEl.style.transition = ''; });
      playerNames[0] = localStorage.getItem('playerName') || 'Игрок';
      playerNames[1] = isAI ? 'Звездочёт' : (n2.value.trim() || 'Игрок 2');
      // Полный сброс игрового состояния перед новой партией
      resetGameState();
      _winProb = 0.5; _probBarDisplay = 0.5; _probBarTarget = 0.5;
      if (_probBarRaf) { cancelAnimationFrame(_probBarRaf); _probBarRaf = null; }
      const _pbWrap = document.getElementById('prob-bar-wrap');
      const _pbFill = document.getElementById('prob-bar-fill');
      if (_pbWrap && _pbFill) { _pbWrap.classList.add('active'); _pbFill.style.width = '50%'; }
      _tutorialMode = false; _tutorialStep = 0;
      _tutorialTooltip = null; _tutorialBlocked = false; _tutorialBtnRect = null;
      _tutorialPulseIdx = -1; _tutorialPolygonSeen = false;
      if (_tutorialRaf) { cancelAnimationFrame(_tutorialRaf); _tutorialRaf = null; }
      _hintEdges = [];
      if (_hintsRaf) { cancelAnimationFrame(_hintsRaf); _hintsRaf = null; }
      document.getElementById('home-screen').style.display = 'none';
      document.getElementById('game').classList.add('ui-hidden');
      fadeTo(document.getElementById('start'), document.getElementById('game'), 300, () => {
        resizeCanvas(); // первый вызов — панели уже видны
        setTimeout(() => {
          resizeCanvas(); // второй вызов — панели имеют реальную высоту
          while (points.length < COUNT) {
            const SIDE_M  = Math.max(32,  Math.round(W * 0.09));   // боковые отступы
            const TOP_M   = Math.max(130, Math.round(H * 0.17));   // верхний — под top-panel
            const BOT_M   = Math.max(100, Math.round(H * 0.13));   // нижний — над bottom-panel
            const x = SIDE_M + Math.random() * (W - SIDE_M * 2);
            const y = TOP_M  + Math.random() * (H - TOP_M - BOT_M);
            if (points.every(p => Math.hypot(p.x - x, p.y - y) >= MIN_DIST))
              points.push({ x, y });
          }
          // Запускаем анимацию появления точек
          const _now = performance.now();
          _pointBirthT = points.map((_, i) => _now + i * 120);
          _startBirthAnim();
        }, 50);
      });
      document.getElementById('pname1').textContent = playerNames[0];
      document.getElementById('pname2').textContent = playerNames[1];
      if (isAI) { stargazerLevel = rankToAiLevel(); }
      if (isAI && localStorage.getItem('tutorialDone') === null && loadProgress().rating === 0) {
        _tutorialMode = true;
        stargazerLevel = 1;
        COUNT = 4;
      }
      const lvlEl = document.getElementById('p2level');
      const starsEl = document.getElementById('ai-level-stars');
      const p1lvlEl = document.getElementById('p1level');
      const p1starsEl = document.getElementById('p1-rank-stars');
      if (isAI) {
        if (lvlEl)    { lvlEl.textContent   = LEVEL_NAMES[stargazerLevel - 1]; lvlEl.style.display   = 'block'; }
        if (starsEl)  { starsEl.textContent = '★'.repeat(stargazerLevel);       starsEl.style.display = 'block'; }
        if (p1lvlEl)  p1lvlEl.style.display  = 'block';
        if (p1starsEl) p1starsEl.style.display = 'block';
      } else {
        if (lvlEl)    lvlEl.style.display    = 'none';
        if (starsEl)  starsEl.style.display  = 'none';
        if (p1lvlEl)  p1lvlEl.style.display  = 'none';
        if (p1starsEl) p1starsEl.style.display = 'none';
      }
      _hintsOn = localStorage.getItem('hintsEnabled') === '1';
      const hbtn = document.getElementById('hints-btn');
      if (hbtn) hbtn.classList.toggle('active', _hintsOn);
      updateUI();
      renderProgressWidget();
      // Запускаем мерцание звёзд во время игры (только для stargazer)
      if (activeTheme === 'stargazer') startGameTwinkleLoop();
      draw();
    }

    // ── canvas / constants ────────────────────────────────────────────────────

    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    let W = canvas.width, H = canvas.height;
    const ctxDL = document.getElementById('c-duel-left').getContext('2d');
    const ctxDR = document.getElementById('c-duel-right').getContext('2d');
    const DW = 900, DH = 700; // размеры duel-canvas (совпадают с W×H)

    /** Convert browser event coords to canvas pixel coords (handles CSS scaling). */
    function _evXY(e, el) {
      const r = el.getBoundingClientRect();
      const sx = el.width / r.width, sy = el.height / r.height;
      return [(e.clientX - r.left) * sx, (e.clientY - r.top) * sy];
    }
    let RADIUS = 3, MIN_DIST = 30, HIT_R = 22;
    let COUNT = 0; // set by mode selection

    // ── adaptive canvas resize ────────────────────────────────────────────────

    let isResizing = false;

    /**
     * Подстраивает размер canvas #c под текущий размер окна и высоту панелей.
     * Пересчитывает RADIUS и MIN_DIST пропорционально меньшей стороне (BASE).
     * Если игра уже идёт — повторно генерирует точки через setTimeout(50ms),
     * чтобы панели успели занять реальную высоту.
     * Защита от рекурсии: флаг isResizing предотвращает вложенные вызовы.
     */
    function resizeCanvas() {
      if (isResizing) return;
      isResizing = true;

      const areaEl = document.getElementById('canvas-area');
      const availW = areaEl ? Math.max(1, areaEl.clientWidth)  : window.innerWidth;
      const availH = Math.max(1, window.innerHeight);

      canvas.width  = Math.min(availW, 430);
      canvas.height = Math.min(availH, 932);
      W = canvas.width;
      H = canvas.height;

      const BASE = Math.min(canvas.width, canvas.height);
      RADIUS   = Math.round(BASE * 0.013);
      HIT_R    = Math.max(22, Math.round(RADIUS * 3.5));
      MIN_DIST = Math.max(50, HIT_R * 2 + 6);

      isResizing = false;

      // Only redraw if a game is active (not on menu, not frozen)
      if (typeof draw === 'function' && points.length > 0 && !gameOver) draw();
    }

    window.addEventListener('resize', resizeCanvas);
    window.addEventListener('orientationchange', () => setTimeout(resizeCanvas, 100));

    let COLOR   = 'rgba(255,255,255,0.9)';
    let PREVIEW = 'rgba(255,255,255,0.35)';
    let FILL    = 'rgba(255,255,255,0.07)';

    const points = []; // filled in startGame()

    let hovered = -1, selected = -1, currentPlayer = 0;
    let previewValidation = null;
    let gameOver = false, winner = -1;
    let _lineAnim = null; // { a, b, player, startT }

    // Последний сделанный ход и состояние анимации подсветки
    let lastMove = null;          // {a, b} — индексы точек последнего отрезка
    let lastMoveAnimT = 0;        // 0..1 — текущий прогресс (0 = нет анимации)
    let lastMoveAnimRaf = null;   // handle от requestAnimationFrame
    let _supLayout = null;        // детерминированная компоновка экрана победы suprematist
    let _chalkPaperCache  = null; // offscreen canvas: кэш текстуры бумаги (chalk)
    let _chalkAnimRaf     = null; // rAF handle анимации chalk-победы
    let _chalkAnimProgress = 0;  // 0→1 прогресс анимации chalk
    let _grainCanvas      = null; // offscreen 256×256 canvas: плёночное зерно
    let _grainFrameCount  = 0;   // счётчик кадров для регенерации зерна
    let _isGameOverCache  = null; // null = не проверено, bool = кешированный результат
    let _winProb          = 0.5; // оценочная вероятность победы игрока 0 (0.0–1.0)
    let _probBarDisplay   = 0.5; // текущее анимированное значение полосы
    let _probBarTarget    = 0.5; // целевое значение (к которому плавно движемся)
    let _probBarRaf       = null; // rAF handle анимации полосы вероятности
    let _tutorialMode      = false; // true during the first-game tutorial
    let _tutorialAutoSave  = false; // set true when tutorial ends → triggers auto-save on win screen
    let _tutorialStep      = 0;     // 0=none, 1=m1 triggered, 2=m2 triggered, 3=m3 triggered
    let _tutorialTooltip   = null;  // {text,x,y,startMs,fadingOut,fadeStartMs} | null
    let _tutorialBlocked   = false; // input blocked while tooltip is visible
    let _tutorialBtnRect   = null;  // {x,y,w,h} of "Понятно" button, set each frame
    let _tutorialPulseIdx  = -1;    // point index to pulse (moment 1), -1=none
    let _tutorialPulseStart = 0;    // performance.now() when pulse started
    let _tutorialPolygonSeen = false; // true once moment 2 was triggered
    let _tutorialRaf       = null;  // animation loop handle
    let _hintsOn    = localStorage.getItem('hintsEnabled') === '1';
    let _hintEdges  = [];  // [{a, b, value:'HIGH'|'MEDIUM'}], top-5 for current player
    let _hintsRaf   = null; // shimmer loop (stargazer theme only)
    let _rankUpRaf     = null; // RAF handle for rank-up ceremony animation
    let _rankUpActive  = false; // true while rank-up ceremony canvas is showing
    const scores = [0, 0];
    const lines = new Map();
    const polygons = [];
    const scoredKeys = new Set();

    // ── geometry ──────────────────────────────────────────────────────────────

    // ── graph ─────────────────────────────────────────────────────────────────

    // ── validation ────────────────────────────────────────────────────────────

    // ── scoring ───────────────────────────────────────────────────────────────

    // ── Звездочёт ─────────────────────────────────────────────────────────────

    // ── Web Audio звуки ───────────────────────────────────────────────────────
    //
    // Все звуки синтезируются через Web Audio API (без файлов), что позволяет
    // обойтись без сетевых запросов и избежать проблем с автовоспроизведением.
    // AudioContext создаётся лениво при первом вызове — браузеры требуют
    // пользовательского жеста (tap/click) для разблокировки аудио.
    //
    // Типы звуков:
    //   'connect' — короткий восходящий тон при соединении двух точек
    //   'score'   — протяжный аккорд при захвате области
    //   'victory' — восходящая арпеджированная последовательность при победе
    let _audioCtx = null;
    /**
     * Воспроизводит синтезированный звуковой эффект через Web Audio API.
     * Ничего не делает, если звук отключён в настройках или AudioContext недоступен.
     * @param {'connect'|'score'|'victory'} type — тип звука
     */
    function playSound(type) {
      if (!window._appSettings.sound) return;
      try {
        if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const ctx = _audioCtx;
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);

        if (type === 'connect') {
          o.frequency.setValueAtTime(440, ctx.currentTime);
          o.frequency.exponentialRampToValueAtTime(880, ctx.currentTime + 0.1);
          g.gain.setValueAtTime(0.1, ctx.currentTime);
          g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
          o.start(); o.stop(ctx.currentTime + 0.2);
        }
        if (type === 'score') {
          o.frequency.setValueAtTime(523, ctx.currentTime);
          g.gain.setValueAtTime(0.15, ctx.currentTime);
          g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
          o.start(); o.stop(ctx.currentTime + 0.4);
        }
        if (type === 'victory') {
          o.disconnect();
          [523, 659, 784, 1046].forEach((freq, i) => {
            const o2 = ctx.createOscillator();
            const g2 = ctx.createGain();
            o2.connect(g2); g2.connect(ctx.destination);
            o2.frequency.value = freq;
            g2.gain.setValueAtTime(0, ctx.currentTime + i * 0.15);
            g2.gain.linearRampToValueAtTime(0.15, ctx.currentTime + i * 0.15 + 0.05);
            g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.15 + 0.3);
            o2.start(ctx.currentTime + i * 0.15);
            o2.stop(ctx.currentTime + i * 0.15 + 0.3);
          });
        }
        if (type === 'twinkle') {
          // Мягкий эфирный перелив — три короткие ноты вверх при сохранении созвездия
          o.disconnect();
          [660, 880, 1320].forEach((freq, i) => {
            const o2 = ctx.createOscillator();
            const g2 = ctx.createGain();
            o2.type = 'sine';
            o2.connect(g2); g2.connect(ctx.destination);
            o2.frequency.value = freq;
            g2.gain.setValueAtTime(0, ctx.currentTime + i * 0.09);
            g2.gain.linearRampToValueAtTime(0.07, ctx.currentTime + i * 0.09 + 0.03);
            g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.09 + 0.18);
            o2.start(ctx.currentTime + i * 0.09);
            o2.stop(ctx.currentTime + i * 0.09 + 0.2);
          });
        }
      } catch(e) {}
    }

    function applyMove(a, b) {
      playSound('connect');
      haptic('light');
      _lineAnimating = true;
      _lineAnim = { a, b, player: currentPlayer, startT: performance.now() };
      _startLineAnimLoop();
      setTimeout(() => {
        _lineAnim = null; _lineAnimating = false;
        lastMove = { a, b };
        lines.set(lineKey(a, b), currentPlayer);
        checkScore(a, b, currentPlayer);
        currentPlayer = 1 - currentPlayer;
        _isGameOverCache = null;
        updateUI(); updateLastMoveBtn();
        if (isGameOver()) { endGame(); return; }
        _probBarTarget = estimateWinProbability();
        startProbBarAnim();
        checkTutorialMoments();
        computeHints();
      }, 200);
    }

    // ── tutorial ──────────────────────────────────────────────────────────────

    /** Show a tutorial tooltip at canvas position (x, y). Blocks game input. */
    function showTutorialTooltip(text, x, y) {
      _tutorialTooltip = { text, x, y, startMs: performance.now(), fadingOut: false, fadeStartMs: 0 };
      _tutorialBlocked = true;
      _tutorialBtnRect = null;
      ensureTutorialLoop();
    }

    /** Begin fade-out of the current tooltip. Input unblocked when fade completes. */
    function startDismissTutorial() {
      if (!_tutorialTooltip || _tutorialTooltip.fadingOut) return;
      _tutorialTooltip.fadingOut = true;
      _tutorialTooltip.fadeStartMs = performance.now();
      ensureTutorialLoop();
    }

    /**
     * Check whether a new tutorial moment should be triggered after a move.
     * Moment 2: first polygon scored.
     * Moment 3: ≤3 valid moves remain.
     */
    function checkTutorialMoments() {
      if (!_tutorialMode || _tutorialBlocked || gameOver) return;
      if (_tutorialStep === 1 && !_tutorialPolygonSeen && polygons.length > 0) {
        _tutorialPolygonSeen = true;
        _tutorialStep = 2;
        _tutorialPulseIdx = -1; // stop moment-1 pulse
        showTutorialTooltip(
          'Созвездие поймано! ✦\nЗамкнутая фигура приносит очко',
          W / 2 - 148, H / 2 - 80
        );
        return;
      }
      if (_tutorialStep === 2 && estimateRemainingMoves() <= 3) {
        _tutorialStep = 3;
        showTutorialTooltip(
          'Финальный рывок — у кого больше созвездий, тот и победил ✦',
          W / 2 - 148, H - 170
        );
      }
    }

    /** Keep a tutorial animation loop running while tooltip or pulse is active. */
    function ensureTutorialLoop() {
      if (_tutorialRaf) return;
      function loop() {
        if (!_tutorialMode || (!_tutorialTooltip && _tutorialPulseIdx < 0)) {
          _tutorialRaf = null; return;
        }
        draw();
        _tutorialRaf = requestAnimationFrame(loop);
      }
      _tutorialRaf = requestAnimationFrame(loop);
    }

    /** Wrap text to lines fitting maxWidth using current ctx font. */
    function tutWrapText(text, maxWidth) {
      const result = [];
      for (const para of text.split('\n')) {
        const words = para.split(' ');
        let line = '';
        for (const w of words) {
          const test = line ? line + ' ' + w : w;
          if (ctx.measureText(test).width > maxWidth && line) { result.push(line); line = w; }
          else line = test;
        }
        if (line) result.push(line);
      }
      return result;
    }

    /**
     * Draw tutorial tooltip and point pulse on top of the game canvas.
     * Called at the end of draw() when _tutorialMode is true.
     */
    function drawTutorialOverlay() {
      // Pulse ring on the selected point (moment 1)
      if (_tutorialPulseIdx >= 0 && points[_tutorialPulseIdx]) {
        const pp = points[_tutorialPulseIdx];
        const t = (performance.now() - _tutorialPulseStart) / 1200;
        const pr = RADIUS * 2 + 4 * Math.sin(t * Math.PI * 2);
        ctx.save();
        ctx.beginPath();
        ctx.arc(pp.x, pp.y, pr, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(225,223,220,0.75)';
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.restore();
      }

      if (!_tutorialTooltip) return;
      const { text, x, y, startMs, fadingOut, fadeStartMs } = _tutorialTooltip;
      const now = performance.now();
      let alpha;
      if (fadingOut) {
        alpha = 1 - Math.min(1, (now - fadeStartMs) / 300);
        if (alpha <= 0) {
          _tutorialTooltip = null;
          _tutorialBlocked = false;
          if (!gameOver) checkTutorialMoments(); // re-check after dismiss
          return;
        }
      } else {
        alpha = Math.min(1, (now - startMs) / 400);
      }

      ctx.save();
      ctx.font = '18px system-ui, sans-serif';
      const pad = 16, lineH = 26, btnH = 34, btnW = 130, boxW = 300;
      const wrappedLines = tutWrapText(text, boxW - pad * 2);
      const boxH = pad * 2 + wrappedLines.length * lineH + 10 + btnH;
      const bx = Math.max(10, Math.min(W - boxW - 10, x));
      const by = Math.max(10, Math.min(H - boxH - 10, y));

      ctx.globalAlpha = alpha;

      // Box
      ctx.fillStyle = 'rgba(26,26,46,0.92)';
      _rrect(ctx, bx, by, boxW, boxH, 10);
      ctx.fill();
      ctx.strokeStyle = 'rgba(248,247,245,0.18)';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Text
      ctx.fillStyle = '#F8F7F5';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      wrappedLines.forEach((ln, i) => ctx.fillText(ln, bx + pad, by + pad + i * lineH));

      // Dismiss button
      const btnX = bx + boxW - pad - btnW;
      const btnY = by + boxH - pad - btnH;
      ctx.fillStyle = 'rgba(248,247,245,0.14)';
      _rrect(ctx, btnX, btnY, btnW, btnH, 6);
      ctx.fill();
      ctx.strokeStyle = 'rgba(248,247,245,0.35)';
      ctx.lineWidth = 1;
      ctx.stroke();
      ctx.fillStyle = '#F8F7F5';
      ctx.font = 'bold 14px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('Понятно →', btnX + btnW / 2, btnY + btnH / 2);

      // Store button rect for click detection (in canvas coordinates)
      _tutorialBtnRect = { x: btnX, y: btnY, w: btnW, h: btnH };

      ctx.restore();
    }

    // ── hints ─────────────────────────────────────────────────────────────────

    /** RAF loop to drive the stargazer shimmer animation for hints. */
    function ensureHintsLoop() {
      if (_hintsRaf) return;
      function loop() {
        if (!_hintsOn || activeTheme !== 'stargazer' || gameOver || !_hintEdges.length) {
          _hintsRaf = null; return;
        }
        draw();
        _hintsRaf = requestAnimationFrame(loop);
      }
      _hintsRaf = requestAnimationFrame(loop);
    }

    /** Draw a small chalk dot with deterministic jitter (used for chalk hint edges). */
    function drawChalkDot(ctx, x, y, r, color) {
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
    }

    /**
     * Draw hint edges on the canvas.
     * Must be called BEFORE the regular edge layer so hints appear underneath.
     */
    function drawHints() {
      if (!_hintEdges.length) return;
      ctx.save();

      const isStargazer = activeTheme === 'stargazer';
      const isChalk = activeTheme === 'chalk';

      _hintEdges.forEach(({ a, b, value }) => {
        const ax = points[a].x, ay = points[a].y;
        const bx = points[b].x, by = points[b].y;

        if (isChalk) {
          // Series of small chalk dots along the edge path
          const dx = bx - ax, dy = by - ay;
          const len = Math.hypot(dx, dy);
          const n = Math.max(3, Math.floor(len / 18));
          const r = value === 'HIGH' ? 3.5 : 2.5;
          const alpha = value === 'HIGH' ? 0.42 : 0.22;
          const color = value === 'HIGH'
            ? CHALK_RAINBOW[currentPlayer * 3 % CHALK_RAINBOW.length]
            : 'rgba(140,115,80,1)';
          const seed = Math.abs(Math.sin(ax * 0.37 + ay * 0.19 + bx * 0.13)) % 1;
          ctx.globalAlpha = alpha;
          for (let k = 0; k <= n; k++) {
            const t = k / n;
            const jx = Math.sin(seed * 31.4 + k * 7.9) * 2.2;
            const jy = Math.cos(seed * 11.7 + k * 13.3) * 2.2;
            drawChalkDot(ctx, ax + dx * t + jx, ay + dy * t + jy, r, color);
          }
          ctx.globalAlpha = 1;
        } else {
          let alpha, dash, lw;
          if (value === 'HIGH') { alpha = 0.35; dash = [8, 6]; lw = 2; }
          else                  { alpha = 0.20; dash = [3, 8]; lw = 1.5; }

          if (isStargazer) {
            // Pulsing shimmer 20%→40%→20% over 2 s
            const phase = (performance.now() % 2000) / 2000;
            const pulse = 0.20 + 0.20 * Math.sin(phase * Math.PI * 2);
            alpha = value === 'HIGH' ? Math.min(0.55, pulse * 1.8) : pulse;
          }

          ctx.globalAlpha = alpha;
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = lw;
          ctx.lineCap = 'round';
          ctx.setLineDash(dash);
          ctx.beginPath();
          ctx.moveTo(ax, ay);
          ctx.lineTo(bx, by);
          ctx.stroke();
          ctx.setLineDash([]);
        }
      });

      ctx.restore();
    }


    /**
     * Завершает игру: устанавливает флаг gameOver, определяет победителя по счёту
     * (−1 при ничье), сбрасывает выделение и перерисовывает поле с экраном победы.
     */
    let _winParticleRaf = null;

    function startWinEffect() {
      // ── White flash ──
      const flash = document.getElementById('win-flash');
      flash.style.transition = 'none';
      flash.style.opacity = '0.6';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        flash.style.transition = 'opacity 0.3s ease';
        flash.style.opacity = '0';
      }));

      // ── Star particles ──
      const pc = document.getElementById('particle-canvas');
      if (!pc) return;
      pc.width  = W; pc.height = H;
      const pctx = pc.getContext('2d');
      const cx = W / 2, cy = H / 2;
      const startT = performance.now();
      if (_winParticleRaf) { cancelAnimationFrame(_winParticleRaf); _winParticleRaf = null; }

      const particles = Array.from({ length: 20 }, () => {
        const angle = Math.random() * Math.PI * 2;
        const speed = 2 + Math.random() * 3;
        return { x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
                 r: 2 + Math.random() * 2 };
      });

      (function loop() {
        const elapsed = performance.now() - startT;
        pctx.clearRect(0, 0, W, H);
        let alive = false;
        particles.forEach(p => {
          const t = elapsed / 800;
          if (t >= 1) return;
          alive = true;
          p.x += p.vx; p.y += p.vy;
          pctx.beginPath();
          pctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          pctx.fillStyle = `rgba(225,223,220,${1 - t})`;
          pctx.fill();
        });
        if (alive) { _winParticleRaf = requestAnimationFrame(loop); }
        else { pctx.clearRect(0, 0, W, H); _winParticleRaf = null; }
      })();
    }

    function endGame() {
      resolveGame();
      const _pbw = document.getElementById('prob-bar-wrap');
      if (_pbw) _pbw.classList.remove('active');
      progressionUpdate();
      // Вычисляем детерминированную компоновку suprematist один раз
      _supLayout = generateSupLayout();
      // Rank-up ceremony runs before normal victory screen (skip during tutorial)
      if (_rankUpNewRank && !_tutorialMode) {
        startRankUpCeremony(_rankUpNewRank);
      } else {
        finishEndGame();
      }
    }

    /**
     * Вторая половина завершения игры — показывает экран результата.
     * Вызывается либо сразу из endGame(), либо после ранг-ап церемонии.
     *
     * Три сценария:
     * • Проигрыш (isAI && winner===1): очищает canvas, показывает #loss-content.
     * • Ничья (winner===-1): затемняет canvas оверлеем, показывает «Ничья».
     * • Победа: затемняет + уменьшает canvas (scale 0.42), затем рассветляет,
     *   показывает #name-constellation для ввода имени созвездия.
     *
     * Для дуэльного режима: переключается на #duel-wrap с двумя отдельными canvas.
     */
    function finishEndGame() {
      _rankUpNewRank = null;

      // Обновляем turn-display: Победа / Ничья / Проигрыш
      const td = document.getElementById('turn-display');
      if (td) {
        if (winner === -1)          td.textContent = 'Ничья';
        else if (isAI && winner === 1) td.textContent = 'Проигрыш';
        else                        td.textContent = 'Победа';
      }

      // Проигрыш: останавливаем все анимации, очищаем canvas, показываем loss-экран
      if (isAI && winner === 1) {
        [_twinkleRaf, _gameTwinkleRaf, _chalkAnimRaf, _hintsRaf]
          .forEach(r => r && cancelAnimationFrame(r));
        _twinkleRaf = _gameTwinkleRaf = _chalkAnimRaf = _hintsRaf = null;
        ctx.clearRect(0, 0, W, H);
        document.getElementById('loss-score-line').textContent = scores[0] + ' : ' + scores[1];
        document.getElementById('loss-names-line').textContent =
          (playerNames[0] || 'Игрок') + '  —  ' + (playerNames[1] || 'Звездочёт');
        document.getElementById('canvas-area').classList.add('lost');
        return;
      }

      draw();
      if (winner >= 0) { startWinEffect(); playSound('victory'); haptic('heavy'); }
      const winName = winner >= 0 ? playerNames[winner] : null;
      document.getElementById('victory-title').textContent = winName ? `Созвездие ${winName}` : 'Ничья';
      document.getElementById('victory-sub').textContent   = winName ? 'победило!' : `${scores[0]} : ${scores[1]}`;
      document.getElementById('victory-rating').textContent =
        (isAI && lastRatingGain > 0)
          ? `+${lastRatingGain} ✦ Всего: ${loadProgress().rating}` : '';
      // Tutorial: override victory sub-text and mark as done
      if (_tutorialMode) {
        localStorage.setItem('tutorialDone', '1');
        _tutorialMode = false;
        _tutorialAutoSave = true;
        if (_tutorialRaf) { cancelAnimationFrame(_tutorialRaf); _tutorialRaf = null; }
        _tutorialTooltip = null; _tutorialBlocked = false;
        document.getElementById('victory-sub').textContent = 'Первое созвездие — оно теперь твоё навсегда ✦';
      }
      document.getElementById('canvas-area').classList.add('ended');

      // Duel-режим: переключаемся на два отдельных canvas
      const isDuel = !isAI;
      document.getElementById('canvas-area').classList.toggle('duel', isDuel);
      if (isDuel) {
        const lp = winner >= 0 ? winner   : 0;
        const rp = winner >= 0 ? 1-winner : 1;
        document.getElementById('duel-name-left').textContent  = `Созвездие ${playerNames[lp] || `Игрок ${lp+1}`}`;
        document.getElementById('duel-name-right').textContent = `Созвездие ${playerNames[rp] || `Игрок ${rp+1}`}`;
        const isDraw = winner < 0;
        document.getElementById('duel-sub-left').textContent  = isDraw ? `${scores[lp]} очков` : 'победило!';
        document.getElementById('duel-sub-right').textContent = isDraw ? `${scores[rp]} очков` : 'в другой раз!';
        document.getElementById('victory-title').style.visibility = 'hidden';
        document.getElementById('victory-sub').style.visibility   = 'hidden';
      }
      // Запускаем мерцание звёзд на экране победы (только тема stargazer)
      if (activeTheme === 'stargazer') startTwinkleLoop();
      // Запускаем покадровую анимацию chalk-победы
      if (activeTheme === 'chalk') startChalkAnim();

      // Анимированная последовательность завершения игры
      const _fadeOverlay = document.getElementById('canvas-fade-overlay');
      const _vc = document.getElementById('victory-content');
      const _gameCanvas = document.getElementById('c');

      if (!winName) {
        // Ничья: затемнение + надпись "Ничья" + поле для сохранения
        requestAnimationFrame(() => { _fadeOverlay.style.opacity = '1'; });
        setTimeout(() => {
          _vc.style.opacity = '1';
          _vc.style.pointerEvents = 'auto';
        }, 800);
        setTimeout(() => {
          _fadeOverlay.style.opacity = '0';
          _gameCanvas.style.transform = 'scale(0.42) translateY(-12%)';
        }, 1200);
        setTimeout(() => {
          const _nc = document.getElementById('name-constellation');
          const _input = document.getElementById('name-const-input');
          _input.value = playerNames[0] || '';
          applyGuestMode();
          _nc.style.opacity = '1';
          _nc.style.pointerEvents = 'auto';
          document.getElementById('victory-actions').style.display = 'none';
          if (_tutorialAutoSave) { _doTutorialAutoSave(_input.value.trim() || 'Моё созвездие'); }
        }, 2000);
      } else {
        // Победа: затемнение + уменьшение → просветление → поле имени снизу
        requestAnimationFrame(() => {
          _fadeOverlay.style.opacity = '1';
          _gameCanvas.style.transform = 'scale(0.42) translateY(-12%)';
        });
        // Фаза 2: overlay исчезает — созвездие снова яркое, но маленькое
        setTimeout(() => { _fadeOverlay.style.opacity = '0'; }, 1000);
        // Фаза 3: появляется поле для имени под созвездием
        setTimeout(() => {
          const _nc = document.getElementById('name-constellation');
          const _input = document.getElementById('name-const-input');
          _input.value = winName;
          applyGuestMode();
          _nc.style.opacity = '1';
          _nc.style.pointerEvents = 'auto';
          document.getElementById('victory-actions').style.display = 'none';
          if (_tutorialAutoSave) { _doTutorialAutoSave(_input.value.trim() || 'Моё созвездие'); }
          else { _input.focus(); }
        }, 1600);
      }
    }

    // ── ui ────────────────────────────────────────────────────────────────────

    let errorTimer;
    /**
     * Показывает сообщение об ошибке в блоке #error на 2.5 секунды.
     * @param {string} msg — текст ошибки
     */
    function showError(msg) {
      const el = document.getElementById('error');
      el.textContent = msg; el.style.opacity = '1';
      clearTimeout(errorTimer);
      errorTimer = setTimeout(() => el.style.opacity = '0', 2500);
    }
    /**
     * Немедленно скрывает сообщение об ошибке (opacity → 0) и отменяет
     * таймер автоскрытия. Вызывается при успешном ходе и при выборе новой точки,
     * чтобы убрать предыдущую ошибку до истечения 2.5 с.
     */
    function clearError() {
      clearTimeout(errorTimer);
      document.getElementById('error').style.opacity = '0';
    }

    /**
     * Обновляет игровой интерфейс верхней панели:
     * — записывает актуальные очки в #score1 и #score2;
     * — обновляет #turn-display строкой «Ход: <имя>» (или «Игрок N» если имя пустое).
     * Вызывается после каждого хода и при старте игры.
     */
    function updateUI() {
      document.getElementById('score1').textContent = scores[0];
      document.getElementById('score2').textContent = scores[1];
      document.getElementById('turn-display').textContent = `Ход: ${playerNames[currentPlayer] || `Игрок ${currentPlayer + 1}`}`;
    }

    // ── draw ──────────────────────────────────────────────────────────────────

    // Версия drawStarPoint для произвольного контекста (используется в drawVictoryDuel)
    /**
     * Полностью перерисовывает canvas. Вызывается после каждого изменения состояния.
     *
     * Во время игры (gameOver = false):
     *   1. Заливки захваченных областей (FILL цвет темы).
     *   2. Все проведённые линии.
     *   3. Превью линии от selected к hovered — пунктир, оранжевый если невалидный,
     *      тематический если валидный; блокирующая точка подсвечивается красным.
     *   4. Все точки; hovered/selected/blocking рисуются с увеличенным радиусом и кольцом.
     *
     * На экране победы (gameOver = true):
     *   1. Все линии (только победителя, если не ничья).
     *   2. Точки победителя, масштабированные по степени вхождения в линии.
     *   3. T().drawVictory(ctx, W, H) — тематическая канвас-графика (art layer).
     *   4. T().postDraw(ctx, W, H)   — постобработка (зерно + виньетка для suprematist).
     *
     * Текст победителя, рейтинг и кнопки отображаются HTML-элементами
     * в #victory-content (не на canvas).
     */
    function draw() {
      if (_rankUpActive) return; // rank-up ceremony owns the canvas right now
      ctx.clearRect(0, 0, W, H);
      if (activeTheme === 'chalk' && !gameOver) drawChalkPaperBg(ctx, W, H);

      // В режиме 2 игроков drawVictoryDuel сама фильтрует линии по секторам,
      // поэтому при победе в режиме 2 игроков не фильтруем — показываем все линии.
      const showPlayer = (gameOver && winner >= 0 && isAI) ? winner : null;

      // Captured region fills (only during active game)
      if (!gameOver) {
        if (activeTheme === 'chalk') {
          polygons.forEach(({ path }, polyIdx) => {
            const poly = path.map(i => points[i]);
            ctx.beginPath();
            ctx.moveTo(poly[0].x, poly[0].y);
            for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
            ctx.closePath();
            ctx.globalAlpha = 0.28;
            ctx.fillStyle = CHALK_FILL[polyIdx % CHALK_FILL.length];
            ctx.fill();
            ctx.globalAlpha = 1;
          });
        } else {
          polygons.forEach(({ path }) => {
            const poly = path.map(i => points[i]);
            ctx.beginPath();
            ctx.moveTo(poly[0].x, poly[0].y);
            for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
            ctx.closePath();
            ctx.fillStyle = FILL;
            ctx.fill();
          });
        }
      }

      // Hint edges (drawn under regular lines)
      if (!gameOver && _hintsOn && _hintEdges.length > 0) drawHints();

      // Drawn lines
      let chalkLineIdx = 0;
      lines.forEach((player, key) => {
        if (showPlayer !== null && player !== showPlayer) return;
        const [a, b] = key.split('-').map(Number);
        const ax = points[a].x, ay = points[a].y;
        const bx = points[b].x, by = points[b].y;

        if (activeTheme === 'stargazer' && !gameOver) {
          // Слой 1: едва заметное широкое свечение
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = 'rgba(225,223,220,0.06)';
          ctx.lineWidth = 7;
          ctx.stroke();
          // Слой 2: тонкий ореол
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = 'rgba(225,223,220,0.11)';
          ctx.lineWidth = 3;
          ctx.stroke();
          // Слой 3: основная тонкая линия
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = 0.85;
          ctx.stroke();
        } else if (activeTheme === 'chalk' && !gameOver) {
          drawChalkLine(ctx, ax, ay, bx, by, CHALK_RAINBOW[chalkLineIdx++ % CHALK_RAINBOW.length]);
        } else {
          // Все остальные темы и экран победы — без изменений
          ctx.beginPath();
          ctx.moveTo(ax, ay);
          ctx.lineTo(bx, by);
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = gameOver ? 2 : 1.5;
          ctx.stroke();
        }
      });

      // Animated line (grows from a to b over 200ms)
      if (_lineAnim && !gameOver) {
        const t = Math.min(1, (performance.now() - _lineAnim.startT) / 200);
        const pa = points[_lineAnim.a], pb = points[_lineAnim.b];
        const ex = pa.x + (pb.x - pa.x) * t;
        const ey = pa.y + (pb.y - pa.y) * t;
        if (activeTheme === 'stargazer') {
          ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(ex, ey);
          ctx.strokeStyle = 'rgba(225,223,220,0.08)'; ctx.lineWidth = 10; ctx.stroke();
          ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(ex, ey);
          ctx.shadowBlur = 8; ctx.shadowColor = COLOR;
          ctx.strokeStyle = COLOR; ctx.lineWidth = 1.2; ctx.stroke();
          ctx.shadowBlur = 0;
        } else {
          ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(ex, ey);
          ctx.strokeStyle = COLOR; ctx.lineWidth = 1.5; ctx.stroke();
        }
      }

      if (!gameOver) {
        // Preview line
        let blockingPoint = -1;
        if (selected !== -1 && hovered !== -1 && hovered !== selected) {
          const v = previewValidation;
          const previewColor = (!v || !v.ok) ? 'rgba(210,208,205,0.55)' : PREVIEW;
          if (v && v.blockingPoint !== undefined) blockingPoint = v.blockingPoint;
          ctx.beginPath();
          ctx.moveTo(points[selected].x, points[selected].y);
          ctx.lineTo(points[hovered].x, points[hovered].y);
          ctx.strokeStyle = previewColor;
          ctx.lineWidth = 2;
          ctx.setLineDash([6, 4]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Points
        // Степень каждой точки по всем проведённым линиям (оба игрока) — нужна для drawStarPoint
        const activeDegree = new Array(COUNT).fill(0);
        lines.forEach((_, key) => {
          const [a, b] = key.split('-').map(Number);
          activeDegree[a]++; activeDegree[b]++;
        });

        if (activeTheme === 'stargazer') {
          // Тема stargazer: звёздный рендер с градиентами и свечением
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            drawStarPoint(ctx, p.x, p.y, activeDegree[i],
              i === hovered, i === selected, i === blockingPoint,
              getTwinkleBoost(i) * 0.6);
            if (bt < 1) ctx.restore();
          });
        } else if (activeTheme === 'chalk') {
          // Chalk: мелковые точки с цветом по игроку
          const cp0 = new Array(COUNT).fill(0), cp1 = new Array(COUNT).fill(0);
          lines.forEach((pl, key) => {
            const [a, b] = key.split('-').map(Number);
            if (pl === 0) { cp0[a]++; cp0[b]++; } else { cp1[a]++; cp1[b]++; }
          });
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            const isHov = i === hovered, isSel = i === selected;
            const isBlocking = i === blockingPoint;
            let pColor, r;
            if (activeDegree[i] === 0) {
              pColor = 'rgba(120,100,80,0.5)'; r = 6;
            } else {
              r = isHov || isSel || isBlocking ? RADIUS + 4 : RADIUS + 2;
              pColor = CHALK_RAINBOW[i % CHALK_RAINBOW.length];
            }
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            drawChalkSpiral(ctx, p.x, p.y, 18, pColor, activeDegree[i]);
            if (isHov || isSel || isBlocking) {
              ctx.beginPath();
              ctx.arc(p.x, p.y, r + 5, 0, Math.PI * 2);
              ctx.strokeStyle = isBlocking ? 'rgba(255,107,107,0.6)' : PREVIEW;
              ctx.lineWidth = 1.5;
              ctx.stroke();
            }
            if (bt < 1) ctx.restore();
          });
        } else {
          // Остальные темы: стандартный рендер твёрдыми кругами
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            const isHov = i === hovered, isSel = i === selected;
            const isBlocking = i === blockingPoint;
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            ctx.beginPath();
            ctx.arc(p.x, p.y, isHov || isSel || isBlocking ? RADIUS + 2 : RADIUS, 0, Math.PI * 2);
            ctx.fillStyle = isBlocking ? '#ff6b6b' : COLOR;
            ctx.fill();
            if (isHov || isSel || isBlocking) {
              ctx.beginPath();
              ctx.arc(p.x, p.y, RADIUS + 5, 0, Math.PI * 2);
              ctx.strokeStyle = isBlocking ? 'rgba(255,107,107,0.6)' : PREVIEW;
              ctx.lineWidth = 1.5;
              ctx.stroke();
            }
            if (bt < 1) ctx.restore();
          });
        }
      } else {
        // Count winner's lines per point
        const degree = new Array(COUNT).fill(0);
        if (winner >= 0) {
          lines.forEach((player, key) => {
            if (player !== winner) return;
            const [a, b] = key.split('-').map(Number);
            degree[a]++;
            degree[b]++;
          });
        }

        // Draw points scaled by degree (0 = hidden)
        points.forEach((p, i) => {
          const d = winner >= 0 ? degree[i] : 1;
          if (d === 0) return;
          if (activeTheme === 'stargazer') {
            // Тема stargazer: звёздный рендер с градиентами (degree из линий победителя)
            // boost=0.7 — постоянная надъяркость на экране победы; +мерцание до ×0.9
            drawStarPoint(ctx, p.x, p.y, d, false, false, false, 0.7 + getTwinkleBoost(i) * 0.9);
          } else {
            const r = d >= 3 ? RADIUS * 2 : d === 2 ? RADIUS * 1.5 : RADIUS;
            ctx.beginPath();
            ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
            ctx.fillStyle = T().dots;
            ctx.fill();
          }
        });

        // Victory overlay: split-screen для 2 игроков, тематическая графика для AI
        if (!isAI) {
          drawVictoryDuel(ctx, W, H);
        } else {
          T().drawVictory(ctx, W, H);
        }
      }

      // Анимация «последнего хода»: перерисовываем отрезок с плавно меняющейся толщиной.
      // lastMoveAnimT — треугольная волна 0→1→0 за 400мс (200мс рост, 200мс спад).
      // Толщина линии: base × (1 + t) → плавно до 2× базовой и обратно.
      if (lastMove && lastMoveAnimT > 0) {
        const base = gameOver ? 2 : 1.5;
        ctx.beginPath();
        ctx.moveTo(points[lastMove.a].x, points[lastMove.a].y);
        ctx.lineTo(points[lastMove.b].x, points[lastMove.b].y);
        ctx.strokeStyle = COLOR;
        ctx.lineWidth = base * (1 + lastMoveAnimT); // от base до 2×base и обратно
        ctx.stroke();
      }

      if (T().postDraw) T().postDraw(ctx, W, H);
      drawGrainOverlay(ctx, W, H);
      if (_tutorialMode) drawTutorialOverlay();
    }

    // ── win-probability bar ───────────────────────────────────────────────────

    /**
     * Вспомогательная функция: рисует скруглённый прямоугольник.
     * Используется вместо ctx.roundRect для совместимости.
     */
    function _rrect(ctx, x, y, w, h, r) {
      const R = Math.min(r, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + R, y);
      ctx.lineTo(x + w - R, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + R);
      ctx.lineTo(x + w, y + h - R);
      ctx.quadraticCurveTo(x + w, y + h, x + w - R, y + h);
      ctx.lineTo(x + R, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - R);
      ctx.lineTo(x, y + R);
      ctx.quadraticCurveTo(x, y, x + R, y);
      ctx.closePath();
    }

    /**
     * Рисует полосу вероятности победы в верхней части игрового canvas.
     * Stargazer: тонкая линия-дорожка + скользящая светящаяся точка на позиции split.
     * Остальные темы: двухцветная полоска в цветах темы (accent слева, мuted справа).
     */
    function drawProbBar() {
      const barW  = W * 0.90;
      const barX  = (W - barW) / 2;
      const barY  = 10;
      const p0    = Math.max(0, Math.min(1, _probBarDisplay));
      const split = barX + barW * p0;
      const t     = T();

      ctx.save();

      if (activeTheme === 'stargazer') {
        // ── Stargazer: одна линия + скользящая светящаяся точка ──
        const midY = barY + 4;

        // Дорожка (едва заметная тонкая линия)
        ctx.fillStyle = 'rgba(248,247,245,0.09)';
        ctx.fillRect(barX, midY - 0.75, barW, 1.5);

        // Внешнее мягкое свечение точки
        const glow = ctx.createRadialGradient(split, midY, 0, split, midY, 16);
        glow.addColorStop(0, 'rgba(225,223,220,0.38)');
        glow.addColorStop(1, 'rgba(225,223,220,0)');
        ctx.fillStyle = glow;
        ctx.fillRect(split - 16, midY - 16, 32, 32);

        // Среднее кольцо
        const mid = ctx.createRadialGradient(split, midY, 0, split, midY, 5.5);
        mid.addColorStop(0,   'rgba(248,247,245,0.95)');
        mid.addColorStop(0.45,'rgba(225,223,220,0.65)');
        mid.addColorStop(1,   'rgba(225,223,220,0)');
        ctx.fillStyle = mid;
        ctx.beginPath();
        ctx.arc(split, midY, 5.5, 0, Math.PI * 2);
        ctx.fill();

        // Яркое ядро
        ctx.beginPath();
        ctx.arc(split, midY, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(248,247,245,0.96)';
        ctx.fill();

      } else {
        // ── Остальные темы: двухцветная полоска в цветах темы ──
        const barH  = 5;
        const r     = 2.5;
        const accentRaw = t.accent || t.lines;

        // Правая дорожка (игрок 1, мuted)
        _rrect(ctx, barX, barY, barW, barH, r);
        ctx.fillStyle = 'rgba(128,128,128,0.14)';
        ctx.fill();

        // Левый сегмент (игрок 0, цвет акцента темы)
        if (p0 > 0.01) {
          _rrect(ctx, barX, barY, barW * p0, barH, r);
          ctx.fillStyle = accentRaw;
          ctx.globalAlpha = 0.72;
          ctx.fill();
          ctx.globalAlpha = 1;
        }

        // Маркер на границе раздела
        ctx.beginPath();
        ctx.arc(split, barY + barH / 2, 3, 0, Math.PI * 2);
        ctx.fillStyle = accentRaw;
        ctx.fill();
      }

      ctx.restore();
    }

    /**
     * Запускает плавную анимацию полосы вероятности к _probBarTarget.
     * Каждый кадр: display += (target − display) × 0.06.
     */
    function startProbBarAnim() {
      if (_probBarRaf) { cancelAnimationFrame(_probBarRaf); _probBarRaf = null; }
      _probBarDisplay = _probBarTarget;
      const fill = document.getElementById('prob-bar-fill');
      if (fill) fill.style.width = (_probBarTarget * 100).toFixed(1) + '%';
    }

    // ── last move ─────────────────────────────────────────────────────────────

    /**
     * Показывает или скрывает кнопку «Последний ход» в зависимости от того,
     * был ли уже сделан хотя бы один ход. Вызывается после каждого хода.
     */
    function updateLastMoveBtn() {
      document.getElementById('last-move-btn')
        .classList.toggle('visible', lines.size > 0);
    }

    /**
     * Запускает анимацию подсветки последнего хода: за 400мс (200мс вверх + 200мс вниз)
     * толщина линии плавно возрастает от базовой до 2× базовой и возвращается обратно.
     *
     * Если анимация уже идёт — перезапускает её с нуля.
     * Использует requestAnimationFrame для покадровой интерполяции.
     */
    function animateLastMove() {
      if (!lastMove) return;
      if (lastMoveAnimRaf) { cancelAnimationFrame(lastMoveAnimRaf); lastMoveAnimRaf = null; }

      const DURATION = 400; // мс: 200 вверх + 200 вниз
      const start = performance.now();

      /**
       * Покадровый callback requestAnimationFrame.
       * t — нормализованный прогресс анимации [0..1] относительно DURATION.
       * lastMoveAnimT — треугольная огибающая: 0→1 за первую половину,
       * 1→0 за вторую; draw() использует её для интерполяции толщины линии.
       * @param {DOMHighResTimeStamp} now — метка времени от rAF
       */
      function frame(now) {
        const t = Math.min((now - start) / DURATION, 1);
        // Треугольная огибающая: 0→1 за первые 200мс, 1→0 за вторые 200мс
        lastMoveAnimT = t < 0.5 ? t * 2 : (1 - t) * 2;
        draw();
        if (t < 1) {
          lastMoveAnimRaf = requestAnimationFrame(frame); // продолжаем анимацию
        } else {
          lastMoveAnimT = 0;
          lastMoveAnimRaf = null;
          draw(); // финальный кадр без подсветки
        }
      }

      lastMoveAnimRaf = requestAnimationFrame(frame);
    }

    document.getElementById('last-move-btn').addEventListener('click', animateLastMove);

    // ── events ────────────────────────────────────────────────────────────────
    //
    // Взаимодействие с canvas реализовано через три обработчика:
    //
    // mousemove  — отслеживает ближайшую к курсору точку (hovered), кэширует
    //              результат validate() для отрисовки превью линии в draw().
    //              Перерисовка происходит только если hovered изменился — оптимизация.
    //
    // mouseleave — сбрасывает hovered и превью при уходе курсора с canvas,
    //              чтобы убрать подсветку и пунктирную линию.
    //
    // click      — двухкликовая модель выбора хода:
    //              1-й клик по точке: записывает в selected
    //              2-й клик по той же точке: снимает выделение
    //              2-й клик по другой точке: проверяет ход через validate();
    //                при успехе — применяет через applyMove() (или напрямую для
    //                отслеживания AI-очереди) и если isAI — запускает
    //                setTimeout(makeAIMove, 800) для имитации «раздумья» ИИ.
    //              Клик в пустоту: сбрасывает selected.

    /**
     * Обработчик движения мыши по canvas.
     * Вычисляет ближайшую точку к курсору в радиусе RADIUS+8 пикселей.
     * Если точка изменилась — пересчитывает previewValidation и перерисовывает поле.
     * previewValidation кэшируется здесь, а не в draw(), чтобы не вызывать
     * validate() на каждый кадр при неподвижном курсоре.
     */
    canvas.addEventListener('mousemove', e => {
      if (gameOver) return;
      const [mx, my] = _evXY(e, canvas);
      const prev = hovered;
      // Ищем точку в радиусе RADIUS+8 (увеличенная зона захвата для удобства)
      hovered = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);
      if (hovered !== prev) {
        // Обновляем превью валидации только если есть выбранная точка и новая цель
        previewValidation = (selected !== -1 && hovered !== -1 && hovered !== selected)
          ? validate(selected, hovered) : null;
        draw();
      }
    });

    /**
     * Обработчик ухода курсора за границу canvas.
     * Сбрасывает hovered и previevValidation — убирает подсветку и пунктирную линию.
     */
    canvas.addEventListener('mouseleave', () => {
      if (gameOver) return;
      hovered = -1; previewValidation = null; draw();
    });

    // Touch support for mobile
    canvas.addEventListener('touchstart', e => {
      e.preventDefault();
      if (gameOver) return;
      const t = e.touches[0];
      const r = canvas.getBoundingClientRect();
      const sx = canvas.width / r.width, sy = canvas.height / r.height;
      const mx = (t.clientX - r.left) * sx, my = (t.clientY - r.top) * sy;
      const prev = hovered;
      hovered = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);
      if (hovered !== prev) {
        previewValidation = (selected !== -1 && hovered !== -1 && hovered !== selected)
          ? validate(selected, hovered) : null;
        draw();
      }
    }, { passive: false });

    canvas.addEventListener('touchend', e => {
      e.preventDefault();
      const t = e.changedTouches[0];
      canvas.dispatchEvent(new MouseEvent('click', { clientX: t.clientX, clientY: t.clientY, bubbles: true }));
    }, { passive: false });

    /**
     * Обработчик клика по canvas — основная логика ввода хода игрока.
     *
     * Состояния selected:
     *   -1 → нет выбранной точки; первый клик устанавливает selected
     *   ≥0 → точка выбрана; второй клик применяет ход или снимает выделение
     *
     * После успешного хода:
     *   — проверяется конец игры (isGameOver)
     *   — если режим AI и сейчас ход Звездочёта — запускается makeAIMove с задержкой 800мс
     *     (имитирует «раздумье» и даёт игроку увидеть свой ход до ответа AI)
     */
    canvas.addEventListener('click', e => {
      if (gameOver || _lineAnimating) return;

      // Tutorial: intercept all clicks while a tooltip is showing
      if (_tutorialBlocked) {
        if (_tutorialBtnRect) {
          const [mx, my] = _evXY(e, canvas);
          const btn = _tutorialBtnRect;
          if (mx >= btn.x && mx <= btn.x + btn.w && my >= btn.y && my <= btn.y + btn.h)
            startDismissTutorial();
        }
        return;
      }

      const [mx, my] = _evXY(e, canvas);
      // Ищем точку под курсором (та же расширенная зона захвата, что и в mousemove)
      const i = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);

      if (i === -1) {
        // Клик в пустоту — снимаем выделение
        selected = -1; previewValidation = null; draw(); return;
      }

      if (selected === -1) {
        // Первый клик: выбираем точку
        selected = i; clearError();
        // Tutorial moment 1: first point ever selected
        if (_tutorialMode && _tutorialStep === 0) {
          _tutorialStep = 1;
          _tutorialPulseIdx = i;
          _tutorialPulseStart = performance.now();
          const px = points[i].x, py = points[i].y;
          const tx = (px + 30 + 300 > W) ? px - 330 : px + 30;
          const ty = (py - 90 < 10) ? py + 20 : py - 90;
          showTutorialTooltip(
            'Ты поставила первую звезду ✦\nСоединяй их линиями, чтобы поймать созвездие',
            tx, ty
          );
        }
      } else if (selected === i) {
        // Повторный клик по той же точке: отменяем выбор
        selected = -1; previewValidation = null;
      } else {
        // Второй клик по другой точке: пытаемся сделать ход
        const v = validate(selected, i);
        if (!v.ok) {
          showError(v.reason); // показываем причину отказа
        } else {
          // Ход валиден — анимируем линию, затем применяем
          const _sa = selected, _sb = i;
          clearError(); selected = -1; previewValidation = null;
          _lineAnimating = true;
          _lineAnim = { a: _sa, b: _sb, player: currentPlayer, startT: performance.now() };
          _startLineAnimLoop();
          setTimeout(() => {
            _lineAnim = null; _lineAnimating = false;
            lastMove = { a: _sa, b: _sb };
            lines.set(lineKey(_sa, _sb), currentPlayer);
            checkScore(_sa, _sb, currentPlayer);
            currentPlayer = 1 - currentPlayer;
            _isGameOverCache = null;
            updateUI(); updateLastMoveBtn();
            checkTutorialMoments();
            computeHints();
            if (isGameOver()) { endGame(); return; }
            _probBarTarget = estimateWinProbability(); startProbBarAnim();
            if (isAI && currentPlayer === 1) {
              if (_tutorialMode) document.getElementById('turn-display').textContent = 'Звездочёт ходит…';
              setTimeout(makeAIMove, 800);
            }
          }, 200);
        }
      }
      draw();
    });

    // ── Home screen background constellation animation ─────────────────────────
    let _homeBgRaf = null;
    let _homeBgData = null;
    let _homeBgTwinkle = [];

    function _stopHomeBgAnim() {
      if (_homeBgRaf) { cancelAnimationFrame(_homeBgRaf); _homeBgRaf = null; }
    }

    function _startHomeBgAnim() {
      _stopHomeBgAnim();
      let saved = [];
      try { saved = JSON.parse(localStorage.getItem('saved_constellations') || '[]'); } catch(e) {}
      _homeBgData = saved.length ? saved[Math.floor(Math.random() * saved.length)] : null;

      const cv = document.getElementById('home-bg-canvas');
      if (!cv) return;

      if (_homeBgData && _homeBgData.points) {
        _homeBgTwinkle = _homeBgData.points.map(() => ({
          phase: Math.random() * Math.PI * 2,
          speed: 0.5 + Math.random() * 0.9
        }));
      }

      function loop(ts) {
        const scr = document.getElementById('home-screen');
        if (!scr || scr.style.display === 'none') { _homeBgRaf = null; return; }
        const pw = scr.offsetWidth || window.innerWidth;
        const ph = scr.offsetHeight || window.innerHeight;
        if (cv.width !== pw * (window.devicePixelRatio||1) | 0) {
          cv.width  = Math.round(pw * (window.devicePixelRatio||1));
          cv.height = Math.round(ph * (window.devicePixelRatio||1));
          cv.style.width  = pw + 'px';
          cv.style.height = ph + 'px';
        }
        const ctx2 = cv.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        ctx2.clearRect(0, 0, cv.width, cv.height);
        ctx2.save();
        ctx2.scale(dpr, dpr);

        if (_homeBgData && _homeBgData.points && _homeBgData.points.length > 0) {
          const pts = _homeBgData.points;
          let mnx = 1, mxx = 0, mny = 1, mxy = 0;
          pts.forEach(p => {
            mnx = Math.min(mnx, p.x); mxx = Math.max(mxx, p.x);
            mny = Math.min(mny, p.y); mxy = Math.max(mxy, p.y);
          });
          const span = Math.max(mxx - mnx, mxy - mny, 0.01);
          // Use square reference so constellation keeps aspect ratio and is ~40% of screen width
          const S_ref = Math.min(pw, ph);
          const scalePx = (S_ref * 0.54) / span;
          const cx0 = pw * 0.5, cy0 = ph * 0.44; // slightly above center
          const mpx = pt => cx0 + (pt.x - (mnx+mxx)/2) * scalePx;
          const mpy = pt => cy0 + (pt.y - (mny+mxy)/2) * scalePx;

          const lns = _homeBgData.lines || [];
          const plgs = _homeBgData.polygons || [];

          // polygons fill
          const _thHome = THEMES[activeTheme] || THEMES.stargazer;
          const _homeLineClr = _thHome.lines || 'rgba(248,247,245,0.88)';
          const _homeFillClr = _thHome.captured || 'rgba(255,235,200,0.04)';
          plgs.forEach(poly => {
            if (!poly.path || poly.path.length < 3) return;
            ctx2.beginPath();
            poly.path.forEach((idx, i) => {
              const pt = pts[idx];
              if (i === 0) ctx2.moveTo(mpx(pt), mpy(pt));
              else ctx2.lineTo(mpx(pt), mpy(pt));
            });
            ctx2.closePath();
            ctx2.fillStyle = _homeFillClr;
            ctx2.fill();
          });

          // 3-pass lines
          const lw1 = Math.max(3, pw * 0.018);
          const lw2 = Math.max(1.0, pw * 0.007);
          const lw3 = Math.max(0.4, pw * 0.0025);
          for (let pass = 0; pass < 3; pass++) {
            ctx2.beginPath();
            lns.forEach(([key]) => {
              const [a, b] = key.split('-').map(Number);
              if (a < pts.length && b < pts.length) {
                ctx2.moveTo(mpx(pts[a]), mpy(pts[a]));
                ctx2.lineTo(mpx(pts[b]), mpy(pts[b]));
              }
            });
            if (pass === 0) { ctx2.strokeStyle = _homeLineClr; ctx2.lineWidth = lw1; ctx2.globalAlpha = 0.05; }
            else if (pass === 1) { ctx2.strokeStyle = _homeLineClr; ctx2.lineWidth = lw2; ctx2.globalAlpha = 0.15; }
            else { ctx2.strokeStyle = _homeLineClr; ctx2.lineWidth = lw3; ctx2.globalAlpha = 0.75; }
            ctx2.stroke();
            ctx2.globalAlpha = 1;
          }

          // stars with twinkling
          const deg = new Array(pts.length).fill(0);
          lns.forEach(([key]) => {
            const [a, b] = key.split('-').map(Number);
            if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
          });
          const prevR = RADIUS;
          RADIUS = Math.max(2, Math.round(pw * 0.014));
          pts.forEach((pt, i) => {
            const tw = _homeBgTwinkle[i];
            const boost = tw ? 0.25 + 0.75 * (0.5 + 0.5 * Math.sin(ts * 0.001 * tw.speed + tw.phase)) : 0.4;
            drawStarPointTo(ctx2, mpx(pt), mpy(pt), Math.max(deg[i], 2), false, false, false, boost * 0.65);
          });
          ctx2.filter = 'none';
          RADIUS = prevR;
        }

        ctx2.restore();
        _homeBgRaf = requestAnimationFrame(loop);
      }
      _homeBgRaf = requestAnimationFrame(loop);
    }

    /** Show the home screen, populate with current player data, hide #start. */
    function showHomeScreen() {
      const p    = loadProgress();
      const name = localStorage.getItem('playerName') || '—';
      document.getElementById('home-player-name').textContent = name;
      document.getElementById('home-rating-pts').textContent  = 'score: ' + p.rating + ' ✦';
      _startHomeBgAnim();
      document.getElementById('home-screen').style.display = 'flex';
      document.getElementById('start').style.display = 'none';
    }

    // ── rank-up ceremony ───────────────────────────────────────────────────────

    /**
     * Show rank-up ceremony on canvas: dark starfield, rank name, emblem.
     * Fades in 800ms, holds 2500ms, calls finishEndGame() when done.
     */
    function startRankUpCeremony(rankInfo) {
      _rankUpActive = true;
      const startMs = performance.now();
      const FADE_IN = 800, HOLD = 2500, FADE_OUT = 500;
      const TOTAL = FADE_IN + HOLD + FADE_OUT;

      function frame() {
        const elapsed = performance.now() - startMs;
        if (elapsed >= TOTAL) {
          _rankUpActive = false;
          _rankUpRaf = null;
          finishEndGame();
          return;
        }

        // Alpha envelope
        let alpha;
        if      (elapsed < FADE_IN)         alpha = elapsed / FADE_IN;
        else if (elapsed < FADE_IN + HOLD)  alpha = 1;
        else                                alpha = 1 - (elapsed - FADE_IN - HOLD) / FADE_OUT;

        ctx.clearRect(0, 0, W, H);
        ctx.save();

        // Dark background
        ctx.globalAlpha = alpha;
        ctx.fillStyle = '#050510';
        ctx.fillRect(0, 0, W, H);

        // Starfield (deterministic, seeded by rank)
        const rk = rankInfo.rank;
        for (let i = 0; i < 180; i++) {
          const sx = Math.abs(Math.sin(i * 127.3 + rk * 11)) * W;
          const sy = Math.abs(Math.cos(i * 73.9  + rk * 7))  * H;
          const sr = 0.4 + Math.abs(Math.sin(i * 211)) * 1.3;
          const sb = 0.25 + 0.55 * Math.abs(Math.sin(i * 333 + performance.now() / 3000));
          ctx.globalAlpha = alpha * sb;
          ctx.fillStyle = '#ffffff';
          ctx.beginPath();
          ctx.arc(sx, sy, sr, 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.globalAlpha = alpha;

        // Sub-text
        ctx.fillStyle = 'rgba(248,247,245,0.75)';
        ctx.font = '20px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('Новый ранг разблокирован', W / 2, H / 2 - 72);

        // Rank name
        ctx.fillStyle = '#C0BDBA';
        ctx.font = 'bold 42px serif';
        ctx.fillText(rankInfo.name, W / 2, H / 2 - 24);

        // Sub-rank numeral (I / II / III)
        ctx.fillStyle = 'rgba(220,218,215,0.7)';
        ctx.font = '24px serif';
        ctx.fillText(['','I','II','III'][rankInfo.subRank], W / 2, H / 2 + 18);

        // Emblem
        drawRankEmblem(rankInfo.rank, W / 2, H / 2 + 100);

        ctx.restore();
        _rankUpRaf = requestAnimationFrame(frame);
      }
      _rankUpRaf = requestAnimationFrame(frame);
    }

    // ── journey screen ("Мой путь") ─────────────────────────────────────────────

    const ACHIEVEMENTS = [
      // ── Победы ──────────────────────────────────────────────────────
      { id: 'first_win',    icon: '✦',  label: 'Первое\nсозвездие',    desc: 'Выиграй первую партию',                        cat: 'win'   },
      { id: 'win10',        icon: '⭐', label: 'Охотник',               desc: 'Одержи 10 побед',                              cat: 'win'   },
      { id: 'streak3',      icon: '💫', label: 'Три\nподряд',           desc: 'Выиграй 3 партии подряд',                      cat: 'win'   },
      { id: 'streak5',      icon: '☄️', label: 'Пять\nзвёзд',           desc: 'Выиграй 5 партий подряд',                      cat: 'win'   },
      { id: 'perfect',      icon: '🔭', label: 'Идеальная\nпартия',    desc: 'Победи, не дав сопернику ни одной линии',      cat: 'win'   },
      { id: 'long_win',     icon: '🌠', label: 'Долгий\nпуть',          desc: 'Победи в длинной партии (21 точка)',           cat: 'win'   },
      // ── Исследование ────────────────────────────────────────────────
      { id: 'games10',      icon: '🌙', label: 'Путник',                desc: 'Сыграй 10 партий',                             cat: 'play'  },
      { id: 'games50',      icon: '🌌', label: 'Странник',              desc: 'Сыграй 50 партий',                             cat: 'play'  },
      // ── Небо ────────────────────────────────────────────────────────
      { id: 'sky5',         icon: '🌟', label: 'Небесная\nколлекция',   desc: 'Сохрани 5 созвездий в своё небо',              cat: 'sky'   },
      // ── Темы ────────────────────────────────────────────────────────
      { id: 'stargazer5',   icon: '🌑', label: 'Ночной\nнаблюдатель',  desc: 'Сыграй 5 партий в теме Stargazer',             cat: 'theme' },
      { id: 'chalk10',      icon: '✏',  label: 'Мастер\nчернил',       desc: 'Сыграй 10 партий в теме Chalk',                cat: 'theme' },
      { id: 'suprematist5', icon: '◻',  label: 'Супрематист',           desc: 'Сыграй 5 партий в теме Suprematist',          cat: 'theme' },
      // ── Ранги ───────────────────────────────────────────────────────
      { id: 'rank3',        icon: '◈',  label: 'Следопыт',              desc: 'Достигни ранга Следопыт (ранг 3)',             cat: 'rank'  },
      { id: 'rank5',        icon: '✦',  label: 'Хранитель',             desc: 'Достигни ранга Хранитель (ранг 5)',            cat: 'rank'  },
      { id: 'legend',       icon: '👑', label: 'Архитектор\nСозвездий', desc: 'Достигни высшего ранга — Архитектор Созвездий', cat: 'rank'  },
    ];

    // Pairs of ACHIEVEMENTS indices for canvas dashed-line connections (legacy)
    const ACH_CAT_EDGES = [[0,1],[1,2],[2,3],[3,4],[4,5], [6,7], [9,10],[10,11], [12,13],[13,14]];

    let _journeyRaf     = null;
    let _journeyTooltip = null; // {idx} of hovered achievement star, or null
    let _journeyCanvas  = null;
    let _journeyCtx     = null;
    let _journeyJustOpened = 0; // performance.now() when screen opened

    /** Unlock newly-met achievements. Mutates p in-place. */
    function checkAchievements(p) {
      const now = Date.now();
      p.achievementsUnlocked = p.achievementsUnlocked || [];
      const unlocked = new Set(p.achievementsUnlocked.map(a => a.id));
      const savedCount = JSON.parse(localStorage.getItem('saved_constellations') || '[]').length;
      const checks = [
        ['first_win',    () => p.gamesWon >= 1],
        ['win10',        () => p.gamesWon >= 10],
        ['streak3',      () => (p.bestStreak || 0) >= 3],
        ['streak5',      () => (p.bestStreak || 0) >= 5],
        ['perfect',      () => (p.perfectWins || 0) >= 1],
        ['long_win',     () => (p.longWins || 0) >= 1],
        ['games10',      () => p.gamesPlayed >= 10],
        ['games50',      () => p.gamesPlayed >= 50],
        ['sky5',         () => savedCount >= 5],
        ['chalk10',      () => (p.chalkGames || 0) >= 10],
        ['stargazer5',   () => (p.stargazerGames || 0) >= 5],
        ['suprematist5', () => (p.suprematistGames || 0) >= 5],
        ['rank3',        () => p.rank >= 3],
        ['rank5',        () => p.rank >= 5],
        ['legend',       () => p.rank >= 10],
      ];
      checks.forEach(([id, fn]) => {
        if (!unlocked.has(id) && fn()) p.achievementsUnlocked.push({ id, ts: now });
      });
    }

    /** Most-played theme display name from progress data. */
    function getFavouriteTheme(p) {
      const counts = { 'Stargazer': p.stargazerGames || 0, 'Chalk': p.chalkGames || 0, 'Suprematist': p.suprematistGames || 0 };
      let best = 'Stargazer', bestN = -1;
      Object.entries(counts).forEach(([k, v]) => { if (v > bestN) { best = k; bestN = v; } });
      return best;
    }

    /** Compute absolute positions for the 8 achievement stars. */
    function getAchStarPositions(JW, JH) {
      return [
        [0.08, 0.80], // first_win
        [0.22, 0.73], // streak3
        [0.36, 0.79], // perfect
        [0.49, 0.70], // chalk10
        [0.61, 0.76], // stargazer5
        [0.73, 0.70], // suprematist5
        [0.83, 0.76], // long_win
        [0.93, 0.70], // legend
      ].map(([rx, ry]) => ({ x: rx * JW, y: ry * JH }));
    }

    // ── Helpers: load/persist saved constellations ────────────────────────────
    function _loadSaved() {
      try { return JSON.parse(localStorage.getItem('saved_constellations') || '[]'); } catch(e) { return []; }
    }
    function _persistSaved(arr) {
      localStorage.setItem('saved_constellations', JSON.stringify(arr));
    }

    // Generate deterministic "nebula address" for a constellation name
    function _constellationAddress(name) {
      const ADJ  = ['Тёмная','Северная','Малая','Дальняя','Тихая','Древняя','Туманная','Холодная','Тонкая','Звёздная'];
      const NOUN = ['Зари','Крыла','Тени','Пути','Звезды','Вуали','Кольца','Завесы','Дуги','Паутины'];
      const h    = k => _skyHash(name + k);
      const adj  = ADJ [Math.floor(h('_na') * ADJ.length)];
      const noun = NOUN[Math.floor(h('_nn') * NOUN.length)];
      const margin = 200;
      const wx   = margin + h('_x') * (_SKY_WORLD - 2 * margin);
      const wy   = margin + h('_y') * (_SKY_WORLD - 2 * margin);
      const coord = (wx * 33.33 + 10000).toFixed(0) + '.' + (wy * 33.33).toFixed(2).replace('.','');
      return `Туманность ${adj} ${noun}  ${coord}`;
    }

    /** Render the journey grid — thumbnail + name only, tap opens detail screen. */
    function _renderJourneyGrid() {
      const grid = document.getElementById('journey-grid');
      if (!grid) return;
      grid.innerHTML = '';
      const saved = _loadSaved();
      if (saved.length === 0) {
        grid.innerHTML = '<div class="journey-empty">Победи в игре и сохрани<br>своё первое созвездие ✦</div>';
        return;
      }
      saved.forEach((item, idx) => {
        const card = document.createElement('div');
        card.className = 'saved-card';
        card.addEventListener('click', () => openConstDetail(item, idx));

        const thumb = document.createElement('canvas');
        thumb.width = 240; thumb.height = 240;
        drawMiniConstellation(thumb, item);

        const info = document.createElement('div');
        info.className = 'saved-card-info';
        const nameEl = document.createElement('div');
        nameEl.className = 'saved-card-name';
        nameEl.textContent = item.name || 'Без названия';
        info.append(nameEl);

        card.append(thumb, info);
        grid.append(card);
      });
    }

    /** Open the sky hub screen (Мои созвездия / Небо picker). */
    /**
     * Открывает экран-хаб «Sky» из главного меню.
     * Останавливает фоновую анимацию созвездия на home-screen чтобы не тратить RAF.
     */
    function openSkyHub() {
      _stopHomeBgAnim();
      document.getElementById('home-screen').style.display = 'none';
      document.getElementById('sky-hub-screen').style.display = 'flex';
    }

    /** Закрывает sky-hub, возвращает на главный экран (запускает фоновую анимацию). */
    function closeSkyHub() {
      document.getElementById('sky-hub-screen').style.display = 'none';
      showHomeScreen();
    }

    // Tracks which screen journey should return to on back-press
    let _journeyReturnTo = 'sky-hub-screen';

    /** Open the "Мои созвездия" screen and populate from localStorage.
     *  @param {string} [returnTo='sky-hub-screen'] — element id to restore on back */
    function openJourneyScreen(returnTo) {
      // Guard: if called as a direct event listener, returnTo will be a MouseEvent — ignore it
      _journeyReturnTo = (typeof returnTo === 'string' ? returnTo : null) || 'sky-hub-screen';
      if (_journeyRaf) { cancelAnimationFrame(_journeyRaf); _journeyRaf = null; }
      _renderJourneyGrid();
      // Hide the screen we came from (default: sky-hub-screen)
      const fromEl = document.getElementById(_journeyReturnTo);
      if (fromEl) fromEl.style.display = 'none';
      // Also hide sky-hub if it's not already the returnTo (it may still be open underneath)
      if (_journeyReturnTo !== 'sky-hub-screen') {
        const sh = document.getElementById('sky-hub-screen');
        if (sh) sh.style.display = 'none';
      }
      document.getElementById('journey').style.display = 'flex';
    }

    /** Close the journey screen. */
    function closeJourneyScreen() {
      if (_journeyRaf) { cancelAnimationFrame(_journeyRaf); _journeyRaf = null; }
      document.getElementById('journey').style.display = 'none';
    }

    // ── Achievements screen ("Мой путь") ─────────────────────────────────────

    let _achEmblemRaf = null;

    function openAchievementsScreen() {
      _loadAchievementsUI();
      document.getElementById('achievements-screen').style.display = 'flex';
    }

    function closeAchievementsScreen() {
      if (_achEmblemRaf) { cancelAnimationFrame(_achEmblemRaf); _achEmblemRaf = null; }
      document.getElementById('achievements-screen').style.display = 'none';
    }

    function _loadAchievementsUI() {
      const p    = loadProgress();
      const info = computeRank(p.rating);

      // ── Rank emblem (animated canvas) ──
      const emblemCanvas = document.getElementById('ach-rank-emblem');
      if (emblemCanvas) {
        const ectx = emblemCanvas.getContext('2d');
        const CW = emblemCanvas.width, CH = emblemCanvas.height;
        if (_achEmblemRaf) { cancelAnimationFrame(_achEmblemRaf); _achEmblemRaf = null; }
        function _drawEmblem() {
          ectx.clearRect(0, 0, CW, CH);
          drawRankEmblemOnCtx(ectx, info.rank, CW / 2, CH / 2);
          _achEmblemRaf = requestAnimationFrame(_drawEmblem);
        }
        _drawEmblem();
      }

      // ── Rank info ──
      document.getElementById('ach-rank-name').textContent    = `Ранг ${info.rank}  ·  ${info.title}`;
      document.getElementById('ach-rank-rating').textContent  = `${p.rating} ✦`;
      const pct = Math.round((info.progress || 0) * 100);
      document.getElementById('ach-rank-bar-fill').style.width = pct + '%';
      document.getElementById('ach-rank-next').textContent =
        info.nextThreshold !== null
          ? `до следующего ранга: ${info.nextThreshold - p.rating} ✦`
          : 'Максимальный ранг ✦';

      // ── Achievement lists ──
      const unlocked  = new Set((p.achievementsUnlocked || []).map(a => a.id));
      const unlockTs  = new Map((p.achievementsUnlocked || []).map(a => [a.id, a.ts]));

      ['win', 'play', 'sky', 'theme', 'rank'].forEach(cat => {
        const container = document.getElementById('ach-list-' + cat);
        if (!container) return;
        container.innerHTML = '';
        container.style.cssText = 'display:flex;flex-direction:column;gap:6px;';
        ACHIEVEMENTS.filter(a => a.cat === cat).forEach(ach => {
          const isUnlocked = unlocked.has(ach.id);
          const ts = unlockTs.get(ach.id);
          const dateStr = ts ? new Date(ts).toLocaleDateString('ru-RU') : '';
          const item = document.createElement('div');
          item.className = 'ach-item' + (isUnlocked ? ' unlocked' : ' locked');
          item.innerHTML =
            '<div class="ach-icon">' + (ach.icon || '✦') + '</div>' +
            '<div class="ach-text">' +
              '<div class="ach-name">' + ach.label.replace('\n', ' ') + '</div>' +
              '<div class="ach-desc">' + (isUnlocked && dateStr ? 'Открыто ' + dateStr : ach.desc) + '</div>' +
            '</div>' +
            '<div class="ach-check">' + (isUnlocked ? '✦' : '○') + '</div>';
          container.appendChild(item);
        });
      });
    }

    /** Draw the full journey screen each frame. */
    function drawJourneyScreen() {
      if (!_journeyCtx) return;
      const jctx = _journeyCtx;
      const JW   = _journeyCanvas.width;
      const JH   = _journeyCanvas.height;
      const now  = performance.now();
      const p    = loadProgress();
      const info = computeRank(p.rating);
      const achMap   = new Map((p.achievementsUnlocked || []).map(a => [a.id, a]));
      const unlocked = new Set(achMap.keys());

      // ── Background ──────────────────────────────────────────────────
      jctx.clearRect(0, 0, JW, JH);
      jctx.fillStyle = '#0A0A1A';
      jctx.fillRect(0, 0, JW, JH);

      // Deterministic twinkling background stars
      for (let i = 0; i < 220; i++) {
        const sx = Math.abs(Math.sin(i * 127.3 + 3)) * JW;
        const sy = Math.abs(Math.cos(i * 73.9  + 5)) * JH;
        const sr = 0.4 + Math.abs(Math.sin(i * 211)) * 1.2;
        const sb = 0.10 + 0.18 * Math.abs(Math.sin(now / 3000 + i * 0.53));
        jctx.globalAlpha = sb;
        jctx.fillStyle = '#ffffff';
        jctx.beginPath(); jctx.arc(sx, sy, sr, 0, Math.PI * 2); jctx.fill();
      }
      jctx.globalAlpha = 1;

      // ── TOP — player card ────────────────────────────────────────────
      const topCX = JW / 2;
      const topY  = 44;

      // Player name
      jctx.fillStyle = 'rgba(248,247,245,0.90)';
      jctx.font = 'bold 28px system-ui, sans-serif';
      jctx.textAlign = 'center'; jctx.textBaseline = 'top';
      jctx.fillText(localStorage.getItem('playerName') || 'Путешественник', topCX, topY);

      // Rank title
      jctx.fillStyle = '#C0BDBA';
      jctx.font = '18px system-ui, sans-serif';
      jctx.fillText(info.title, topCX, topY + 36);

      // Rating
      jctx.fillStyle = 'rgba(248,247,245,0.45)';
      jctx.font = '13px system-ui, sans-serif';
      jctx.fillText(`${p.rating} \u2726`, topCX, topY + 62);

      // Progress bar to next rank
      const barW = Math.min(280, JW * 0.32);
      const barH = 6;
      const barX = topCX - barW / 2;
      const barY = topY + 84;
      jctx.globalAlpha = 1;
      jctx.fillStyle = 'rgba(248,247,245,0.10)';
      jctx.fillRect(barX, barY, barW, barH);
      if (info.progress > 0) {
        const g = jctx.createLinearGradient(barX, 0, barX + barW, 0);
        g.addColorStop(0, '#C0BDBA'); g.addColorStop(1, '#F0D080');
        jctx.fillStyle = g;
        jctx.fillRect(barX, barY, barW * info.progress, barH);
      }
      if (info.nextThreshold !== null) {
        jctx.fillStyle = 'rgba(248,247,245,0.30)';
        jctx.font = '11px system-ui, sans-serif';
        jctx.fillText(`до следующего ранга: ${info.nextThreshold - p.rating} \u2726`, topCX, barY + barH + 7);
      }

      // Rank emblem — right side, rotating 1 full turn per 30 s
      const emblemX = Math.min(topCX + barW / 2 + 82, JW - 68);
      const emblemY = topY + 64;
      jctx.save();
      jctx.translate(emblemX, emblemY);
      jctx.rotate((now / 30000) * Math.PI * 2);
      drawRankEmblemOnCtx(jctx, info.rank, 0, 0);
      jctx.restore();

      // ── MIDDLE — stats grid (2 rows × 3 cols) ───────────────────────
      const gridY      = topY + 120;
      const cellW      = Math.min(170, JW / 4.2);
      const cellH      = 62;
      const cols       = 3;
      const gridLeft   = topCX - (cols * cellW) / 2;
      const winPct     = p.gamesPlayed > 0 ? Math.round(100 * p.gamesWon / p.gamesPlayed) : 0;
      const aiLvlNames = ['—','Начинающий','Любопытный','Опытный','Мудрый','Звездочёт'];
      const stats = [
        ['Партий сыграно', p.gamesPlayed],
        ['Побед',          p.gamesWon],
        ['% побед',        `${winPct}%`],
        ['Лучшая серия',   p.bestStreak || 0],
        ['Любимая тема',   getFavouriteTheme(p)],
        ['Уровень ИИ',     aiLvlNames[rankToAiLevel()] || '—'],
      ];

      stats.forEach(([label, val], i) => {
        const col = i % cols;
        const row = Math.floor(i / cols);
        const cx  = gridLeft + col * cellW + cellW / 2;
        const cy  = gridY + row * cellH;
        jctx.globalAlpha = 1;
        // Cell bg
        jctx.fillStyle = 'rgba(248,247,245,0.04)';
        jctx.strokeStyle = 'rgba(248,247,245,0.08)'; jctx.lineWidth = 1;
        jctx.beginPath(); jctx.rect(cx - cellW / 2 + 3, cy, cellW - 6, cellH - 5); jctx.fill(); jctx.stroke();
        // Value
        jctx.fillStyle = 'rgba(248,247,245,0.88)';
        jctx.font = `bold ${typeof val === 'number' ? '20' : '14'}px system-ui, sans-serif`;
        jctx.textAlign = 'center'; jctx.textBaseline = 'middle';
        jctx.fillText(String(val), cx, cy + cellH * 0.38);
        // Label
        jctx.fillStyle = 'rgba(248,247,245,0.38)';
        jctx.font = '11px system-ui, sans-serif';
        jctx.fillText(label, cx, cy + cellH * 0.72);
      });

      // ── BOTTOM — achievement constellation map ───────────────────────
      const starPos   = getAchStarPositions(JW, JH);
      const sinceOpen = now - _journeyJustOpened;

      // Category dashed lines
      jctx.save();
      jctx.strokeStyle = 'rgba(220,218,215,0.22)'; jctx.lineWidth = 1;
      jctx.setLineDash([4, 7]);
      ACH_CAT_EDGES.forEach(([ai, bi]) => {
        jctx.beginPath(); jctx.moveTo(starPos[ai].x, starPos[ai].y);
        jctx.lineTo(starPos[bi].x, starPos[bi].y); jctx.stroke();
      });
      jctx.setLineDash([]); jctx.restore();

      // Achievement stars
      ACHIEVEMENTS.forEach((ach, i) => {
        const pos        = starPos[i];
        const isUnlocked = unlocked.has(ach.id);
        const twinkle    = isUnlocked ? 0.5 + 0.5 * Math.sin(now / 800 + i * 1.37) : 0;
        const starR      = isUnlocked ? 7 + twinkle * 2 : 4;

        // Gold pulse for first 3 s on screen open (all unlocked stars)
        if (isUnlocked && sinceOpen < 3000) {
          const pulseA = ((3000 - sinceOpen) / 3000) * 0.35 * Math.abs(Math.sin(sinceOpen / 180));
          if (pulseA > 0.01) {
            jctx.globalAlpha = pulseA;
            jctx.fillStyle = '#C0BDBA';
            jctx.beginPath(); jctx.arc(pos.x, pos.y, 30, 0, Math.PI * 2); jctx.fill();
          }
        }

        // Soft glow behind unlocked star
        if (isUnlocked) {
          jctx.globalAlpha = 0.16 + twinkle * 0.16;
          jctx.fillStyle = '#C0BDBA';
          jctx.beginPath(); jctx.arc(pos.x, pos.y, 22, 0, Math.PI * 2); jctx.fill();
        }

        // Star dot
        jctx.globalAlpha = isUnlocked ? 0.80 + twinkle * 0.20 : 0.25;
        jctx.fillStyle = isUnlocked ? '#C0BDBA' : 'rgba(180,180,220,0.8)';
        jctx.beginPath(); jctx.arc(pos.x, pos.y, starR, 0, Math.PI * 2); jctx.fill();
        jctx.globalAlpha = 1;

        // Label below star (split on \n)
        jctx.fillStyle = isUnlocked ? 'rgba(248,247,245,0.65)' : 'rgba(248,247,245,0.28)';
        jctx.font = '11px system-ui, sans-serif';
        jctx.textAlign = 'center'; jctx.textBaseline = 'top';
        ach.label.split('\n').forEach((ln, li) => {
          jctx.fillText(ln, pos.x, pos.y + starR + 6 + li * 13);
        });
      });

      jctx.globalAlpha = 1;

      // ── TOOLTIP on hovered star ──────────────────────────────────────
      if (_journeyTooltip !== null) {
        const ti         = _journeyTooltip.idx;
        const ach        = ACHIEVEMENTS[ti];
        const achData    = achMap.get(ach.id);
        const isUnlocked = unlocked.has(ach.id);
        const pos        = starPos[ti];

        const line1 = ach.label.replace('\n', ' ');
        const line2 = isUnlocked
          ? (achData && achData.ts ? `Открыто ${new Date(achData.ts).toLocaleDateString('ru-RU')}` : 'Открыто')
          : ach.desc;

        const pad = 12, lineH = 20, boxW = 196, boxH = pad * 2 + 2 * lineH;
        let tx = pos.x - boxW / 2;
        let ty = pos.y - boxH - 20;
        tx = Math.max(8, Math.min(JW - boxW - 8, tx));
        ty = Math.max(8, ty);

        jctx.save();
        jctx.fillStyle = 'rgba(10,10,26,0.94)';
        jctx.strokeStyle = 'rgba(220,218,215,0.50)'; jctx.lineWidth = 1;
        jctx.beginPath(); jctx.rect(tx, ty, boxW, boxH); jctx.fill(); jctx.stroke();

        jctx.textAlign = 'center'; jctx.textBaseline = 'top';
        jctx.fillStyle = isUnlocked ? '#C0BDBA' : 'rgba(248,247,245,0.80)';
        jctx.font = 'bold 13px system-ui, sans-serif';
        jctx.fillText(line1, tx + boxW / 2, ty + pad);

        jctx.fillStyle = isUnlocked ? 'rgba(248,247,245,0.60)' : 'rgba(248,247,245,0.40)';
        jctx.font = '12px system-ui, sans-serif';
        jctx.fillText(line2, tx + boxW / 2, ty + pad + lineH);
        jctx.restore();
      }
    }

    // Journey button (start screen → journey screen)
    document.getElementById('journey-btn').addEventListener('click', () => {
      openJourneyScreen('start');
    });

    // Journey back button (journey → sky hub)
    document.getElementById('journey-back-btn').addEventListener('click', () => {
      closeJourneyScreen();
      const returnEl = document.getElementById(_journeyReturnTo);
      if (returnEl) returnEl.style.display = 'flex';
      // Restart home bg animation if returning to home screen
      if (_journeyReturnTo === 'home-screen') _startHomeBgAnim();
    });

    // ── sky screen ("Общее небо") — zoomable galaxy canvas ──────────────────

    const _SKY_WORLD      = 3000;
    const _SKY_SMAX       = 3.0;
    const _SKY_THRESH_DOT = 0.15;  // ниже → heatmap-точки (LOD1)
    const _SKY_THRESH     = 0.50;  // выше → полное созвездие (LOD3), между → galaxy (LOD2)
    const _SKY_CELL       = 300;   // размер ячейки процедурных звёзд

    let _skyMode  = 'global'; // 'global' | 'personal'
    let _skyData  = null, _skyPos = [];
    let _skyScale = 0.22, _skyOffX = 0, _skyOffY = 0;
    let _skyRaf   = null, _skyOpen = false;
    let _skyCV    = null, _skyCX  = null;
    let _skyDrag  = null, _skyPinch = null;
    let _skyAnimRaf  = null;
    let _skyLoadTimer = null;
    let _bgStars  = null; // оставляем для rank-up анимации
    const _skyBgCache = new Map(); // "cx,cy" → stars[] LRU, max 200 cells
    window._skyBgCacheRef = _skyBgCache; // регистрируем для applyTheme (без TDZ)
    let _skyBgPreStars = null; // pre-generated fully random bg stars (replaces cell hash)
    let _mySkyNames = new Set(); // names of user's own saved constellations

    /**
     * Возвращает userId текущего игрока, или null если гость.
     * 'null' (строка) из localStorage трактуется как «гость».
     */
    function _skyGetUserId() {
      const uid = localStorage.getItem('userId');
      return (!uid || uid === 'null') ? null : uid;
    }
    let _skyHighlightId    = null; // name of highlighted constellation
    let _skyHighlightPulseT = 0;  // performance.now() when pulse started (0 = off)
    const _SKY_PULSE_DUR   = 2400; // 3 × 800ms
    let _skyChannel        = null; // Supabase Realtime channel

    function _skyHash(s) {
      let h = 0x811c9dc5;
      for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 0x01000193) >>> 0; }
      return h / 0x100000000;
    }

    // Палитра тёплых оттенков для фоновых звёзд
    const _BG_COLORS = [
      '255,252,245', // молочно-белый
      '255,245,220', // тёплый кремовый
      '255,230,190', // янтарный отблеск
      '240,235,255', // холодный белый (редкие)
      '255,255,255', // чистый белый
    ];

    function _skyEnsureBg() {
      if (_bgStars) return;
      // Позиции — Math.random() чтобы не было линейных артефактов хэша
      // 700 мелких + 80 средних + 20 крупных, все — простые точки
      _bgStars = [
        ...Array.from({ length: 700 }, (_, i) => ({
          x:   Math.random() * _SKY_WORLD,
          y:   Math.random() * _SKY_WORLD,
          r:   0.3 + _skyHash('bsr' + i) * 1.0,
          a:   0.06 + _skyHash('bsa' + i) * 0.28,
          col: _BG_COLORS[Math.floor(_skyHash('bsc' + i) * _BG_COLORS.length)],
        })),
        ...Array.from({ length: 80 }, (_, i) => ({
          x:   Math.random() * _SKY_WORLD,
          y:   Math.random() * _SKY_WORLD,
          r:   1.1 + _skyHash('bmr' + i) * 1.3,
          a:   0.14 + _skyHash('bma' + i) * 0.36,
          col: _BG_COLORS[Math.floor(_skyHash('bmc' + i) * _BG_COLORS.length)],
        })),
        ...Array.from({ length: 20 }, (_, i) => ({
          x:   Math.random() * _SKY_WORLD,
          y:   Math.random() * _SKY_WORLD,
          r:   2.0 + _skyHash('blr' + i) * 1.5,
          a:   0.30 + _skyHash('bla' + i) * 0.30,
          col: _BG_COLORS[Math.floor(_skyHash('blc' + i) * _BG_COLORS.length)],
        })),
      ];
    }

    /** Минимальный масштаб: мировой прямоугольник заполняет экран по наименьшей стороне. */
    function _skyMinScale() {
      if (!_skyCV) return 0.08;
      return Math.min(_skyCV.width, _skyCV.height) / _SKY_WORLD;
    }

    /** Зажимает offset чтобы мир не уходил за экран. */
    function _skyClampOffset() {
      if (!_skyCV) return;
      const W = _skyCV.width, H = _skyCV.height;
      const wW = _SKY_WORLD * _skyScale, wH = _SKY_WORLD * _skyScale;
      if (wW <= W) { _skyOffX = (W - wW) / 2; }
      else { _skyOffX = Math.min(0, Math.max(W - wW, _skyOffX)); }
      if (wH <= H) { _skyOffY = (H - wH) / 2; }
      else { _skyOffY = Math.min(0, Math.max(H - wH, _skyOffY)); }
    }

    /** Возвращает звёзды ячейки (cx, cy) из LRU-кэша. */
    function _skyGetCellStars(cx, cy) {
      const key = cx + ',' + cy;
      if (_skyBgCache.has(key)) {
        const s = _skyBgCache.get(key);
        _skyBgCache.delete(key); _skyBgCache.set(key, s); // LRU: поднимаем вверх
        return s;
      }
      // Генерируем детерминированно через _skyHash
      const stars = [];
      const density = 28; // звёзд на ячейку
      for (let i = 0; i < density; i++) {
        const sx = (cx + _skyHash(cx + '_' + cy + '_x' + i)) * _SKY_CELL;
        const sy = (cy + _skyHash(cx + '_' + cy + '_y' + i)) * _SKY_CELL;
        stars.push({
          x: sx, y: sy,
          r: 0.3 + _skyHash(cx + '_' + cy + '_r' + i) * 1.2,
          a: 0.06 + _skyHash(cx + '_' + cy + '_a' + i) * 0.26,
          col: _BG_COLORS[Math.floor(_skyHash(cx + '_' + cy + '_c' + i) * _BG_COLORS.length)],
        });
      }
      if (_skyBgCache.size >= 200) _skyBgCache.delete(_skyBgCache.keys().next().value);
      _skyBgCache.set(key, stars);
      return stars;
    }

    function _skyW2S(wx, wy) {
      return { x: wx * _skyScale + _skyOffX, y: wy * _skyScale + _skyOffY };
    }

    function _skyClamp(s) { return Math.max(_skyMinScale(), Math.min(_SKY_SMAX, s)); }

    function _skyZoom(newS, cx, cy) {
      newS = _skyClamp(newS);
      const wx = (cx - _skyOffX) / _skyScale;
      const wy = (cy - _skyOffY) / _skyScale;
      _skyOffX = cx - wx * newS;
      _skyOffY = cy - wy * newS;
      _skyScale = newS;
    }

    function _skyItemToPos(item, fadeIn) {
      const margin = 200;
      const id = String(item.id || item.name || '');
      // Если сервер вернул gx/gy — используем их (0-1 → мировые координаты)
      const wx = (item.gx != null)
        ? item.gx * _SKY_WORLD
        : margin + _skyHash(id + '_x') * (_SKY_WORLD - 2 * margin);
      const wy = (item.gy != null)
        ? item.gy * _SKY_WORLD
        : margin + _skyHash(id + '_y') * (_SKY_WORLD - 2 * margin);
      return {
        id,
        name:       item.name || '—',
        wx, wy,
        hasCoord:   item.gx != null,
        c:          item.data || {},
        opacity:    fadeIn ? 0 : 1,
        fadeStartT: fadeIn ? performance.now() : 0,
      };
    }

    function _skyBuildPos(data) {
      const placed = [];
      const MIN_DIST = 120;
      _skyPos = data.map(item => {
        const p = _skyItemToPos(item, false);
        // Collision avoidance только для созвездий без серверных координат
        if (!p.hasCoord) {
          let tries = 0;
          while (tries < 30) {
            const clash = placed.find(q => Math.hypot(p.wx - q.wx, p.wy - q.wy) < MIN_DIST);
            if (!clash) break;
            const angle = _skyHash(item.id + '_nudge' + tries) * Math.PI * 2;
            p.wx = Math.max(200, Math.min(_SKY_WORLD - 200, p.wx + Math.cos(angle) * MIN_DIST));
            p.wy = Math.max(200, Math.min(_SKY_WORLD - 200, p.wy + Math.sin(angle) * MIN_DIST));
            tries++;
          }
        }
        placed.push(p);
        return p;
      });
    }

    function _skyDraw() {
      if (!_skyCX || !_skyOpen) return;
      const ctx = _skyCX;
      const W = _skyCV.width, H = _skyCV.height;
      const sk = THEMES[activeTheme] || THEMES.stargazer;

      ctx.fillStyle = sk.skyBg;
      ctx.fillRect(0, 0, W, H);

      // Culling bounds in world coords (generous pad for smooth pop-in)
      const pad = Math.max(300, 400 / _skyScale);
      const wL = (-_skyOffX) / _skyScale - pad,  wR = (W - _skyOffX) / _skyScale + pad;
      const wT = (-_skyOffY) / _skyScale - pad,  wB = (H - _skyOffY) / _skyScale + pad;

      // ── Случайные фоновые звёзды (pre-generated, fully random) ──────────
      if (sk.skyBgStar && _skyBgPreStars) {
        _skyBgPreStars.forEach(s => {
          if (s.x < wL || s.x > wR || s.y < wT || s.y > wB) return;
          const { x, y } = _skyW2S(s.x, s.y);
          const r = Math.max(0.4, Math.min(2.0, s.r));
          ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${s.col},${s.a})`; ctx.fill();
        });
      }

      // Highlight state
      const _now = performance.now();
      let _hlElapsed = -1;
      if (_skyHighlightPulseT > 0) {
        _hlElapsed = _now - _skyHighlightPulseT;
        if (_hlElapsed >= _SKY_PULSE_DUR) {
          _skyHighlightPulseT = 0; _skyHighlightId = null; _hlElapsed = -1;
        }
      }

      // ── LOD 1: Heatmap точки (очень маленький масштаб) ────────────────────
      if (_skyScale < _SKY_THRESH_DOT) {
        _skyPos.forEach(p => {
          if (p.wx < wL || p.wx > wR || p.wy < wT || p.wy > wB) return;
          const { x, y } = _skyW2S(p.wx, p.wy);
          const isHL   = _skyHighlightId && p.name === _skyHighlightId;
          const isMine = !isHL && (_skyMode === 'personal' || p.id.startsWith('local_') || _mySkyNames.has(p.name));
          ctx.beginPath(); ctx.arc(x, y, isHL ? 3 : 2, 0, Math.PI * 2);
          ctx.fillStyle = isHL ? sk.skyDotHL : isMine ? sk.skyDotMine : sk.skyDotOther;
          ctx.fill();
        });

      // ── LOD 2: Galaxy glow / simple dots ──────────────────────────────────
      } else if (_skyScale < _SKY_THRESH) {
        _skyPos.forEach(p => {
          if (p.wx < wL || p.wx > wR || p.wy < wT || p.wy > wB) return;
          if (p.opacity < 1 && p.fadeStartT > 0)
            p.opacity = Math.min(1, (_now - p.fadeStartT) / 1000);
          ctx.globalAlpha = p.opacity;
          const { x, y } = _skyW2S(p.wx, p.wy);
          const r = 1.2 + 5 * (_skyScale / _SKY_THRESH);
          const isHL   = _skyHighlightId && p.name === _skyHighlightId;
          const isMine = !isHL && (_skyMode === 'personal' || p.id.startsWith('local_') || _mySkyNames.has(p.name));
          const blinkMult = (isHL && _hlElapsed >= 0)
            ? 0.55 + 0.45 * Math.abs(Math.sin(_hlElapsed / 370 * Math.PI)) : 1;

          if (sk.skyGlow) {
            // Stargazer: glowing halos
            const haloR = r * (isHL ? 5 : 2.2);
            const g = ctx.createRadialGradient(x, y, 0, x, y, haloR);
            if (isHL) {
              g.addColorStop(0,   `rgba(255,252,242,${blinkMult.toFixed(3)})`);
              g.addColorStop(0.35,`rgba(230,218,200,${(0.38*blinkMult).toFixed(3)})`);
              g.addColorStop(1,   'rgba(10,6,30,0)');
            } else if (isMine) {
              g.addColorStop(0,   'rgba(255,245,220,0.42)');
              g.addColorStop(0.4, 'rgba(220,210,185,0.10)');
              g.addColorStop(1,   'rgba(10,6,30,0)');
            } else {
              g.addColorStop(0,   'rgba(255,255,255,0.28)');
              g.addColorStop(0.4, 'rgba(200,200,220,0.06)');
              g.addColorStop(1,   'rgba(10,6,30,0)');
            }
            ctx.beginPath(); ctx.arc(x, y, haloR, 0, Math.PI * 2);
            ctx.fillStyle = g; ctx.fill();
            const coreR = isHL ? Math.max(1.2, r * 0.55) : Math.max(0.8, r * 0.28);
            ctx.beginPath(); ctx.arc(x, y, coreR, 0, Math.PI * 2);
            ctx.fillStyle = isHL
              ? `rgba(255,252,245,${(0.72 + 0.28*blinkMult).toFixed(3)})`
              : isMine ? 'rgba(255,248,230,0.88)' : 'rgba(240,240,255,0.78)';
            ctx.fill();
          } else {
            // Светлые темы: чёткие точки
            const dotR = isHL ? Math.max(2.5, r * 0.6) : Math.max(1.4, r * 0.35);
            ctx.beginPath(); ctx.arc(x, y, dotR, 0, Math.PI * 2);
            ctx.fillStyle = isHL ? sk.skyDotHL : isMine ? sk.skyDotMine : sk.skyDotOther;
            ctx.fill();
          }
          ctx.globalAlpha = 1;
        });

      // ── LOD 3: Полное созвездие ────────────────────────────────────────────
      } else {
        const CSIZE = 90;
        _skyPos.forEach(p => {
          if (p.wx < wL || p.wx > wR || p.wy < wT || p.wy > wB) return;
          if (p.opacity < 1 && p.fadeStartT > 0)
            p.opacity = Math.min(1, (_now - p.fadeStartT) / 1000);

          const { x: cx, y: cy } = _skyW2S(p.wx, p.wy);
          const pts = p.c.points || [];
          const lns = p.c.lines  || [];
          const sz  = CSIZE * _skyScale;
          const wp  = (p.c.winner >= 0) ? p.c.winner : 0;
          const isHL   = _skyHighlightId && p.name === _skyHighlightId;
          const isMine = !isHL && (_skyMode === 'personal' || p.id.startsWith('local_') || _mySkyNames.has(p.name));

          const deg = new Array(pts.length).fill(0);
          lns.forEach(([key, pl]) => {
            if (pl !== wp) return;
            const [a, b] = key.split('-').map(Number);
            if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
          });

          const mpx = pt => cx + (pt.x - 0.5) * sz;
          const mpy = pt => cy + (pt.y - 0.5) * sz;
          const aScale = isHL ? 1.0 : isMine ? 0.80 : 0.50;
          ctx.globalAlpha = p.opacity * aScale;

          // Only dots — no connecting lines in sky view
          if (sk.skyGlow) {
            const _prevR = RADIUS;
            RADIUS = Math.max(1, Math.round(sz * 0.013));
            const hlBlink = isHL && _hlElapsed >= 0
              ? 0.3 + 0.4 * Math.abs(Math.sin(_hlElapsed / 300 * Math.PI)) : 0;
            const boost = isHL ? 0.4 + hlBlink : isMine ? 0.3 : 0.1;
            pts.forEach((pt, i) => {
              if (deg[i] === 0) return;
              drawStarPointTo(ctx, mpx(pt), mpy(pt), Math.max(deg[i], 2), false, false, false, boost);
            });
            ctx.filter = 'none'; RADIUS = _prevR;
          } else {
            // Светлые темы: только точки
            const sr = sk.skyStarRGB;
            const dotR = Math.max(1.5, sz * 0.022);
            const hlBlink = isHL && _hlElapsed >= 0
              ? 0.3 + 0.4 * Math.abs(Math.sin(_hlElapsed / 300 * Math.PI)) : 0;
            const blinkA = isHL ? (0.65 + 0.35 * hlBlink) : isMine ? 0.85 : 0.65;
            pts.forEach((pt, i) => {
              if (deg[i] === 0) return;
              ctx.beginPath();
              ctx.arc(mpx(pt), mpy(pt), dotR * Math.min(deg[i], 3) * 0.5, 0, Math.PI * 2);
              ctx.fillStyle = `rgba(${sr},${blinkA})`; ctx.fill();
            });
          }

          // Подпись
          if (_skyScale > 0.65) {
            ctx.globalAlpha = p.opacity * (isHL ? 0.92 : isMine ? 0.60 : 0.38);
            const fs = Math.min(13, 9 * _skyScale);
            ctx.font = isHL ? `500 ${fs}px sans-serif` : `300 ${fs}px sans-serif`;
            ctx.fillStyle = isHL ? sk.skyLabelHL : isMine ? sk.skyLabelMine : sk.skyLabelOther;
            ctx.textAlign = 'center';
            ctx.fillText(p.name, cx, cy + sz / 2 + fs + 4);
            ctx.textAlign = 'left';
          }
          ctx.globalAlpha = 1;
        });
      }
    }

    function _skyLoop() { _skyDraw(); _skyRaf = requestAnimationFrame(_skyLoop); }

    /**
     * Debounced viewport query — подгружает созвездия в текущем viewport.
     * Вызывается из обработчиков pan/zoom.
     */
    function _skyBboxLoad() {
      if (!_skyCV || !_skyOpen || _skyMode !== 'global') return;
      clearTimeout(_skyLoadTimer);
      _skyLoadTimer = setTimeout(async () => {
        if (!navigator.onLine) return;
        const W = _skyCV.width, H = _skyCV.height;
        const wL = (-_skyOffX) / _skyScale;
        const wT = (-_skyOffY) / _skyScale;
        const wR = (W - _skyOffX) / _skyScale;
        const wB = (H - _skyOffY) / _skyScale;
        // Нормализуем в [0,1] — gx/gy хранятся как доли _SKY_WORLD
        const x0 = Math.max(0, wL / _SKY_WORLD);
        const y0 = Math.max(0, wT / _SKY_WORLD);
        const x1 = Math.min(1, wR / _SKY_WORLD);
        const y1 = Math.min(1, wB / _SKY_WORLD);
        // Пропускаем если viewport вне мира или охватывает всё (слишком далеко)
        if (x0 >= x1 || y0 >= y1 || (x1 - x0) > 0.95) return;
        const { data, error } = await sb.from('constellations')
          .select('id, name, data, user_id, gx, gy, created_at')
          .gte('gx', x0).lte('gx', x1)
          .gte('gy', y0).lte('gy', y1)
          .order('created_at', { ascending: false })
          .limit(300);
        if (error || !data || !data.length) return;
        const seen = new Set(_skyData ? _skyData.map(d => d.id) : []);
        const fresh = data.filter(d => !seen.has(d.id));
        if (!fresh.length) return;
        _skyData = [...(_skyData || []), ...fresh];
        const uid = _skyGetUserId();
        if (uid) fresh.forEach(d => { if (d.user_id === uid) _mySkyNames.add(d.name); });
        _skyBuildPos(_skyData);
      }, 150);
    }

    function _skyFlyToHighlight() {
      if (!_skyHighlightId || !_skyPos.length || !_skyCV) return;
      const t = _skyPos.find(p => p.name === _skyHighlightId);
      if (!t) return;
      const W = _skyCV.width, H = _skyCV.height;
      const ts = 1.2;
      const tx = W / 2 - t.wx * ts, ty = H / 2 - t.wy * ts;
      const s0 = _skyScale, x0 = _skyOffX, y0 = _skyOffY;
      const dur = 700, t0 = performance.now();
      if (_skyAnimRaf) cancelAnimationFrame(_skyAnimRaf);
      function step(now) {
        const e = 1 - Math.pow(1 - Math.min(1, (now - t0) / dur), 3);
        _skyScale = s0 + (ts - s0) * e;
        _skyOffX  = x0 + (tx - x0) * e;
        _skyOffY  = y0 + (ty - y0) * e;
        if (e < 1) { _skyAnimRaf = requestAnimationFrame(step); return; }
        _skyAnimRaf = null;
        _skyHighlightPulseT = performance.now(); // start 3-pulse sequence
      }
      _skyAnimRaf = requestAnimationFrame(step);
    }

    function _skyApplyModeUI() {
      document.querySelectorAll('.sky-mode-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.mode === _skyMode);
      });
    }

    async function _skyLoadPersonal() {
      const st  = document.getElementById('sky-status');
      const uid = _skyGetUserId();

      // Authenticated users: load from Supabase filtered by user_id
      if (uid) {
        st.textContent = 'Загрузка ✦'; st.style.display = 'block';
        const { data, error } = await sb.from('constellations')
          .select('id, name, data, gx, gy, created_at')
          .eq('user_id', uid)
          .order('created_at', { ascending: false });
        st.style.display = 'none';
        if (!error && data && data.length) {
          _skyData = data;
          _skyBuildPos(data);
          if (_skyHighlightId) _skyFlyToHighlight();
          return;
        }
        // Supabase returned nothing or error → fall through to localStorage
      }

      // Guests or Supabase fallback: use localStorage
      let saved = [];
      try { saved = JSON.parse(localStorage.getItem('saved_constellations') || '[]'); } catch(e) {}
      if (!saved.length) {
        st.textContent = 'Сохрани своё первое созвездие ✦'; st.style.display = 'block';
        _skyData = []; _skyPos = [];
        return;
      }
      st.style.display = 'none';
      // Normalise to same shape as Supabase rows
      const rows = saved.map((item, i) => ({ id: 'local_' + i, name: item.name || '—', data: item }));
      _skyData = rows;
      _skyBuildPos(rows);
      if (_skyHighlightId) _skyFlyToHighlight();
    }

    /**
     * Показывает сообщение «Нет соединения» с кнопкой «Повторить» в #sky-status.
     * @param {function} retryFn — вызывается при нажатии на кнопку
     */
    function _skyShowOfflineUI(retryFn) {
      const st = document.getElementById('sky-status');
      st.style.pointerEvents = 'auto';
      st.innerHTML = 'Нет соединения ✦<br><button id="sky-retry-btn">Повторить</button>';
      st.style.display = 'block';
      document.getElementById('sky-retry-btn').addEventListener('click', retryFn);
    }

    /**
     * Загружает глобальное небо из Supabase.
     * При отсутствии сети или превышении таймаута 6с — показывает кнопку «Повторить».
     */
    async function _skyReloadGlobal() {
      const st = document.getElementById('sky-status');
      st.innerHTML = '';
      st.style.pointerEvents = 'none';
      st.textContent = 'Загрузка ✦'; st.style.display = 'block';

      // Быстрая проверка: если браузер знает что нет сети — не ждём
      if (!navigator.onLine) {
        _skyShowOfflineUI(_skyReloadGlobal);
        return;
      }

      // Fetch с таймаутом 6 секунд
      let result;
      try {
        const fetchPromise = sb.from('constellations')
          .select('id, name, data, user_id, gx, gy, created_at')
          .order('created_at', { ascending: false })
          .limit(100);
        const timeoutPromise = new Promise((_, rej) =>
          setTimeout(() => rej(new Error('timeout')), 6000)
        );
        result = await Promise.race([fetchPromise, timeoutPromise]);
      } catch(e) {
        _skyShowOfflineUI(_skyReloadGlobal);
        return;
      }

      const { data, error } = result;
      st.style.display = 'none';

      if (error) {
        console.error('Supabase error:', error);
        _skyShowOfflineUI(_skyReloadGlobal);
        return;
      }
      if (!data || !data.length) {
        st.textContent = 'Будь первым кто сохранит созвездие ✦'; st.style.display = 'block';
        return;
      }
      _skyData = data;
      // Supplement _mySkyNames with server-side user_id matches
      const uid = _skyGetUserId();
      if (uid) {
        data.forEach(d => { if (d.user_id === uid) _mySkyNames.add(d.name); });
      }
      _skyBuildPos(data);
      if (_skyHighlightId) _skyFlyToHighlight();
      _skySubscribe();
    }

    /** Generate (once) a large set of fully random bg stars covering the world. */
    function _skyEnsurePreStars() {
      if (_skyBgPreStars) return;
      const N = 3200; // total bg stars: ~1.8x more than current, truly random
      _skyBgPreStars = [];
      for (let i = 0; i < N; i++) {
        // Vary density: 80% tiny (r 0.3-1.1), 16% medium (r 1.1-2.2), 4% bright (r 2.0-3.2)
        const tier = Math.random();
        const r = tier < 0.80 ? 0.3 + Math.random() * 0.8
                : tier < 0.96 ? 1.1 + Math.random() * 1.1
                :               2.0 + Math.random() * 1.2;
        const a = tier < 0.80 ? 0.05 + Math.random() * 0.22
                : tier < 0.96 ? 0.12 + Math.random() * 0.32
                :               0.28 + Math.random() * 0.32;
        _skyBgPreStars.push({
          x:   Math.random() * _SKY_WORLD,
          y:   Math.random() * _SKY_WORLD,
          r, a,
          col: _BG_COLORS[Math.floor(Math.random() * _BG_COLORS.length)],
        });
      }
    }

    async function openSkyScreen(mode = 'global') {
      _skyMode = mode;
      _skyOpen = true;
      _skyData = null; _skyPos = [];  // reset on each open so mode switch reloads
      try {
        const saved = JSON.parse(localStorage.getItem('saved_constellations') || '[]');
        _mySkyNames = new Set(saved.map(s => s.name));
      } catch(e) { _mySkyNames = new Set(); }
      _skyEnsureBg();        // для rank-up анимаций
      _skyEnsurePreStars();  // random bg stars for sky canvas
      document.getElementById('sky-hub-screen').style.display = 'none';
      document.getElementById('sky-screen').style.display = 'flex';
      _skyCV = document.getElementById('sky-canvas');
      _skyCV.width  = window.innerWidth;
      _skyCV.height = window.innerHeight;
      _skyCX = _skyCV.getContext('2d');
      _skyCV.style.background = (THEMES[activeTheme] || THEMES.stargazer).skyBg;
      _skyScale = Math.max(0.22, _skyMinScale()); // мир заполняет экран
      _skyOffX  = _skyCV.width  / 2 - _SKY_WORLD / 2 * _skyScale;
      _skyOffY  = _skyCV.height / 2 - _SKY_WORLD / 2 * _skyScale;
      _skyClampOffset();
      if (_skyRaf) cancelAnimationFrame(_skyRaf);
      _skyLoop();
      _skyApplyModeUI();

      if (_skyMode === 'personal') { _skyLoadPersonal(); return; }
      _skyReloadGlobal();
    }

    function _skySubscribe() {
      if (_skyChannel) { sb.removeChannel(_skyChannel); _skyChannel = null; }
      _skyChannel = sb.channel('sky')
        .on('postgres_changes',
          { event: 'INSERT', schema: 'public', table: 'constellations' },
          (payload) => {
            if (!_skyData) _skyData = [];
            _skyData.unshift(payload.new);
            _skyPos.unshift(_skyItemToPos(payload.new, true));
          }
        )
        .subscribe();
    }

    function _skyClose() {
      _skyOpen = false;
      if (_skyRaf)     { cancelAnimationFrame(_skyRaf);     _skyRaf     = null; }
      if (_skyAnimRaf) { cancelAnimationFrame(_skyAnimRaf); _skyAnimRaf = null; }
      if (_skyChannel) { sb.removeChannel(_skyChannel);     _skyChannel = null; }
      document.getElementById('sky-screen').style.display = 'none';
      document.getElementById('sky-hub-screen').style.display = 'flex';
    }

    let _skyMineIdx = -1; // текущий индекс в цикле по своим созвездиям

    function _skyGetMineList() {
      const lastName = localStorage.getItem('lastConstellationName');
      const mine = _skyPos.filter(p => _mySkyNames.has(p.name) || p.id.startsWith('local_'));
      // Последнее сохранённое — первым в списке
      if (lastName) {
        const li = mine.findIndex(p => p.name === lastName);
        if (li > 0) { const [it] = mine.splice(li, 1); mine.unshift(it); }
      }
      return mine;
    }

    function _skyFlyCto(t) {
      if (!t || !_skyCV) return;
      _skyHighlightId = t.name;
      _skyHighlightPulseT = performance.now();
      const W = _skyCV.width, H = _skyCV.height;
      const ts = 1.2;
      const tx = W / 2 - t.wx * ts, ty = H / 2 - t.wy * ts;
      const s0 = _skyScale, x0 = _skyOffX, y0 = _skyOffY;
      const dur = 700, t0 = performance.now();
      if (_skyAnimRaf) cancelAnimationFrame(_skyAnimRaf);
      function _animStep(now) {
        const e = 1 - Math.pow(1 - Math.min(1, (now - t0) / dur), 3);
        _skyScale = s0 + (ts - s0) * e;
        _skyOffX  = x0 + (tx - x0) * e;
        _skyOffY  = y0 + (ty - y0) * e;
        if (e < 1) _skyAnimRaf = requestAnimationFrame(_animStep);
      }
      _skyAnimRaf = requestAnimationFrame(_animStep);
      // Обновляем счётчик в кнопке
      const mine = _skyGetMineList();
      const idx  = mine.indexOf(t);
      const nav  = document.getElementById('sky-mine-counter');
      if (nav) nav.textContent = mine.length > 1 ? `${idx + 1} / ${mine.length}` : '';
    }

    function _skyFindMine(dir = 1) {
      if (!_skyPos.length || !_skyCV) return;
      const mine = _skyGetMineList();
      if (!mine.length) {
        const st = document.getElementById('sky-status');
        if (st) { st.textContent = 'Твоих созвездий нет ✦'; st.style.display = 'block'; }
        return;
      }
      _skyMineIdx = (_skyMineIdx + dir + mine.length) % mine.length;
      _skyFlyCto(mine[_skyMineIdx]);
    }

    // UI buttons
    document.getElementById('sky-back-btn').addEventListener('click', _skyClose);
    document.getElementById('sky-zoom-in').addEventListener('click', () => {
      _skyZoom(_skyScale * 1.4, (_skyCV?.width || window.innerWidth) / 2, (_skyCV?.height || window.innerHeight) / 2);
    });
    document.getElementById('sky-zoom-out').addEventListener('click', () => {
      _skyZoom(_skyScale / 1.4, (_skyCV?.width || window.innerWidth) / 2, (_skyCV?.height || window.innerHeight) / 2);
    });
    document.getElementById('sky-find-mine').addEventListener('click', () => _skyFindMine(1));
    document.getElementById('sky-mine-prev').addEventListener('click',  () => _skyFindMine(-1));
    document.getElementById('sky-mine-next').addEventListener('click',  () => _skyFindMine(1));

    // Mode toggle
    document.querySelectorAll('.sky-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        if (mode === _skyMode) return;
        _skyMode = mode;
        _skyApplyModeUI();
        if (_skyChannel) { sb.removeChannel(_skyChannel); _skyChannel = null; }
        _skyHighlightId = null; _skyHighlightPulseT = 0;
        if (mode === 'personal') {
          _skyLoadPersonal();
        } else {
          // reload global using shared loader (handles offline/timeout gracefully)
          _skyData = null; _skyPos = [];
          _skyReloadGlobal();
        }
      });
    });

    // Mouse drag & wheel
    const _skyEl = document.getElementById('sky-canvas');
    _skyEl.addEventListener('mousedown', e => {
      _skyDrag = { x: e.clientX, y: e.clientY, ox: _skyOffX, oy: _skyOffY };
    });
    window.addEventListener('mousemove', e => {
      if (!_skyDrag || !_skyOpen) return;
      _skyOffX = _skyDrag.ox + (e.clientX - _skyDrag.x);
      _skyOffY = _skyDrag.oy + (e.clientY - _skyDrag.y);
      _skyClampOffset();
      _skyDrag.ox = _skyOffX; _skyDrag.oy = _skyOffY;
      _skyDrag.x  = e.clientX; _skyDrag.y  = e.clientY;
      _skyBboxLoad();
    });
    window.addEventListener('mouseup', () => { _skyDrag = null; });
    _skyEl.addEventListener('wheel', e => {
      if (!_skyOpen) return;
      e.preventDefault();
      _skyZoom(_skyScale * (e.deltaY < 0 ? 1.12 : 1 / 1.12), e.clientX, e.clientY);
      _skyClampOffset();
      _skyBboxLoad();
    }, { passive: false });

    // Touch pan + pinch
    _skyEl.addEventListener('touchstart', e => {
      e.preventDefault();
      if (e.touches.length === 1) {
        const t = e.touches[0];
        _skyDrag = { x: t.clientX, y: t.clientY, ox: _skyOffX, oy: _skyOffY };
        _skyPinch = null;
      } else if (e.touches.length >= 2) {
        _skyDrag = null;
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        _skyPinch = {
          d: Math.hypot(dx, dy),
          mx: (e.touches[0].clientX + e.touches[1].clientX) / 2,
          my: (e.touches[0].clientY + e.touches[1].clientY) / 2,
          s0: _skyScale, ox: _skyOffX, oy: _skyOffY,
        };
      }
    }, { passive: false });

    _skyEl.addEventListener('touchmove', e => {
      e.preventDefault();
      if (!_skyOpen) return;
      if (e.touches.length === 1 && _skyDrag) {
        const t = e.touches[0];
        _skyOffX = _skyDrag.ox + (t.clientX - _skyDrag.x);
        _skyOffY = _skyDrag.oy + (t.clientY - _skyDrag.y);
        _skyClampOffset();
        _skyDrag.ox = _skyOffX; _skyDrag.oy = _skyOffY;
        _skyDrag.x  = t.clientX; _skyDrag.y  = t.clientY;
        _skyBboxLoad();
      } else if (e.touches.length >= 2 && _skyPinch) {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        const nd = Math.hypot(dx, dy);
        const ns = _skyClamp(_skyPinch.s0 * (nd / _skyPinch.d));
        const wx = (_skyPinch.mx - _skyPinch.ox) / _skyPinch.s0;
        const wy = (_skyPinch.my - _skyPinch.oy) / _skyPinch.s0;
        _skyOffX = _skyPinch.mx - wx * ns;
        _skyOffY = _skyPinch.my - wy * ns;
        _skyScale = ns;
        _skyClampOffset();
        _skyBboxLoad();
      }
    }, { passive: false });

    _skyEl.addEventListener('touchend', e => {
      if (e.touches.length === 0) { _skyDrag = null; _skyPinch = null; }
      else if (e.touches.length === 1) {
        _skyPinch = null;
        const t = e.touches[0];
        _skyDrag = { x: t.clientX, y: t.clientY, ox: _skyOffX, oy: _skyOffY };
      }
    }, { passive: false });

    // Journey canvas: star hover and tap detection (legacy, canvas removed)
    (function() {
      const jc = document.getElementById('journey-canvas');
      if (!jc) return;
      function hit(clientX, clientY) {
        if (!_journeyCanvas) return;
        const starPos = getAchStarPositions(_journeyCanvas.width, _journeyCanvas.height);
        const rect = jc.getBoundingClientRect();
        const mx = clientX - rect.left, my = clientY - rect.top;
        for (let i = 0; i < starPos.length; i++) {
          if (Math.hypot(mx - starPos[i].x, my - starPos[i].y) <= 30) {
            _journeyTooltip = { idx: i }; return;
          }
        }
        _journeyTooltip = null;
      }
      jc.addEventListener('mousemove',  e => hit(e.clientX, e.clientY));
      jc.addEventListener('click',      e => hit(e.clientX, e.clientY));
      jc.addEventListener('mouseleave', () => { _journeyTooltip = null; });
      jc.addEventListener('touchstart', e => {
        e.preventDefault();
        const t = e.touches[0]; hit(t.clientX, t.clientY);
      }, { passive: false });
    })();

    /**
     * Главный сброс сессии: отменяет все активные RAF-анимации,
     * скрывает игровой экран, возвращает стартовый экран на первый шаг.
     * Вызывается кнопкой «←» в top-panel и кнопкой «Выход» на экране проигрыша.
     */
    function goToMenu() {
      [_twinkleRaf, _gameTwinkleRaf, _chalkAnimRaf, _probBarRaf,
       _hintsRaf, _rankUpRaf, _tutorialRaf, lastMoveAnimRaf, _lineAnimRaf, _winParticleRaf, _pointBirthRaf]
        .forEach(r => r && cancelAnimationFrame(r));
      _twinkleRaf = _gameTwinkleRaf = _chalkAnimRaf = _probBarRaf =
        _hintsRaf = _rankUpRaf = _tutorialRaf = lastMoveAnimRaf = _lineAnimRaf = _winParticleRaf = _pointBirthRaf = null;
      _pointBirthT = [];
      const _pcanvas = document.getElementById('particle-canvas');
      if (_pcanvas) _pcanvas.getContext('2d').clearRect(0, 0, _pcanvas.width, _pcanvas.height);
      const _flash = document.getElementById('win-flash');
      if (_flash) { _flash.style.transition = 'none'; _flash.style.opacity = '0'; }
      _lineAnimating = false; _lineAnim = null;
      const pbw = document.getElementById('prob-bar-wrap');
      if (pbw) pbw.classList.remove('active');
      const _p = loadProgress();
      const _info = computeRank(_p.rating);
      document.getElementById('home-player-name').textContent = localStorage.getItem('playerName') || '—';
      document.getElementById('home-rating-pts').textContent  = 'score: ' + _p.rating + ' ✦';
      document.getElementById('game').classList.remove('ui-hidden');
      document.getElementById('start').style.display = 'none';
      // Pass _startHomeBgAnim as onShown callback so it runs AFTER home-screen
      // gets display:flex — otherwise the loop's display===none check kills it instantly
      fadeTo(document.getElementById('game'), document.getElementById('home-screen'), 300, _startHomeBgAnim);
    }

    // ── In-game UI toggle ─────────────────────────────────────────────────────
    document.getElementById('ui-toggle-btn').addEventListener('click', () => {
      document.getElementById('game').classList.toggle('ui-hidden');
      // Wait for panels to fully render before measuring their height
      requestAnimationFrame(() => setTimeout(resizeCanvas, 80));
    });

    // ── Home screen: length picker ────────────────────────────────────────────
    const _HOME_LENGTHS = [
      { count: 7,  label: 'короткая',
        pts: [[0.25,0.20],[0.72,0.15],[0.85,0.55],[0.62,0.82],[0.18,0.78],[0.10,0.42],[0.50,0.48]] },
      { count: 13, label: 'обычная',
        pts: [[0.22,0.18],[0.55,0.12],[0.80,0.20],[0.88,0.50],[0.72,0.78],[0.45,0.85],[0.18,0.72],
              [0.08,0.45],[0.30,0.32],[0.62,0.42],[0.42,0.55],[0.75,0.58],[0.15,0.20]] },
      { count: 21, label: 'длинная',
        pts: [[0.12,0.15],[0.35,0.10],[0.62,0.08],[0.82,0.18],[0.92,0.42],[0.88,0.65],[0.72,0.82],
              [0.50,0.90],[0.28,0.85],[0.10,0.70],[0.05,0.48],[0.08,0.28],[0.25,0.22],[0.48,0.18],
              [0.70,0.28],[0.85,0.50],[0.75,0.70],[0.55,0.80],[0.35,0.72],[0.20,0.55],[0.40,0.45]] }
    ];
    let _homeSelectedLength = parseInt(localStorage.getItem('homeLength') || '7');
    let _homeLengthOpen = false;

    function _drawLengthPreview(cv, pts) {
      const dpr = window.devicePixelRatio || 1;
      const S = 76;
      cv.width = S * dpr; cv.height = S * dpr;
      cv.style.width = S + 'px'; cv.style.height = S + 'px';
      const ctx = cv.getContext('2d');
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, S, S);
      const pad = 9;
      pts.forEach(([nx, ny]) => {
        const x = pad + nx * (S - 2*pad);
        const y = pad + ny * (S - 2*pad);
        const r = 1.7;
        const g = ctx.createRadialGradient(x, y, 0, x, y, r * 5.5);
        g.addColorStop(0,    'rgba(255,235,190,0.40)');
        g.addColorStop(0.35, 'rgba(255,235,190,0.10)');
        g.addColorStop(1,    'rgba(255,235,190,0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(x, y, r * 5.5, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle = 'rgba(255,245,220,0.88)';
        ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
      });
    }

    function _buildLengthCards() {
      const container = document.getElementById('home-length-options');
      if (container.dataset.built) return;
      container.dataset.built = '1';
      _HOME_LENGTHS.forEach(opt => {
        const card = document.createElement('div');
        card.className = 'home-length-card' + (opt.count === _homeSelectedLength ? ' active' : '');
        card.dataset.count = opt.count;
        const cv = document.createElement('canvas');
        _drawLengthPreview(cv, opt.pts);
        const lbl = document.createElement('div');
        lbl.className = 'home-lc-label';
        lbl.textContent = opt.label;
        card.appendChild(cv);
        card.appendChild(lbl);
        card.addEventListener('click', () => {
          _homeSelectedLength = opt.count;
          document.getElementById('home-length-label').textContent = opt.label;
          document.querySelectorAll('.home-length-card').forEach(c =>
            c.classList.toggle('active', parseInt(c.dataset.count) === _homeSelectedLength)
          );
          _toggleLengthPicker(false);
        });
        container.appendChild(card);
      });
    }

    function _toggleLengthPicker(force) {
      _homeLengthOpen = force !== undefined ? force : !_homeLengthOpen;
      const opts = document.getElementById('home-length-options');
      if (_homeLengthOpen) {
        _buildLengthCards();
        opts.style.display = 'flex';
      } else {
        opts.style.display = 'none';
      }
    }

    // ── Home screen buttons ───────────────────────────────────────────────────

    document.getElementById('home-settings-icon').addEventListener('click', openSettingsScreen);
    // Init active class from saved/default length
    document.querySelectorAll('.home-len-btn').forEach(b =>
      b.classList.toggle('active', parseInt(b.dataset.count) === _homeSelectedLength)
    );
    document.querySelectorAll('.home-len-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        _homeSelectedLength = parseInt(btn.dataset.count);
        localStorage.setItem('homeLength', _homeSelectedLength);
        document.querySelectorAll('.home-len-btn').forEach(b =>
          b.classList.toggle('active', b === btn)
        );
      });
    });
    document.getElementById('home-sky-nav-btn').addEventListener('click', openSkyHub);

    // Sky hub buttons
    document.getElementById('sky-hub-back-btn').addEventListener('click', closeSkyHub);
    document.getElementById('sky-hub-journey-btn').addEventListener('click', () => openJourneyScreen('sky-hub-screen'));
    document.getElementById('sky-hub-sky-btn').addEventListener('click', () => openSkyScreen('global'));

    document.getElementById('home-play-btn').addEventListener('click', () => {
      COUNT = _homeSelectedLength;
      isAI = true;
      playerNames[0] = localStorage.getItem('playerName') || 'Игрок 1';
      playerNames[1] = 'Звездочёт';
      stargazerLevel = rankToAiLevel();
      _stopHomeBgAnim();
      document.getElementById('home-screen').style.display = 'none';
      startGame();
    });

    function openStub(title) {
      document.getElementById('stub-title').textContent = title;
      document.getElementById('stub-screen').style.display = 'flex';
    }
    document.getElementById('stub-back-btn').addEventListener('click', () => {
      document.getElementById('stub-screen').style.display = 'none';
    });

    // ── Home nav canvas icons ─────────────────────────────────────────────────
    (function _drawHomeIcons() {
      const dpr = window.devicePixelRatio || 1;
      const S = 40;

      function _setupCanvas(id) {
        const cv = document.getElementById(id);
        if (!cv) return null;
        cv.width  = S * dpr; cv.height = S * dpr;
        cv.style.width = S + 'px'; cv.style.height = S + 'px';
        const c = cv.getContext('2d');
        c.scale(dpr, dpr);
        return c;
      }

      // ── 1. Single game-style star (Мои созвездия) ──
      (function() {
        const c = _setupCanvas('home-icon-constellations');
        if (!c) return;
        const cx = S/2, cy = S/2;
        // Halo
        const hg = c.createRadialGradient(cx, cy, 0, cx, cy, 17);
        hg.addColorStop(0,    'rgba(255,200,120,0.38)');
        hg.addColorStop(0.28, 'rgba(255,200,120,0.10)');
        hg.addColorStop(1,    'rgba(255,200,120,0)');
        c.fillStyle = hg; c.beginPath(); c.arc(cx, cy, 17, 0, Math.PI*2); c.fill();
        // 4 spike rays (✦ shape)
        c.save();
        [[0],[Math.PI/2],[Math.PI],[Math.PI*1.5]].forEach(([a]) => {
          const grad = c.createLinearGradient(cx, cy,
            cx + Math.cos(a)*14, cy + Math.sin(a)*14);
          grad.addColorStop(0, 'rgba(255,245,210,0.55)');
          grad.addColorStop(1, 'rgba(255,245,210,0)');
          c.strokeStyle = grad; c.lineWidth = 0.9;
          c.beginPath(); c.moveTo(cx, cy);
          c.lineTo(cx + Math.cos(a)*14, cy + Math.sin(a)*14); c.stroke();
        });
        c.restore();
        // Bright core
        const cg = c.createRadialGradient(cx, cy, 0, cx, cy, 4);
        cg.addColorStop(0,    'rgba(255,245,210,0.95)');
        cg.addColorStop(0.4,  'rgba(255,245,210,0.50)');
        cg.addColorStop(1,    'rgba(255,245,210,0)');
        c.fillStyle = cg; c.beginPath(); c.arc(cx, cy, 4, 0, Math.PI*2); c.fill();
      })();

      // ── 2. Mini constellation (Небо) ──
      (function() {
        const c = _setupCanvas('home-icon-sky');
        if (!c) return;
        // 5 stars — irregular constellation shape
        const pts = [
          { x: 20, y:  7, r: 2.2 },  // top — brightest
          { x: 33, y: 17, r: 1.5 },  // right
          { x: 28, y: 31, r: 1.7 },  // bottom right
          { x: 12, y: 31, r: 1.4 },  // bottom left
          { x:  8, y: 17, r: 1.5 },  // left
        ];
        const lines = [[0,1],[1,2],[2,3],[3,4],[4,0],[1,3]];
        // Lines first (dim)
        c.strokeStyle = 'rgba(255,245,210,0.20)'; c.lineWidth = 0.7;
        lines.forEach(([a, b]) => {
          c.beginPath(); c.moveTo(pts[a].x, pts[a].y);
          c.lineTo(pts[b].x, pts[b].y); c.stroke();
        });
        // Stars
        pts.forEach(({ x, y, r }) => {
          const hg = c.createRadialGradient(x, y, 0, x, y, r * 3.5);
          hg.addColorStop(0, 'rgba(255,200,120,0.28)');
          hg.addColorStop(1, 'rgba(255,200,120,0)');
          c.fillStyle = hg; c.beginPath(); c.arc(x, y, r * 3.5, 0, Math.PI*2); c.fill();
          const cg = c.createRadialGradient(x, y, 0, x, y, r);
          cg.addColorStop(0, 'rgba(255,245,210,0.95)');
          cg.addColorStop(1, 'rgba(255,245,210,0)');
          c.fillStyle = cg; c.beginPath(); c.arc(x, y, r, 0, Math.PI*2); c.fill();
        });
      })();

      // ── 3. 8-pointed star-gear (Настройки) — skipped if canvas removed ──
      (function() {
        const c = _setupCanvas('home-icon-settings');
        if (!c) return;
        const cx = S/2, cy = S/2;
        const outerR = 15, innerR = 9, holeR = 5.5;
        const pts8 = 8;
        // Draw 8-pointed star
        c.beginPath();
        for (let i = 0; i < pts8 * 2; i++) {
          const ang = (i * Math.PI / pts8) - Math.PI / 2;
          const r   = i % 2 === 0 ? outerR : innerR;
          const x   = cx + r * Math.cos(ang);
          const y   = cy + r * Math.sin(ang);
          i === 0 ? c.moveTo(x, y) : c.lineTo(x, y);
        }
        c.closePath();
        c.fillStyle = 'rgba(255,245,210,0.75)';
        c.fill();
        // Punch center hole with destination-out
        c.globalCompositeOperation = 'destination-out';
        c.beginPath(); c.arc(cx, cy, holeR, 0, Math.PI*2); c.fill();
        c.globalCompositeOperation = 'source-over';
        // Subtle outer glow
        const hg = c.createRadialGradient(cx, cy, outerR - 2, cx, cy, outerR + 6);
        hg.addColorStop(0, 'rgba(255,200,120,0.12)');
        hg.addColorStop(1, 'rgba(255,200,120,0)');
        c.fillStyle = hg; c.beginPath(); c.arc(cx, cy, outerR + 6, 0, Math.PI*2); c.fill();
      })();
    })();

    // ── Настройки ─────────────────────────────────────────────────────────────
    //
    // Настройки хранятся в localStorage под ключом 'app_settings' как JSON-строка.
    // При старте страницы объект читается в window._appSettings (до загрузки DOM),
    // чтобы haptic() и playSound() могли работать сразу.
    //
    // Экран настроек управляет тремя группами:
    //   1. Системные переключатели — звук и вибрация
    //   2. Режим звёздного свечения — все точки ('all') или только активные ('active')
    //   3. Выбор темы — stargazer / minimal / suprematist / chalk

    /** Сохраняет текущий window._appSettings в localStorage. */
    function _saveSettings() {
      localStorage.setItem('app_settings', JSON.stringify(window._appSettings));
    }
    /**
     * Синхронизирует состояние кнопок экрана настроек с window._appSettings и activeTheme.
     * Вызывается при открытии экрана и после каждого изменения настройки.
     */
    function _applySettingsUI() {
      document.getElementById('st-sound')    .classList.toggle('on', !!window._appSettings.sound);
      document.getElementById('st-vibration').classList.toggle('on', !!window._appSettings.vibration);
      document.getElementById('sg-all')   .classList.toggle('active', window._appSettings.starGlow !== 'active');
      document.getElementById('sg-active').classList.toggle('active', window._appSettings.starGlow === 'active');
      // Theme buttons
      document.querySelectorAll('.s-theme-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.theme === activeTheme);
      });
    }
    /** Открывает экран настроек: обновляет UI до текущего состояния, затем показывает экран. */
    function openSettingsScreen() {
      _applySettingsUI();
      document.getElementById('settings-screen').style.display = 'flex';
    }
    document.getElementById('settings-back-btn').addEventListener('click', () => {
      document.getElementById('settings-screen').style.display = 'none';
      showHomeScreen();
    });

    // ── Profile Screen ────────────────────────────────────────────────────────
    // Required Supabase table (run once in Supabase SQL editor):
    //   CREATE TABLE IF NOT EXISTS profiles (
    //     user_id TEXT PRIMARY KEY, username TEXT,
    //     rating INT DEFAULT 0, updated_at TIMESTAMPTZ DEFAULT NOW()
    //   );
    //   ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;
    //   CREATE POLICY "read all" ON profiles FOR SELECT USING (true);
    //   CREATE POLICY "own write" ON profiles FOR INSERT WITH CHECK (true);
    //   CREATE POLICY "own update" ON profiles FOR UPDATE USING (true);
    // ────────────────────────────────────────────────────────────────────────

    const _PROFILE_EMOJIS = [
      '✦','⭐','🌟','💫','🔭','🌙','☄️','🪐','🌌','🌠',
      '⚡','🎯','🦉','🦊','🐺','🦁','🐉','🌺','🌸','🌊',
      '🏔','🎪','🔮','🌻','🦋','🎨','🌈','🦚','🐬','🦄',
      '🏅','🎖','👑','🗝','⚔️','🛸','🌀','✨','🕊','🐙'
    ];

    /** Refresh avatar display from localStorage. */
    function _refreshProfileAvatar() {
      const type  = localStorage.getItem('avatarType')  || 'emoji';
      const value = localStorage.getItem('avatarValue') || '✦';
      const photo = document.getElementById('profile-avatar-photo');
      const emoji = document.getElementById('profile-avatar-emoji');
      if (type === 'photo' && value) {
        photo.src = value; photo.style.display = 'block'; emoji.style.display = 'none';
      } else {
        emoji.textContent = value; photo.style.display = 'none'; emoji.style.display = 'block';
      }
    }

    /** Populate all profile stats from localStorage. */
    function _loadProfileUI() {
      const p    = loadProgress();
      const name = localStorage.getItem('playerName') || '—';
      const info = computeRank(p.rating);

      // Name
      document.getElementById('profile-name-display').textContent = name;
      document.getElementById('profile-name-input').value = name;
      document.getElementById('profile-rank-display').textContent = info.title + ' · ' + p.rating + ' ✦';

      // Avatar
      _refreshProfileAvatar();

      // Stats numbers
      const constellations = (() => {
        try { return JSON.parse(localStorage.getItem('saved_constellations') || '[]').length; }
        catch(e) { return 0; }
      })();
      const losses = Math.max(0, (p.gamesPlayed || 0) - (p.gamesWon || 0) - (p.gamesDraw || 0));
      document.getElementById('pstat-score').textContent  = p.rating || 0;
      document.getElementById('pstat-best').textContent   = p.bestScore || 0;
      document.getElementById('pstat-games').textContent  = p.gamesPlayed || 0;
      document.getElementById('pstat-const').textContent  = constellations;
      document.getElementById('pstat-wins').textContent   = p.gamesWon || 0;
      document.getElementById('pstat-losses').textContent = losses;
      document.getElementById('pstat-draws').textContent  = p.gamesDraw || 0;

      // Logout / Login button label
      const uid = _skyGetUserId();
      const isGuest = !uid;
      document.getElementById('profile-logout-label').textContent = isGuest ? 'Войти' : 'Выйти из аккаунта';
      document.getElementById('profile-logout-icon').textContent  = isGuest ? '→' : '↩';
    }

    /** Fetch leaderboard position from Supabase with offline fallback. */
    async function _fetchLeaderboardRank() {
      const rankEl = document.getElementById('profile-lb-rank');
      const infoEl = document.getElementById('profile-lb-info');
      const uid    = _skyGetUserId();
      const p      = loadProgress();
      const myRating = p.rating || 0;

      // Try to upsert our profile first (so we appear in leaderboard)
      if (uid) {
        const name = localStorage.getItem('playerName') || 'Игрок';
        sb.from('profiles').upsert({ user_id: uid, username: name, rating: myRating, updated_at: new Date().toISOString() }).then(() => {}).catch(() => {});
      }

      try {
        // Count how many users have strictly higher rating
        const { count: above, error: e1 } = await sb
          .from('profiles')
          .select('*', { count: 'exact', head: true })
          .gt('rating', myRating);
        if (e1) throw e1;

        // Count total players
        const { count: total, error: e2 } = await sb
          .from('profiles')
          .select('*', { count: 'exact', head: true });
        if (e2) throw e2;

        const rank = (above || 0) + 1;
        const tot  = Math.max(rank, total || 1);
        rankEl.textContent = '#' + rank;
        infoEl.textContent = 'из ' + tot + ' игроков\nsupabase ✦';
        infoEl.style.whiteSpace = 'pre-line';
      } catch (_) {
        rankEl.textContent = '#—';
        infoEl.textContent = 'рейтинг недоступен\nоффлайн';
        infoEl.style.whiteSpace = 'pre-line';
      }
    }

    /** Open the profile screen. */
    function openProfileScreen() {
      _loadProfileUI();
      document.getElementById('profile-lb-rank').textContent = '…';
      document.getElementById('profile-lb-info').textContent = 'загрузка';
      document.getElementById('profile-screen').style.display = 'flex';
      _fetchLeaderboardRank();
    }

    /** Close the profile screen, returning to home. */
    function closeProfileScreen() {
      document.getElementById('profile-screen').style.display = 'none';
      showHomeScreen();
    }

    // Back button
    document.getElementById('profile-back-btn').addEventListener('click', closeProfileScreen);

    // Achievements button → open journey/achievements screen, return to home on back
    document.getElementById('profile-achievements-btn').addEventListener('click', () => {
      closeProfileScreen();
      openAchievementsScreen();
    });

    document.getElementById('ach-back-btn').addEventListener('click', () => {
      closeAchievementsScreen();
      openProfileScreen();
    });

    // Logout / Login
    document.getElementById('profile-logout-btn').addEventListener('click', () => {
      const uid = _skyGetUserId();
      if (!uid) {
        // Guest → show auth screen
        closeProfileScreen();
        document.getElementById('home-screen').style.display = 'none';
        document.getElementById('auth-screen').style.display = 'flex';
      } else {
        // Authenticated → sign out (clear Supabase token + local state)
        sb.auth.signOut().catch(() => {});
        localStorage.removeItem('userId');
        localStorage.removeItem('guestMode');
        closeProfileScreen();
        document.getElementById('home-screen').style.display = 'none';
        document.getElementById('auth-screen').style.display = 'flex';
      }
    });

    // ── Name editing inside profile ────────────────────────────────────────
    const _profNameDisplay = document.getElementById('profile-name-display');
    const _profNameInput   = document.getElementById('profile-name-input');
    _profNameDisplay.addEventListener('click', () => {
      _profNameDisplay.style.display = 'none';
      _profNameInput.style.display   = 'block';
      _profNameInput.focus(); _profNameInput.select();
    });
    function _saveProfileName() {
      const val = _profNameInput.value.trim() || 'Игрок';
      try { localStorage.setItem('playerName', val); } catch(e) {}
      _profNameDisplay.textContent    = val;
      document.getElementById('home-player-name').textContent = val;
      _profNameInput.style.display    = 'none';
      _profNameDisplay.style.display  = '';
    }
    _profNameInput.addEventListener('blur', _saveProfileName);
    _profNameInput.addEventListener('keydown', e => {
      if (e.key === 'Enter')  _profNameInput.blur();
      if (e.key === 'Escape') { _profNameInput.style.display = 'none'; _profNameDisplay.style.display = ''; }
    });

    // ── Avatar picker ─────────────────────────────────────────────────────
    // Build emoji grid
    (function() {
      const grid = document.getElementById('avatar-emoji-grid');
      _PROFILE_EMOJIS.forEach(em => {
        const btn = document.createElement('button');
        btn.className = 'avatar-emoji-btn';
        btn.textContent = em;
        btn.addEventListener('click', () => {
          localStorage.setItem('avatarType',  'emoji');
          localStorage.setItem('avatarValue', em);
          _refreshProfileAvatar();
          // update home-player-name area if needed (future avatar display there)
          closeAvatarPicker();
        });
        grid.appendChild(btn);
      });
    })();

    function openAvatarPicker() {
      // Mark currently selected emoji
      const curVal = localStorage.getItem('avatarValue') || '✦';
      document.querySelectorAll('.avatar-emoji-btn').forEach(btn => {
        btn.classList.toggle('active', btn.textContent === curVal);
      });
      document.getElementById('avatar-picker').style.display = 'flex';
    }
    function closeAvatarPicker() {
      document.getElementById('avatar-picker').style.display = 'none';
    }

    document.getElementById('profile-avatar-zone').addEventListener('click', openAvatarPicker);
    document.getElementById('avatar-picker-close').addEventListener('click', closeAvatarPicker);
    document.getElementById('avatar-picker-backdrop').addEventListener('click', closeAvatarPicker);

    // File upload
    const _avatarFileInput = document.getElementById('avatar-file-input');
    document.getElementById('avatar-upload-btn').addEventListener('click', () => {
      _avatarFileInput.click();
    });
    _avatarFileInput.addEventListener('change', () => {
      const file = _avatarFileInput.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          localStorage.setItem('avatarType',  'photo');
          localStorage.setItem('avatarValue', e.target.result);
        } catch(_) {
          // localStorage quota exceeded — silently skip
        }
        _refreshProfileAvatar();
        closeAvatarPicker();
        _avatarFileInput.value = '';
      };
      reader.readAsDataURL(file);
    });
    // ── End Profile Screen ────────────────────────────────────────────────
    document.getElementById('st-sound').addEventListener('click', () => {
      window._appSettings.sound = !window._appSettings.sound;
      _saveSettings(); _applySettingsUI();
    });
    document.getElementById('st-vibration').addEventListener('click', () => {
      window._appSettings.vibration = !window._appSettings.vibration;
      _saveSettings(); _applySettingsUI();
    });
    document.querySelectorAll('.s-seg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        window._appSettings.starGlow = btn.dataset.glow;
        _saveSettings(); _applySettingsUI();
      });
    });
    document.querySelectorAll('.s-theme-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        applyTheme(btn.dataset.theme);
        _applySettingsUI();
      });
    });
    // home-settings-btn removed; settings opened via #home-settings-icon in topbar

    // ── Constellation detail screen ───────────────────────────────────────────
    let _detailRaf    = null;
    let _detailTwinkle = null;   // {idx, startMs, duration, waitUntil}
    let _detailItem   = null;
    let _detailIdx    = -1;

    function _detailPickTwinkle() {
      if (!_detailItem) return;
      const pts = _detailItem.points || [];
      const lns = _detailItem.lines  || [];
      const wp  = _detailItem.winner >= 0 ? _detailItem.winner : 0;
      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });
      const cands = pts.map((_, i) => i).filter(i => deg[i] > 0);
      if (!cands.length) return;
      const idx = cands[Math.floor(Math.random() * cands.length)];
      const dur = 900 + Math.random() * 500;
      _detailTwinkle = { idx, startMs: performance.now(), duration: dur,
                         waitUntil: performance.now() + dur + 1000 + Math.random() * 2500 };
    }

    function _drawDetailConst() {
      const cv = document.getElementById('const-detail-canvas');
      if (!cv || !_detailItem) return;
      const dpr = window.devicePixelRatio || 1;
      const ctx = cv.getContext('2d');
      const CW = cv.width, CH = cv.height;

      ctx.clearRect(0, 0, CW, CH);
      ctx.fillStyle = '#060612'; ctx.fillRect(0, 0, CW, CH);

      // Faint bg stars
      for (let i = 0; i < 90; i++) {
        const sx = Math.abs(Math.sin(i * 127.3 + 3)) * CW;
        const sy = Math.abs(Math.cos(i * 73.9  + 5)) * CH;
        const sr = (0.3 + Math.abs(Math.sin(i * 211)) * 0.6) * dpr;
        const sa = 0.04 + 0.10 * Math.abs(Math.sin(performance.now() / 3200 + i * 0.53));
        ctx.globalAlpha = sa;
        ctx.beginPath(); ctx.arc(sx, sy, sr, 0, Math.PI * 2);
        ctx.fillStyle = '#fff'; ctx.fill();
      }
      ctx.globalAlpha = 1;

      const item   = _detailItem;
      const pts    = item.points || [];
      const lns    = item.lines  || [];
      const wp     = item.winner >= 0 ? item.winner : 0;

      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });

      const active = pts.filter((_, i) => deg[i] > 0);
      if (!active.length) return;

      const PAD  = 72 * dpr;
      const minX = Math.min(...active.map(p => p.x));
      const maxX = Math.max(...active.map(p => p.x));
      const minY = Math.min(...active.map(p => p.y));
      const maxY = Math.max(...active.map(p => p.y));
      const srcW = (maxX - minX) || 0.1;
      const srcH = (maxY - minY) || 0.1;
      const scl  = Math.min((CW - PAD * 2) / srcW, (CH - PAD * 2) / srcH);
      const ofX  = PAD + ((CW - PAD * 2) - srcW * scl) / 2;
      const ofY  = PAD + ((CH - PAD * 2) - srcH * scl) / 2;
      const tx = p => (p.x - minX) * scl + ofX;
      const ty = p => (p.y - minY) * scl + ofY;

      // Glowing lines (same as drawVictoryDuel stargazer)
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (!pts[a] || !pts[b]) return;
        const ax = tx(pts[a]), ay = ty(pts[a]), bx = tx(pts[b]), by = ty(pts[b]);
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.07)'; ctx.lineWidth = 12 * dpr; ctx.stroke();
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.18)'; ctx.lineWidth = 4.5 * dpr; ctx.stroke();
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.88)'; ctx.lineWidth = 1.3 * dpr; ctx.stroke();
      });

      // Stars with twinkling — temporarily set RADIUS for this canvas size
      const _prevR = RADIUS;
      RADIUS = Math.round(Math.min(CW, CH) * 0.013 / dpr);
      pts.forEach((p, i) => {
        if (deg[i] === 0) return;
        let boost = 0;
        if (_detailTwinkle && _detailTwinkle.idx === i) {
          const t2 = Math.min((performance.now() - _detailTwinkle.startMs) / _detailTwinkle.duration, 1);
          const env = t2 < 0.3 ? t2 / 0.3 : (1 - t2) / 0.7;
          boost = Math.sin(env * Math.PI * 0.5);
        }
        drawStarPointTo(ctx, tx(p), ty(p), Math.max(deg[i], 2), false, false, false, 0.7 + boost * 0.9);
      });
      RADIUS = _prevR;
    }

    function _startDetailAnim() {
      if (_detailRaf) { cancelAnimationFrame(_detailRaf); _detailRaf = null; }
      _detailTwinkle = null;
      _detailPickTwinkle();
      function frame() {
        if (!_detailTwinkle || performance.now() >= _detailTwinkle.waitUntil) _detailPickTwinkle();
        _drawDetailConst();
        _detailRaf = requestAnimationFrame(frame);
      }
      _detailRaf = requestAnimationFrame(frame);
    }

    function openConstDetail(item, idx) {
      _detailItem = item; _detailIdx = idx;
      // Size canvas
      const wrap = document.getElementById('const-detail-canvas-wrap');
      const cv   = document.getElementById('const-detail-canvas');
      const dpr  = window.devicePixelRatio || 1;
      // Use rAF so offsetWidth is valid after display:flex
      requestAnimationFrame(() => {
        cv.width  = wrap.offsetWidth  * dpr;
        cv.height = wrap.offsetHeight * dpr;
        _startDetailAnim();
      });
      // Name
      document.getElementById('const-detail-name-text').textContent = item.name || '—';
      document.getElementById('const-detail-name-text').style.display = 'block';
      document.getElementById('const-detail-name-input').style.display  = 'none';
      // Address (if published)
      const addrEl = document.getElementById('const-detail-addr');
      addrEl.textContent = item.publishedAt ? (item.skyAddr || _constellationAddress(item.name)) : '';
      // Publish btn
      const pb = document.getElementById('const-detail-publish-btn');
      if (item.publishedAt) {
        pb.textContent = '✦ Опубликовано'; pb.classList.add('published'); pb.disabled = true;
      } else {
        pb.textContent = 'В небо ✦'; pb.classList.remove('published'); pb.disabled = false;
      }
      document.getElementById('const-detail-screen').style.display = 'flex';
    }

    function closeConstDetail() {
      if (_detailRaf) { cancelAnimationFrame(_detailRaf); _detailRaf = null; }
      document.getElementById('const-detail-screen').style.display = 'none';
    }

    document.getElementById('const-detail-back-btn').addEventListener('click', closeConstDetail);

    // Rename: toggle name-text ↔ input
    function _startDetailRename() {
      const nameText  = document.getElementById('const-detail-name-text');
      const nameInput = document.getElementById('const-detail-name-input');
      nameInput.value = _detailItem.name || '';
      nameText.style.display  = 'none';
      nameInput.style.display = 'block';
      nameInput.focus(); nameInput.select();
    }
    function _commitDetailRename() {
      const nameText  = document.getElementById('const-detail-name-text');
      const nameInput = document.getElementById('const-detail-name-input');
      const newName   = nameInput.value.trim() || _detailItem.name;
      if (newName !== _detailItem.name) {
        const oldName = _detailItem.name;
        const arr = _loadSaved();
        arr[_detailIdx].name = newName;
        if (arr[_detailIdx].publishedAt) {
          arr[_detailIdx].skyAddr = _constellationAddress(newName);
          // Обновляем запись по старому имени — не создаём дубликат
          const uid = _skyGetUserId();
          sb.from('constellations')
            .update({ name: newName, data: arr[_detailIdx] })
            .eq('name', oldName)
            .eq('user_id', uid)
            .catch(() => {});
        }
        _persistSaved(arr);
        _detailItem = arr[_detailIdx];
        localStorage.setItem('lastConstellationName', newName);
        _renderJourneyGrid();
      }
      nameText.textContent    = _detailItem.name;
      nameText.style.display  = 'block';
      nameInput.style.display = 'none';
    }
    document.getElementById('const-detail-name-text').addEventListener('click',  _startDetailRename);
    document.getElementById('const-detail-name-input').addEventListener('blur',  _commitDetailRename);
    document.getElementById('const-detail-name-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('const-detail-name-input').blur();
    });

    // Publish — with save-to-sky animation from the detail canvas
    function _detailPublishAnimation(item, onDone) {
      const VW = window.innerWidth, VH = window.innerHeight;
      const dpr = window.devicePixelRatio || 1;
      // ── Цвета из активной темы ──────────────────────────────────────────────
      const _pt = THEMES[activeTheme] || THEMES.stargazer;
      const _pBg      = _pt.skyBg      || '#060612';
      const _pStarRGB = _pt.skyStarRGB || '255,245,210';
      const _pHaloRGB = _pt.skyBgStar  ? '255,200,120' : _pStarRGB;
      const _pLabel   = _pt.skyLabelHL || 'rgba(255,248,235,1)';
      const _pHasBgStars = !!_pt.skyBgStar;
      // ───────────────────────────────────────────────────────────────────────

      // Compute star screen positions from the detail canvas + fit transform
      const cv   = document.getElementById('const-detail-canvas');
      const rect = cv.getBoundingClientRect();
      const SW = rect.width, SH = rect.height;

      const pts = item.points || [];
      const lns = item.lines  || [];
      const wp  = (item.winner >= 0) ? item.winner : 0;

      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });
      const active = pts.filter((_, i) => deg[i] > 0);
      if (!active.length) { onDone(); return; }

      const PAD  = Math.round(Math.min(SW, SH) * 0.14);
      const minX = Math.min(...active.map(p => p.x));
      const maxX = Math.max(...active.map(p => p.x));
      const minY = Math.min(...active.map(p => p.y));
      const maxY = Math.max(...active.map(p => p.y));
      const srcW = (maxX - minX) || 0.1;
      const srcH = (maxY - minY) || 0.1;
      const scl  = Math.min((SW - PAD * 2) / srcW, (SH - PAD * 2) / srcH);
      const ofX  = PAD + ((SW - PAD * 2) - srcW * scl) / 2;
      const ofY  = PAD + ((SH - PAD * 2) - srcH * scl) / 2;

      const snapPts = pts.map(p => ({
        sx: rect.left + (p.x - minX) * scl + ofX,
        sy: rect.top  + (p.y - minY) * scl + ofY,
      }));

      // Target: screen center
      const tX = VW / 2, tY = VH / 2;
      const skyS = 0.22;
      const skyOX = VW / 2 - _SKY_WORLD / 2 * skyS;
      const skyOY = VH / 2 - _SKY_WORLD / 2 * skyS;
      _skyEnsureBg();

      function _drawBgStar(c, sx, sy, r, alpha, mA) {
        const fa = alpha * mA; if (fa <= 0.003) return;
        const coreR = Math.max(0.5, r * 1.2), haloR = Math.max(1.5, r * 6);
        const hg = c.createRadialGradient(sx, sy, 0, sx, sy, haloR);
        hg.addColorStop(0,    `rgba(${_pHaloRGB},${Math.min(0.72, fa * 0.55).toFixed(3)})`);
        hg.addColorStop(0.28, `rgba(${_pHaloRGB},${(fa * 0.14).toFixed(3)})`);
        hg.addColorStop(1,    `rgba(${_pHaloRGB},0)`);
        c.fillStyle = hg; c.beginPath(); c.arc(sx, sy, haloR, 0, Math.PI*2); c.fill();
        const cg = c.createRadialGradient(sx, sy, 0, sx, sy, coreR);
        cg.addColorStop(0,    `rgba(${_pStarRGB},${Math.min(0.95, fa * 0.95).toFixed(3)})`);
        cg.addColorStop(0.35, `rgba(${_pStarRGB},${(fa * 0.55).toFixed(3)})`);
        cg.addColorStop(0.75, `rgba(${_pStarRGB},${(fa * 0.12).toFixed(3)})`);
        cg.addColorStop(1,    `rgba(${_pStarRGB},0)`);
        c.fillStyle = cg; c.beginPath(); c.arc(sx, sy, coreR, 0, Math.PI*2); c.fill();
      }

      // Overlay canvas
      const ov = document.createElement('canvas');
      ov.width = VW * dpr; ov.height = VH * dpr;
      ov.style.cssText = `position:fixed;inset:0;width:${VW}px;height:${VH}px;z-index:9997;pointer-events:none;`;
      document.body.appendChild(ov);
      const oc = ov.getContext('2d');
      oc.scale(dpr, dpr);

      const T_SKY = 400, T_SHRINK = 1600, T_BLINK = 1000, T_TEXT = 400, T_HOLD = 1000, T_FADE = 600;
      const TOTAL = T_SHRINK + T_BLINK + T_TEXT + T_HOLD + T_FADE;
      const startT = performance.now();

      function frame() {
        const elapsed = performance.now() - startT;
        const done    = elapsed >= TOTAL;
        oc.clearRect(0, 0, VW, VH);

        const fadeStart = T_SHRINK + T_BLINK + T_TEXT + T_HOLD;
        const masterA   = elapsed >= fadeStart ? Math.max(0, 1 - (elapsed - fadeStart) / T_FADE) : 1;

        // Background (theme-aware)
        const bgA = Math.min(1, elapsed / T_SKY) * masterA;
        oc.globalAlpha = bgA;
        oc.fillStyle = _pBg; oc.fillRect(0, 0, VW, VH);
        oc.globalAlpha = 1;
        if (_pHasBgStars) {
          _bgStars.forEach(s => {
            const sx = s.x * skyS + skyOX, sy = s.y * skyS + skyOY;
            if (sx < -10 || sx > VW + 10 || sy < -10 || sy > VH + 10) return;
            _drawBgStar(oc, sx, sy, Math.max(0.4, s.r * skyS * 5), s.a, bgA);
          });
        }

        // Phase 1: stars fly to center
        if (elapsed < T_SHRINK) {
          const t = elapsed / T_SHRINK;
          function eoc(x) { return 1 - Math.pow(1 - x, 3); }
          snapPts.forEach((p, i) => {
            const stagger = snapPts.length > 1 ? 0.12 / snapPts.length : 0;
            const delay   = i * stagger;
            const tStar   = Math.max(0, Math.min(1, (t - delay) / (1 - delay)));
            const ease    = eoc(tStar);
            const dx = tX - p.sx, dy = tY - p.sy;
            const ang = Math.atan2(dy, dx);
            const sign = (i % 2 === 0 ? 1 : -1);
            const arcH = (10 + (i * 13) % 28);
            const arc  = sign * arcH * Math.sin(tStar * Math.PI);
            const px = p.sx + dx * ease + (-Math.sin(ang)) * arc;
            const py = p.sy + dy * ease + ( Math.cos(ang)) * arc;
            const starA = Math.max(0, 1 - tStar * 1.15) * masterA;
            const coreR = Math.max(0.3, 4 * (1 - ease * 0.84));
            if (starA < 0.01) return;
            const haloR = coreR * 5.5;
            const hg = oc.createRadialGradient(px, py, 0, px, py, haloR);
            hg.addColorStop(0,    `rgba(${_pHaloRGB},${(starA * 0.48).toFixed(3)})`);
            hg.addColorStop(0.35, `rgba(${_pHaloRGB},${(starA * 0.10).toFixed(3)})`);
            hg.addColorStop(1,    `rgba(${_pHaloRGB},0)`);
            oc.fillStyle = hg; oc.beginPath(); oc.arc(px, py, haloR, 0, Math.PI*2); oc.fill();
            const cg = oc.createRadialGradient(px, py, 0, px, py, coreR);
            cg.addColorStop(0,    `rgba(${_pStarRGB},${(starA * 0.95).toFixed(3)})`);
            cg.addColorStop(0.45, `rgba(${_pStarRGB},${(starA * 0.40).toFixed(3)})`);
            cg.addColorStop(1,    `rgba(${_pStarRGB},0)`);
            oc.fillStyle = cg; oc.beginPath(); oc.arc(px, py, coreR, 0, Math.PI*2); oc.fill();
          });
          const tLate = Math.max(0, (t - 0.6) / 0.4);
          _drawSkyStar(oc, tX, tY, tLate * masterA, 2.5, tLate > 0.3, _pStarRGB);
        }

        // Phase 2: blink
        if (elapsed >= T_SHRINK && elapsed < T_SHRINK + T_BLINK) {
          const blink = 0.45 + 0.55 * Math.abs(Math.sin((elapsed - T_SHRINK) / T_BLINK * Math.PI * 4));
          _drawSkyStar(oc, tX, tY, blink * masterA, 2.5, true, _pStarRGB);
        }

        // Phase 3-4: star + text
        if (elapsed >= T_SHRINK + T_BLINK) {
          _drawSkyStar(oc, tX, tY, masterA, 2.5, true, _pStarRGB);
          const textA = Math.min(1, (elapsed - T_SHRINK - T_BLINK) / T_TEXT) * masterA;
          if (textA > 0.01) {
            oc.save(); oc.globalAlpha = textA;
            oc.font = '500 15px "Raleway", sans-serif';
            oc.textAlign = 'center';
            oc.shadowColor = `rgba(${_pStarRGB},0.40)`; oc.shadowBlur = 14;
            oc.fillStyle = _pLabel;
            oc.fillText('Опубликовано в небо ✦', tX, tY + 50);
            oc.restore();
          }
        }

        if (!done) requestAnimationFrame(frame);
        else { ov.remove(); onDone(); }
      }
      requestAnimationFrame(frame);
    }

    document.getElementById('const-detail-publish-btn').addEventListener('click', async () => {
      if (!_detailItem || _detailItem.publishedAt) return;
      const pb = document.getElementById('const-detail-publish-btn');
      pb.textContent = '...'; pb.disabled = true;

      // Save data immediately (in parallel with animation)
      const arr = _loadSaved();
      arr[_detailIdx].publishedAt = new Date().toISOString();
      arr[_detailIdx].skyAddr = _constellationAddress(_detailItem.name);
      _persistSaved(arr);
      _detailItem = arr[_detailIdx];
      playSound('twinkle');
      haptic('medium');
      sb.from('constellations').insert({ name: _detailItem.name, data: arr[_detailIdx], user_id: _skyGetUserId(), gx: Math.random(), gy: Math.random() }).catch(() => {});

      // Play animation, then update UI
      _detailPublishAnimation(_detailItem, () => {
        pb.textContent = '✦ Опубликовано'; pb.classList.add('published'); pb.disabled = true;
        document.getElementById('const-detail-addr').textContent = _detailItem.skyAddr;
        _renderJourneyGrid();
      });
    });

    // Share — builds a standalone PNG (constellation + name) and shares / copies it
    function _makeShareCanvas(item) {
      const W = 600, H = 720;
      const cv = document.createElement('canvas');
      cv.width = W; cv.height = H;
      const ctx = cv.getContext('2d');

      // Dark starfield background
      ctx.fillStyle = '#060612';
      ctx.fillRect(0, 0, W, H);

      // Faint bg stars (deterministic)
      for (let i = 0; i < 90; i++) {
        const sx = Math.abs(Math.sin(i * 127.3 + 3.7)) * W;
        const sy = Math.abs(Math.cos(i * 73.9  + 1.1)) * H;
        ctx.globalAlpha = 0.03 + Math.abs(Math.sin(i * 211.7)) * 0.09;
        ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.arc(sx, sy, 0.5 + (i % 3) * 0.25, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;

      // ── Constellation ──
      const pts = item.points || [];
      const lns = item.lines  || [];
      const wp  = (item.winner >= 0) ? item.winner : 0;

      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });

      const active = pts.filter((_, i) => deg[i] > 0);
      if (active.length) {
        const ZONE_H = H - 160; // reserve bottom for name
        const PAD    = 70;
        const minX = Math.min(...active.map(p => p.x));
        const maxX = Math.max(...active.map(p => p.x));
        const minY = Math.min(...active.map(p => p.y));
        const maxY = Math.max(...active.map(p => p.y));
        const srcW = (maxX - minX) || 0.1;
        const srcH = (maxY - minY) || 0.1;
        const scl  = Math.min((W - PAD * 2) / srcW, (ZONE_H - PAD * 2) / srcH);
        const ofX  = (W - srcW * scl) / 2;
        const ofY  = PAD + (ZONE_H - PAD * 2 - srcH * scl) / 2;
        const mx = p => (p.x - minX) * scl + ofX;
        const my = p => (p.y - minY) * scl + ofY;

        // 3-pass glowing lines
        lns.forEach(([key, pl]) => {
          if (pl !== wp) return;
          const [a, b] = key.split('-').map(Number);
          if (!pts[a] || !pts[b]) return;
          const ax = mx(pts[a]), ay = my(pts[a]);
          const bx = mx(pts[b]), by = my(pts[b]);
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = 'rgba(248,247,245,0.07)'; ctx.lineWidth = 22; ctx.stroke();
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = 'rgba(248,247,245,0.18)'; ctx.lineWidth = 9;  ctx.stroke();
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = 'rgba(248,247,245,0.88)'; ctx.lineWidth = 2.5; ctx.stroke();
        });

        // Stars
        const _prevR = RADIUS;
        RADIUS = Math.round(W * 0.015); // ~9px for 600px canvas
        pts.forEach((p, i) => {
          if (deg[i] === 0) return;
          drawStarPointTo(ctx, mx(p), my(p), Math.max(deg[i], 2), false, false, false, 0.6);
        });
        RADIUS = _prevR;
      }

      // ── Separator line ──
      ctx.strokeStyle = 'rgba(255,245,210,0.10)';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(48, H - 128); ctx.lineTo(W - 48, H - 128); ctx.stroke();

      // ── Constellation name ──
      const name = item.name || '—';
      ctx.font = '300 36px -apple-system, "SF Pro Display", "Helvetica Neue", sans-serif';
      ctx.fillStyle = 'rgba(255,245,210,0.92)';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(name, W / 2, H - 84);

      // ── Address (if published) ──
      const addr = item.skyAddr || (item.publishedAt ? _constellationAddress(item.name) : '');
      if (addr) {
        ctx.font = '300 15px -apple-system, "SF Pro Display", "Helvetica Neue", sans-serif';
        ctx.fillStyle = 'rgba(255,245,210,0.30)';
        ctx.fillText(addr, W / 2, H - 46);
      }

      // ── Stargazer watermark ──
      ctx.font = '200 13px -apple-system, "SF Pro Display", "Helvetica Neue", sans-serif';
      ctx.fillStyle = 'rgba(255,245,210,0.16)';
      ctx.fillText('✦  Stargazer', W / 2, H - 18);

      return cv;
    }

    document.getElementById('const-detail-share-btn').addEventListener('click', async () => {
      if (!_detailItem) return;
      const btn = document.getElementById('const-detail-share-btn');
      btn.disabled = true;
      try {
        const shareCv = _makeShareCanvas(_detailItem);
        const blob = await new Promise(res => shareCv.toBlob(res, 'image/png'));
        const fname = (_detailItem.name || 'constellation').replace(/[^\w\u0400-\u04FF ]/g, '_') + '.png';
        const file = new File([blob], fname, { type: 'image/png' });

        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          // iOS / Android native share sheet with image
          await navigator.share({ files: [file], title: _detailItem.name });
        } else if (navigator.clipboard && navigator.clipboard.write) {
          // Desktop — copy image to clipboard
          await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
          showToast('Картинка скопирована ✦');
        } else {
          // Fallback — download
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = fname; a.click();
          setTimeout(() => URL.revokeObjectURL(url), 2000);
        }
      } catch(e) {
        if (e.name !== 'AbortError') showToast('Не удалось поделиться');
      } finally {
        btn.disabled = false;
      }
    });

    // Inline name editing on home screen
    // Clicking player name row on home screen opens profile
    document.getElementById('home-player-name-row').addEventListener('click', () => { openProfileScreen(); });

    // ← Меню (in-game top panel)
    document.getElementById('back-to-menu-btn').addEventListener('click', goToMenu);
    document.getElementById('loss-play-again-btn').addEventListener('click', startGame);
    document.getElementById('loss-to-menu-btn').addEventListener('click', goToMenu);

    // Кнопка «Играть снова» — повторяет партию с теми же настройками
    document.getElementById('play-again-btn').addEventListener('click', startGame);

    document.getElementById('start-back-btn').addEventListener('click', () => showStep('game-mode-step'));


    // «Сохранить в небо ✦» — анимация + фактическое сохранение
    // Вспомогательная: рисует звезду-точку на overlay
    function _drawSkyStar(ctx, x, y, alpha, r, withGlow, starRGB) {
      if (alpha <= 0) return;
      const sr = starRGB || '255,245,210';
      ctx.save();
      ctx.globalAlpha = alpha;
      if (withGlow) {
        const g = ctx.createRadialGradient(x, y, 0, x, y, r * 7);
        g.addColorStop(0,    `rgba(${sr},0.95)`);
        g.addColorStop(0.25, `rgba(${sr},0.35)`);
        g.addColorStop(1,    `rgba(${sr},0)`);
        ctx.beginPath(); ctx.arc(x, y, r * 7, 0, Math.PI * 2);
        ctx.fillStyle = g; ctx.fill();
      }
      ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${sr},1.0)`;
      ctx.fill();
      ctx.restore();
    }

    /**
     * saveToSkyAnimation — анимация сохранения созвездия:
     *   созвездие плавно сжимается сверху → становится точкой на небе →
     *   точка подмигивает → "Созвездие сохранено ✦" → затемнение → onDone()
     */
    function saveToSkyAnimation(constName, onDone) {
      const VW = window.innerWidth, VH = window.innerHeight;
      const dpr = window.devicePixelRatio || 1;
      // ── Цвета из активной темы ──────────────────────────────────────────────
      const _at = THEMES[activeTheme] || THEMES.stargazer;
      const _aBg      = _at.skyBg      || '#060612';
      const _aStarRGB = _at.skyStarRGB || '255,245,210';
      // Тёплый янтарный ореол только для тёмной (stargazer) темы; остальные — цвет звезды
      const _aHaloRGB = _at.skyBgStar  ? '255,200,120' : _aStarRGB;
      const _aLabel   = _at.skyLabelHL || 'rgba(255,248,235,1)';
      const _aHasBgStars = !!_at.skyBgStar;
      // ───────────────────────────────────────────────────────────────────────

      // Снапшот игрового созвездия в экранных координатах
      const rect   = canvas.getBoundingClientRect();
      const scaleX = rect.width  / W;
      const scaleY = rect.height / H;
      const snapPts = points.map(p => ({
        sx: rect.left + p.x * scaleX,
        sy: rect.top  + p.y * scaleY
      }));
      const snapEdges = Array.from(lines.keys()).map(key => {
        const [a, b] = key.split('-').map(Number); return [a, b];
      });
      const startCX = snapPts.reduce((s, p) => s + p.sx, 0) / snapPts.length;
      const startCY = snapPts.reduce((s, p) => s + p.sy, 0) / snapPts.length;

      // Целевая позиция — центр экрана
      const skyS   = 0.22;
      const skyOX  = VW / 2 - _SKY_WORLD / 2 * skyS;
      const skyOY  = VH / 2 - _SKY_WORLD / 2 * skyS;
      const tX  = VW / 2;
      const tY  = VH / 2;

      _skyEnsureBg();

      // Рисует звезду как в игре, но уменьшенную в 3× (ореол + ядро, без спайков, без blur)
      function _drawAnimBgStar(c, sx, sy, r, alpha, mA) {
        const fa = alpha * mA;
        if (fa <= 0.003) return;
        const coreR = Math.max(0.5, r * 1.2);
        const haloR = Math.max(1.5, r * 6);
        // Ореол — тема: тёплый янтарь для stargazer, цвет звезды для остальных
        const hg = c.createRadialGradient(sx, sy, 0, sx, sy, haloR);
        hg.addColorStop(0,    `rgba(${_aHaloRGB},${Math.min(0.72, fa * 0.55).toFixed(3)})`);
        hg.addColorStop(0.28, `rgba(${_aHaloRGB},${(fa * 0.14).toFixed(3)})`);
        hg.addColorStop(1,    `rgba(${_aHaloRGB},0)`);
        c.fillStyle = hg;
        c.beginPath(); c.arc(sx, sy, haloR, 0, Math.PI * 2); c.fill();
        // Ядро — цвет звезды из темы
        const cg = c.createRadialGradient(sx, sy, 0, sx, sy, coreR);
        cg.addColorStop(0,    `rgba(${_aStarRGB},${Math.min(0.95, fa * 0.95).toFixed(3)})`);
        cg.addColorStop(0.35, `rgba(${_aStarRGB},${(fa * 0.55).toFixed(3)})`);
        cg.addColorStop(0.75, `rgba(${_aStarRGB},${(fa * 0.12).toFixed(3)})`);
        cg.addColorStop(1,    `rgba(${_aStarRGB},0)`);
        c.fillStyle = cg;
        c.beginPath(); c.arc(sx, sy, coreR, 0, Math.PI * 2); c.fill();
      }

      // Overlay
      const ov = document.createElement('canvas');
      ov.width  = VW * dpr; ov.height = VH * dpr;
      ov.style.cssText = `position:fixed;inset:0;width:${VW}px;height:${VH}px;z-index:9997;pointer-events:none;`;
      document.body.appendChild(ov);
      const oc = ov.getContext('2d');
      oc.scale(dpr, dpr);

      // Тайминги (мс)
      const T_SKY    = 400;   // небо появляется
      const T_SHRINK = 1600;  // созвездие летит и сжимается
      const T_BLINK  = 1000;  // точка подмигивает
      const T_TEXT   = 400;   // текст появляется
      const T_HOLD   = 1000;  // текст держится
      const T_FADE   = 600;   // всё гаснет
      const TOTAL    = T_SHRINK + T_BLINK + T_TEXT + T_HOLD + T_FADE;

      const startT = performance.now();
      function eio(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

      function frame() {
        const elapsed = performance.now() - startT;
        const done    = elapsed >= TOTAL;

        oc.clearRect(0, 0, VW, VH);

        // Мастер-прозрачность: угасание в конце
        const fadeStart = T_SHRINK + T_BLINK + T_TEXT + T_HOLD;
        const masterA   = elapsed >= fadeStart
          ? Math.max(0, 1 - (elapsed - fadeStart) / T_FADE) : 1;

        // ── Фон: цвет из темы ──
        const bgA = Math.min(1, elapsed / T_SKY) * masterA;
        oc.globalAlpha = bgA;
        oc.fillStyle = _aBg;
        oc.fillRect(0, 0, VW, VH);

        oc.globalAlpha = 1;
        // Фоновые звёзды — только для тёмных тем (skyBgStar = true)
        if (_aHasBgStars) {
          _bgStars.forEach(s => {
            const sx = s.x * skyS + skyOX;
            const sy = s.y * skyS + skyOY;
            if (sx < -10 || sx > VW + 10 || sy < -10 || sy > VH + 10) return;
            // Радиус — 1/3 от игрового (игра: r*skyS*15, здесь r*skyS*5)
            const r = Math.max(0.4, s.r * skyS * 5);
            _drawAnimBgStar(oc, sx, sy, r, s.a, bgA);
          });
        }

        // ── Фаза 1: каждая звезда летит к центру по своей дуге ──
        if (elapsed < T_SHRINK) {
          const t = elapsed / T_SHRINK;
          function eoc(x) { return 1 - Math.pow(1 - x, 3); } // ease-out-cubic

          snapPts.forEach((p, i) => {
            // Небольшой стаггер: каждая звезда стартует чуть позже
            const stagger = snapPts.length > 1 ? 0.12 / snapPts.length : 0;
            const delay   = i * stagger;
            const tStar   = Math.max(0, Math.min(1, (t - delay) / (1 - delay)));
            const ease    = eoc(tStar);

            // Перпендикулярная дуга: величина и знак уникальны для каждой точки
            const dx    = tX - p.sx;
            const dy    = tY - p.sy;
            const ang   = Math.atan2(dy, dx);
            const perpX = -Math.sin(ang);
            const perpY =  Math.cos(ang);
            const sign  = (i % 2 === 0 ? 1 : -1);
            const arcH  = (10 + (i * 13) % 28); // 10–38px уникальный для звезды
            const arc   = sign * arcH * Math.sin(tStar * Math.PI); // 0 → пик → 0

            const px = p.sx + dx * ease + perpX * arc;
            const py = p.sy + dy * ease + perpY * arc;

            // Звезда гаснет и уменьшается по мере приближения
            const starA = Math.max(0, 1 - tStar * 1.15) * masterA;
            const coreR = Math.max(0.3, 4 * (1 - ease * 0.84));
            if (starA < 0.01) return;

            // Ореол — цвет из темы
            const haloR = coreR * 5.5;
            const hg = oc.createRadialGradient(px, py, 0, px, py, haloR);
            hg.addColorStop(0,    `rgba(${_aHaloRGB},${(starA * 0.48).toFixed(3)})`);
            hg.addColorStop(0.35, `rgba(${_aHaloRGB},${(starA * 0.10).toFixed(3)})`);
            hg.addColorStop(1,    `rgba(${_aHaloRGB},0)`);
            oc.fillStyle = hg;
            oc.beginPath(); oc.arc(px, py, haloR, 0, Math.PI * 2); oc.fill();

            // Ядро — цвет из темы
            const cg = oc.createRadialGradient(px, py, 0, px, py, coreR);
            cg.addColorStop(0,    `rgba(${_aStarRGB},${(starA * 0.95).toFixed(3)})`);
            cg.addColorStop(0.45, `rgba(${_aStarRGB},${(starA * 0.40).toFixed(3)})`);
            cg.addColorStop(1,    `rgba(${_aStarRGB},0)`);
            oc.fillStyle = cg;
            oc.beginPath(); oc.arc(px, py, coreR, 0, Math.PI * 2); oc.fill();
          });

          // Целевая точка появляется только в последние 40% фазы
          const tLate = Math.max(0, (t - 0.6) / 0.4);
          _drawSkyStar(oc, tX, tY, tLate * masterA, 2.5, tLate > 0.3, _aStarRGB);
        }

        // ── Фаза 2: точка мигает ──
        if (elapsed >= T_SHRINK && elapsed < T_SHRINK + T_BLINK) {
          const t     = (elapsed - T_SHRINK) / T_BLINK;
          const blink = 0.45 + 0.55 * Math.abs(Math.sin(t * Math.PI * 4));
          _drawSkyStar(oc, tX, tY, blink * masterA, 2.5, true, _aStarRGB);
        }

        // ── Фазы 3–4: звезда + текст + удержание ──
        if (elapsed >= T_SHRINK + T_BLINK) {
          _drawSkyStar(oc, tX, tY, masterA, 2.5, true, _aStarRGB);
          const textElapsed = elapsed - T_SHRINK - T_BLINK;
          const textA = Math.min(1, textElapsed / T_TEXT) * masterA;
          if (textA > 0.01) {
            oc.save();
            oc.globalAlpha = textA;
            oc.font = '500 15px "Raleway", sans-serif';
            oc.textAlign = 'center';
            oc.shadowColor = `rgba(${_aStarRGB},0.40)`;
            oc.shadowBlur  = 14;
            oc.fillStyle = _aLabel;
            oc.fillText('Созвездие сохранено ✦', tX, tY + 50);
            oc.restore();
          }
        }

        if (!done) requestAnimationFrame(frame);
        else       { ov.remove(); onDone(); }
      }
      requestAnimationFrame(frame);
    }

    document.getElementById('name-const-save-btn').addEventListener('click', () => {
      const nameInput = document.getElementById('name-const-input');
      const name = nameInput.value.trim() || 'Без названия';
      const constellation = {
        name,
        points:    points.map(p => ({ x: p.x / W, y: p.y / H })),
        lines:     Array.from(lines.entries()),
        polygons:  polygons.map(pg => ({ path: pg.path, player: pg.player })),
        winner,
        createdAt:   new Date().toISOString(),
        publishedAt: new Date().toISOString(),   // уже публикуется сразу
        skyAddr:     _constellationAddress(name),
      };
      const saveBtn = document.getElementById('name-const-save-btn');
      saveBtn.disabled = true;

      // 1. Сохраняем в localStorage сразу, чтобы небо знало о созвездии
      try {
        const key = 'saved_constellations';
        const existing = JSON.parse(localStorage.getItem(key) || '[]');
        existing.unshift(constellation);
        localStorage.setItem(key, JSON.stringify(existing));
        localStorage.setItem('lastConstellationName', name);
      } catch(e) {}

      // 2. Отправляем в Supabase параллельно с анимацией (с user_id если авторизован)
      const supabasePromise = sb.from('constellations').insert({
        name,
        data: constellation,
        user_id: _skyGetUserId(),
        gx: Math.random(),
        gy: Math.random(),
      });
      playSound('twinkle');
      haptic('heavy');

      // 3. Анимация: небо открывается, созвездие летит в точку
      saveToSkyAnimation(name, async () => {
        await supabasePromise; // ждём завершения (обычно уже готово)
        saveBtn.style.display = 'none';
        saveBtn.disabled = false;
        goToMenu();
      });
    });
    document.getElementById('name-const-again-btn').addEventListener('click', startGame);

    // Кнопка «← В меню» на экране победы
    document.getElementById('to-menu-btn').addEventListener('click', goToMenu);

    // Кнопка «Сменить ранг»: циклически переключает ранг 1→2→…→10→1
    document.getElementById('change-rank-btn').addEventListener('click', () => {
      const p = loadProgress();
      p.rank = p.rank >= RANKS.length ? 1 : p.rank + 1;
      p.rating = RANK_THRESHOLDS[p.rank - 1];
      saveProgress(p);
      renderProgressWidget();
    });

    // 💡 hints toggle (in-game top panel)
    document.getElementById('hints-btn').addEventListener('click', () => {
      _hintsOn = !_hintsOn;
      localStorage.setItem('hintsEnabled', _hintsOn ? '1' : '0');
      document.getElementById('hints-btn').classList.toggle('active', _hintsOn);
      const cb = document.getElementById('hints-checkbox');
      if (cb) cb.checked = _hintsOn;
      if (_hintsOn) { computeHints(); }
      else {
        _hintEdges = [];
        if (_hintsRaf) { cancelAnimationFrame(_hintsRaf); _hintsRaf = null; }
      }
      draw();
    });

    // 💡 hints checkbox on start screen
    (function() {
      const cb = document.getElementById('hints-checkbox');
      cb.checked = localStorage.getItem('hintsEnabled') === '1';
      cb.addEventListener('change', () => {
        localStorage.setItem('hintsEnabled', cb.checked ? '1' : '0');
        _hintsOn = cb.checked;
      });
    })();

    // ── Auth / Tutorial screens ───────────────────────────────────────────────

    /**
     * Настраивает кнопки победного экрана в зависимости от состояния авторизации:
     * - tutorial auto-save: скрываем обе кнопки, показываем "Сохранено ✦"
     * - гость: только "В мои созвездия" (без Supabase)
     * - авторизован: обе кнопки — "В мои созвездия" и "В небо ✦"
     *   (при "В небо" — локальное сохранение происходит автоматически)
     */
    function applyGuestMode() {
      const isGuest    = localStorage.getItem('guestMode') === 'true';
      const saveSkyBtn = document.getElementById('name-const-save-btn');
      const saveLocBtn = document.getElementById('name-const-local-save-btn');
      const guestDiv   = document.getElementById('name-const-guest');
      const savedDiv   = document.getElementById('name-const-saved');
      guestDiv.style.display = 'none';
      if (_tutorialAutoSave) {
        // Туториал: авто-сохранение, кнопок нет
        saveSkyBtn.style.display = 'none';
        saveLocBtn.style.display = 'none';
        savedDiv.style.display   = '';
      } else if (isGuest) {
        // Гость: только локальное сохранение
        saveSkyBtn.style.display = 'none';
        saveLocBtn.style.display = '';
        savedDiv.style.display   = 'none';
      } else {
        // Авторизован: обе кнопки
        saveSkyBtn.style.display = '';
        saveLocBtn.style.display = '';
        savedDiv.style.display   = 'none';
      }
    }

    /** Авто-сохраняет первое созвездие туториала в localStorage. */
    function _doTutorialAutoSave(name) {
      if (!_tutorialAutoSave) return;
      _tutorialAutoSave = false;
      const constellation = {
        name,
        points:    points.map(p => ({ x: p.x / W, y: p.y / H })),
        lines:     Array.from(lines.entries()),
        polygons:  polygons.map(pg => ({ path: pg.path, player: pg.player })),
        winner,
        createdAt: new Date().toISOString(),
        skyAddr:   _constellationAddress(name),
      };
      try {
        const existing = JSON.parse(localStorage.getItem('saved_constellations') || '[]');
        existing.unshift(constellation);
        localStorage.setItem('saved_constellations', JSON.stringify(existing));
        localStorage.setItem('lastConstellationName', name);
      } catch(e) {}
      playSound('twinkle');
      haptic('medium');
    }

    // Сохранить в мои созвездия (только localStorage, без Supabase, без публикации)
    document.getElementById('name-const-local-save-btn').addEventListener('click', () => {
      const nameInput = document.getElementById('name-const-input');
      const name = nameInput.value.trim() || 'Без названия';
      const constellation = {
        name,
        points:    points.map(p => ({ x: p.x / W, y: p.y / H })),
        lines:     Array.from(lines.entries()),
        polygons:  polygons.map(pg => ({ path: pg.path, player: pg.player })),
        winner,
        createdAt: new Date().toISOString(),
        skyAddr:   _constellationAddress(name),
        // НЕТ publishedAt — созвездие не опубликовано в общем небе
      };
      try {
        const existing = JSON.parse(localStorage.getItem('saved_constellations') || '[]');
        existing.unshift(constellation);
        localStorage.setItem('saved_constellations', JSON.stringify(existing));
        localStorage.setItem('lastConstellationName', name);
      } catch(e) {}
      playSound('twinkle');
      haptic('medium');
      const btn = document.getElementById('name-const-local-save-btn');
      btn.style.display = 'none';
      document.getElementById('name-const-saved').style.display = '';
      setTimeout(() => goToMenu(), 1500);
    });

    // Установится функцией initTutorial; вызывается из initAuth после закрытия логина.
    let _proceedFromAuth = null;

    // ── Tutorial ──────────────────────────────────────────────────────────────
    (function initTutorial() {
      const screen  = document.getElementById('tutorial-screen');
      const tc      = document.getElementById('tutorial-canvas');
      const tcx     = tc.getContext('2d');
      const TW = tc.width, TH = tc.height;
      // Star positions: top-center, bottom-left, bottom-right, top-right
      const SP = [ {x:140,y:40}, {x:58,y:165}, {x:222,y:165}, {x:222,y:72} ];

      const titleEl = document.getElementById('tutorial-title');
      const descEl  = document.getElementById('tutorial-desc');
      const nextBtn = document.getElementById('tutorial-next-btn');
      const dotsEl  = document.getElementById('tutorial-dots');

      // ── state ──────────────────────────────────────────────────────────
      let phase = 0;
      const FADE = 650;
      let sAlpha = [0,0,0,0];
      let sStart = [-1,-1,-1,-1];
      let tLines = [];
      let tPolys = [];
      let sel = -1;
      let aiLine = null;
      let scoreAnim = null;
      let _raf = 0;

      // ── draw helpers ────────────────────────────────────────────────────
      function drawStar(p, a, pulse) {
        if (pulse) {
          const t = performance.now() / 1000;
          const rr = 11 + 3 * Math.sin(t * 3.5);
          tcx.beginPath(); tcx.arc(p.x, p.y, rr, 0, Math.PI * 2);
          tcx.strokeStyle = `rgba(225,223,220,${0.45 + 0.2*Math.sin(t*3.5)})`;
          tcx.lineWidth = 1.5; tcx.stroke();
        }
        const g = tcx.createRadialGradient(p.x, p.y, 0, p.x, p.y, 11);
        g.addColorStop(0, `rgba(248,247,245,${a*0.9})`);
        g.addColorStop(1, 'rgba(248,247,245,0)');
        tcx.fillStyle = g;
        tcx.beginPath(); tcx.arc(p.x, p.y, 11, 0, Math.PI * 2); tcx.fill();
        tcx.beginPath(); tcx.arc(p.x, p.y, 3, 0, Math.PI * 2);
        tcx.fillStyle = `rgba(255,255,255,${a})`; tcx.fill();
      }

      function drawSeg(a, b, prog, owner) {
        const pa = SP[a], pb = SP[b];
        const ex = pa.x+(pb.x-pa.x)*prog, ey = pa.y+(pb.y-pa.y)*prog;
        tcx.save(); tcx.beginPath(); tcx.moveTo(pa.x,pa.y); tcx.lineTo(ex,ey);
        tcx.strokeStyle = owner ? 'rgba(225,223,220,0.65)' : 'rgba(248,247,245,0.65)';
        tcx.lineWidth = 1.5; tcx.stroke(); tcx.restore();
      }

      // ── main render loop ────────────────────────────────────────────────
      function draw() {
        const now = performance.now();
        tcx.clearRect(0, 0, TW, TH);

        for (let i = 0; i < 4; i++)
          if (sStart[i] >= 0) sAlpha[i] = Math.min(1, (now - sStart[i]) / FADE);

        let aiJustDone = false;
        if (aiLine && !aiLine.done) {
          aiLine.prog = Math.min(1, (now - aiLine.t0) / 850);
          if (aiLine.prog >= 1) { aiLine.done = true; aiJustDone = true; }
        }

        // polygon fills
        for (const poly of tPolys) {
          if (poly.alpha < 0.12) poly.alpha = Math.min(0.12, poly.alpha + 0.0025);
          tcx.beginPath(); tcx.moveTo(poly.pts[0].x, poly.pts[0].y);
          for (let i = 1; i < poly.pts.length; i++) tcx.lineTo(poly.pts[i].x, poly.pts[i].y);
          tcx.closePath(); tcx.fillStyle = `rgba(225,223,220,${poly.alpha})`; tcx.fill();
        }

        // dashed hint for next connection
        if ((phase === 3 && sAlpha[2] > 0.4) || phase === 6) {
          const [ha, hb] = phase === 3 ? [0,2] : [0,3];
          tcx.save(); tcx.beginPath(); tcx.moveTo(SP[ha].x,SP[ha].y); tcx.lineTo(SP[hb].x,SP[hb].y);
          tcx.strokeStyle = 'rgba(248,247,245,0.18)'; tcx.lineWidth = 1.5;
          tcx.setLineDash([4,6]); tcx.stroke(); tcx.restore();
        }

        for (const ln of tLines) drawSeg(ln.a, ln.b, 1, ln.owner);
        if (aiLine) drawSeg(aiLine.a, aiLine.b, aiLine.prog, 1);

        // "+1" float
        if (scoreAnim) {
          const t = (now - scoreAnim.t0) / 1100;
          if (t < 1) {
            const a = t < 0.35 ? t/0.35 : 1-(t-0.35)/0.65;
            tcx.font = '300 22px Raleway, sans-serif';
            tcx.fillStyle = `rgba(248,247,245,${a*0.9})`;
            tcx.textAlign = 'center';
            tcx.fillText('+1', scoreAnim.x, scoreAnim.y - 14*t);
          } else { scoreAnim = null; }
        }

        // stars
        const pulse = getPulse();
        for (let i = 0; i < 4; i++) {
          if (sAlpha[i] <= 0) continue;
          if (i === sel) {
            tcx.beginPath(); tcx.arc(SP[i].x, SP[i].y, 12, 0, Math.PI*2);
            tcx.strokeStyle = 'rgba(248,247,245,0.65)'; tcx.lineWidth = 1.8; tcx.stroke();
          }
          drawStar(SP[i], sAlpha[i], pulse.includes(i));
        }

        if (aiJustDone) afterAIDone();
        _raf = requestAnimationFrame(draw);
      }

      function getPulse() {
        if (phase === 1) return [0, 1];
        if (phase === 3) return sel >= 0 ? [sel === 0 ? 2 : 0] : [0, 2];
        if (phase === 6) return sel >= 0 ? [sel === 0 ? 3 : 0] : [0, 3];
        return [];
      }

      // ── phase logic ─────────────────────────────────────────────────────
      function fadeTitle(text, sub, delay) {
        const go = () => {
          titleEl.style.opacity = '0';
          setTimeout(() => {
            titleEl.textContent = text;
            titleEl.style.opacity = '1';
            if (sub !== undefined) {
              descEl.style.opacity = '0';
              descEl.textContent = sub || '';
              if (sub) setTimeout(() => { descEl.style.opacity = '1'; }, 200);
            }
          }, 380);
        };
        delay ? setTimeout(go, delay) : go();
      }

      function appear(idx, after) {
        setTimeout(() => { sStart[idx] = performance.now(); }, after);
      }
      function startAILine(a, b, after) {
        setTimeout(() => { aiLine = {a, b, prog:0, t0:performance.now(), done:false}; }, after);
      }

      function afterAIDone() {
        tLines.push({a: aiLine.a, b: aiLine.b, owner: 1});
        aiLine = null;
        if (phase === 2) {
          phase = 3; // line 1-2 done → user closes triangle
        } else if (phase === 5) {
          setTimeout(() => { fadeTitle('Ты можешь победить его'); phase = 6; }, 300);
        }
      }

      function onConnect(a, b) {
        sel = -1;
        tLines.push({a, b, owner: 0});
        if (phase === 1) {
          phase = 2;
          fadeTitle('Замкни созвездие!');
          appear(2, 350);
          startAILine(1, 2, 900);
        } else if (phase === 3) {
          tPolys.push({pts: [SP[0],SP[1],SP[2]], alpha: 0});
          scoreAnim = {x: 130, y: 100, t0: performance.now()};
          fadeTitle('Молодец! ✦');
          phase = 4;
          appear(3, 900);
          setTimeout(() => {
            fadeTitle('Соперник тоже будет собирать звёзды');
            phase = 5;
            startAILine(2, 3, 500);
          }, 1900);
        } else if (phase === 6) {
          tPolys.push({pts: [SP[0],SP[2],SP[3]], alpha: 0});
          scoreAnim = {x: 196, y: 90, t0: performance.now()};
          fadeTitle('Поздравляю! ✦', 'Собирай звёзды и выигрывай у соперника');
          phase = 7;
          setTimeout(() => {
            nextBtn.textContent = 'Играть!';
            nextBtn.style.display = '';
            nextBtn.style.opacity = '0';
            nextBtn.style.transition = 'opacity 0.5s ease';
            requestAnimationFrame(() => requestAnimationFrame(() => { nextBtn.style.opacity = '1'; }));
          }, 1400);
        }
      }

      // ── canvas input ────────────────────────────────────────────────────
      tc.addEventListener('pointerdown', e => {
        e.preventDefault();
        if (phase !== 1 && phase !== 3 && phase !== 6) return;
        const r = tc.getBoundingClientRect();
        const cx = (e.clientX - r.left) * (TW / r.width);
        const cy = (e.clientY - r.top)  * (TH / r.height);
        const active = phase === 1 ? [0,1] : phase === 3 ? [0,2] : [0,3];
        let hit = -1;
        for (const i of active) {
          if (sAlpha[i] > 0.4 && Math.hypot(SP[i].x-cx, SP[i].y-cy) < 28) { hit = i; break; }
        }
        if (hit < 0) { sel = -1; return; }
        if (sel < 0) { sel = hit; }
        else if (sel === hit) { sel = -1; }
        else { onConnect(Math.min(sel,hit), Math.max(sel,hit)); }
      });

      // ── "Играть!" ────────────────────────────────────────────────────────
      nextBtn.addEventListener('click', () => {
        if (phase < 7) return;
        try {
          localStorage.setItem('tutorial_v4_seen', '1');
          localStorage.setItem('tutorialDone', '1');
        } catch(e2) {}
        cancelAnimationFrame(_raf);
        screen.style.display = 'none';
        isAI = true;
        COUNT = 7;
        const saved = localStorage.getItem('playerName');
        if (saved) document.getElementById('name1').value = saved;
        startGame();
      });

      function showTutorial() {
        if (localStorage.getItem('tutorial_v4_seen')) {
          showHomeScreen(); return;
        }
        phase = 0; sAlpha = [0,0,0,0]; sStart = [-1,-1,-1,-1];
        tLines = []; tPolys = []; sel = -1; aiLine = null; scoreAnim = null;
        titleEl.textContent = 'Соедини эти две звезды';
        titleEl.style.opacity = '1';
        descEl.textContent = ''; descEl.style.opacity = '0';
        dotsEl.style.display = 'none';
        nextBtn.style.display = 'none'; nextBtn.style.opacity = '0';
        document.getElementById('tutorial-content').style.opacity = '1';
        screen.style.display = 'flex';
        if (_raf) cancelAnimationFrame(_raf);
        _raf = requestAnimationFrame(draw);
        setTimeout(() => {
          appear(0, 0);
          appear(1, 480);
          setTimeout(() => { phase = 1; }, 480 + FADE + 80);
        }, 500);
      }

      _proceedFromAuth = showTutorial;

      if (localStorage.getItem('userId')) {
        if (!localStorage.getItem('tutorial_v4_seen')) {
          showTutorial();
          document.getElementById('start').style.display = 'none';
        } else {
          showHomeScreen();
        }
      }
    })();

    // ── Auth ──────────────────────────────────────────────────────────────────
    (function initAuth() {
      const authScreen  = document.getElementById('auth-screen');
      const startScreen = document.getElementById('start');
      const mainBtns    = document.getElementById('auth-main-btns');
      const emailPanel  = document.getElementById('auth-email-panel');
      const emailInput  = document.getElementById('auth-field-email');
      const passInput   = document.getElementById('auth-field-pass');
      const errEl       = document.getElementById('auth-email-error');
      const okEl        = document.getElementById('auth-email-success');
      const submitBtn   = document.getElementById('auth-email-submit');
      let   authTab     = 'login'; // 'login' | 'signup'

      function hideAuth() {
        authScreen.style.transition = 'opacity 300ms';
        authScreen.style.opacity = '0';
        setTimeout(() => {
          authScreen.style.display = 'none';
          authScreen.style.opacity = '1';
          authScreen.style.transition = '';
          if (typeof _proceedFromAuth === 'function') {
            _proceedFromAuth();
          } else {
            showHomeScreen();
          }
        }, 300);
      }

      // ── Persistent login: restore Supabase session on every launch ──────
      (async function checkSession() {
        // Fast path: guest mode saved explicitly
        if (localStorage.getItem('guestMode') === 'true') return;

        try {
          const { data: { session } } = await sb.auth.getSession();
          if (session && session.user) {
            // Valid session found — restore userId and go straight to home
            const uid  = session.user.id;
            const name = (session.user.email || '').split('@')[0] || 'Игрок';
            localStorage.setItem('userId',    uid);
            localStorage.setItem('guestMode', 'false');
            if (!localStorage.getItem('playerName')) {
              localStorage.setItem('playerName', name);
            }
            return; // auth screen stays hidden, app continues normally
          }
        } catch(e) {}

        // No valid session → show auth only if also no userId in localStorage
        if (!localStorage.getItem('userId')) {
          startScreen.style.display = 'none';
          authScreen.style.display  = 'flex';
        }
      })();

      // Keep userId in sync when Supabase refreshes the token silently
      sb.auth.onAuthStateChange((event, session) => {
        if (event === 'SIGNED_IN' && session) {
          localStorage.setItem('userId',    session.user.id);
          localStorage.setItem('guestMode', 'false');
        } else if (event === 'SIGNED_OUT') {
          localStorage.removeItem('userId');
        }
      });

      function _showComingSoon() {
        const t = document.createElement('div');
        t.textContent = 'Скоро ✦';
        t.style.cssText = `position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
          background:rgba(22,20,17,0.95);color:rgba(248,247,245,0.9);
          padding:14px 28px;border-radius:12px;font-size:15px;letter-spacing:2px;
          border:1px solid rgba(225,223,220,0.25);z-index:9999;
          animation:_comingSoonAnim 1.8s ease forwards;pointer-events:none;`;
        if (!document.getElementById('_coming-soon-style')) {
          const s = document.createElement('style');
          s.id = '_coming-soon-style';
          s.textContent = `@keyframes _comingSoonAnim{
            0%{opacity:0;transform:translate(-50%,-54%)}
            20%{opacity:1;transform:translate(-50%,-50%)}
            70%{opacity:1}
            100%{opacity:0;transform:translate(-50%,-46%)}}`;
          document.head.appendChild(s);
        }
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 1800);
      }

      // ── Apple / Google ────────────────────────────────────────────────
      document.getElementById('auth-apple').addEventListener('click', _showComingSoon);
      document.getElementById('auth-google').addEventListener('click', _showComingSoon);

      // ── Guest / skip ──────────────────────────────────────────────────
      document.getElementById('auth-skip').addEventListener('click', () => {
        try {
          localStorage.setItem('guestMode', 'true');
          localStorage.setItem('userId', 'null');
        } catch(e) {}
        hideAuth();
      });

      // ── Email panel open / back ───────────────────────────────────────
      document.getElementById('auth-email-open').addEventListener('click', () => {
        mainBtns.style.display = 'none';
        emailPanel.style.display = 'flex';
        emailInput.focus();
      });

      document.getElementById('auth-email-back').addEventListener('click', () => {
        emailPanel.style.display = 'none';
        mainBtns.style.display = 'flex';
        errEl.textContent = '';
        okEl.textContent = '';
        emailInput.value = '';
        passInput.value = '';
      });

      // ── Tab switch (login ↔ signup) ───────────────────────────────────
      document.querySelectorAll('.auth-tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          authTab = btn.dataset.authTab;
          document.querySelectorAll('.auth-tab-btn').forEach(b =>
            b.classList.toggle('active', b === btn)
          );
          submitBtn.textContent = authTab === 'login' ? 'Войти' : 'Зарегистрироваться';
          passInput.autocomplete  = authTab === 'login' ? 'current-password' : 'new-password';
          errEl.textContent = '';
          okEl.textContent = '';
        });
      });

      // ── Submit ────────────────────────────────────────────────────────
      async function doEmailAuth() {
        const email    = emailInput.value.trim();
        const password = passInput.value;
        errEl.textContent = '';
        okEl.textContent  = '';

        if (!email || !password) {
          errEl.textContent = 'Заполните почту и пароль';
          return;
        }
        if (password.length < 6) {
          errEl.textContent = 'Пароль — минимум 6 символов';
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = '...';

        try {
          let user = null;

          if (authTab === 'login') {
            const { data, error } = await sb.auth.signInWithPassword({ email, password });
            if (error) throw error;
            user = data.user;
          } else {
            const { data, error } = await sb.auth.signUp({ email, password });
            if (error) throw error;
            user = data.user;
            // Supabase может потребовать подтверждения email
            if (!user || data.session === null) {
              okEl.textContent = 'Проверьте почту — отправили ссылку для подтверждения ✦';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Зарегистрироваться';
              return;
            }
          }

          // Успешный вход
          const uid       = user.id;
          const rawEmail  = user.email || '';
          const name      = rawEmail.split('@')[0] || 'Игрок';
          try {
            localStorage.setItem('userId',    uid);
            localStorage.setItem('guestMode', 'false');
            // Устанавливаем имя только если ещё не задано
            if (!localStorage.getItem('playerName')) {
              localStorage.setItem('playerName', name);
            }
            // Обновляем отображение имени на домашнем экране
            const nameEl = document.getElementById('home-player-name');
            if (nameEl) nameEl.textContent = localStorage.getItem('playerName') || name;
          } catch(e) {}
          hideAuth();

        } catch (err) {
          const msg = err.message || '';
          if (/invalid.*credentials|wrong.*password|Invalid login/i.test(msg)) {
            errEl.textContent = 'Неверная почта или пароль';
          } else if (/already.*registered|User already/i.test(msg)) {
            errEl.textContent = 'Аккаунт уже существует — попробуйте войти';
          } else if (/rate.?limit/i.test(msg)) {
            errEl.textContent = 'Слишком много попыток, подождите немного';
          } else {
            errEl.textContent = msg || 'Что-то пошло не так';
          }
          submitBtn.disabled = false;
          submitBtn.textContent = authTab === 'login' ? 'Войти' : 'Зарегистрироваться';
        }
      }

      submitBtn.addEventListener('click', doEmailAuth);

      // Enter в полях формы — отправить
      [emailInput, passInput].forEach(el =>
        el.addEventListener('keydown', e => { if (e.key === 'Enter') doEmailAuth(); })
      );
    })();

  </script>
</body>
</html>
