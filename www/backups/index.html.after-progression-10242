    /** Render rank title + rating in the bottom panel #rank-display. */
    function renderProgressWidget() {
      const p = loadProgress();
      const el = document.getElementById('rank-display');
      if (!el) return;
      const info = computeRank(p.rating);
      el.textContent = `${info.title} · ${p.rating}`;
      const p1lvlEl = document.getElementById('p1level');
      const p1starsEl = document.getElementById('p1-rank-stars');
      if (p1lvlEl) p1lvlEl.textContent = info.name;
      if (p1starsEl) p1starsEl.textContent = '★'.repeat(info.rank);
    }

    /**
     * Universal screen transition: fade hideEl out, then fade showEl in.
     * @param {HTMLElement} hideEl  - element to fade out
     * @param {HTMLElement} showEl  - element to fade in (always set to display:flex)
     * @param {number}      duration - ms for each half of the fade
     * @param {Function}    [onShown] - called after showEl is visible (inside rAF)
     */
    function fadeTo(hideEl, showEl, duration = 300, onShown = null) {
      hideEl.style.transition = `opacity ${duration}ms`;
      hideEl.style.opacity = '0';
      setTimeout(() => {
        hideEl.style.display = 'none';
        hideEl.style.opacity = '1';
        hideEl.style.transition = '';
        showEl.style.opacity = '0';
        showEl.style.display = 'flex';
        requestAnimationFrame(() => {
          showEl.style.transition = `opacity ${duration}ms`;
          showEl.style.opacity = '1';
          if (onShown) onShown();
        });
      }, duration);
    }

    /** Render up to 3 most recent saved constellations into #home-cards. */
    function refreshHomeConstellations() {
      const cards = document.getElementById('home-cards');
      if (!cards) return;
      const hint  = document.querySelector('.home-recent-hint');
      let saved = [];
      try { saved = JSON.parse(localStorage.getItem('saved_constellations') || '[]'); } catch(e) {}
      cards.innerHTML = '';
      if (saved.length === 0) {
        for (let i = 0; i < 3; i++) {
          const c = document.createElement('div');
          c.className = 'home-card';
          c.innerHTML = '<span class="home-card-icon">✦</span>';
          cards.appendChild(c);
        }
        if (hint) hint.style.display = '';
        return;
      }
      if (hint) hint.style.display = 'none';
      const recent = saved.slice(0, 3);
      for (let i = 0; i < 3; i++) {
        const card = document.createElement('div');
        card.className = 'home-card';
        if (recent[i]) {
          const cv = document.createElement('canvas');
          cv.width = 240; cv.height = 240;
          cv.style.cssText = 'width:100%;height:100%;display:block;border-radius:11px;';
          drawMiniConstellation(cv, recent[i]);
          card.style.padding = '0';
          card.style.overflow = 'hidden';
          card.appendChild(cv);
        } else {
          card.innerHTML = '<span class="home-card-icon">✦</span>';
        }
        cards.appendChild(card);
      }
    }

