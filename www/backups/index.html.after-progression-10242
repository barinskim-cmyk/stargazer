    /** Fetch leaderboard position from Supabase with offline fallback + cache. */
    async function _fetchLeaderboardRank() {
      const rankEl = document.getElementById('profile-lb-rank');
      const infoEl = document.getElementById('profile-lb-info');
      const uid    = _skyGetUserId();
      const p      = loadProgress();
      const myRating = p.rating || 0;

      // Helper to show cached data
      function _showCached() {
        try {
          const cached = JSON.parse(localStorage.getItem('lb_cache') || 'null');
          if (cached) {
            const mins = Math.round((Date.now() - cached.ts) / 60000);
            const timeStr = mins < 1 ? '<1m' : mins < 60 ? mins + 'm' : Math.round(mins/60) + 'h';
            rankEl.textContent = '#' + cached.rank;
            infoEl.textContent = t('lb_of') + ' ' + cached.total + ' ' + t('lb_players') + '\n' + t('lb_cached') + ' ' + timeStr + ' ago';
            infoEl.style.whiteSpace = 'pre-line';
            return true;
          }
        } catch(_) {}
        return false;
      }

      // If offline — show cache immediately
      if (!navigator.onLine) {
        if (!_showCached()) {
          rankEl.textContent = '#—';
          infoEl.textContent = t('lb_unavailable');
        }
        return;
      }

      // Try to upsert our profile first (so we appear in leaderboard)
      if (uid) {
        const name = localStorage.getItem('playerName') || t('player_default');
        sb.from('profiles').upsert({ user_id: uid, username: name, rating: myRating, updated_at: new Date().toISOString() }).then(() => {}).catch(() => {});
      }

      try {
        // Count how many users have strictly higher rating
        const { count: above, error: e1 } = await sb
          .from('profiles')
          .select('*', { count: 'exact', head: true })
          .gt('rating', myRating);
        if (e1) throw e1;

        // Count total players
        const { count: total, error: e2 } = await sb
          .from('profiles')
          .select('*', { count: 'exact', head: true });
        if (e2) throw e2;

        const rank = (above || 0) + 1;
        const tot  = Math.max(rank, total || 1);

        // Cache result
        try { localStorage.setItem('lb_cache', JSON.stringify({ rank, total: tot, ts: Date.now() })); } catch(_) {}

        rankEl.textContent = '#' + rank;
        infoEl.textContent = t('lb_of') + ' ' + tot + ' ' + t('lb_players') + '\nsupabase ✦';
        infoEl.style.whiteSpace = 'pre-line';
      } catch (_) {
        if (!_showCached()) {
          rankEl.textContent = '#—';
          infoEl.textContent = t('lb_unavailable');
        }
      }
    }

