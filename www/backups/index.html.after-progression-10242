    /** Draw a mini constellation preview — same visual as victory screen (glow lines + stars). */
    function drawMiniConstellation(canvas, data) {
      const S   = canvas.width; // 240
      const ctx = canvas.getContext('2d');
      ctx.fillStyle = '#060612';
      ctx.fillRect(0, 0, S, S);

      const pts = data.points || [];
      const lns = data.lines  || [];
      const wp  = (data.winner >= 0) ? data.winner : 0;

      // Degree map — only winner's connections
      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });

      const active = pts.filter((_, i) => deg[i] > 0);
      if (!active.length) return;

      // Fit active points to canvas with padding
      const PAD  = Math.round(S * 0.14);
      const minX = Math.min(...active.map(p => p.x));
      const maxX = Math.max(...active.map(p => p.x));
      const minY = Math.min(...active.map(p => p.y));
      const maxY = Math.max(...active.map(p => p.y));
      const srcW = (maxX - minX) || 0.1;
      const srcH = (maxY - minY) || 0.1;
      const scl  = Math.min((S - PAD * 2) / srcW, (S - PAD * 2) / srcH);
      const ofX  = PAD + ((S - PAD * 2) - srcW * scl) / 2;
      const ofY  = PAD + ((S - PAD * 2) - srcH * scl) / 2;
      const tx = p => (p.x - minX) * scl + ofX;
      const ty = p => (p.y - minY) * scl + ofY;

      // Faint background stars
      for (let i = 0; i < 28; i++) {
        const sx = Math.abs(Math.sin(i * 127.3 + 3)) * S;
        const sy = Math.abs(Math.cos(i * 73.9  + 5)) * S;
        ctx.globalAlpha = 0.04 + Math.abs(Math.sin(i * 211)) * 0.07;
        ctx.beginPath(); ctx.arc(sx, sy, 0.6, 0, Math.PI * 2);
        ctx.fillStyle = '#fff'; ctx.fill();
      }
      ctx.globalAlpha = 1;

      // Glowing lines — same three-pass as victory stargazer theme
      lns.forEach(([key, pl]) => {
        if (pl !== wp) return;
        const [a, b] = key.split('-').map(Number);
        if (!pts[a] || !pts[b]) return;
        const ax = tx(pts[a]), ay = ty(pts[a]);
        const bx = tx(pts[b]), by = ty(pts[b]);
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.07)'; ctx.lineWidth = 9; ctx.stroke();
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.18)'; ctx.lineWidth = 3.5; ctx.stroke();
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = 'rgba(248,247,245,0.88)'; ctx.lineWidth = 1.2; ctx.stroke();
      });

      // Stars with glow — same as victory screen
      const _prevR = RADIUS;
      RADIUS = Math.round(S * 0.013); // ~3 for 240px
      pts.forEach((p, i) => {
        if (deg[i] === 0) return;
        drawStarPointTo(ctx, tx(p), ty(p), Math.max(deg[i], 2), false, false, false, 0.5);
      });
      RADIUS = _prevR;
    }

