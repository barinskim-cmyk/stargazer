    /**
     * Активирует тему: обновляет COLOR/PREVIEW/FILL, фон body и стартового экрана,
     * цвет текста, подсвечивает активную кнопку. Вызывает draw() если игра идёт.
     * @param {string} name — ключ из THEMES
     */
    function applyTheme(name) {
      if (!THEMES[name]) return;
      activeTheme = name;
      localStorage.setItem('theme', name);
      const t = THEMES[name];
      COLOR   = t.lines;
      PREVIEW = t.preview;
      FILL    = t.captured;
      const root = document.documentElement;
      root.style.setProperty('--th-bg',          t.background);   // фон страницы и игрового поля
      root.style.setProperty('--th-panel-bg',    t.panelBg);      // фон верхней/нижней панелей
      root.style.setProperty('--th-vignette',    t.vignette);     // непрозрачность виньетки 0–1
      root.style.setProperty('--th-text',        t.text);         // основной текст UI
      root.style.setProperty('--th-text2',       t.textSecondary);// вспомогательный/приглушённый текст
      root.style.setProperty('--th-btn-bg',      t.buttonBg);     // фон кнопок
      root.style.setProperty('--th-btn-text',    t.buttonText);   // текст кнопок
      root.style.setProperty('--th-btn-border',  t.buttonBorder); // граница кнопок
      root.style.setProperty('--th-accent',      t.accent);       // акцент (focus-кольцо, .active)
      root.style.setProperty('--th-btn-glow',    t.buttonGlow ?? 'transparent'); // свечение кнопок (stargazer)
      root.style.setProperty('--th-len-glow',    t.lenGlow    ?? 'transparent'); // свечение текста длины игры
      root.style.setProperty('--th-font',        t.font ?? "'Raleway', sans-serif");
      root.style.setProperty('--th-card-bg',     t.cardBg     ?? 'rgba(128,128,128,0.04)'); // фон карточек/плиток
      root.style.setProperty('--th-card-border', t.cardBorder ?? 'rgba(128,128,128,0.10)'); // граница карточек
      document.body.style.background = t.background;
      document.getElementById('start').style.background = t.background;
      document.getElementById('grain-overlay').style.opacity = t.grainOpacity;
      document.querySelectorAll('.theme-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.theme === name)
      );
      // Обновляем фон sky-canvas если он уже создан (безопасно через DOM)
      const _skyCanvasEl = document.getElementById('sky-canvas');
      if (_skyCanvasEl) _skyCanvasEl.style.background = t.skyBg || t.background;
      // Сбрасываем кэш фоновых звёзд — безопасно через window
