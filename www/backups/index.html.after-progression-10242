     * Использует знаки векторных произведений.
     * @param {number} p1x,p1y — начало первого отрезка
     * @param {number} p2x,p2y — конец первого отрезка
     * @param {number} p3x,p3y — начало второго отрезка
     * @param {number} p4x,p4y — конец второго отрезка
     * @returns {boolean} true, если отрезки пересекаются строго внутри
     */
    function properlyIntersects(p1x, p1y, p2x, p2y, p3x, p3y, p4x, p4y) {
      // 2D векторное произведение: знак говорит, по какую сторону от вектора лежит точка
      function cross(ax, ay, bx, by) { return ax * by - ay * bx; }
      // d1,d2 — по разные ли стороны отрезка p3-p4 лежат точки p1 и p2
      const d1 = cross(p4x - p3x, p4y - p3y, p1x - p3x, p1y - p3y);
      const d2 = cross(p4x - p3x, p4y - p3y, p2x - p3x, p2y - p3y);
      // d3,d4 — по разные ли стороны отрезка p1-p2 лежат точки p3 и p4
      const d3 = cross(p2x - p1x, p2y - p1y, p3x - p1x, p3y - p1y);
      const d4 = cross(p2x - p1x, p2y - p1y, p4x - p1x, p4y - p1y);
      // Пересечение строго внутри — оба условия должны выполняться одновременно
      return ((d1 > 0 && d2 < 0) || (d1 < 0 && d2 > 0)) &&
             ((d3 > 0 && d4 < 0) || (d3 < 0 && d4 > 0));
    }

    /**
     * Проверяет, проходит ли отрезок (a, b) через уже захваченную область.
     * Выполняет три теста: конечные точки внутри полигона, середина отрезка внутри,
     * строгое пересечение с рёбрами полигона.
     * @param {number} a — индекс первой точки отрезка
     * @param {number} b — индекс второй точки отрезка
     * @returns {boolean} true, если отрезок проходит через захваченную область
     */
    function segmentPassesThroughCapture(a, b) {
      const pa = points[a], pb = points[b];
      const mx = (pa.x + pb.x) / 2, my = (pa.y + pb.y) / 2;
      for (const { path } of polygons) {
        const poly = path.map(i => points[i]);
        const ps   = new Set(path);
        if (!ps.has(a) && pointInPolygon(pa.x, pa.y, poly)) return true;
        if (!ps.has(b) && pointInPolygon(pb.x, pb.y, poly)) return true;
        if (pointInPolygon(mx, my, poly)) return true;
        const n = path.length;
        for (let i = 0; i < n; i++) {
          const j = (i + 1) % n;
          if (path[i] === a || path[i] === b || path[j] === a || path[j] === b) continue;
          if (properlyIntersects(pa.x, pa.y, pb.x, pb.y,
                                 poly[i].x, poly[i].y, poly[j].x, poly[j].y)) return true;
        }
      }
      return false;
    }

    /**
     * Ищет точку, лежащую на отрезке (a, b) и тем самым блокирующую его проведение.
     * Проверяет расстояние от каждой точки до прямой и параметр t проекции.
     * @param {number} a — индекс начальной точки отрезка
     * @param {number} b — индекс конечной точки отрезка
     * @returns {number} индекс блокирующей точки или -1, если таковой нет
     */
    function pointBlockingSegment(a, b) {
      const ax = points[a].x, ay = points[a].y;
      const bx = points[b].x, by = points[b].y;
      const dx = bx - ax, dy = by - ay;
      const len2 = dx * dx + dy * dy, len = Math.sqrt(len2);
      for (let i = 0; i < COUNT; i++) {
        if (i === a || i === b) continue;
        const ex = points[i].x - ax, ey = points[i].y - ay;
        if (Math.abs(dx * ey - dy * ex) / len > RADIUS) continue;
        const t = (ex * dx + ey * dy) / len2;
        if (t > 0.02 && t < 0.98) return i;
      }
      return -1;
    }

    /**
     * Проверяет, замыкает ли добавление ребра (a, b) только недопустимые фигуры.
     * Недопустимая фигура — та, внутри которой есть свободные точки.
     * Если все замыкаемые пути содержат свободные точки — ход запрещён.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {boolean} true, если ход запрещён по этому правилу
     */
    function closesInvalidFigure(a, b) {
      const paths = findPaths(a, b, null);
      if (paths.length === 0) return false;
      const unscored = paths.filter(path => !scoredKeys.has([...path].sort((a,b)=>a-b).join(',')));
      if (unscored.length === 0) return false;
      return !unscored.some(path => !hasFreePointsInside(path));
    }

    /**
     * Проверяет, пересекает ли новый отрезок (a, b) любую из уже нарисованных линий.
     * Игнорирует линии, у которых есть общая вершина с новым отрезком.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {boolean} true, если пересечение найдено
     */
    function segmentCrossesExistingLine(a, b) {
      const pa = points[a], pb = points[b];
      for (const key of lines.keys()) {
        const [u, v] = key.split('-').map(Number);
        if (u === a || u === b || v === a || v === b) continue;
        if (properlyIntersects(pa.x, pa.y, pb.x, pb.y,
                               points[u].x, points[u].y, points[v].x, points[v].y)) return true;
      }
      return false;
    }

    /**
     * Единая точка валидации хода — последовательно применяет все правила.
     * Порядок проверок: уже нарисована → точка на отрезке → пересечение линий →
     * проход через захваченную область → замыкание недопустимой фигуры.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {{ok: boolean, reason?: string, blockingPoint?: number}}
     */
    function validate(a, b) {
      if (lines.has(lineKey(a, b)))
        return { ok: false, reason: 'Эта линия уже проведена' };
      const bp = pointBlockingSegment(a, b);
      if (bp !== -1)
        return { ok: false, reason: 'Линия проходит через другую точку', blockingPoint: bp };
      if (segmentCrossesExistingLine(a, b))
        return { ok: false, reason: 'Линия пересекает существующую линию' };
      if (segmentPassesThroughCapture(a, b))
        return { ok: false, reason: 'Линия проходит через захваченную область' };
      if (closesInvalidFigure(a, b))
        return { ok: false, reason: 'Внутри фигуры есть свободные точки' };
      return { ok: true };
    }

    // ── scoring ───────────────────────────────────────────────────────────────

    /**
     * После добавления ребра (newA, newB) проверяет, замкнул ли игрок допустимую фигуру.
     * Если замкнул — засчитывает очко, отмечает минимальную по площади фигуру как захваченную.
     * @param {number} newA — индекс первой точки нового ребра
     * @param {number} newB — индекс второй точки нового ребра
     * @param {number} player — индекс игрока (0 или 1)
     */
    function checkScore(newA, newB, player) {
      const newKey = lineKey(newA, newB);
      const paths  = findPaths(newA, newB, newKey);
      const valid  = paths.filter(path => {
        const key = [...path].sort((a, b) => a - b).join(',');
        return !scoredKeys.has(key) && !hasFreePointsInside(path);
      });
      if (valid.length === 0) return;
      valid.sort((a, b) => polygonArea(a) - polygonArea(b));
      const best    = valid[0];
      const polyKey = [...best].sort((a, b) => a - b).join(',');
      scores[player]++;
      scoredKeys.add(polyKey);
      polygons.push({ path: best, player });
      playSound('score');
      haptic('medium');
    }

    // ── Звездочёт ─────────────────────────────────────────────────────────────

    /**
     * Проверяет, приведёт ли добавление ребра (a, b) к замыканию допустимой фигуры (очку).
     * Временно добавляет ребро в граф, ищет циклы, затем откатывает изменение.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {boolean} true, если ход даст очко
     */
    function moveWouldScore(a, b) {
      const key = lineKey(a, b);
      lines.set(key, currentPlayer);
      const paths = findPaths(a, b, key);
      lines.delete(key);
      return paths.some(path => {
        const pk = [...path].sort((x, y) => x - y).join(',');
        return !scoredKeys.has(pk) && !hasFreePointsInside(path);
      });
    }

    /**
     * Проверяет, получит ли соперник возможность замкнуть фигуру после хода (a, b).
     * Временно добавляет ребро и перебирает все допустимые ответные ходы соперника.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {boolean} true, если хотя бы один ответный ход соперника даст очко
     */
    function givesOpponentScore(a, b) {
      const key = lineKey(a, b);
      lines.set(key, currentPlayer);
      let gives = false;
      outer: for (let i = 0; i < COUNT; i++) {
        for (let j = i + 1; j < COUNT; j++) {
          if (validate(i, j).ok && moveWouldScore(i, j)) {
            gives = true; break outer;
          }
        }
      }
      lines.delete(key);
      return gives;
    }

    /**
     * Подсчитывает число «перспективных» пар вершин — пар (u, v) без прямого ребра,
     * между которыми уже существует путь по текущим линиям, и этот путь при замыкании
     * образует допустимую фигуру (без свободных точек внутри).
     * Используется как метрика «близости к замыканию» для AI.
     * @returns {number} количество перспективных пар
     */
    function countPromisingPairs() {
      let count = 0;
      for (let u = 0; u < COUNT; u++) {
        for (let v = u + 1; v < COUNT; v++) {
          if (lines.has(lineKey(u, v))) continue;
          const paths = findPaths(u, v, null, 8); // AI lookahead: ограниченная глубина
          if (paths.length === 0) continue;
          const hasPromising = paths.some(path => {
            if (path.length < 3) return false;
            const pk = [...path].sort((a, b) => a - b).join(',');
            if (scoredKeys.has(pk)) return false;
            return !hasFreePointsInside(path);
          });
          if (hasPromising) count++;
        }
      }
      return count;
    }

    /**
     * Оценивает ход (a, b) по числу перспективных пар после его выполнения.
     * Больше перспективных пар = ход лучше строит цепочки к будущим фигурам.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {number} количество перспективных пар после хода
     */
    function chainScore(a, b) {
      const key = lineKey(a, b);
      lines.set(key, currentPlayer);
      const score = countPromisingPairs();
      lines.delete(key);
      return score;
    }

    /**
     * Подсчитывает, сколько допустимых ходов соперника приведут к немедленному очку
     * после того, как Звездочёт сделает ход (a, b).
     * Чем меньше — тем меньше угроз оставляет этот ход.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {number} количество потенциально опасных ответных ходов соперника
     */
    function opponentChainScore(a, b) {
      const key = lineKey(a, b);
      lines.set(key, currentPlayer);
      let count = 0;
      for (let i = 0; i < COUNT; i++)
        for (let j = i + 1; j < COUNT; j++)
          if (validate(i, j).ok && moveWouldScore(i, j)) count++;
      lines.delete(key);
      return count;
    }

    /**
     * Вычисляет суммарный балл хода (a, b) по системе штрафов и бонусов:
     *   +10  ход замыкает фигуру (очко для Звездочёта)
     *   -8   после хода соперник сможет замкнуть фигуру
     *   +5   ход увеличивает число перспективных цепочек (строит к фигуре)
     *   -3   после хода у соперника остаются готовые к замыканию ходы
     *   +1   базовый балл (нейтральный ход)
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     * @returns {number} итоговый балл хода
     */
    function scoreMove(a, b) {
      let s = 1;
      if (moveWouldScore(a, b))                             s += 10;
      if (givesOpponentScore(a, b))                         s -=  8;
      if (chainScore(a, b) > countPromisingPairs())         s +=  5;
      if (opponentChainScore(a, b) > 0)                     s -=  3;
      return s;
    }

    /**
     * Главная функция хода Звездочёта. Поведение зависит от stargazerLevel (1–5):
     *   Уровень 1–4: первый ход всегда случайный; далее умная логика срабатывает
     *                с вероятностью level × 20% (остальное — случайный ход).
     *   Уровень 5: все ходы умные, включая первый.
     *
     * Умная логика (приоритеты):
     *   1. Взять ход, замыкающий фигуру (немедленное очко).
     *   2. Избегать ходов, после которых соперник сможет замкнуть фигуру.
     *   3. Из оставшихся — максимальный chainScore; тай-брейкер через scoreMove.
     * При отсутствии допустимых ходов вызывает endGame().
     */
    function makeAIMove() {
      if (gameOver) return;
      if (_tutorialBlocked) { setTimeout(makeAIMove, 200); return; } // wait for tutorial dismiss

      const moves = [];
      for (let i = 0; i < COUNT; i++)
        for (let j = i + 1; j < COUNT; j++)
          if (validate(i, j).ok) moves.push([i, j]);
      if (moves.length === 0) { endGame(); return; }

      // Tutorial: never take scoring moves so the player always wins
      if (_tutorialMode) {
        const nonScoring = moves.filter(([a, b]) => !moveWouldScore(a, b));
        const pool = nonScoring.length > 0 ? nonScoring : moves;
        const [a, b] = pool[Math.floor(Math.random() * pool.length)];
        applyMove(a, b); return;
      }

      const isFirstMove = lines.size === 0;

      /**
       * Выбирает случайный допустимый ход из массива moves и применяет его.
       * Используется как запасной вариант при низких уровнях сложности и как
       * первый ход для уровней 1–4 (чтобы не давать AI преимущества с первого хода).
       */
      const randomMove = () => {
        const [a, b] = moves[Math.floor(Math.random() * moves.length)];
        applyMove(a, b);
      };

      if (isFirstMove && stargazerLevel < 5) {
        randomMove(); return;
      }

      if (Math.random() >= stargazerLevel * 0.2) {
        randomMove(); return;
      }

      // Умная логика ─────────────────────────────────────────────────────────

      // Priority 1: take a scoring move if available
      const scoring = moves.filter(([a, b]) => moveWouldScore(a, b));
      if (scoring.length > 0) {
        const [a, b] = scoring[Math.floor(Math.random() * scoring.length)];
        applyMove(a, b); return;
      }

      // Priority 2: avoid moves that hand the opponent a scoring move
      const safe = moves.filter(([a, b]) => !givesOpponentScore(a, b));
      const pool = safe.length > 0 ? safe : moves;

      // Priority 3: prefer moves that extend our promising chains
      const scored = pool.map(([a, b]) => ({ a, b, s: chainScore(a, b) }));
      const maxS = Math.max(...scored.map(x => x.s));
      const best = scored.filter(x => x.s === maxS);
      const sm = best.map(({ a, b }) => ({ a, b, s: scoreMove(a, b) }));
      const maxSM = Math.max(...sm.map(x => x.s));
      const pick = sm.filter(x => x.s === maxSM);
      const { a, b } = pick[Math.floor(Math.random() * pick.length)];
      applyMove(a, b);
    }

    /**
     * Применяет ход: добавляет ребро в граф, проверяет очко, передаёт ход следующему игроку.
     * Используется и для ходов человека (из обработчика клика), и для ходов Звездочёта.
     * @param {number} a — индекс первой точки
     * @param {number} b — индекс второй точки
     */
    function _startLineAnimLoop() {
      if (_lineAnimRaf) cancelAnimationFrame(_lineAnimRaf);
      (function loop() {
        if (!_lineAnim) { _lineAnimRaf = null; return; }
        draw();
        _lineAnimRaf = requestAnimationFrame(loop);
      })();
    }

    // ── Web Audio звуки ───────────────────────────────────────────────────────
    //
    // Все звуки синтезируются через Web Audio API (без файлов), что позволяет
    // обойтись без сетевых запросов и избежать проблем с автовоспроизведением.
    // AudioContext создаётся лениво при первом вызове — браузеры требуют
    // пользовательского жеста (tap/click) для разблокировки аудио.
    //
    // Типы звуков:
    //   'connect' — короткий восходящий тон при соединении двух точек
    //   'score'   — протяжный аккорд при захвате области
    //   'victory' — восходящая арпеджированная последовательность при победе
    let _audioCtx = null;
    /**
     * Воспроизводит синтезированный звуковой эффект через Web Audio API.
     * Ничего не делает, если звук отключён в настройках или AudioContext недоступен.
     * @param {'connect'|'score'|'victory'} type — тип звука
     */
    function playSound(type) {
      if (!window._appSettings.sound) return;
      try {
        if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const ctx = _audioCtx;
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);

        if (type === 'connect') {
          o.frequency.setValueAtTime(440, ctx.currentTime);
          o.frequency.exponentialRampToValueAtTime(880, ctx.currentTime + 0.1);
          g.gain.setValueAtTime(0.1, ctx.currentTime);
          g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
          o.start(); o.stop(ctx.currentTime + 0.2);
        }
        if (type === 'score') {
          o.frequency.setValueAtTime(523, ctx.currentTime);
          g.gain.setValueAtTime(0.15, ctx.currentTime);
          g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
          o.start(); o.stop(ctx.currentTime + 0.4);
        }
        if (type === 'victory') {
          o.disconnect();
          [523, 659, 784, 1046].forEach((freq, i) => {
            const o2 = ctx.createOscillator();
            const g2 = ctx.createGain();
            o2.connect(g2); g2.connect(ctx.destination);
            o2.frequency.value = freq;
            g2.gain.setValueAtTime(0, ctx.currentTime + i * 0.15);
            g2.gain.linearRampToValueAtTime(0.15, ctx.currentTime + i * 0.15 + 0.05);
            g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.15 + 0.3);
            o2.start(ctx.currentTime + i * 0.15);
            o2.stop(ctx.currentTime + i * 0.15 + 0.3);
          });
        }
        if (type === 'twinkle') {
          // Мягкий эфирный перелив — три короткие ноты вверх при сохранении созвездия
          o.disconnect();
          [660, 880, 1320].forEach((freq, i) => {
            const o2 = ctx.createOscillator();
            const g2 = ctx.createGain();
            o2.type = 'sine';
            o2.connect(g2); g2.connect(ctx.destination);
            o2.frequency.value = freq;
            g2.gain.setValueAtTime(0, ctx.currentTime + i * 0.09);
            g2.gain.linearRampToValueAtTime(0.07, ctx.currentTime + i * 0.09 + 0.03);
            g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.09 + 0.18);
            o2.start(ctx.currentTime + i * 0.09);
            o2.stop(ctx.currentTime + i * 0.09 + 0.2);
          });
        }
      } catch(e) {}
    }

    function applyMove(a, b) {
      playSound('connect');
      haptic('light');
      _lineAnimating = true;
      _lineAnim = { a, b, player: currentPlayer, startT: performance.now() };
      _startLineAnimLoop();
      setTimeout(() => {
        _lineAnim = null; _lineAnimating = false;
        lastMove = { a, b };
        lines.set(lineKey(a, b), currentPlayer);
        checkScore(a, b, currentPlayer);
        currentPlayer = 1 - currentPlayer;
        _isGameOverCache = null;
        updateUI(); updateLastMoveBtn();
        if (isGameOver()) { endGame(); return; }
        _probBarTarget = estimateWinProbability();
        startProbBarAnim();
        checkTutorialMoments();
        computeHints();
      }, 200);
    }

    // ── tutorial ──────────────────────────────────────────────────────────────

    /** Count remaining valid moves on the board. */
    function estimateRemainingMoves() {
      let n = 0;
      for (let i = 0; i < COUNT; i++)
        for (let j = i + 1; j < COUNT; j++)
          if (validate(i, j).ok) n++;
      return n;
    }

    /** Show a tutorial tooltip at canvas position (x, y). Blocks game input. */
    function showTutorialTooltip(text, x, y) {
      _tutorialTooltip = { text, x, y, startMs: performance.now(), fadingOut: false, fadeStartMs: 0 };
      _tutorialBlocked = true;
      _tutorialBtnRect = null;
      ensureTutorialLoop();
    }

    /** Begin fade-out of the current tooltip. Input unblocked when fade completes. */
    function startDismissTutorial() {
      if (!_tutorialTooltip || _tutorialTooltip.fadingOut) return;
      _tutorialTooltip.fadingOut = true;
      _tutorialTooltip.fadeStartMs = performance.now();
      ensureTutorialLoop();
    }

    /**
     * Check whether a new tutorial moment should be triggered after a move.
     * Moment 2: first polygon scored.
     * Moment 3: ≤3 valid moves remain.
     */
    function checkTutorialMoments() {
      if (!_tutorialMode || _tutorialBlocked || gameOver) return;
      if (_tutorialStep === 1 && !_tutorialPolygonSeen && polygons.length > 0) {
        _tutorialPolygonSeen = true;
        _tutorialStep = 2;
        _tutorialPulseIdx = -1; // stop moment-1 pulse
        showTutorialTooltip(
          t('tut_caught'),
          W / 2 - 148, H / 2 - 80
        );
        return;
      }
      if (_tutorialStep === 2 && estimateRemainingMoves() <= 3) {
        _tutorialStep = 3;
        showTutorialTooltip(
          t('tut_final'),
          W / 2 - 148, H - 170
        );
      }
    }

    /** Keep a tutorial animation loop running while tooltip or pulse is active. */
    function ensureTutorialLoop() {
      if (_tutorialRaf) return;
      function loop() {
        if (!_tutorialMode || (!_tutorialTooltip && _tutorialPulseIdx < 0)) {
          _tutorialRaf = null; return;
        }
        draw();
        _tutorialRaf = requestAnimationFrame(loop);
      }
      _tutorialRaf = requestAnimationFrame(loop);
    }

    /** Wrap text to lines fitting maxWidth using current ctx font. */
    function tutWrapText(text, maxWidth) {
      const result = [];
      for (const para of text.split('\n')) {
        const words = para.split(' ');
        let line = '';
        for (const w of words) {
          const test = line ? line + ' ' + w : w;
          if (ctx.measureText(test).width > maxWidth && line) { result.push(line); line = w; }
          else line = test;
        }
        if (line) result.push(line);
      }
      return result;
    }

    /**
     * Draw tutorial tooltip and point pulse on top of the game canvas.
     * Called at the end of draw() when _tutorialMode is true.
     */
    function drawTutorialOverlay() {
      // Pulse ring on the selected point (moment 1)
      if (_tutorialPulseIdx >= 0 && points[_tutorialPulseIdx]) {
        const pp = points[_tutorialPulseIdx];
        const t = (performance.now() - _tutorialPulseStart) / 1200;
        const pr = RADIUS * 2 + 4 * Math.sin(t * Math.PI * 2);
        ctx.save();
        ctx.beginPath();
        ctx.arc(pp.x, pp.y, pr, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(225,223,220,0.75)';
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.restore();
      }

      if (!_tutorialTooltip) return;
      const { text, x, y, startMs, fadingOut, fadeStartMs } = _tutorialTooltip;
      const now = performance.now();
      let alpha;
      if (fadingOut) {
        alpha = 1 - Math.min(1, (now - fadeStartMs) / 300);
        if (alpha <= 0) {
          _tutorialTooltip = null;
          _tutorialBlocked = false;
          if (!gameOver) checkTutorialMoments(); // re-check after dismiss
          return;
        }
      } else {
        alpha = Math.min(1, (now - startMs) / 400);
      }

      ctx.save();
      ctx.font = '18px system-ui, sans-serif';
      const pad = 16, lineH = 26, btnH = 34, btnW = 130, boxW = 300;
      const wrappedLines = tutWrapText(text, boxW - pad * 2);
      const boxH = pad * 2 + wrappedLines.length * lineH + 10 + btnH;
      const bx = Math.max(10, Math.min(W - boxW - 10, x));
      const by = Math.max(10, Math.min(H - boxH - 10, y));

      ctx.globalAlpha = alpha;

      // Box
      ctx.fillStyle = 'rgba(26,26,46,0.92)';
      _rrect(ctx, bx, by, boxW, boxH, 10);
      ctx.fill();
      ctx.strokeStyle = 'rgba(248,247,245,0.18)';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Text
      ctx.fillStyle = '#F8F7F5';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      wrappedLines.forEach((ln, i) => ctx.fillText(ln, bx + pad, by + pad + i * lineH));

      // Dismiss button
      const btnX = bx + boxW - pad - btnW;
      const btnY = by + boxH - pad - btnH;
      ctx.fillStyle = 'rgba(248,247,245,0.14)';
      _rrect(ctx, btnX, btnY, btnW, btnH, 6);
      ctx.fill();
      ctx.strokeStyle = 'rgba(248,247,245,0.35)';
      ctx.lineWidth = 1;
      ctx.stroke();
      ctx.fillStyle = '#F8F7F5';
      ctx.font = 'bold 14px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('Понятно →', btnX + btnW / 2, btnY + btnH / 2);

      // Store button rect for click detection (in canvas coordinates)
      _tutorialBtnRect = { x: btnX, y: btnY, w: btnW, h: btnH };

      ctx.restore();
    }

    // ── hints ─────────────────────────────────────────────────────────────────

    /**
     * Count how many scoring moves the opponent would have if we play (i, j).
     * Stops counting at 2 (used for the no-spoilers threshold).
     */
    function countOpponentScoring(i, j) {
      const k = lineKey(i, j);
      lines.set(k, currentPlayer);
      const opp = 1 - currentPlayer;
      let count = 0;
      outer: for (let a = 0; a < COUNT; a++) {
        for (let b = a + 1; b < COUNT; b++) {
          if (!validate(a, b).ok) continue;
          const ek = lineKey(a, b);
          lines.set(ek, opp);
          const ps = findPaths(a, b, ek, 6);
          lines.delete(ek);
          if (ps.some(p => {
            const pk = [...p].sort((x, y) => x - y).join(',');
            return !scoredKeys.has(pk) && !hasFreePointsInside(p);
          })) { if (++count >= 2) break outer; }
        }
      }
      lines.delete(k);
      return count;
    }

    /**
     * Recompute _hintEdges: top-5 promising edges for the current player.
     * Called after every move. Clears hints when it is the AI's turn.
     */
    function computeHints() {
      _hintEdges = [];
      if (!_hintsOn || gameOver || points.length === 0) return;
      if (isAI && currentPlayer === 1) return; // AI's turn — no hints

      // Total degree per point (all drawn edges)
      const degree = new Array(COUNT).fill(0);
      lines.forEach((_, key) => {
        const [a, b] = key.split('-').map(Number);
        degree[a]++; degree[b]++;
      });

      const candidates = [];
      for (let i = 0; i < COUNT; i++) {
        for (let j = i + 1; j < COUNT; j++) {
          if (!validate(i, j).ok) continue;

          // HIGH: closing a polygon of ≤ 5 sides for current player
          let value = null;
          const k = lineKey(i, j);
          lines.set(k, currentPlayer);
          const paths = findPaths(i, j, k, 8);
          lines.delete(k);
          const closing = paths.filter(p => {
            const pk = [...p].sort((a, b) => a - b).join(',');
            return !scoredKeys.has(pk) && !hasFreePointsInside(p) && p.length <= 5;
          });
          if (closing.length > 0) value = 'HIGH';

          // MEDIUM: extends an existing chain (≥ 2 shared drawn-edge endpoints)
          if (!value && degree[i] + degree[j] >= 2) value = 'MEDIUM';

          if (!value) continue;

          // No-spoilers: skip if opponent can score ≥ 2 times in response
          if (countOpponentScoring(i, j) >= 2) continue;

          candidates.push({ a: i, b: j, value });
        }
      }

      // HIGH first, then MEDIUM; keep top 5
      candidates.sort((x, y) => (x.value === 'HIGH' ? 0 : 1) - (y.value === 'HIGH' ? 0 : 1));
      _hintEdges = candidates.slice(0, 5);

      if (activeTheme === 'stargazer' && _hintEdges.length > 0) ensureHintsLoop();
    }

    /** RAF loop to drive the stargazer shimmer animation for hints. */
    function ensureHintsLoop() {
      if (_hintsRaf) return;
      function loop() {
        if (!_hintsOn || activeTheme !== 'stargazer' || gameOver || !_hintEdges.length) {
          _hintsRaf = null; return;
        }
        draw();
        _hintsRaf = requestAnimationFrame(loop);
      }
      _hintsRaf = requestAnimationFrame(loop);
    }

    /** Draw a small chalk dot with deterministic jitter (used for chalk hint edges). */
    function drawChalkDot(ctx, x, y, r, color) {
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
    }

    /**
     * Draw hint edges on the canvas.
     * Must be called BEFORE the regular edge layer so hints appear underneath.
     */
    function drawHints() {
      if (!_hintEdges.length) return;
      ctx.save();

      const isStargazer = activeTheme === 'stargazer';
      const isChalk = activeTheme === 'chalk';

      _hintEdges.forEach(({ a, b, value }) => {
        const ax = points[a].x, ay = points[a].y;
        const bx = points[b].x, by = points[b].y;

        if (isChalk) {
          // Series of small chalk dots along the edge path
          const dx = bx - ax, dy = by - ay;
          const len = Math.hypot(dx, dy);
          const n = Math.max(3, Math.floor(len / 18));
          const r = value === 'HIGH' ? 3.5 : 2.5;
          const alpha = value === 'HIGH' ? 0.42 : 0.22;
          const color = value === 'HIGH'
            ? CHALK_RAINBOW[currentPlayer * 3 % CHALK_RAINBOW.length]
            : 'rgba(140,115,80,1)';
          const seed = Math.abs(Math.sin(ax * 0.37 + ay * 0.19 + bx * 0.13)) % 1;
          ctx.globalAlpha = alpha;
          for (let k = 0; k <= n; k++) {
            const t = k / n;
            const jx = Math.sin(seed * 31.4 + k * 7.9) * 2.2;
            const jy = Math.cos(seed * 11.7 + k * 13.3) * 2.2;
            drawChalkDot(ctx, ax + dx * t + jx, ay + dy * t + jy, r, color);
          }
          ctx.globalAlpha = 1;
        } else {
          let alpha, dash, lw;
          if (value === 'HIGH') { alpha = 0.35; dash = [8, 6]; lw = 2; }
          else                  { alpha = 0.20; dash = [3, 8]; lw = 1.5; }

          if (isStargazer) {
            // Pulsing shimmer 20%→40%→20% over 2 s
            const phase = (performance.now() % 2000) / 2000;
            const pulse = 0.20 + 0.20 * Math.sin(phase * Math.PI * 2);
            alpha = value === 'HIGH' ? Math.min(0.55, pulse * 1.8) : pulse;
          }

          ctx.globalAlpha = alpha;
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = lw;
          ctx.lineCap = 'round';
          ctx.setLineDash(dash);
          ctx.beginPath();
          ctx.moveTo(ax, ay);
          ctx.lineTo(bx, by);
          ctx.stroke();
          ctx.setLineDash([]);
        }
      });

      ctx.restore();
    }

    // ── game over ─────────────────────────────────────────────────────────────

    /**
     * Проверяет, остались ли на поле допустимые ходы.
     * Перебирает все пары точек C(COUNT, 2) через validate().
     * @returns {boolean} true, если ни одного допустимого хода нет
     */
    function isGameOver() {
      if (_isGameOverCache !== null) return _isGameOverCache;
      for (let i = 0; i < COUNT; i++)
        for (let j = i + 1; j < COUNT; j++)
          if (validate(i, j).ok) { _isGameOverCache = false; return false; }
      _isGameOverCache = true;
      return true;
    }

    /**
     * Завершает игру: устанавливает флаг gameOver, определяет победителя по счёту
     * (−1 при ничье), сбрасывает выделение и перерисовывает поле с экраном победы.
     */
    let _winParticleRaf = null;

    function startWinEffect() {
      // ── White flash ──
      const flash = document.getElementById('win-flash');
      flash.style.transition = 'none';
      flash.style.opacity = '0.6';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        flash.style.transition = 'opacity 0.3s ease';
        flash.style.opacity = '0';
      }));

      // ── Star particles ──
      const pc = document.getElementById('particle-canvas');
      if (!pc) return;
      pc.width  = Math.round(W * _canvasDpr);
      pc.height = Math.round(H * _canvasDpr);
      pc.style.width  = W + 'px';
      pc.style.height = H + 'px';
      const pctx = pc.getContext('2d');
      pctx.scale(_canvasDpr, _canvasDpr);
      const cx = W / 2, cy = H / 2;
      const startT = performance.now();
      if (_winParticleRaf) { cancelAnimationFrame(_winParticleRaf); _winParticleRaf = null; }

      const particles = Array.from({ length: 20 }, () => {
        const angle = Math.random() * Math.PI * 2;
        const speed = 2 + Math.random() * 3;
        return { x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
                 r: 2 + Math.random() * 2 };
      });

      (function loop() {
        const elapsed = performance.now() - startT;
        pctx.clearRect(0, 0, W, H);
        let alive = false;
        particles.forEach(p => {
          const t = elapsed / 800;
          if (t >= 1) return;
          alive = true;
          p.x += p.vx; p.y += p.vy;
          pctx.beginPath();
          pctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          pctx.fillStyle = `rgba(225,223,220,${1 - t})`;
          pctx.fill();
        });
        if (alive) { _winParticleRaf = requestAnimationFrame(loop); }
        else { pctx.clearRect(0, 0, W, H); _winParticleRaf = null; }
      })();
    }

    function endGame() {
      gameOver = true;
      winner = scores[0] > scores[1] ? 0 : scores[1] > scores[0] ? 1 : -1; // -1 = draw
      // Бонусные очки: победитель +1 (= захваченные поля + 1), ничья — без бонуса
      if (winner >= 0) scores[winner] += 1;
      selected = -1; previewValidation = null;
      const _pbw = document.getElementById('prob-bar-wrap');
      if (_pbw) _pbw.classList.remove('active');
      progressionUpdate();
      // Вычисляем детерминированную компоновку suprematist один раз
      _supLayout = generateSupLayout();
      // Rank-up ceremony runs before normal victory screen (skip during tutorial)
      if (_rankUpNewRank && !_tutorialMode) {
        startRankUpCeremony(_rankUpNewRank);
      } else {
        finishEndGame();
      }
    }

    /**
     * Вторая половина завершения игры — показывает экран результата.
     * Вызывается либо сразу из endGame(), либо после ранг-ап церемонии.
     *
     * Три сценария:
     * • Проигрыш (isAI && winner===1): очищает canvas, показывает #loss-content.
     * • Ничья (winner===-1): затемняет canvas оверлеем, показывает «Ничья».
     * • Победа: затемняет + уменьшает canvas (scale 0.42), затем рассветляет,
     *   показывает #name-constellation для ввода имени созвездия.
     *
     * Для дуэльного режима: переключается на #duel-wrap с двумя отдельными canvas.
     */
    function finishEndGame() {
      _rankUpNewRank = null;

      // Обновляем turn-display: Победа / Ничья / Проигрыш
      const td = document.getElementById('turn-display');
      if (td) {
        if (winner === -1)          td.textContent = t('turn_draw');
        else if (isAI && winner === 1) td.textContent = t('turn_loss');
        else                        td.textContent = t('turn_win');
      }

      // Проигрыш: останавливаем все анимации, очищаем canvas, показываем loss-экран
      if (isAI && winner === 1) {
        [_twinkleRaf, _gameTwinkleRaf, _chalkAnimRaf, _hintsRaf]
          .forEach(r => r && cancelAnimationFrame(r));
        _twinkleRaf = _gameTwinkleRaf = _chalkAnimRaf = _hintsRaf = null;
        ctx.setTransform(_canvasDpr, 0, 0, _canvasDpr, 0, 0);
        ctx.clearRect(0, 0, W, H);
        document.getElementById('loss-score-line').textContent = scores[0] + ' : ' + scores[1];
        document.getElementById('loss-names-line').textContent =
          (playerNames[0] || t('player_default')) + '  —  ' + (playerNames[1] || t('ai_name'));
        document.getElementById('canvas-area').classList.add('lost');
        return;
      }

      draw();
      if (winner >= 0) { startWinEffect(); playSound('victory'); haptic('heavy'); }
      const winName = winner >= 0 ? playerNames[winner] : null;
      document.getElementById('victory-title').textContent = winName ? `${t('duel_name_prefix')} ${winName}` : t('turn_draw');
      document.getElementById('victory-sub').textContent   = winName ? t('victory_sub_win') : `${scores[0]} : ${scores[1]}`;
      document.getElementById('victory-rating').textContent =
        (isAI && lastRatingGain > 0)
          ? `+${lastRatingGain} ✦  ${loadProgress().rating}` : '';
      // Tutorial: override victory sub-text and mark as done
      if (_tutorialMode) {
        localStorage.setItem('tutorialDone', '1');
        _tutorialMode = false;
        _tutorialAutoSave = true;
        if (_tutorialRaf) { cancelAnimationFrame(_tutorialRaf); _tutorialRaf = null; }
        _tutorialTooltip = null; _tutorialBlocked = false;
        document.getElementById('victory-sub').textContent = t('victory_first_const');
      }
      document.getElementById('canvas-area').classList.add('ended');

      // Duel-режим: переключаемся на два отдельных canvas
      const isDuel = !isAI;
      document.getElementById('canvas-area').classList.toggle('duel', isDuel);
      if (isDuel) {
        const lp = winner >= 0 ? winner   : 0;
        const rp = winner >= 0 ? 1-winner : 1;
        document.getElementById('duel-name-left').textContent  = `${t('duel_name_prefix')} ${playerNames[lp] || (t('player_default') + ' ' + (lp+1))}`;
        document.getElementById('duel-name-right').textContent = `${t('duel_name_prefix')} ${playerNames[rp] || (t('player_default') + ' ' + (rp+1))}`;
        const isDraw = winner < 0;
        document.getElementById('duel-sub-left').textContent  = isDraw ? `${scores[lp]} ${t('duel_pts')}` : t('duel_won');
        document.getElementById('duel-sub-right').textContent = isDraw ? `${scores[rp]} ${t('duel_pts')}` : t('duel_next_time');
        document.getElementById('victory-title').style.visibility = 'hidden';
        document.getElementById('victory-sub').style.visibility   = 'hidden';
      }
      // Запускаем мерцание звёзд на экране победы (только тема stargazer)
      if (activeTheme === 'stargazer') startTwinkleLoop();
      // Запускаем покадровую анимацию chalk-победы
      if (activeTheme === 'chalk') startChalkAnim();

      // Анимированная последовательность завершения игры
      const _fadeOverlay = document.getElementById('canvas-fade-overlay');
      const _vc = document.getElementById('victory-content');
      const _gameCanvas = document.getElementById('c');

      if (!winName) {
        // Ничья: затемнение + надпись "Ничья" + поле для сохранения
        requestAnimationFrame(() => { _fadeOverlay.style.opacity = '1'; });
        setTimeout(() => {
          _vc.style.opacity = '1';
          _vc.style.pointerEvents = 'auto';
        }, 800);
        setTimeout(() => {
          _fadeOverlay.style.opacity = '0';
          _gameCanvas.style.transform = 'scale(0.42) translateY(-12%)';
        }, 1200);
        setTimeout(() => {
          const _nc = document.getElementById('name-constellation');
          const _input = document.getElementById('name-const-input');
          _input.value = playerNames[0] || '';
          applyGuestMode();
          _nc.style.opacity = '1';
          _nc.style.pointerEvents = 'auto';
          document.getElementById('victory-actions').style.display = 'none';
          if (_tutorialAutoSave) { _doTutorialAutoSave(_input.value.trim() || 'Моё созвездие'); }
        }, 2000);
      } else {
        // Победа: затемнение + уменьшение → просветление → поле имени снизу
        requestAnimationFrame(() => {
          _fadeOverlay.style.opacity = '1';
          _gameCanvas.style.transform = 'scale(0.42) translateY(-12%)';
        });
        // Фаза 2: overlay исчезает — созвездие снова яркое, но маленькое
        setTimeout(() => { _fadeOverlay.style.opacity = '0'; }, 1000);
        // Фаза 3: появляется поле для имени под созвездием
        setTimeout(() => {
          const _nc = document.getElementById('name-constellation');
          const _input = document.getElementById('name-const-input');
          _input.value = winName;
          applyGuestMode();
          _nc.style.opacity = '1';
          _nc.style.pointerEvents = 'auto';
          document.getElementById('victory-actions').style.display = 'none';
          if (_tutorialAutoSave) { _doTutorialAutoSave(_input.value.trim() || 'Моё созвездие'); }
          else { _input.focus(); }
        }, 1600);
      }
    }

    // ── ui ────────────────────────────────────────────────────────────────────

    let errorTimer;
    /**
     * Показывает сообщение об ошибке в блоке #error на 2.5 секунды.
     * @param {string} msg — текст ошибки
     */
    function showError(msg) {
      const el = document.getElementById('error');
      el.textContent = msg; el.style.opacity = '1';
      clearTimeout(errorTimer);
      errorTimer = setTimeout(() => el.style.opacity = '0', 2500);
    }
    /**
     * Немедленно скрывает сообщение об ошибке (opacity → 0) и отменяет
     * таймер автоскрытия. Вызывается при успешном ходе и при выборе новой точки,
     * чтобы убрать предыдущую ошибку до истечения 2.5 с.
     */
    function clearError() {
      clearTimeout(errorTimer);
      document.getElementById('error').style.opacity = '0';
    }

    /**
     * Обновляет игровой интерфейс верхней панели:
     * — записывает актуальные очки в #score1 и #score2;
     * — обновляет #turn-display строкой «Ход: <имя>» (или «Игрок N» если имя пустое).
     * Вызывается после каждого хода и при старте игры.
     */
    function updateUI() {
      document.getElementById('score1').textContent = scores[0];
      document.getElementById('score2').textContent = scores[1];
      const _turnName = playerNames[currentPlayer] || (t('player_default') + ' ' + (currentPlayer + 1));
      const _turnEl = document.getElementById('turn-display');
      _turnEl.textContent = `${t('turn_display')} ${_turnName}`;
      _turnEl.dataset.turnPlayer = _turnName;
    }

    // ── draw ──────────────────────────────────────────────────────────────────

    /**
     * Возвращает дополнительный буст яркости для точки i в текущий момент.
     * 0.0 = нет мерцания, 1.0 = максимум (финальная яркость регулируется в вызове).
     * Используется только при gameOver в теме stargazer.
     */
    function getTwinkleBoost(i) {
      function calcBoost(state) {
        if (!state || state.idx !== i) return 0;
        const t = Math.min((performance.now() - state.startMs) / state.duration, 1);
        const env = t < 0.3 ? t / 0.3 : (1 - t) / 0.7;
        return Math.sin(env * Math.PI * 0.5);
      }
      return Math.max(calcBoost(_twinkleState), calcBoost(_gameTwinkleState));
    }

    /**
     * Запускает rAF-петлю мерцания звёзд для экрана победы.
     * Случайно выбирает точку победителя, анимирует её (2–3 с),
     * затем ждёт 2–7 с и выбирает следующую.
     */
    function startTwinkleLoop() {
      if (_twinkleRaf) return; // уже запущена

      function pickNext() {
        // Выбираем случайную точку победителя с degree > 0
        const candidates = [];
        if (winner < 0) return; // ничья — не мерцаем
        const deg = new Array(points.length).fill(0);
        lines.forEach((player, key) => {
          if (player !== winner) return;
          const [a, b] = key.split('-').map(Number);
          deg[a]++; deg[b]++;
        });
        points.forEach((_, i) => { if (deg[i] > 0) candidates.push(i); });
        if (candidates.length === 0) return;
        const idx = candidates[Math.floor(Math.random() * candidates.length)];
        const duration = 900 + Math.random() * 500;   // 0.9–1.4 с
        const waitUntil = performance.now() + duration + 1000 + Math.random() * 2500; // +1–3.5 с
        _twinkleState = { idx, startMs: performance.now(), duration, waitUntil };
      }

      function loop() {
        if (!gameOver) { _twinkleRaf = null; _twinkleState = null; return; }
        const now = performance.now();
        // Проверяем, нужно ли начать следующий цикл мерцания
        if (!_twinkleState || now >= _twinkleState.waitUntil) pickNext();
        draw();
        _twinkleRaf = requestAnimationFrame(loop);
      }

      pickNext();
      _twinkleRaf = requestAnimationFrame(loop);
    }

    /**
     * Запускает rAF-петлю мерцания звёзд во время активной игры.
     * Мерцает любая точка (не только соединённые). Чуть быстрее чем на победном экране.
     * Останавливается при gameOver или смене темы.
     */
    function startGameTwinkleLoop() {
      if (_gameTwinkleRaf) return; // уже запущена

      function pickNext() {
        if (points.length === 0) return;
        const idx = Math.floor(Math.random() * points.length);
        const duration  = 500 + Math.random() * 600;          // 0.5–1.1 с
        const waitUntil = performance.now() + duration + 800 + Math.random() * 2500; // +0.8–3.3 с
        _gameTwinkleState = { idx, startMs: performance.now(), duration, waitUntil };
      }

      function loop() {
        if (gameOver || activeTheme !== 'stargazer') {
          _gameTwinkleRaf = null;
          _gameTwinkleState = null;
          return;
        }
        const now = performance.now();
        if (!_gameTwinkleState || now >= _gameTwinkleState.waitUntil) pickNext();
        draw();
        _gameTwinkleRaf = requestAnimationFrame(loop);
      }

      pickNext();
      _gameTwinkleRaf = requestAnimationFrame(loop);
    }

    /**
     * Рисует одну точку в стиле "звезда" для темы stargazer.
     * Два слоя радиальных градиентов: мягкое ядро + внешнее свечение.
     * Радиус ядра растёт с количеством соединений (каппинг: 5 отрезков).
     * Цвет свечения — синий (#8888FF) или красный (#ff6b6b) для блокирующей точки.
     *
     * @param {CanvasRenderingContext2D} ctx
     * @param {number} px        — x-координата
     * @param {number} py        — y-координата
     * @param {number} degree    — количество линий, исходящих из точки
     * @param {boolean} isHov    — курсор над точкой
     * @param {boolean} isSel    — точка выбрана (selected)
     * @param {boolean} isBlocking — точка блокирует невалидный ход
     */
    /**
     * Universal star drawing function — used everywhere in the app.
     * drawStarPoint / drawStarPointTo are thin aliases for backward compat.
     */
    function _drawStarImpl(c, px, py, degree, isHov, isSel, isBlocking, boost, glowFull) {
      c.save();
      const BASE = RADIUS + 3;
      const deg  = Math.min(degree, 8);
      const coreR = BASE * (1 + deg * 0.20);
      const glowR = coreR * (isHov || isSel ? 5.5 : 3.5);

      const glowAlpha = isBlocking ? 0.72 :
                        isSel      ? 0.68 :
                        isHov      ? 0.55 :
                        deg >= 7   ? 0.34 :
                        deg >= 6   ? 0.28 :
                        deg >= 5   ? 0.22 :
                        deg >= 4   ? 0.16 :
                        deg >= 3   ? 0.11 :
                        deg >= 2   ? 0.06 :
                        deg >= 1   ? 0.03 : 0.01;

      const boostedAlpha = Math.min(glowAlpha + boost * 0.40, 0.95);
      const boostedGlowR = glowR  * (1 + boost * 0.25);
      const boostedCoreR = coreR  * (1 + boost * 0.20);

      const spikeScale = deg === 0 ? 0.00 :
                         deg === 1 ? 0.12 :
                         deg === 2 ? 0.28 :
                         deg === 3 ? 0.44 :
                         deg === 4 ? 0.58 :
                         deg === 5 ? 0.72 :
                         deg === 6 ? 0.84 :
                         deg === 7 ? 0.93 : 1.00;

      const glowColor = isBlocking ? '255,70,70' : '255,200,120';
      const haloR = boostedGlowR * 1.8 * (0.3 + spikeScale * 0.7);
      const a = boostedAlpha;

      if (glowFull) {
        // ── Слой 1: круговой ореол (shadowBlur вместо ctx.filter) ─────────
        c.save();
        c.shadowBlur  = Math.max(8, haloR * 0.22);
        c.shadowColor = `rgba(${glowColor},${(a * 0.28).toFixed(3)})`;
        const circleGrad = c.createRadialGradient(px, py, 0, px, py, haloR);
        circleGrad.addColorStop(0,    `rgba(${glowColor},${Math.min(a * 0.55, 0.92).toFixed(3)})`);
        circleGrad.addColorStop(0.12, `rgba(${glowColor},${(a * 0.42).toFixed(3)})`);
        circleGrad.addColorStop(0.28, `rgba(${glowColor},${(a * 0.22).toFixed(3)})`);
        circleGrad.addColorStop(0.50, `rgba(${glowColor},${(a * 0.09).toFixed(3)})`);
        circleGrad.addColorStop(0.75, `rgba(${glowColor},${(a * 0.03).toFixed(3)})`);
        circleGrad.addColorStop(1,    `rgba(${glowColor},0)`);
        c.beginPath(); c.arc(px, py, haloR, 0, Math.PI * 2);
        c.fillStyle = circleGrad; c.fill();
        c.restore();

        // ── Слой 2: короткие лучи-блики (shadowBlur вместо ctx.filter) ─────
        if (degree > 0) {
          const spikeLen = boostedGlowR * 0.93 * spikeScale;
          const spikePasses = [
            { base: boostedCoreR * 1.1,  alpha: boostedAlpha * 0.12, sblur: Math.max(10, spikeLen * 0.40) },
            { base: boostedCoreR * 0.55, alpha: boostedAlpha * 0.28, sblur: Math.max(7,  spikeLen * 0.28) },
            { base: boostedCoreR * 0.22, alpha: boostedAlpha * 0.70, sblur: Math.max(4,  spikeLen * 0.16) },
          ];
          spikePasses.forEach(({ base, alpha, sblur }) => {
            c.save();
            c.shadowBlur  = sblur;
            c.shadowColor = `rgba(${glowColor},${Math.min(alpha * 1.2, 0.95).toFixed(3)})`;
            [0, Math.PI / 2, Math.PI, Math.PI * 3 / 2].forEach(angle => {
              const ex = Math.cos(angle), ey = Math.sin(angle);
              const nx = -ey, ny = ex;
              c.beginPath();
              c.moveTo(px + nx * base, py + ny * base);
              c.lineTo(px + ex * spikeLen, py + ey * spikeLen);
              c.lineTo(px - nx * base, py - ny * base);
              c.closePath();
              const sg = c.createLinearGradient(px, py, px + ex * spikeLen, py + ey * spikeLen);
              sg.addColorStop(0,    `rgba(${glowColor},${(alpha * 0.30).toFixed(3)})`);
              sg.addColorStop(0.18, `rgba(${glowColor},${(alpha * 0.85).toFixed(3)})`);
              sg.addColorStop(0.45, `rgba(${glowColor},${(alpha * 0.28).toFixed(3)})`);
              sg.addColorStop(0.75, `rgba(${glowColor},${(alpha * 0.06).toFixed(3)})`);
              sg.addColorStop(1,    `rgba(${glowColor},0)`);
              c.fillStyle = sg; c.fill();
            });
            c.restore();
          });
        }
      }

      // ── Слой 3: яркое круглое ядро (shadowBlur вместо ctx.filter) ──────
      c.save();
      c.shadowBlur  = Math.max(6, boostedCoreR * 0.7);
      c.shadowColor = `rgba(${isBlocking ? '255,110,110' : '255,230,170'},0.70)`;
      const coreColor = isBlocking ? '255,110,110' : '255,245,210';
      const coreGrad = c.createRadialGradient(px, py, 0, px, py, boostedCoreR);
      coreGrad.addColorStop(0,    `rgba(${coreColor},0.95)`);
      coreGrad.addColorStop(0.25, `rgba(${coreColor},0.80)`);
      coreGrad.addColorStop(0.55, `rgba(${coreColor},0.35)`);
      coreGrad.addColorStop(0.80, `rgba(${coreColor},0.08)`);
      coreGrad.addColorStop(1,    `rgba(${coreColor},0)`);
      c.beginPath(); c.arc(px, py, boostedCoreR, 0, Math.PI * 2);
      c.fillStyle = coreGrad; c.fill();
      c.restore();

      c.restore();
    }

    // drawStarPoint — main game canvas (respects starGlow setting)
    function drawStarPoint(ctx, px, py, degree, isHov, isSel, isBlocking, boost = 0) {
      const glowFull = window._appSettings.starGlow !== 'active' || isHov || isSel;
      _drawStarImpl(ctx, px, py, degree, isHov, isSel, isBlocking, boost, glowFull);
    }

    // drawStarPointTo — arbitrary context (victory, detail, home bg, sky, achievements…)
    function drawStarPointTo(c, px, py, degree, isHov, isSel, isBlocking, boost = 0) {
      _drawStarImpl(c, px, py, degree, isHov, isSel, isBlocking, boost, true);
    }

    /**
     * Полностью перерисовывает canvas. Вызывается после каждого изменения состояния.
     *
     * Во время игры (gameOver = false):
     *   1. Заливки захваченных областей (FILL цвет темы).
     *   2. Все проведённые линии.
     *   3. Превью линии от selected к hovered — пунктир, оранжевый если невалидный,
     *      тематический если валидный; блокирующая точка подсвечивается красным.
     *   4. Все точки; hovered/selected/blocking рисуются с увеличенным радиусом и кольцом.
     *
     * На экране победы (gameOver = true):
     *   1. Все линии (только победителя, если не ничья).
     *   2. Точки победителя, масштабированные по степени вхождения в линии.
     *   3. T().drawVictory(ctx, W, H) — тематическая канвас-графика (art layer).
     *   4. T().postDraw(ctx, W, H)   — постобработка (зерно + виньетка для suprematist).
     *
     * Текст победителя, рейтинг и кнопки отображаются HTML-элементами
     * в #victory-content (не на canvas).
     */
    function draw() {
      if (_rankUpActive) return; // rank-up ceremony owns the canvas right now
      ctx.setTransform(_canvasDpr, 0, 0, _canvasDpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      if (activeTheme === 'chalk' && !gameOver) drawChalkPaperBg(ctx, W, H);

      // В режиме 2 игроков drawVictoryDuel сама фильтрует линии по секторам,
      // поэтому при победе в режиме 2 игроков не фильтруем — показываем все линии.
      const showPlayer = (gameOver && winner >= 0 && isAI) ? winner : null;

      // Captured region fills (only during active game)
      if (!gameOver) {
        if (activeTheme === 'chalk') {
          polygons.forEach(({ path }, polyIdx) => {
            const poly = path.map(i => points[i]);
            ctx.beginPath();
            ctx.moveTo(poly[0].x, poly[0].y);
            for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
            ctx.closePath();
            ctx.globalAlpha = 0.28;
            ctx.fillStyle = CHALK_FILL[polyIdx % CHALK_FILL.length];
            ctx.fill();
            ctx.globalAlpha = 1;
          });
        } else {
          polygons.forEach(({ path }) => {
            const poly = path.map(i => points[i]);
            ctx.beginPath();
            ctx.moveTo(poly[0].x, poly[0].y);
            for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
            ctx.closePath();
            ctx.fillStyle = FILL;
            ctx.fill();
          });
        }
      }

      // Hint edges (drawn under regular lines)
      if (!gameOver && _hintsOn && _hintEdges.length > 0) drawHints();

      // Drawn lines
      let chalkLineIdx = 0;
      lines.forEach((player, key) => {
        if (showPlayer !== null && player !== showPlayer) return;
        const [a, b] = key.split('-').map(Number);
        const ax = points[a].x, ay = points[a].y;
        const bx = points[b].x, by = points[b].y;

        if (activeTheme === 'stargazer' && !gameOver) {
          ctx.save();
          ctx.lineCap = 'round';
          ctx.shadowBlur  = 3;
          ctx.shadowColor = COLOR;
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
          ctx.strokeStyle = COLOR; ctx.lineWidth = 1.0; ctx.stroke();
          ctx.restore();
        } else if (activeTheme === 'chalk' && !gameOver) {
          drawChalkLine(ctx, ax, ay, bx, by, CHALK_RAINBOW[chalkLineIdx++ % CHALK_RAINBOW.length]);
        } else {
          // Все остальные темы и экран победы — без изменений
          ctx.beginPath();
          ctx.moveTo(ax, ay);
          ctx.lineTo(bx, by);
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = gameOver ? 2 : 1.5;
          ctx.stroke();
        }
      });

      // Animated line (grows from a to b over 200ms)
      if (_lineAnim && !gameOver) {
        const t = Math.min(1, (performance.now() - _lineAnim.startT) / 200);
        const pa = points[_lineAnim.a], pb = points[_lineAnim.b];
        const ex = pa.x + (pb.x - pa.x) * t;
        const ey = pa.y + (pb.y - pa.y) * t;
        if (activeTheme === 'stargazer') {
          ctx.save();
          ctx.lineCap = 'round';
          ctx.shadowBlur  = 4;
          ctx.shadowColor = COLOR;
          ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(ex, ey);
          ctx.strokeStyle = COLOR; ctx.lineWidth = 1.2; ctx.stroke();
          ctx.restore();
        } else {
          ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(ex, ey);
          ctx.strokeStyle = COLOR; ctx.lineWidth = 1.5; ctx.stroke();
        }
      }

      if (!gameOver) {
        // Preview line
        let blockingPoint = -1;
        if (selected !== -1 && hovered !== -1 && hovered !== selected) {
          const v = previewValidation;
          const previewColor = (!v || !v.ok) ? 'rgba(210,208,205,0.55)' : PREVIEW;
          if (v && v.blockingPoint !== undefined) blockingPoint = v.blockingPoint;
          ctx.beginPath();
          ctx.moveTo(points[selected].x, points[selected].y);
          ctx.lineTo(points[hovered].x, points[hovered].y);
          ctx.strokeStyle = previewColor;
          ctx.lineWidth = 2;
          ctx.setLineDash([6, 4]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Points
        // Степень каждой точки по всем проведённым линиям (оба игрока) — нужна для drawStarPoint
        const activeDegree = new Array(COUNT).fill(0);
        lines.forEach((_, key) => {
          const [a, b] = key.split('-').map(Number);
          activeDegree[a]++; activeDegree[b]++;
        });

        if (activeTheme === 'stargazer') {
          // Тема stargazer: звёздный рендер с градиентами и свечением
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            drawStarPoint(ctx, p.x, p.y, activeDegree[i],
              i === hovered, i === selected, i === blockingPoint,
              getTwinkleBoost(i) * 0.6);
            if (bt < 1) ctx.restore();
          });
        } else if (activeTheme === 'chalk') {
          // Chalk: мелковые точки с цветом по игроку
          const cp0 = new Array(COUNT).fill(0), cp1 = new Array(COUNT).fill(0);
          lines.forEach((pl, key) => {
            const [a, b] = key.split('-').map(Number);
            if (pl === 0) { cp0[a]++; cp0[b]++; } else { cp1[a]++; cp1[b]++; }
          });
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            const isHov = i === hovered, isSel = i === selected;
            const isBlocking = i === blockingPoint;
            let pColor, r;
            if (activeDegree[i] === 0) {
              pColor = 'rgba(120,100,80,0.5)'; r = 6;
            } else {
              r = isHov || isSel || isBlocking ? RADIUS + 4 : RADIUS + 2;
              pColor = CHALK_RAINBOW[i % CHALK_RAINBOW.length];
            }
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            drawChalkSpiral(ctx, p.x, p.y, 18, pColor, activeDegree[i]);
            if (isHov || isSel || isBlocking) {
              ctx.beginPath();
              ctx.arc(p.x, p.y, r + 5, 0, Math.PI * 2);
              ctx.strokeStyle = isBlocking ? 'rgba(255,107,107,0.6)' : PREVIEW;
              ctx.lineWidth = 1.5;
              ctx.stroke();
            }
            if (bt < 1) ctx.restore();
          });
        } else {
          // Остальные темы: стандартный рендер твёрдыми кругами
          points.forEach((p, i) => {
            const bt = _pointBirthScale(i);
            if (bt === 0) return;
            const isHov = i === hovered, isSel = i === selected;
            const isBlocking = i === blockingPoint;
            if (bt < 1) { ctx.save(); ctx.globalAlpha = bt; ctx.translate(p.x, p.y); ctx.scale(bt, bt); ctx.translate(-p.x, -p.y); }
            ctx.beginPath();
            ctx.arc(p.x, p.y, isHov || isSel || isBlocking ? RADIUS + 2 : RADIUS, 0, Math.PI * 2);
            ctx.fillStyle = isBlocking ? '#ff6b6b' : COLOR;
            ctx.fill();
            if (isHov || isSel || isBlocking) {
              ctx.beginPath();
              ctx.arc(p.x, p.y, RADIUS + 5, 0, Math.PI * 2);
              ctx.strokeStyle = isBlocking ? 'rgba(255,107,107,0.6)' : PREVIEW;
              ctx.lineWidth = 1.5;
              ctx.stroke();
            }
            if (bt < 1) ctx.restore();
          });
        }
      } else {
        // Count winner's lines per point
        const degree = new Array(COUNT).fill(0);
        if (winner >= 0) {
          lines.forEach((player, key) => {
            if (player !== winner) return;
            const [a, b] = key.split('-').map(Number);
            degree[a]++;
            degree[b]++;
          });
        }

        // Draw points scaled by degree (0 = hidden)
        points.forEach((p, i) => {
          const d = winner >= 0 ? degree[i] : 1;
          if (d === 0) return;
          if (activeTheme === 'stargazer') {
            // Тема stargazer: звёздный рендер с градиентами (degree из линий победителя)
            // boost=0.7 — постоянная надъяркость на экране победы; +мерцание до ×0.9
            drawStarPoint(ctx, p.x, p.y, d, false, false, false, 0.7 + getTwinkleBoost(i) * 0.9);
          } else {
            const r = d >= 3 ? RADIUS * 2 : d === 2 ? RADIUS * 1.5 : RADIUS;
            ctx.beginPath();
            ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
            ctx.fillStyle = T().dots;
            ctx.fill();
          }
        });

        // Victory overlay: split-screen для 2 игроков, тематическая графика для AI
        if (!isAI) {
          drawVictoryDuel(ctx, W, H);
        } else {
          T().drawVictory(ctx, W, H);
        }
      }

      // Анимация «последнего хода»: перерисовываем отрезок с плавно меняющейся толщиной.
      // lastMoveAnimT — треугольная волна 0→1→0 за 400мс (200мс рост, 200мс спад).
      // Толщина линии: base × (1 + t) → плавно до 2× базовой и обратно.
      if (lastMove && lastMoveAnimT > 0) {
        const base = gameOver ? 2 : 1.5;
        ctx.beginPath();
        ctx.moveTo(points[lastMove.a].x, points[lastMove.a].y);
        ctx.lineTo(points[lastMove.b].x, points[lastMove.b].y);
        ctx.strokeStyle = COLOR;
        ctx.lineWidth = base * (1 + lastMoveAnimT); // от base до 2×base и обратно
        ctx.stroke();
      }

      if (T().postDraw) T().postDraw(ctx, W, H);
      drawGrainOverlay(ctx, W, H);
      if (_tutorialMode) drawTutorialOverlay();
    }

    // ── win-probability bar ───────────────────────────────────────────────────

    /**
     * Оценивает вероятность победы игрока 0 (0.0–1.0).
     * Четыре взвешенных компоненты → сигмоида.
     */
    function estimateWinProbability() {
      if (COUNT === 0 || points.length === 0) return 0.5;

      // Степени точек по каждому игроку
      const deg0 = new Array(COUNT).fill(0);
      const deg1 = new Array(COUNT).fill(0);
      const degT = new Array(COUNT).fill(0); // суммарная степень (оба игрока)
      lines.forEach((player, key) => {
        const [a, b] = key.split('-').map(Number);
        degT[a]++; degT[b]++;
        if (player === 0) { deg0[a]++; deg0[b]++; }
        else              { deg1[a]++; deg1[b]++; }
      });

      // Компонента 1: разница очков (вес 0.4)
      const totalScore = scores[0] + scores[1];
      const maxPossible = Math.max(1, totalScore + 4);
      const c1 = ((scores[0] - scores[1]) / maxPossible) * 0.4;

      // Компонента 2: разница захваченных полигонов (вес 0.3)
      const polys0 = polygons.filter(p => p.player === 0).length;
      const polys1 = polygons.filter(p => p.player === 1).length;
      const totalPolys = Math.max(1, polys0 + polys1);
      const c2 = ((polys0 - polys1) / totalPolys) * 0.3;

      // Компонента 3: средняя длина цепи (вес 0.2)
      const avg0 = deg0.reduce((s, d) => s + d, 0) / COUNT;
      const avg1 = deg1.reduce((s, d) => s + d, 0) / COUNT;
      const c3 = ((avg0 - avg1) / 10) * 0.2;

      // Компонента 4: хаб-узлы — cascade risk (вес 0.1)
      // Узел с степенью ≥ 4 считается хабом; чем больше рёбер игрока в хабе, тем выше риск
      const maxHubDeg = 6;
      let hubAdv = 0, hubCount = 0;
      for (let i = 0; i < COUNT; i++) {
        if (degT[i] >= 4) {
          hubAdv += (deg0[i] - deg1[i]) / maxHubDeg;
          hubCount++;
        }
      }
      const c4 = hubCount > 0 ? (hubAdv / hubCount) * 0.1 : 0;

      const raw = c1 + c2 + c3 + c4;
      return 1 / (1 + Math.exp(-6 * raw));
    }

    /**
     * Вспомогательная функция: рисует скруглённый прямоугольник.
     * Используется вместо ctx.roundRect для совместимости.
     */
    function _rrect(ctx, x, y, w, h, r) {
      const R = Math.min(r, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + R, y);
      ctx.lineTo(x + w - R, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + R);
      ctx.lineTo(x + w, y + h - R);
      ctx.quadraticCurveTo(x + w, y + h, x + w - R, y + h);
      ctx.lineTo(x + R, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - R);
      ctx.lineTo(x, y + R);
      ctx.quadraticCurveTo(x, y, x + R, y);
      ctx.closePath();
    }

    /**
     * Рисует полосу вероятности победы в верхней части игрового canvas.
     * Stargazer: тонкая линия-дорожка + скользящая светящаяся точка на позиции split.
     * Остальные темы: двухцветная полоска в цветах темы (accent слева, мuted справа).
     */
    function drawProbBar() {
      const barW  = W * 0.90;
      const barX  = (W - barW) / 2;
      const barY  = 10;
      const p0    = Math.max(0, Math.min(1, _probBarDisplay));
      const split = barX + barW * p0;
      const t     = T();

      ctx.save();

      if (activeTheme === 'stargazer') {
        // ── Stargazer: одна линия + скользящая светящаяся точка ──
        const midY = barY + 4;

        // Дорожка (едва заметная тонкая линия)
        ctx.fillStyle = 'rgba(248,247,245,0.09)';
        ctx.fillRect(barX, midY - 0.75, barW, 1.5);

        // Внешнее мягкое свечение точки
        const glow = ctx.createRadialGradient(split, midY, 0, split, midY, 16);
        glow.addColorStop(0, 'rgba(225,223,220,0.38)');
        glow.addColorStop(1, 'rgba(225,223,220,0)');
        ctx.fillStyle = glow;
        ctx.fillRect(split - 16, midY - 16, 32, 32);

        // Среднее кольцо
        const mid = ctx.createRadialGradient(split, midY, 0, split, midY, 5.5);
        mid.addColorStop(0,   'rgba(248,247,245,0.95)');
        mid.addColorStop(0.45,'rgba(225,223,220,0.65)');
        mid.addColorStop(1,   'rgba(225,223,220,0)');
        ctx.fillStyle = mid;
        ctx.beginPath();
        ctx.arc(split, midY, 5.5, 0, Math.PI * 2);
        ctx.fill();

        // Яркое ядро
        ctx.beginPath();
        ctx.arc(split, midY, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(248,247,245,0.96)';
        ctx.fill();

      } else {
        // ── Остальные темы: двухцветная полоска в цветах темы ──
        const barH  = 5;
        const r     = 2.5;
        const accentRaw = t.accent || t.lines;

        // Правая дорожка (игрок 1, мuted)
        _rrect(ctx, barX, barY, barW, barH, r);
        ctx.fillStyle = 'rgba(128,128,128,0.14)';
        ctx.fill();

        // Левый сегмент (игрок 0, цвет акцента темы)
        if (p0 > 0.01) {
          _rrect(ctx, barX, barY, barW * p0, barH, r);
          ctx.fillStyle = accentRaw;
          ctx.globalAlpha = 0.72;
          ctx.fill();
          ctx.globalAlpha = 1;
        }

        // Маркер на границе раздела
        ctx.beginPath();
        ctx.arc(split, barY + barH / 2, 3, 0, Math.PI * 2);
        ctx.fillStyle = accentRaw;
        ctx.fill();
      }

      ctx.restore();
    }

    /**
     * Запускает плавную анимацию полосы вероятности к _probBarTarget.
     * Каждый кадр: display += (target − display) × 0.06.
     */
    function startProbBarAnim() {
      if (_probBarRaf) { cancelAnimationFrame(_probBarRaf); _probBarRaf = null; }
      _probBarDisplay = _probBarTarget;
      const fill = document.getElementById('prob-bar-fill');
      if (fill) fill.style.width = (_probBarTarget * 100).toFixed(1) + '%';
    }

    // ── last move ─────────────────────────────────────────────────────────────

    /**
     * Показывает или скрывает кнопку «Последний ход» в зависимости от того,
     * был ли уже сделан хотя бы один ход. Вызывается после каждого хода.
     */
    function updateLastMoveBtn() {
      document.getElementById('last-move-btn')
        .classList.toggle('visible', lines.size > 0);
    }

    /**
     * Запускает анимацию подсветки последнего хода: за 400мс (200мс вверх + 200мс вниз)
     * толщина линии плавно возрастает от базовой до 2× базовой и возвращается обратно.
     *
     * Если анимация уже идёт — перезапускает её с нуля.
     * Использует requestAnimationFrame для покадровой интерполяции.
     */
    function animateLastMove() {
      if (!lastMove) return;
      if (lastMoveAnimRaf) { cancelAnimationFrame(lastMoveAnimRaf); lastMoveAnimRaf = null; }

      const DURATION = 400; // мс: 200 вверх + 200 вниз
      const start = performance.now();

      /**
       * Покадровый callback requestAnimationFrame.
       * t — нормализованный прогресс анимации [0..1] относительно DURATION.
       * lastMoveAnimT — треугольная огибающая: 0→1 за первую половину,
       * 1→0 за вторую; draw() использует её для интерполяции толщины линии.
       * @param {DOMHighResTimeStamp} now — метка времени от rAF
       */
      function frame(now) {
        const t = Math.min((now - start) / DURATION, 1);
        // Треугольная огибающая: 0→1 за первые 200мс, 1→0 за вторые 200мс
        lastMoveAnimT = t < 0.5 ? t * 2 : (1 - t) * 2;
        draw();
        if (t < 1) {
          lastMoveAnimRaf = requestAnimationFrame(frame); // продолжаем анимацию
        } else {
          lastMoveAnimT = 0;
          lastMoveAnimRaf = null;
          draw(); // финальный кадр без подсветки
        }
      }

      lastMoveAnimRaf = requestAnimationFrame(frame);
    }

    document.getElementById('last-move-btn').addEventListener('click', animateLastMove);

    // ── events ────────────────────────────────────────────────────────────────
    //
    // Взаимодействие с canvas реализовано через три обработчика:
    //
    // mousemove  — отслеживает ближайшую к курсору точку (hovered), кэширует
    //              результат validate() для отрисовки превью линии в draw().
    //              Перерисовка происходит только если hovered изменился — оптимизация.
    //
    // mouseleave — сбрасывает hovered и превью при уходе курсора с canvas,
    //              чтобы убрать подсветку и пунктирную линию.
    //
    // click      — двухкликовая модель выбора хода:
    //              1-й клик по точке: записывает в selected
    //              2-й клик по той же точке: снимает выделение
    //              2-й клик по другой точке: проверяет ход через validate();
    //                при успехе — применяет через applyMove() (или напрямую для
    //                отслеживания AI-очереди) и если isAI — запускает
    //                setTimeout(makeAIMove, 800) для имитации «раздумья» ИИ.
    //              Клик в пустоту: сбрасывает selected.

    /**
     * Обработчик движения мыши по canvas.
     * Вычисляет ближайшую точку к курсору в радиусе RADIUS+8 пикселей.
     * Если точка изменилась — пересчитывает previewValidation и перерисовывает поле.
     * previewValidation кэшируется здесь, а не в draw(), чтобы не вызывать
     * validate() на каждый кадр при неподвижном курсоре.
     */
    canvas.addEventListener('mousemove', e => {
      if (gameOver) return;
      const [mx, my] = _evXY(e, canvas);
      const prev = hovered;
      // Ищем точку в радиусе RADIUS+8 (увеличенная зона захвата для удобства)
      hovered = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);
      if (hovered !== prev) {
        // Обновляем превью валидации только если есть выбранная точка и новая цель
        previewValidation = (selected !== -1 && hovered !== -1 && hovered !== selected)
          ? validate(selected, hovered) : null;
        draw();
      }
    });

    /**
     * Обработчик ухода курсора за границу canvas.
     * Сбрасывает hovered и previevValidation — убирает подсветку и пунктирную линию.
     */
    canvas.addEventListener('mouseleave', () => {
      if (gameOver) return;
      hovered = -1; previewValidation = null; draw();
    });

    // Touch support for mobile
    canvas.addEventListener('touchstart', e => {
      e.preventDefault();
      if (gameOver) return;
      const t = e.touches[0];
      const r = canvas.getBoundingClientRect();
      const sx = canvas.width / r.width, sy = canvas.height / r.height;
      const mx = (t.clientX - r.left) * sx, my = (t.clientY - r.top) * sy;
      const prev = hovered;
      hovered = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);
      if (hovered !== prev) {
        previewValidation = (selected !== -1 && hovered !== -1 && hovered !== selected)
          ? validate(selected, hovered) : null;
        draw();
      }
    }, { passive: false });

    canvas.addEventListener('touchend', e => {
      e.preventDefault();
      const t = e.changedTouches[0];
      canvas.dispatchEvent(new MouseEvent('click', { clientX: t.clientX, clientY: t.clientY, bubbles: true }));
    }, { passive: false });

    /**
     * Обработчик клика по canvas — основная логика ввода хода игрока.
     *
     * Состояния selected:
     *   -1 → нет выбранной точки; первый клик устанавливает selected
     *   ≥0 → точка выбрана; второй клик применяет ход или снимает выделение
     *
     * После успешного хода:
     *   — проверяется конец игры (isGameOver)
     *   — если режим AI и сейчас ход Звездочёта — запускается makeAIMove с задержкой 800мс
     *     (имитирует «раздумье» и даёт игроку увидеть свой ход до ответа AI)
     */
    canvas.addEventListener('click', e => {
      if (gameOver || _lineAnimating) return;

      // Tutorial: intercept all clicks while a tooltip is showing
      if (_tutorialBlocked) {
        if (_tutorialBtnRect) {
          const [mx, my] = _evXY(e, canvas);
          const btn = _tutorialBtnRect;
          if (mx >= btn.x && mx <= btn.x + btn.w && my >= btn.y && my <= btn.y + btn.h)
            startDismissTutorial();
        }
        return;
      }

      const [mx, my] = _evXY(e, canvas);
      // Ищем точку под курсором (та же расширенная зона захвата, что и в mousemove)
      const i = points.findIndex(p => Math.hypot(p.x - mx, p.y - my) <= HIT_R);

      if (i === -1) {
        // Клик в пустоту — снимаем выделение
        selected = -1; previewValidation = null; draw(); return;
      }

      if (selected === -1) {
        // Первый клик: выбираем точку
        selected = i; clearError();
        // Tutorial moment 1: first point ever selected
        if (_tutorialMode && _tutorialStep === 0) {
          _tutorialStep = 1;
          _tutorialPulseIdx = i;
          _tutorialPulseStart = performance.now();
          const px = points[i].x, py = points[i].y;
          const tx = (px + 30 + 300 > W) ? px - 330 : px + 30;
          const ty = (py - 90 < 10) ? py + 20 : py - 90;
          showTutorialTooltip(
            t('tut_first_star'),
            tx, ty
          );
        }
      } else if (selected === i) {
        // Повторный клик по той же точке: отменяем выбор
        selected = -1; previewValidation = null;
      } else {
        // Второй клик по другой точке: пытаемся сделать ход
        const v = validate(selected, i);
        if (!v.ok) {
          showError(v.reason); // показываем причину отказа
        } else {
          // Ход валиден — анимируем линию, затем применяем
          const _sa = selected, _sb = i;
          clearError(); selected = -1; previewValidation = null;
          _lineAnimating = true;
          _lineAnim = { a: _sa, b: _sb, player: currentPlayer, startT: performance.now() };
          _startLineAnimLoop();
          setTimeout(() => {
            _lineAnim = null; _lineAnimating = false;
            lastMove = { a: _sa, b: _sb };
            lines.set(lineKey(_sa, _sb), currentPlayer);
            checkScore(_sa, _sb, currentPlayer);
            currentPlayer = 1 - currentPlayer;
            _isGameOverCache = null;
            updateUI(); updateLastMoveBtn();
            checkTutorialMoments();
            computeHints();
            if (isGameOver()) { endGame(); return; }
            _probBarTarget = estimateWinProbability(); startProbBarAnim();
            if (isAI && currentPlayer === 1) {
              if (_tutorialMode) document.getElementById('turn-display').textContent = t('ai_thinking');
              setTimeout(makeAIMove, 800);
            }
          }, 200);
        }
      }
      draw();
    });

    // ── themes ────────────────────────────────────────────────────────────────

    /**
     * Возвращает активный объект темы.
     * Объявлена как function-declaration для хойстинга (используется в draw() выше).
     * @returns {object}
     */
    function T() { return THEMES[activeTheme]; }

    /**
     * Рендер экрана победы для тем "stargazer" и "chalk" по умолчанию.
     * Тело пустое: эти темы не добавляют специальной канвас-графики к стандартному
     * виду (линии + точки победителя, масштабированные по степени), нарисованному
     * в draw(). Текст победителя отображается HTML-блоком #victory-content.
     * @param {CanvasRenderingContext2D} ctx
     * @param {number} W — ширина canvas
     * @param {number} H — высота canvas
     */
    function defaultDrawVictory(ctx, W, H) {
      // Канвас-арт отсутствует: победный контент отображается в #victory-content (HTML).
    }

    /**
     * Рендер экрана победы для темы "minimal".
     * Стиль: органическая нейронная карта — узлы разного размера, соединённые
     * плавными S-образными кривыми Безье.
     *
     * Слои (снизу вверх):
     *   1. S-образные кубические кривые Безье вдоль каждого отрезка победителя
     *      (globalAlpha 0.55, lineWidth 1.5) — соединения между узлами.
     *   2. Круги-узлы поверх кривых; радиус = BASE_R × 1.4^degree:
     *        degree=1 → только тонкое кольцо (нет заливки)
     *        degree=2 → белая заливка + обводка 2px
     *        degree≥3 → белая заливка + обводка 2.5px + чёрное ядро r×0.18
     *
     * При winner === -1 (ничья) функция не рисует ничего.
     * Текст победителя отображается HTML-блоком #victory-content ниже canvas.
     * @param {CanvasRenderingContext2D} ctx
     * @param {number} W — ширина canvas
     * @param {number} H — высота canvas
     */
    function drawVictoryMinimal(ctx, W, H) {
      // Ничья — ничего не рисовать
      if (winner < 0) { ctx.clearRect(0, 0, W, H); return; }

      ctx.clearRect(0, 0, W, H);

      // Степень каждой точки: сколько отрезков победителя к ней примыкает
      const degree = new Array(COUNT).fill(0);
      lines.forEach((player, key) => {
        if (player !== winner) return;
        const [a, b] = key.split('-').map(Number);
        degree[a]++; degree[b]++;
      });

      // Радиус узла: BASE_R × 1.4^degree (экспоненциальный рост по активности)
      const BASE_R = RADIUS * 4; // 16px при RADIUS=4
      const radii = points.map((_, i) =>
        degree[i] > 0 ? BASE_R * Math.pow(1.4, degree[i]) : 0
      );

      // ── Слой 1: S-образные кривые Безье вдоль отрезков победителя ────────────
      // Контрольные точки cp1 и cp2 смещены по перпендикуляру в противоположные
      // стороны (cp1 вправо, cp2 влево от направления отрезка) — даёт S-форму.
      ctx.strokeStyle = '#000000';
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.55;

      lines.forEach((player, key) => {
        if (player !== winner) return;
        const [a, b] = key.split('-').map(Number);
        const p1 = points[a], p2 = points[b];
        const dx = p2.x - p1.x, dy = p2.y - p1.y;
        const len = Math.hypot(dx, dy);
        if (len === 0) return;
        const nx = -dy / len, ny = dx / len;    // единичный перпендикуляр
        const offset = len * 0.25;              // смещение = 25% длины отрезка
        // cp1 смещён +перпендикуляр, cp2 — −перпендикуляр → S-образный изгиб
        const cp1 = { x: p1.x + dx / 3 + nx * offset, y: p1.y + dy / 3 + ny * offset };
        const cp2 = { x: p1.x + 2 * dx / 3 - nx * offset, y: p1.y + 2 * dy / 3 - ny * offset };
        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.bezierCurveTo(cp1.x, cp1.y, cp2.x, cp2.y, p2.x, p2.y);
        ctx.stroke();
      });

      ctx.globalAlpha = 1; // сбрасываем прозрачность перед кругами

      // ── Слой 2: круги-узлы поверх кривых (обрезаем по границам канваса) ─────
      ctx.save();
      ctx.beginPath();
      ctx.rect(0, 0, W, H);
      ctx.clip();
      points.forEach((p, i) => {
        if (degree[i] === 0) return;
        const r = radii[i];
        ctx.beginPath();
        ctx.arc(p.x, p.y, r, 0, Math.PI * 2);

        if (degree[i] === 1) {
          // Тонкое кольцо — только обводка, без заливки
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 1.5;
          ctx.stroke();
        } else if (degree[i] === 2) {
          // Белая заливка + обводка 2px
          ctx.fillStyle = '#ffffff';
          ctx.fill();
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 2;
          ctx.stroke();
        } else {
          // degree ≥ 3: белая заливка + толстая обводка + чёрное ядро
          ctx.fillStyle = '#ffffff';
          ctx.fill();
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 2.5;
          ctx.stroke();
          // Маленькое чёрное ядро в центре узла
          ctx.beginPath();
          ctx.arc(p.x, p.y, r * 0.18, 0, Math.PI * 2);
          ctx.fillStyle = '#000000';
          ctx.fill();
        }
      });
      ctx.restore();

    }

    /**
     * Вычисляет детерминированную компоновку экрана победы (suprematist).
     * Вызывается один раз в endGame(), результат сохраняется в _supLayout.
     * Каждый визуальный элемент отражает результат игры.
     */
    function generateSupLayout() {
      const creamColor = '#F5F0E8';
      const goldColor  = '#C0BDBA';
      const ANGLE = 37 * Math.PI / 180;  // фиксированный угол диагонали
      const DIAG  = Math.hypot(W, H);

      // ── Данные игры ─────────────────────────────────────────────────────────
      const winPolys  = polygons.filter(p => p.player === winner);
      const losePolys = polygons.filter(p => p.player !== winner && p.player >= 0);
      const winScore  = winPolys.length;
      const loseScore = losePolys.length;
      const scoreDiff = winScore - loseScore;
      const domination = winScore / Math.max(1, winScore + loseScore);
      const totalLines = lines.size;

      // Степень каждой точки — сколько линий победителя к ней примыкает
      const degree = new Array(COUNT).fill(0);
      lines.forEach((player, key) => {
        if (player !== winner) return;
        const [a, b] = key.split('-').map(Number);
        degree[a]++; degree[b]++;
      });

      // Центроид набора вершин
      const centroid = path => {
        const v = path.map(i => points[i]);
        return { x: v.reduce((s,p)=>s+p.x,0)/v.length,
                 y: v.reduce((s,p)=>s+p.y,0)/v.length };
      };

      // Полигоны победителя/проигравшего по убыванию площади
      const winnerPolys = winPolys
        .map(({ path }) => ({ path, area: polygonArea(path) }))
        .sort((a, b) => b.area - a.area);
      const loserPolys = losePolys
        .map(({ path }) => ({ path, area: polygonArea(path) }))
        .sort((a, b) => b.area - a.area);

      // ── Цвета: player 0 → красный dominant, player 1 → чёрный ─────────────
      const mainColor = (winner === 0) ? '#CC2200' : '#1A1A1A';
      const darkColor = (winner === 0) ? '#1A1A1A' : '#CC2200';

      // ── Главный круг ─────────────────────────────────────────────────────────
      // Позиция = centroid активных точек победителя; радиус зависит от domination
      let mainCx, mainCy;
      const activePts = points.filter((_, i) => degree[i] > 0);
      if (activePts.length > 0) {
        mainCx = activePts.reduce((s, p) => s + p.x, 0) / activePts.length;
        mainCy = activePts.reduce((s, p) => s + p.y, 0) / activePts.length;
      } else {
        mainCx = W / 2; mainCy = H / 2;
      }
      const mainR = Math.min(W, H) * (0.18 + domination * 0.22);

      // Число колец = 3 + winScore, максимум 7
      const ringCount = Math.min(3 + winScore, 7);

      // ── Второй круг (проигравший) ────────────────────────────────────────────
      let secondCircle = null;
      if (loseScore > 0) {
        const lc = loserPolys.length > 0
          ? centroid(loserPolys[0].path)
          : { x: W * 0.65, y: H * 0.35 };
        const r2 = mainR * (0.15 + loseScore * 0.07);
        secondCircle = { cx: lc.x, cy: lc.y, r2 };
      }

      // ── Диагональные линии ───────────────────────────────────────────────────
      // Количество = round(totalLines/4), min 1, max 4
      // Через centroid полигонов победителя (по убыванию площади)
      // Толщина убывает: первая (наибольший полигон) — толще всего
      const lineCount = Math.min(Math.max(1, Math.round(totalLines / 4)), 4);
      const diagLines = [];
      for (let k = 0; k < lineCount; k++) {
        const c = winnerPolys[k]
          ? centroid(winnerPolys[k].path)
          : { x: W * (0.3 + k * 0.15), y: H * (0.4 + k * 0.1) };
        diagLines.push({ ax: c.x, ay: c.y, thickness: 4 + (lineCount - 1 - k) * 3 });
      }

      // ── Прямоугольники ───────────────────────────────────────────────────────
      // Один на каждый полигон победителя (максимум 5)
      // Центр = centroid полигона, ширина = sqrt(area)*0.8, высота = ширина*0.22
      const rects = winnerPolys.slice(0, 5).map(({ path, area }, k) => {
        const c = centroid(path);
        const w = Math.sqrt(area) * 0.8;
        return {
          cx: c.x, cy: c.y, w, h: w * 0.22,
          color: k === 0 ? mainColor : (k % 2 === 1 ? darkColor : mainColor),
        };
      });

      // ── Маленькие золотые точки ──────────────────────────────────────────────
      // Количество = loseScore + 1, min 1, max 5
      // Позиции: centroid полигонов проигравшего, затем точки с max degree победителя
      const dotCount = Math.min(Math.max(1, loseScore + 1), 5);
      const dotR = Math.min(W, H) * 0.012;
      const dots = [];
      for (let k = 0; k < Math.min(loseScore, dotCount); k++) {
        if (loserPolys[k]) {
          const c = centroid(loserPolys[k].path);
          dots.push({ x: c.x, y: c.y, r: dotR });
        }
      }
      if (dots.length < dotCount) {
        const byDeg = points
          .map((p, i) => ({ p, d: degree[i] }))
          .filter(({ d }) => d > 0)
          .sort((a, b) => b.d - a.d);
        for (let k = 0; dots.length < dotCount && k < byDeg.length; k++) {
          dots.push({ x: byDeg[k].p.x, y: byDeg[k].p.y, r: dotR });
        }
        const fallbacks = [
          { x: W*0.2, y: H*0.2 }, { x: W*0.8, y: H*0.8 },
          { x: W*0.5, y: H*0.5 }, { x: W*0.3, y: H*0.7 }, { x: W*0.7, y: H*0.3 },
        ];
        for (let k = 0; dots.length < dotCount; k++) {
          dots.push({ x: fallbacks[k].x, y: fallbacks[k].y, r: dotR });
        }
      }

      // ── Штриховой блок ───────────────────────────────────────────────────────
      // В углу, противоположном главному кругу
      const hatchX = mainCx < W / 2 ? W * 0.82 : W * 0.18;
      const hatchY = H * 0.12;
      const hatchCount = Math.min(Math.max(3, 3 + scoreDiff), 9);

      // ── Сетка ────────────────────────────────────────────────────────────────
      // Видима только при близкой игре (scoreDiff <= 2), скрыта при разгроме (>= 5)
      const showGrid = scoreDiff <= 2;

      return {
        ANGLE, DIAG, mainColor, darkColor, creamColor, goldColor,
        mainCx, mainCy, mainR, ringCount,
        secondCircle, diagLines, rects, dots,
        hatchX, hatchY, hatchCount, showGrid, degree,
      };
    }

    /**
     * Рендер экрана победы для темы "suprematist".
     * Только рендеринг из _supLayout — без вычислений и Math.random().
     */
    function drawVictorySuprematist(ctx, W, H) {
      if (!_supLayout) return;
      const {
        ANGLE, DIAG, mainColor, darkColor, creamColor, goldColor,
        mainCx, mainCy, mainR, ringCount,
        secondCircle, diagLines, rects, dots,
        hatchX, hatchY, hatchCount, showGrid, degree,
      } = _supLayout;

      // ── Слой 1: кремовый фон ────────────────────────────────────────────────
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = creamColor;
      ctx.fillRect(0, 0, W, H);

      // ── Слой 2: фоновая решётка (только при близкой игре) ───────────────────
      if (showGrid) {
        ctx.save();
        ctx.globalAlpha = 0.10;
        ctx.strokeStyle = '#1A1A1A';
        ctx.lineWidth = 1;
        points.forEach((p, i) => {
          if (degree[i] < 3) return;
          ctx.beginPath(); ctx.moveTo(0, p.y); ctx.lineTo(W, p.y); ctx.stroke();
          ctx.beginPath(); ctx.moveTo(p.x, 0); ctx.lineTo(p.x, H); ctx.stroke();
        });
        ctx.restore();
      }

      // ── Слой 3: прямоугольники — по одному на полигон победителя ────────────
      rects.forEach(({ cx, cy, w, h, color }) => {
        ctx.save();
        ctx.translate(cx, cy);
        ctx.rotate(ANGLE);
        ctx.fillStyle = color;
        ctx.fillRect(-w / 2, -h / 2, w, h);
        ctx.restore();
      });

      // ── Слой 4: штриховой угловой блок ──────────────────────────────────────
      {
        ctx.save();
        ctx.translate(hatchX, hatchY);
        ctx.rotate(ANGLE);
        ctx.strokeStyle = '#1A1A1A';
        ctx.lineWidth = 2.5;
        ctx.globalAlpha = 0.50;
        const GAP = 11, LEN = 210;
        for (let k = 0; k < hatchCount; k++) {
          const off = (k - (hatchCount - 1) / 2) * GAP;
          ctx.beginPath();
          ctx.moveTo(-LEN / 2, off);
          ctx.lineTo( LEN / 2, off);
          ctx.stroke();
        }
        ctx.restore();
      }

      // ── Слой 5: диагональные линии через centroid полигонов победителя ───────
      diagLines.forEach(({ ax, ay, thickness }) => {
        ctx.save();
        ctx.translate(ax, ay);
        ctx.rotate(ANGLE);
        ctx.strokeStyle = '#1A1A1A';
        ctx.lineWidth = thickness;
        ctx.beginPath(); ctx.moveTo(-DIAG, 0); ctx.lineTo(DIAG, 0); ctx.stroke();
        ctx.restore();
      });

      // ── Слой 6: главный круг — число колец отражает winScore ────────────────
      {
        for (let k = 0; k < ringCount; k++) {
          const frac = 1 - (k / ringCount) * 0.88;
          const color = k === ringCount - 1 ? darkColor : (k % 2 === 0 ? mainColor : creamColor);
          ctx.beginPath();
          ctx.arc(mainCx, mainCy, mainR * frac, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.fill();
        }
        // Центральная метка
        ctx.beginPath();
        ctx.arc(mainCx, mainCy, mainR * 0.07, 0, Math.PI * 2);
        ctx.fillStyle = creamColor;
        ctx.fill();
      }

      // ── Слой 7: второй круг (проигравший) — размер зависит от loseScore ──────
      if (secondCircle) {
        const { cx, cy, r2 } = secondCircle;
        const d = Math.hypot(cx - mainCx, cy - mainCy);
        if (d > Math.abs(mainR - r2)) { // не поглощён главным кругом
          const rings2  = [r2, r2 * 0.60];
          const colors2 = [darkColor, goldColor];
          for (let k = 0; k < rings2.length; k++) {
            ctx.beginPath();
            ctx.arc(cx, cy, rings2[k], 0, Math.PI * 2);
            ctx.fillStyle = colors2[k];
            ctx.fill();
          }
          ctx.beginPath();
          ctx.arc(cx, cy, r2 * 0.08, 0, Math.PI * 2);
          ctx.fillStyle = creamColor;
          ctx.fill();
        }
      }

      // ── Слой 8: золотые точки — позиции из данных проигравшего ──────────────
      ctx.fillStyle = goldColor;
      dots.forEach(({ x, y, r }) => {
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
      });

      // ── Шум: 4 слоя поверх композиции (эстетика супрематизма) ────────────────
      ctx.save();

      // Слой шума 1: мелкое зерно — плёнка
      for (let i = 0; i < 60000; i++) {
        const x = Math.random() * W;
        const y = Math.random() * H;
        if (Math.random() < 0.55) {
          ctx.fillStyle = `rgba(0,0,0,${(Math.random() * 0.08).toFixed(4)})`;
        } else {
          ctx.fillStyle = `rgba(255,255,255,${(Math.random() * 0.06).toFixed(4)})`;
        }
        ctx.fillRect(x, y, 1, 1);
      }

      // Слой шума 2: средние пятна — старая бумага / ризограф
      for (let i = 0; i < 800; i++) {
        ctx.fillStyle = `rgba(0,0,0,${(Math.random() * 0.12).toFixed(4)})`;
        ctx.fillRect(Math.random() * W, Math.random() * H, 2, 2);
      }

      // Слой шума 3: крупные точки — типографский растр, кластер вокруг элементов
      // Возможные якоря: главный круг, прямоугольники, золотые точки
      const anchors = [
        { x: mainCx, y: mainCy },
        ...rects.map(rc => ({ x: rc.cx, y: rc.cy })),
        ...dots.map(d => ({ x: d.x, y: d.y })),
      ];
      for (let i = 0; i < 150; i++) {
        let x, y;
        if (anchors.length > 0 && Math.random() < 0.7) {
          const a = anchors[Math.floor(Math.random() * anchors.length)];
          x = a.x + (Math.random() - 0.5) * 160;
          y = a.y + (Math.random() - 0.5) * 160;
        } else {
          x = Math.random() * W;
          y = Math.random() * H;
        }
        const pw = 3 + Math.random() * 3;
        const ph = 3 + Math.random() * 3;
        ctx.fillStyle = `rgba(0,0,0,${(Math.random() * 0.18).toFixed(4)})`;
        ctx.fillRect(x, y, pw, ph);
      }

      // Слой шума 4: горизонтальные полосы — старый печатный станок
      const stripeCount = 6 + Math.floor(Math.random() * 5);
      for (let i = 0; i < stripeCount; i++) {
        const sy = Math.random() * H;
        const sh = 1 + Math.random() * 2;
        ctx.fillStyle = `rgba(0,0,0,${(Math.random() * 0.05).toFixed(4)})`;
        ctx.fillRect(0, sy, W, sh);
      }

      ctx.restore();
    }

    // (виньетка перенесена в #vignette-overlay — глобальный CSS-оверлей)

    /**
     * Рендер экрана победы для режима 2 игроков (не AI).
     * Делит canvas пополам вертикально: левый сектор — победитель, правый — проигравший.
     * При ничье (winner === -1): левый = player 0, правый = player 1, нейтральные подписи.
     * Каждый сектор рисует свои: фон, захваченные области, линии, точки (через clip).
     * Текст имён и статусов рисуется непосредственно на canvas (не HTML).
     * @param {CanvasRenderingContext2D} ctx
     * @param {number} W — ширина canvas
     * @param {number} H — высота canvas
     */
    function drawVictoryDuel(ctx, W, H) {
      const leftPlayer  = winner >= 0 ? winner   : 0;
      const rightPlayer = winner >= 0 ? 1-winner : 1;

      // Вычисляет массив степеней точек по линиям конкретного игрока
      function degreeOf(pl) {
        const d = new Array(COUNT).fill(0);
        lines.forEach((player, key) => {
          if (player !== pl) return;
          const [a, b] = key.split('-').map(Number);
          d[a]++; d[b]++;
        });
        return d;
      }

      const degL = degreeOf(leftPlayer);
      const degR = degreeOf(rightPlayer);

      /**
       * Вычисляет трансформацию точек игрока в пространство DW×DH.
       * Масштабирует bounding-box активных точек с отступом PAD.
       */
      function makeTransform(deg) {
        const PAD = 90;
        const active = points.filter((_, i) => deg[i] > 0);
        if (active.length === 0) return { tx: p => p.x, ty: p => p.y, scale: 1 };
        const minX = Math.min(...active.map(p => p.x));
        const maxX = Math.max(...active.map(p => p.x));
        const minY = Math.min(...active.map(p => p.y));
        const maxY = Math.max(...active.map(p => p.y));
        const srcW = (maxX - minX) || 1;
        const srcH = (maxY - minY) || 1;
        const scale = Math.min((DW - PAD*2) / srcW, (DH - PAD*2) / srcH);
        const offX = PAD + ((DW - PAD*2) - srcW * scale) / 2;
        const offY = PAD + ((DH - PAD*2) - srcH * scale) / 2;
        return {
          tx: p => (p.x - minX) * scale + offX,
          ty: p => (p.y - minY) * scale + offY,
          scale,
        };
      }

      const tfL = makeTransform(degL);
      const tfR = makeTransform(degR);

      /**
       * Рисует созвездие одного игрока на переданный контекст c.
       * Рендер зависит от activeTheme: stargazer — звёзды, minimal — S-кривые,
       * suprematist — базовые слои + виниловый круг, остальные — T().dots/lines.
       */
      function drawConstellation(c, player, deg, tf) {
        c.clearRect(0, 0, DW, DH);
        c.fillStyle = T().background;
        c.fillRect(0, 0, DW, DH);

        if (activeTheme === 'stargazer') {
          // ── Stargazer: светящиеся линии + звёзды ──────────────────────────
          c.lineCap = 'round';
          lines.forEach((pl, key) => {
            if (pl !== player) return;
            const [a, b] = key.split('-').map(Number);
            const ax = tf.tx(points[a]), ay = tf.ty(points[a]);
            const bx = tf.tx(points[b]), by = tf.ty(points[b]);
            c.save();
            c.lineCap = 'round';
            c.shadowBlur  = 3;
            c.shadowColor = 'rgba(248,247,245,0.90)';
            c.beginPath(); c.moveTo(ax, ay); c.lineTo(bx, by);
            c.strokeStyle = 'rgba(248,247,245,0.88)'; c.lineWidth = 1.4; c.stroke();
            c.restore();
          });
          points.forEach((p, i) => {
            const d = deg[i];
            if (d === 0) return;
            const twinkle = getTwinkleBoost(i);
            drawStarPointTo(c, tf.tx(p), tf.ty(p), Math.max(d, 2), false, false, false, 0.7 + twinkle * 0.9);
          });

        } else if (activeTheme === 'minimal') {
          // ── Minimal: S-кривые + увеличенные узлы (аналог drawVictoryMinimal) ─
          const sc = tf.scale;
          c.strokeStyle = '#000000';
          c.lineWidth   = 1.5 * sc;
          c.globalAlpha = 0.55;
          lines.forEach((pl, key) => {
            if (pl !== player) return;
            const [a, b] = key.split('-').map(Number);
            const x1 = tf.tx(points[a]), y1 = tf.ty(points[a]);
            const x2 = tf.tx(points[b]), y2 = tf.ty(points[b]);
            const dx = x2 - x1, dy = y2 - y1;
            const len = Math.hypot(dx, dy);
            if (len === 0) return;
            const nx = -dy / len, ny = dx / len;
            const off = len * 0.25;
            c.beginPath();
            c.moveTo(x1, y1);
            c.bezierCurveTo(x1+dx/3+nx*off, y1+dy/3+ny*off,
                            x1+2*dx/3-nx*off, y1+2*dy/3-ny*off,
                            x2, y2);
            c.stroke();
          });
          c.globalAlpha = 1;
          const BASE_R = RADIUS * 4 * sc;
          points.forEach((p, i) => {
            const d = deg[i];
            if (d === 0) return;
            const r = BASE_R * Math.pow(1.4, d);
            const px = tf.tx(p), py = tf.ty(p);
            c.beginPath(); c.arc(px, py, r, 0, Math.PI * 2);
            if (d === 1) {
              c.strokeStyle = '#000000'; c.lineWidth = 1.5 * sc; c.stroke();
            } else if (d === 2) {
              c.fillStyle = '#ffffff'; c.fill();
              c.strokeStyle = '#000000'; c.lineWidth = 2 * sc; c.stroke();
            } else {
              c.fillStyle = '#ffffff'; c.fill();
              c.strokeStyle = '#000000'; c.lineWidth = 2.5 * sc; c.stroke();
              c.beginPath(); c.arc(px, py, r * 0.18, 0, Math.PI * 2);
              c.fillStyle = '#000000'; c.fill();
            }
          });

        } else {
          // ── Suprematist / Chalk / Default: полигоны + линии + точки ─────────
          polygons.forEach(({ path, player: pl }, polyIdx) => {
            if (pl !== player) return;
            const poly = path.map(i => points[i]);
            c.beginPath();
            c.moveTo(tf.tx(poly[0]), tf.ty(poly[0]));
            for (let k = 1; k < poly.length; k++) c.lineTo(tf.tx(poly[k]), tf.ty(poly[k]));
            c.closePath();
            if (activeTheme === 'chalk') {
              c.globalAlpha = 0.28;
              c.fillStyle = CHALK_FILL[polyIdx % CHALK_FILL.length];
              c.fill();
              c.globalAlpha = 1;
            } else {
              c.fillStyle = T().captured; c.fill();
            }
          });
          lines.forEach((pl, key) => {
            if (pl !== player) return;
            const [a, b] = key.split('-').map(Number);
            const ax = tf.tx(points[a]), ay = tf.ty(points[a]);
            const bx = tf.tx(points[b]), by = tf.ty(points[b]);
            c.beginPath(); c.moveTo(ax, ay); c.lineTo(bx, by);
            c.strokeStyle = T().lines; c.lineWidth = 2; c.stroke();
          });
          points.forEach((p, i) => {
            const d = deg[i];
            if (d === 0) return;
            const px = tf.tx(p), py = tf.ty(p);
            if (activeTheme === 'chalk') {
              drawChalkSpiral(c, px, py, 24, CHALK_RAINBOW[i % CHALK_RAINBOW.length], d);
            } else {
              const r = d >= 3 ? RADIUS*2 : d === 2 ? RADIUS*1.5 : RADIUS;
              c.beginPath(); c.arc(px, py, r, 0, Math.PI * 2);
              c.fillStyle = T().dots; c.fill();
            }
          });
          // ── Suprematist: виниловый круг по centroid активных точек игрока ──
          if (activeTheme === 'suprematist') {
            const creamColor = '#F5F0E8';
            const mainColor  = player === 0 ? '#CC2200' : '#1A1A1A';
            const darkColor  = player === 0 ? '#1A1A1A' : '#CC2200';
            const activeObjs = points.filter((_, i) => deg[i] > 0);
            if (activeObjs.length > 0) {
              const cx = activeObjs.reduce((s, p) => s + tf.tx(p), 0) / activeObjs.length;
              const cy = activeObjs.reduce((s, p) => s + tf.ty(p), 0) / activeObjs.length;
              const winScore   = polygons.filter(p => p.player === player).length;
              const loseScore  = polygons.filter(p => p.player !== player && p.player >= 0).length;
              const domination = winScore / Math.max(1, winScore + loseScore);
              const mainR      = Math.min(DW, DH) * (0.18 + domination * 0.22);
              const ringCount  = Math.min(3 + winScore, 7);
              for (let k = 0; k < ringCount; k++) {
                const frac  = 1 - (k / ringCount) * 0.88;
                const color = k === ringCount - 1 ? darkColor : (k % 2 === 0 ? mainColor : creamColor);
                c.beginPath(); c.arc(cx, cy, mainR * frac, 0, Math.PI * 2);
                c.fillStyle = color; c.fill();
              }
              c.beginPath(); c.arc(cx, cy, mainR * 0.07, 0, Math.PI * 2);
              c.fillStyle = creamColor; c.fill();
            }
          }
        }
      }

      // Рисуем каждое созвездие в свой canvas
      drawConstellation(ctxDL, leftPlayer,  degL, tfL);
      drawConstellation(ctxDR, rightPlayer, degR, tfR);
    }

    // ── Chalk theme ──────────────────────────────────────────────────────────────

    const CHALK_RAINBOW = ['#FF3B3B', '#FF8C00', '#FFD700', '#4CAF50', '#2196F3', '#9C27B0', '#FF69B4'];
    const CHALK_FILL    = ['#FF6B6B', '#FFD93D', '#6BCB77', '#4D96FF', '#FF6FC8', '#C77DFF', '#FF9A3C'];

    /**
     * Рисует кремовый фон с зернистостью бумаги.
     * Текстура генерируется один раз в offscreen canvas и кэшируется.
     */
    function drawChalkPaperBg(ctx, W, H) {
      if (!_chalkPaperCache || _chalkPaperCache.width !== W || _chalkPaperCache.height !== H) {
        const oc = document.createElement('canvas');
        oc.width = W; oc.height = H;
        const oc2 = oc.getContext('2d');
        oc2.fillStyle = '#F9F8F6';
        oc2.fillRect(0, 0, W, H);
        // Слой 1: мелкий шум — 25000 точек 1×1px
        for (let i = 0; i < 25000; i++) {
          oc2.fillStyle = `rgba(180,160,120,${(Math.random() * 0.06).toFixed(3)})`;
          oc2.fillRect(Math.random() * W, Math.random() * H, 1, 1);
        }
        // Слой 2: крупнее — 3000 точек 2×2px
        for (let i = 0; i < 3000; i++) {
          oc2.fillStyle = `rgba(160,140,120,${(Math.random() * 0.04).toFixed(3)})`;
          oc2.fillRect(Math.random() * W, Math.random() * H, 2, 2);
        }
        // Слой 3: редкие волокна бумаги — горизонтальные штрихи ±15°
        oc2.strokeStyle = 'rgba(180,170,155,0.06)';
        oc2.lineWidth = 0.5;
        for (let i = 0; i < 200; i++) {
          const x = Math.random() * W;
          const y = Math.random() * H;
          const len = 15 + Math.random() * 25;
          const angle = (Math.random() - 0.5) * (Math.PI / 6);
          oc2.beginPath();
          oc2.moveTo(x, y);
          oc2.lineTo(x + Math.cos(angle) * len, y + Math.sin(angle) * len);
          oc2.stroke();
        }
        _chalkPaperCache = oc;
      }
      ctx.drawImage(_chalkPaperCache, 0, 0);
    }

    /**
     * Рисует точку в стиле мелка: 5 арок с детерминированным дрожанием по позиции,
     * белый блик и едва заметный контур.
     */
    function drawChalkSpiral(ctx, cx, cy, maxR, color, degree) {
      const seed = (cx * 0.37 + cy * 0.19) % 1;
      const minTurns = 1.2;
      const maxTurns = 4.5;
      const maxDegree = 6;
      const turns = Math.min(maxTurns,
        minTurns + ((degree || 0) / maxDegree) * (maxTurns - minTurns));
      const r = maxR * (1 + (degree || 0) * 0.08);
      const steps = Math.round(40 + turns * 18);

      ctx.save();
      ctx.strokeStyle = color;
      ctx.lineWidth = 2.0;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.globalAlpha = 0.88;

      // Собираем точки спирали
      const pts = [];
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        const angle = t * turns * Math.PI * 2;

        // Органическое дыхание радиуса — медленные синусоиды, не на каждом шаге
        const breathe = Math.sin(t * 2.1 + seed * 6.28) * 0.14;
        const drift   = Math.sin(t * 0.8 + seed * 3.14) * 0.07;
        const curR = t * r * (1 + breathe + drift);

        // Центр спирали чуть плавает (не прыгает — именно плавает)
        const driftX = Math.sin(t * 1.3 + seed * 5.1) * r * 0.06;
        const driftY = Math.cos(t * 1.1 + seed * 4.3) * r * 0.06;

        pts.push({
          x: cx + driftX + curR * Math.cos(angle),
          y: cy + driftY + curR * Math.sin(angle),
        });
      }

      // Рисуем через quadraticCurveTo — плавные кривые, не прямые отрезки
      ctx.beginPath();
      ctx.moveTo(pts[0].x, pts[0].y);
      for (let i = 1; i < pts.length - 1; i++) {
        const mx = (pts[i].x + pts[i + 1].x) / 2;
        const my = (pts[i].y + pts[i + 1].y) / 2;
        ctx.quadraticCurveTo(pts[i].x, pts[i].y, mx, my);
      }
      const last = pts[pts.length - 1];
      ctx.lineTo(last.x, last.y);
      ctx.stroke();

      // Маленькая точка в центре
      ctx.beginPath();
      ctx.arc(cx, cy, 1.8, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.globalAlpha = 0.7;
      ctx.fill();

      ctx.restore();
    }

    /**
     * Рисует линию в стиле мелка: сегментированный путь с детерминированным дрожанием.
     */
    function drawChalkLine(ctx, x1, y1, x2, y2, color) {
      const SEGS = 9;
      const dx = x2 - x1, dy = y2 - y1;
      const seed = Math.abs(Math.sin(x1 * y2 * 0.017 + y1 * x2 * 0.013)) % 1;
      const pts = [[x1, y1]];
      for (let k = 1; k < SEGS; k++) {
        const t = k / SEGS;
        const j = 2.2 * 0.6;
        pts.push([
          x1 + dx * t + Math.sin(seed * 31.4 + k * 17.1) * j,
          y1 + dy * t + Math.cos(seed * 11.7 + k * 23.9) * j,
        ]);
      }
      pts.push([x2, y2]);
      ctx.save();
      ctx.lineCap = 'round'; ctx.lineJoin = 'round';
      ctx.beginPath();
      ctx.moveTo(pts[0][0], pts[0][1]);
      for (let k = 1; k < pts.length; k++) ctx.lineTo(pts[k][0], pts[k][1]);
      ctx.strokeStyle = color;
      ctx.globalAlpha = 0.9;
      ctx.lineWidth   = 2.2;
      ctx.shadowBlur  = 0;
      ctx.shadowColor = 'transparent';
      ctx.filter      = 'none';
      ctx.stroke();
      ctx.shadowBlur  = 0;
      ctx.shadowColor = 'transparent';
      ctx.filter      = 'none';
      ctx.restore();
    }

    /**
     * Экран победы в стиле детского рисунка мелком.
     * Элементы появляются поочерёдно через _chalkAnimProgress (0→1).
     * Группы: bg → loser polys → loser pts → winner polys → winner pts → decor → text.
     */
    function drawVictoryChalk(ctx, W, H) {
      const p  = _chalkAnimProgress;
      const N  = 7;
      const ga = k => Math.max(0, Math.min(1, (p - k / N) / 0.05));

      const wp = winner >= 0 ? winner   : 0;
      const lp = winner >= 0 ? 1-winner : 1;
      const wC = CHALK_RAINBOW[wp % CHALK_RAINBOW.length];
      const lC = CHALK_RAINBOW[lp % CHALK_RAINBOW.length];

      // Степени точек по игрокам
      const wDeg = new Array(COUNT).fill(0);
      const lDeg = new Array(COUNT).fill(0);
      lines.forEach((player, key) => {
        const [a, b] = key.split('-').map(Number);
        if (player === wp) { wDeg[a]++; wDeg[b]++; }
        else               { lDeg[a]++; lDeg[b]++; }
      });

      // ── 0: бумажный фон (всегда видим сразу) ────────────────────────────────
      ctx.globalAlpha = 1;
      drawChalkPaperBg(ctx, W, H);

      // ── 1: полигоны + линии проигравшего ────────────────────────────────────
      if (ga(1) > 0) {
        ctx.globalAlpha = ga(1) * 0.28;
        polygons.forEach(({ path, player: pl }, polyIdx) => {
          if (pl !== lp) return;
          const poly = path.map(i => points[i]);
          ctx.beginPath();
          ctx.moveTo(poly[0].x, poly[0].y);
          for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
          ctx.closePath(); ctx.fillStyle = CHALK_FILL[polyIdx % CHALK_FILL.length]; ctx.fill();
        });
        ctx.globalAlpha = ga(1);
        let vLLineIdx = 0;
        lines.forEach((player, key) => {
          if (player !== lp) return;
          const [a, b] = key.split('-').map(Number);
          drawChalkLine(ctx, points[a].x, points[a].y, points[b].x, points[b].y,
            CHALK_RAINBOW[vLLineIdx++ % CHALK_RAINBOW.length]);
        });
        ctx.globalAlpha = 1;
      }

      // ── 2: точки проигравшего ────────────────────────────────────────────────
      if (ga(2) > 0) {
        ctx.globalAlpha = ga(2);
        points.forEach((pt, i) => {
          if (lDeg[i] === 0) return;
          drawChalkSpiral(ctx, pt.x, pt.y, 24, CHALK_RAINBOW[i % CHALK_RAINBOW.length], lDeg[i]);
        });
        ctx.globalAlpha = 1;
      }

      // ── 3: полигоны + линии победителя ──────────────────────────────────────
      if (ga(3) > 0) {
        ctx.globalAlpha = ga(3) * 0.28;
        polygons.forEach(({ path, player: pl }, polyIdx) => {
          if (pl !== wp) return;
          const poly = path.map(i => points[i]);
          ctx.beginPath();
          ctx.moveTo(poly[0].x, poly[0].y);
          for (let k = 1; k < poly.length; k++) ctx.lineTo(poly[k].x, poly[k].y);
          ctx.closePath(); ctx.fillStyle = CHALK_FILL[polyIdx % CHALK_FILL.length]; ctx.fill();
        });
        ctx.globalAlpha = ga(3);
        let vWLineIdx = 0;
        lines.forEach((player, key) => {
          if (player !== wp) return;
          const [a, b] = key.split('-').map(Number);
          drawChalkLine(ctx, points[a].x, points[a].y, points[b].x, points[b].y,
            CHALK_RAINBOW[vWLineIdx++ % CHALK_RAINBOW.length]);
        });
        ctx.globalAlpha = 1;
      }

      // ── 4: точки победителя ──────────────────────────────────────────────────
      if (ga(4) > 0) {
        ctx.globalAlpha = ga(4);
        points.forEach((pt, i) => {
          if (wDeg[i] === 0) return;
          drawChalkSpiral(ctx, pt.x, pt.y, 24, CHALK_RAINBOW[i % CHALK_RAINBOW.length], wDeg[i]);
        });
        ctx.globalAlpha = 1;
      }

      // ── 5: декор вокруг точек победителя ────────────────────────────────────
      if (ga(5) > 0) {
        ctx.globalAlpha = ga(5);
        const wR = parseInt(wC.slice(1,3),16);
        const wG = parseInt(wC.slice(3,5),16);
        const wB = parseInt(wC.slice(5,7),16);
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillStyle = wC;
        points.forEach((pt, i) => {
          if (wDeg[i] < 2) return;
          // 3–5 звёздочек вокруг точки
          const nStars = 3 + (i % 3);
          for (let s = 0; s < nStars; s++) {
            const ang  = (s / nStars) * Math.PI * 2 + i * 0.7;
            const dist = 15 + Math.abs(Math.sin(i * 5.3 + s * 2.1)) * 8;
            const sz   = 10 + Math.abs(Math.sin(i * 3.7 + s)) * 4;
            ctx.font = `${Math.round(sz)}px serif`;
            ctx.fillStyle = wC;
            ctx.fillText('✦', pt.x + Math.cos(ang) * dist, pt.y + Math.sin(ang) * dist);
          }
          // 2 маленьких кружка
          for (let c = 0; c < 2; c++) {
            const ang2  = i * 1.3 + c * 2.7 + Math.PI;
            const dist2 = 22 + Math.abs(Math.sin(i * 7.1 + c)) * 5;
            const cr    = 2 + Math.abs(Math.sin(i * 4.3 + c * 2.5)) * 2;
            ctx.beginPath();
            ctx.arc(pt.x + Math.cos(ang2) * dist2, pt.y + Math.sin(ang2) * dist2, cr, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${wR},${wG},${wB},0.5)`;
            ctx.fill();
          }
        });
        ctx.globalAlpha = 1;
      }

      // ── 6: текст (счёт + нарратив) на холсте ────────────────────────────────
      if (ga(6) > 0) {
        ctx.globalAlpha = ga(6);
        ctx.shadowColor = 'rgba(0,0,0,0.2)'; ctx.shadowBlur = 3;
        ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.font = 'bold 52px Raleway, sans-serif';
        ctx.fillStyle = CHALK_RAINBOW[wp % CHALK_RAINBOW.length];
        ctx.fillText(`${scores[wp]} : ${scores[lp]}`, W / 2, H * 0.06);
        ctx.font = '300 28px Raleway, sans-serif';
        ctx.fillStyle = 'rgba(80,60,40,0.8)';
        const msg = winner >= 0
          ? `${playerNames[wp] || (t('player_default') + ' ' + (wp + 1))} ${t('duel_won')}`
          : t('turn_draw') + '!';
        ctx.fillText(msg, W / 2, H * 0.15);
        ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;
      }
    }

    // ── Film grain overlay (all themes) ──────────────────────────────────────

    /** Генерирует/обновляет offscreen 256×256 canvas с плёночным зерном. */
    function regenerateGrain() {
      if (!_grainCanvas) {
        _grainCanvas = document.createElement('canvas');
        _grainCanvas.width = 256;
        _grainCanvas.height = 256;
      }
      const gc = _grainCanvas.getContext('2d');
      gc.clearRect(0, 0, 256, 256);
      const count = Math.round(256 * 256 * 0.2);
      for (let i = 0; i < count; i++) {
        const x = Math.random() * 256;
        const y = Math.random() * 256;
        const alpha = Math.random() * 0.022;
        gc.fillStyle = `rgba(255,255,255,${alpha.toFixed(4)})`;
        gc.fillRect(x, y, 1, 1);
      }
    }

    /**
     * Рисует тайлингом плёночный шум поверх текущего canvas.
     * Вызывается в конце draw() каждые 3 кадра — зерно «движется».
     */
    function drawGrainOverlay(ctx, W, H) {
      if (!_grainCanvas) regenerateGrain();
      ctx.save();
      ctx.globalCompositeOperation = 'screen';
      for (let x = 0; x < W; x += 256) {
        for (let y = 0; y < H; y += 256) {
          ctx.drawImage(_grainCanvas, x, y);
        }
      }
      ctx.globalCompositeOperation = 'source-over';
      ctx.restore();
    }

    /** Запускает анимацию chalk-экрана победы. */
    function startChalkAnim() {
      if (_chalkAnimRaf) return;
      _chalkAnimProgress = 0;
      function loop() {
        if (!gameOver || activeTheme !== 'chalk') { _chalkAnimRaf = null; return; }
        _chalkAnimProgress = Math.min(_chalkAnimProgress + 0.018, 1);
        draw();
        if (_chalkAnimProgress < 1) _chalkAnimRaf = requestAnimationFrame(loop);
        else _chalkAnimRaf = null;
      }
      _chalkAnimRaf = requestAnimationFrame(loop);
    }

