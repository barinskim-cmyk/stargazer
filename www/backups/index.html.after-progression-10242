    // «Сохранить в небо ✦» — анимация + фактическое сохранение
    // Вспомогательная: рисует звезду-точку на overlay
    function _drawSkyStar(ctx, x, y, alpha, r, withGlow, starRGB) {
      if (alpha <= 0) return;
      const sr = starRGB || '255,245,210';
      ctx.save();
      ctx.globalAlpha = alpha;
      if (withGlow) {
        const g = ctx.createRadialGradient(x, y, 0, x, y, r * 7);
        g.addColorStop(0,    `rgba(${sr},0.95)`);
        g.addColorStop(0.25, `rgba(${sr},0.35)`);
        g.addColorStop(1,    `rgba(${sr},0)`);
        ctx.beginPath(); ctx.arc(x, y, r * 7, 0, Math.PI * 2);
        ctx.fillStyle = g; ctx.fill();
      }
      ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${sr},1.0)`;
      ctx.fill();
      ctx.restore();
    }

    /**
     * saveToSkyAnimation — анимация сохранения созвездия:
     *   созвездие плавно сжимается сверху → становится точкой на небе →
     *   точка подмигивает → "Созвездие сохранено ✦" → затемнение → onDone()
     */
    function saveToSkyAnimation(constName, onDone) {
      const dpr = window.devicePixelRatio || 1;

      // ── Reuse the pre-existing overlay canvas (never add/remove DOM nodes) ──
      // Adding/removing a canvas with ov.width = VW*dpr can trigger iOS WKWebView
      // layout recalculation and cause the viewport-stretch bug.
      // Instead we show/hide a static canvas that lives permanently in the DOM.
      const ov = document.getElementById('sky-anim-overlay');
      // Measure from document (body is position:fixed so clientWidth = viewport)
      const VW = document.documentElement.clientWidth  || window.innerWidth;
      const VH = document.documentElement.clientHeight || window.innerHeight;
      // Set explicit CSS pixel size to prevent iOS from using canvas bitmap size for layout
      ov.style.width  = VW + 'px';
      ov.style.height = VH + 'px';
      ov.width  = Math.round(VW * dpr);
      ov.height = Math.round(VH * dpr);
      ov.style.display = 'block';
      const oc = ov.getContext('2d');
      oc.setTransform(1, 0, 0, 1, 0, 0); // reset any previous transform
      oc.scale(dpr, dpr);

      // ── Цвета из активной темы ──────────────────────────────────────────────
      const _at = THEMES[activeTheme] || THEMES.stargazer;
      const _aBg      = _at.skyBg      || '#060612';
      const _aStarRGB = _at.skyStarRGB || '255,245,210';
      // Тёплый янтарный ореол только для тёмной (stargazer) темы; остальные — цвет звезды
      const _aHaloRGB = _at.skyBgStar  ? '255,200,120' : _aStarRGB;
      const _aLabel   = _at.skyLabelHL || 'rgba(255,248,235,1)';
      const _aHasBgStars = !!_at.skyBgStar;
      // ───────────────────────────────────────────────────────────────────────

      // Снапшот игрового созвездия в экранных координатах
      const rect   = canvas.getBoundingClientRect();
      const scaleX = rect.width  / W;
      const scaleY = rect.height / H;
      const snapPts = points.map(p => ({
        sx: rect.left + p.x * scaleX,
        sy: rect.top  + p.y * scaleY
      }));
      const snapEdges = Array.from(lines.keys()).map(key => {
        const [a, b] = key.split('-').map(Number); return [a, b];
      });
      const startCX = snapPts.reduce((s, p) => s + p.sx, 0) / snapPts.length;
      const startCY = snapPts.reduce((s, p) => s + p.sy, 0) / snapPts.length;

      // Целевая позиция — центр экрана
      const skyS   = 0.22;
      const skyOX  = VW / 2 - _SKY_WORLD / 2 * skyS;
      const skyOY  = VH / 2 - _SKY_WORLD / 2 * skyS;
      const tX  = VW / 2;
      const tY  = VH / 2;

      _skyEnsureBg();

      // Рисует звезду как в игре, но уменьшенную в 3× (ореол + ядро, без спайков, без blur)
      function _drawAnimBgStar(c, sx, sy, r, alpha, mA) {
        const fa = alpha * mA;
        if (fa <= 0.003) return;
        const coreR = Math.max(0.5, r * 1.2);
        const haloR = Math.max(1.5, r * 6);
        // Ореол — тема: тёплый янтарь для stargazer, цвет звезды для остальных
        const hg = c.createRadialGradient(sx, sy, 0, sx, sy, haloR);
        hg.addColorStop(0,    `rgba(${_aHaloRGB},${Math.min(0.72, fa * 0.55).toFixed(3)})`);
        hg.addColorStop(0.28, `rgba(${_aHaloRGB},${(fa * 0.14).toFixed(3)})`);
        hg.addColorStop(1,    `rgba(${_aHaloRGB},0)`);
        c.fillStyle = hg;
        c.beginPath(); c.arc(sx, sy, haloR, 0, Math.PI * 2); c.fill();
        // Ядро — цвет звезды из темы
        const cg = c.createRadialGradient(sx, sy, 0, sx, sy, coreR);
        cg.addColorStop(0,    `rgba(${_aStarRGB},${Math.min(0.95, fa * 0.95).toFixed(3)})`);
        cg.addColorStop(0.35, `rgba(${_aStarRGB},${(fa * 0.55).toFixed(3)})`);
        cg.addColorStop(0.75, `rgba(${_aStarRGB},${(fa * 0.12).toFixed(3)})`);
        cg.addColorStop(1,    `rgba(${_aStarRGB},0)`);
        c.fillStyle = cg;
        c.beginPath(); c.arc(sx, sy, coreR, 0, Math.PI * 2); c.fill();
      }

      // Тайминги (мс)
      const T_SKY    = 400;   // небо появляется
      const T_SHRINK = 1600;  // созвездие летит и сжимается
      const T_BLINK  = 1000;  // точка подмигивает
      const T_TEXT   = 400;   // текст появляется
      const T_HOLD   = 1000;  // текст держится
      const T_FADE   = 600;   // всё гаснет
      const TOTAL    = T_SHRINK + T_BLINK + T_TEXT + T_HOLD + T_FADE;

      const startT = performance.now();
      function eio(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

      function frame() {
        const elapsed = performance.now() - startT;
        const done    = elapsed >= TOTAL;

        oc.clearRect(0, 0, VW, VH);

        // Мастер-прозрачность: угасание в конце
        const fadeStart = T_SHRINK + T_BLINK + T_TEXT + T_HOLD;
        const masterA   = elapsed >= fadeStart
          ? Math.max(0, 1 - (elapsed - fadeStart) / T_FADE) : 1;

        // ── Фон: цвет из темы ──
        const bgA = Math.min(1, elapsed / T_SKY) * masterA;
        oc.globalAlpha = bgA;
        oc.fillStyle = _aBg;
        oc.fillRect(0, 0, VW, VH);

        oc.globalAlpha = 1;
        // Фоновые звёзды — только для тёмных тем (skyBgStar = true)
        if (_aHasBgStars) {
          _bgStars.forEach(s => {
            const sx = s.x * skyS + skyOX;
            const sy = s.y * skyS + skyOY;
            if (sx < -10 || sx > VW + 10 || sy < -10 || sy > VH + 10) return;
            // Радиус — 1/3 от игрового (игра: r*skyS*15, здесь r*skyS*5)
            const r = Math.max(0.4, s.r * skyS * 5);
            _drawAnimBgStar(oc, sx, sy, r, s.a, bgA);
          });
        }

        // ── Фаза 1: каждая звезда летит к центру по своей дуге ──
        if (elapsed < T_SHRINK) {
          const t = elapsed / T_SHRINK;
          function eoc(x) { return 1 - Math.pow(1 - x, 3); } // ease-out-cubic

          snapPts.forEach((p, i) => {
            // Небольшой стаггер: каждая звезда стартует чуть позже
            const stagger = snapPts.length > 1 ? 0.12 / snapPts.length : 0;
            const delay   = i * stagger;
            const tStar   = Math.max(0, Math.min(1, (t - delay) / (1 - delay)));
            const ease    = eoc(tStar);

            // Перпендикулярная дуга: величина и знак уникальны для каждой точки
            const dx    = tX - p.sx;
            const dy    = tY - p.sy;
            const ang   = Math.atan2(dy, dx);
            const perpX = -Math.sin(ang);
            const perpY =  Math.cos(ang);
            const sign  = (i % 2 === 0 ? 1 : -1);
            const arcH  = (10 + (i * 13) % 28); // 10–38px уникальный для звезды
            const arc   = sign * arcH * Math.sin(tStar * Math.PI); // 0 → пик → 0

            const px = p.sx + dx * ease + perpX * arc;
            const py = p.sy + dy * ease + perpY * arc;

            // Звезда гаснет и уменьшается по мере приближения
            const starA = Math.max(0, 1 - tStar * 1.15) * masterA;
            const coreR = Math.max(0.3, 4 * (1 - ease * 0.84));
            if (starA < 0.01) return;

            // Ореол — цвет из темы
            const haloR = coreR * 5.5;
            const hg = oc.createRadialGradient(px, py, 0, px, py, haloR);
            hg.addColorStop(0,    `rgba(${_aHaloRGB},${(starA * 0.48).toFixed(3)})`);
            hg.addColorStop(0.35, `rgba(${_aHaloRGB},${(starA * 0.10).toFixed(3)})`);
            hg.addColorStop(1,    `rgba(${_aHaloRGB},0)`);
            oc.fillStyle = hg;
            oc.beginPath(); oc.arc(px, py, haloR, 0, Math.PI * 2); oc.fill();

            // Ядро — цвет из темы
            const cg = oc.createRadialGradient(px, py, 0, px, py, coreR);
            cg.addColorStop(0,    `rgba(${_aStarRGB},${(starA * 0.95).toFixed(3)})`);
            cg.addColorStop(0.45, `rgba(${_aStarRGB},${(starA * 0.40).toFixed(3)})`);
            cg.addColorStop(1,    `rgba(${_aStarRGB},0)`);
            oc.fillStyle = cg;
            oc.beginPath(); oc.arc(px, py, coreR, 0, Math.PI * 2); oc.fill();
          });

          // Целевая точка появляется только в последние 40% фазы
          const tLate = Math.max(0, (t - 0.6) / 0.4);
          _drawSkyStar(oc, tX, tY, tLate * masterA, 2.5, tLate > 0.3, _aStarRGB);
        }

        // ── Фаза 2: точка мигает ──
        if (elapsed >= T_SHRINK && elapsed < T_SHRINK + T_BLINK) {
          const t     = (elapsed - T_SHRINK) / T_BLINK;
          const blink = 0.45 + 0.55 * Math.abs(Math.sin(t * Math.PI * 4));
          _drawSkyStar(oc, tX, tY, blink * masterA, 2.5, true, _aStarRGB);
        }

        // ── Фазы 3–4: звезда + текст + удержание ──
        if (elapsed >= T_SHRINK + T_BLINK) {
          _drawSkyStar(oc, tX, tY, masterA, 2.5, true, _aStarRGB);
          const textElapsed = elapsed - T_SHRINK - T_BLINK;
          const textA = Math.min(1, textElapsed / T_TEXT) * masterA;
          if (textA > 0.01) {
            oc.save();
            oc.globalAlpha = textA;
            oc.font = '500 15px "Raleway", sans-serif';
            oc.textAlign = 'center';
            oc.shadowColor = `rgba(${_aStarRGB},0.40)`;
            oc.shadowBlur  = 14;
            oc.fillStyle = _aLabel;
            oc.fillText(t('victory_saved'), tX, tY + 50);
            oc.restore();
          }
        }

        if (!done) requestAnimationFrame(frame);
        else {
          // Hide overlay (not remove — keeping in DOM avoids iOS WKWebView layout recalc)
          ov.style.display = 'none';
          ov.style.width = '';
          ov.style.height = '';
          try { window.scrollTo(0, 0); } catch(e) {}
          onDone();
        }
      }
      requestAnimationFrame(frame);
    }

