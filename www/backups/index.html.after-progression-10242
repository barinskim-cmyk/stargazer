<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <script>
    // Глобальные настройки — читаем сразу, до загрузки остального JS
    window._appSettings = Object.assign(
      { sound: true, vibration: true, starGlow: 'all' },
      (() => { try { return JSON.parse(localStorage.getItem('app_settings') || '{}'); } catch(e) { return {}; } })()
    );

    async function haptic(style = 'light') {
      if (!window._appSettings.vibration) return;
      try {
        if (window.Capacitor?.isNativePlatform()) {
          await Capacitor.Plugins.Haptics.impact({ style: style.toUpperCase() });
        }
      } catch(e) {}
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@100;200;300&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --th-bg:          #1a1a2e;
      --th-panel-bg:    #1a1a2e;
      --th-text:        #F8F7F5;
      --th-text2:       rgba(248,247,245,0.50);
      --th-btn-bg:      transparent;
      --th-btn-text:    rgba(255,245,210,0.95);
      --th-btn-border:  rgba(255,245,210,0.55);
      --th-accent:      #C0BDBA;
      --th-vignette:    0;
      --th-btn-glow:    rgba(255,245,210,0.18);
      --th-font:        'Raleway', sans-serif;
      --th-card-bg:     rgba(248,247,245,0.04);
      --th-card-border: rgba(248,247,245,0.09);
    }
    * { box-sizing: border-box; }
    html {
      width: 100%; height: 100%;
      overflow: hidden;
      overscroll-behavior: none;
    }
    body {
      margin: 0;
      /* Fix iOS 26 WKWebView content-inset shift: lock body to full viewport */
      position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      overscroll-behavior: none;
      background: var(--th-bg);
      font-family: var(--th-font, 'Raleway', sans-serif);
      color: var(--th-text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    canvas { cursor: pointer; display: block; touch-action: none; }

    /* ── start screen ── */
    #start {
      position: absolute; inset: 0; background: var(--th-bg); box-sizing: border-box;
      display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 28px;
      z-index: 10;
      padding-top: calc(env(safe-area-inset-top, 0px) + 72px);
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 24px);
      padding-left: calc(env(safe-area-inset-left, 0px) + 28px);
      padding-right: calc(env(safe-area-inset-right, 0px) + 28px);
    }
    #start h1 { font-size: 13px; font-weight: 200; letter-spacing: 10px; color: var(--th-text2); text-transform: uppercase; margin: 0 0 8px; }
    #title-scattered {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .tl {
      position: absolute;
      font-family: 'Raleway', sans-serif;
      font-weight: 100;
      color: rgba(248,247,245,0.07);
      line-height: 1;
      letter-spacing: -0.02em;
      user-select: none;
    }
    #start .fields { display: flex; flex-direction: column; gap: 12px; width: 260px; }
    #start input {
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      border-radius: 10px; padding: 10px 14px; font-size: 15px; color: var(--th-btn-text); outline: none; width: 100%;
      transition: box-shadow 0.15s;
    }
    #start input::placeholder { color: var(--th-text2); }
    #start input:focus { border-color: var(--th-accent); box-shadow: 0 0 16px 3px var(--th-btn-glow); }
    #start button {
      margin-top: 6px; padding: 10px; width: 100%;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      border-radius: 10px; color: var(--th-btn-text); font-size: 15px; cursor: pointer;
      transition: filter 0.15s, box-shadow 0.15s;
    }
    #start button:hover { filter: brightness(1.15); box-shadow: 0 0 16px 3px var(--th-btn-glow); }
    #start button:disabled { opacity: 0.35; cursor: default; }
    .start-step { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px; text-align: center; }
    .start-step p { margin: 0; font-size: 14px; color: var(--th-text2); letter-spacing: 1px; }
    .mode-btns { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .mode-btn {
      width: 200px; padding: 14px 10px; border-radius: 8px; cursor: pointer;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      color: var(--th-btn-text); font-size: 15px; text-align: center;
      transition: filter 0.15s, box-shadow 0.15s;
    }
    .mode-btn:hover { filter: brightness(1.15); box-shadow: 0 0 16px 3px var(--th-btn-glow); }
    .mode-btn .sub { display: block; font-size: 13px; font-weight: normal; margin-top: 6px; color: var(--th-text2); opacity: 1; }
    #game-mode-step .mode-btn { width: 200px; }
    #game-mode-step { display: flex; }
    #map-step, #name-step, #game-length-step { display: none; }
    .length-btns { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .length-btn {
      width: 200px; padding: 14px 10px; border-radius: 8px; cursor: pointer;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      color: var(--th-btn-text); font-size: 15px; text-align: center;
      transition: filter 0.15s, box-shadow 0.15s;
    }
    .length-btn:hover { filter: brightness(1.15); box-shadow: 0 0 16px 3px var(--th-btn-glow); }
    .length-btn .sub { display: block; font-size: 13px; font-weight: normal; margin-top: 6px; color: var(--th-text2); opacity: 1; }
    #p2level { font-size: 11px; color: var(--th-text2); margin-top: 3px; display: none; }
    #ai-level-stars { font-size: 11px; color: var(--th-accent); margin-top: 2px; letter-spacing: 1px; display: none; }
    #p1-rank-stars  { font-size: 11px; color: var(--th-accent); margin-top: 2px; letter-spacing: 1px; display: none; }
    .start-bottom { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .start-themes { display: flex; gap: 6px; }
    .hints-toggle {
      display: flex; align-items: center; gap: 7px;
      font-size: 12px; color: var(--th-text2); cursor: pointer; user-select: none;
    }
    .hints-toggle input[type=checkbox] { cursor: pointer; accent-color: var(--th-accent); width: 14px; height: 14px; }
    #hints-btn {
      background: none; border: 1px solid var(--th-btn-border); border-radius: 10px;
      min-width: 44px; min-height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 18px; line-height: 1;
      color: var(--th-text); opacity: 0.45; transition: opacity 0.15s, box-shadow 0.15s;
    }
    #hints-btn:hover { opacity: 0.8; }
    #hints-btn.active { opacity: 1; box-shadow: 0 0 8px 2px var(--th-btn-glow); }

    /* ── game layout ── */
    #game {
      display: none; position: absolute; inset: 0;
      background: var(--th-bg);
    }
    #top-panel {
      position: absolute; top: 0; left: 0; right: 0; z-index: 5;
      box-sizing: border-box;
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: stretch; gap: 12px;
      padding-top: calc(env(safe-area-inset-top, 0px) + 48px);
      padding-left: calc(env(safe-area-inset-left, 0px) + 20px);
      padding-right: calc(env(safe-area-inset-right, 0px) + 20px);
      padding-bottom: 10px;
      background: var(--th-panel-bg); border-bottom: 1px solid var(--th-btn-border);
    }
    /* ── back-to-menu button (top-left of top-panel) ── */
    .tp-left { display: flex; align-items: center; gap: 8px; }
    #p1-cell { align-self: stretch; }
    .tp-right { display: flex; align-items: center; justify-content: flex-end; gap: 10px; align-self: stretch; }
    #turn-display { text-align: center; }
    #back-to-menu-btn {
      min-width: 44px; min-height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--th-text2);
      font-size: 20px; cursor: pointer; padding: 0; flex-shrink: 0;
      opacity: 0.6; transition: opacity 0.15s;
    }
    #back-to-menu-btn:hover, #back-to-menu-btn:active { opacity: 1; }
    #prob-bar-wrap {
      position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
      background: rgba(16,15,13,0.55); overflow: hidden; display: none;
    }
    #prob-bar-wrap.active { display: block; }
    #prob-bar-fill {
      height: 100%; width: 50%;
      background: linear-gradient(90deg, #9A9895, #C0BDBA);
      transition: width 0.4s ease-out;
    }
    .player-cell { display: flex; flex-direction: column; min-width: 0; overflow: hidden; }
    .player-cell .p-name  { font-size: 14px; font-weight: bold; color: var(--th-text); line-height: 1.2; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
    .player-cell .p-score { font-size: 28px; font-weight: bold; color: var(--th-text); line-height: 1; margin-top: auto; }
    .player-cell .p-sub   { font-size: 12px; color: var(--th-text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
    #p2-cell { text-align: right; align-items: flex-end; min-width: 0; overflow: hidden; }
    #turn-display {
      font-size: 13px; padding: 6px 14px; text-align: center;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      border-radius: 10px; color: var(--th-text); white-space: nowrap;
      transition: box-shadow 0.15s;
    }
    #canvas-area {
      position: absolute; inset: 0;
      display: flex; overflow: hidden;
      justify-content: center; align-items: flex-start;
    }
    #c { display: block; max-width: 100%; transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: center center; }
    #error {
      position: absolute; bottom: calc(env(safe-area-inset-bottom, 0px) + 28px); left: 50%; transform: translateX(-50%);
      font-size: 14px; font-weight: bold;
      color: #D5D3D0; background: rgba(210,208,205,0.12);
      border: 1px solid rgba(210,208,205,0.35);
      padding: 5px 18px; border-radius: 10px;
      opacity: 0; transition: opacity 0.2s;
      pointer-events: none; white-space: nowrap; z-index: 5;
    }
    #win-flash {
      position: absolute; inset: 0; background: white;
      opacity: 0; pointer-events: none; z-index: 4;
    }
    #particle-canvas {
      position: absolute; inset: 0; pointer-events: none; z-index: 4;
      display: block;
    }
    #canvas-fade-overlay {
      position: absolute; inset: 0;
      background: rgba(0, 0, 0, 0.6);
      opacity: 0; pointer-events: none;
      transition: opacity 0.8s ease;
      z-index: 1;
    }
    #victory-content {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 10px; padding: 20px; color: var(--th-text);
      opacity: 0; pointer-events: none;
      transition: opacity 0.6s ease;
      z-index: 2;
    }
    #name-constellation {
      position: absolute;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 40px);
      left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 14px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.6s ease;
      z-index: 3; width: 280px;
    }
    #name-const-label { font-size: 16px; color: var(--th-text); text-align: center; }
    #name-const-input {
      width: 100%; padding: 10px 14px; border-radius: 8px; box-sizing: border-box;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      color: var(--th-text); font-size: 15px; outline: none;
    }
    #name-const-actions { display: flex; flex-direction: column; align-items: center; gap: 8px; width: 100%; }
    #name-const-actions button {
      width: 100%; padding: 12px 10px; border-radius: 8px; cursor: pointer;
      background: var(--th-btn-bg) !important;
      border: 1px solid var(--th-btn-border) !important;
      color: var(--th-btn-text) !important;
      font-size: 15px; text-align: center;
      transition: filter 0.15s;
    }
    #name-const-actions button:hover { filter: brightness(1.15) !important; }
    #name-const-guest {
      font-size: 12px; color: var(--th-text2);
      text-align: center; display: none;
    }
    #loss-content {
      position: absolute; inset: 0;
      display: none; flex-direction: column; align-items: center; justify-content: center;
      gap: 16px; color: var(--th-text);
    }
    #canvas-area.lost #loss-content { display: flex; }
    #loss-title { font-size: 28px; font-weight: bold; opacity: 0.7; }
    #loss-score-line { font-size: 44px; font-weight: bold; letter-spacing: 6px; }
    #loss-names-line { font-size: 13px; opacity: 0.45; letter-spacing: 0.5px; }
    #loss-actions { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    #loss-actions button {
      width: 200px; padding: 14px 10px; border-radius: 8px; cursor: pointer;
      background: var(--th-btn-bg) !important;
      border: 1px solid var(--th-btn-border) !important;
      color: var(--th-btn-text) !important;
      font-size: 15px; text-align: center;
      transition: filter 0.15s, box-shadow 0.15s;
    }
    #loss-actions button:hover { filter: brightness(1.15) !important; box-shadow: 0 0 16px 3px var(--th-btn-glow) !important; }
    /* Duel victory: два канваса бок о бок */
    #duel-wrap {
      display: none;
      flex-direction: row;
      gap: 12px;
      width: 100%;
      height: 100%;
      align-items: stretch;
      justify-content: center;
      padding: 12px;
      box-sizing: border-box;
    }
    #canvas-area.duel #duel-wrap { display: flex; }
    #canvas-area.duel > #c       { display: none; }
    .duel-panel {
      flex: 1;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 0;
    }
    .duel-panel canvas {
      width: 100%;
      height: auto;
      max-height: calc(100vh - 160px - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px));
      object-fit: contain;
      border-radius: 8px;
      display: block;
    }
    .duel-label {
      position: absolute;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
      left: calc(env(safe-area-inset-left, 0px) + 20px);
      right: calc(env(safe-area-inset-right, 0px) + 20px);
      pointer-events: none;
    }
    #duel-right .duel-label { text-align: right; }
    .duel-name {
      font-size: 15px;
      font-weight: bold;
      color: var(--th-text);
      opacity: 0.80;
    }
    .duel-sub {
      font-size: 13px;
      color: var(--th-text2);
      margin-top: 2px;
      opacity: 0.60;
    }
    #victory-title  { font-size: 28px; font-weight: bold; }
    #victory-sub    { font-size: 20px; color: var(--th-text2); }
    #victory-rating { font-size: 14px; color: var(--th-text2); min-height: 20px; }
    #victory-actions { position: absolute; bottom: calc(env(safe-area-inset-bottom, 0px) + 24px); right: calc(env(safe-area-inset-right, 0px) + 24px); display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
    #to-menu-btn { display: none !important; }
    #victory-actions button {
      padding: 0 24px; min-height: 44px;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      border-radius: 10px; color: var(--th-btn-text); font-size: 15px; cursor: pointer;
      transition: filter 0.15s;
    }
    #victory-actions button:hover { filter: brightness(1.15); }
    #bottom-panel {
      position: absolute; bottom: 0; left: 0; right: 0; z-index: 5;
      min-height: 50px; box-sizing: border-box;
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 10px;
      padding-left: calc(env(safe-area-inset-left, 0px) + 20px);
      padding-right: calc(env(safe-area-inset-right, 0px) + 20px);
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
      background: var(--th-panel-bg); border-top: 1px solid var(--th-btn-border);
    }
    /* ── game UI panels: theme-aware ── */
    #top-panel, #bottom-panel {
      background: var(--th-panel-bg);
      border-color: var(--th-btn-border);
    }
    #top-panel { border-bottom-color: var(--th-btn-border); }
    #top-panel label, #top-panel span, #top-panel p,
    #bottom-panel label, #bottom-panel span, #bottom-panel p {
      color: var(--th-text);
    }
    #turn-display {
      background: transparent !important;
      color: var(--th-btn-text) !important;
      border: 1px solid var(--th-btn-border) !important;
    }
    #rank-display { font-size: 13px; color: var(--th-text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex-shrink: 1; }
    #last-move-btn {
      font-size: 14px; padding: 0 16px; min-height: 44px;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      border-radius: 10px; color: var(--th-btn-text); cursor: pointer;
      transition: filter 0.15s; display: none;
    }
    #last-move-btn:hover { filter: brightness(1.15); }
    #last-move-btn.visible { display: block; }
    #theme-switcher { display: flex; gap: 6px; }
    .theme-btn {
      width: 28px; height: 28px; border-radius: 4px; cursor: pointer;
      border: 1px solid transparent;
      transition: filter 0.15s, box-shadow 0.15s;
    }
    .theme-btn:hover  { filter: brightness(1.15); box-shadow: 0 0 16px 3px var(--th-btn-glow); }
    .theme-btn.active { outline: 2px solid var(--th-accent); outline-offset: 1px; }
    .theme-btn[data-theme="stargazer"]   { background: #0b0b14; border-color: rgba(255,255,255,0.2); }
    .theme-btn[data-theme="minimal"]     { background: #FFFFFF; border-color: rgba(0,0,0,0.2); }
    .theme-btn[data-theme="suprematist"] { background: #F5F0E8; border-color: rgba(0,0,0,0.2); }
    .theme-btn[data-theme="chalk"]       { background: #4A90D9; }

    /* ── journey screen ("Мои созвездия") ── */
    #journey {
      position: absolute; inset: 0; z-index: 11;
      display: none; flex-direction: column;
      background: var(--th-bg); box-sizing: border-box;
    }
    #journey-topbar {
      display: flex; align-items: center; gap: 14px; flex-shrink: 0;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) calc(env(safe-area-inset-right, 0px) + 16px) 16px calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #journey-back-btn {}
    #journey-screen-title {
      font-size: 20px; font-weight: 300; color: var(--th-text); letter-spacing: 0.4px;
    }
    #journey-grid {
      flex: 1; overflow-y: auto;
      padding: 4px calc(env(safe-area-inset-right, 0px) + 16px) calc(env(safe-area-inset-bottom, 0px) + 20px) calc(env(safe-area-inset-left, 0px) + 16px);
      display: flex; flex-wrap: wrap; gap: 12px; align-content: flex-start;
    }
    .saved-card {
      width: calc(50% - 6px);
      background: var(--th-card-bg); border: 1px solid var(--th-card-border);
      border-radius: 10px; overflow: hidden; cursor: pointer;
      transition: border-color 0.15s;
    }
    .saved-card:active { border-color: var(--th-btn-border); }
    .saved-card canvas { display: block; width: 100%; height: auto; }
    .saved-card-info { padding: 7px 10px 9px; }
    .saved-card-name {
      font-size: 12px; color: var(--th-text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      text-align: center;
    }
    .journey-empty {
      width: 100%; text-align: center; padding-top: 80px;
      font-size: 15px; color: var(--th-text2); line-height: 1.7;
    }
    #journey-btn {
      margin-top: 4px; font-size: 14px; padding: 0 16px; min-height: 44px;
      display: flex; align-items: center;
      background: transparent; border: 1px solid var(--th-card-border);
      border-radius: 10px; color: var(--th-text2); cursor: pointer;
      transition: color 0.15s, border-color 0.15s; font-family: var(--th-font);
    }
    #journey-btn:hover { color: var(--th-text); border-color: var(--th-btn-border); }

    /* ── screen transitions ── */
    #start, #game { transition: opacity 0.2s; }

    /* ── in-game UI toggle button ── */
    #ui-toggle-btn {
      position: absolute;
      top: calc(env(safe-area-inset-top, 0px) + 12px);
      left: calc(env(safe-area-inset-left, 0px) + 12px);
      z-index: 10;
      background: rgba(0,0,0,0.30);
      border: 1px solid rgba(248,247,245,0.14);
      border-radius: 8px;
      color: rgba(248,247,245,0.50);
      font-size: 20px; letter-spacing: 1px;
      width: 40px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; padding: 0;
      transition: opacity 0.15s;
    }
    #ui-toggle-btn:active { opacity: 0.6; }
    /* Hide panels + prob-bar when ui-hidden is active */
    #game.ui-hidden #top-panel    { display: none; }
    #game.ui-hidden #bottom-panel { display: none; }

    /* ── Global: overflow prevention and protective margins ── */

    /* Nothing overflows the viewport */
    * { max-width: 100%; }

    /* All buttons: theme-aware */
    button:not(.theme-btn) {
      background: transparent !important;
      border: 1px solid var(--th-btn-border) !important;
      color: var(--th-btn-text) !important;
    }
    button:not(.theme-btn):hover, button:not(.theme-btn):active {
      background: var(--th-card-bg) !important;
      box-shadow: 0 0 14px 2px var(--th-btn-glow) !important;
    }
    /* ── exceptions: buttons that should stay minimal ── */
    #auth-apple { background: #FFFFFF !important; color: #000000 !important; border: none !important; box-shadow: none !important; }
    #auth-skip  { background: transparent !important; border: none !important; box-shadow: none !important; color: var(--th-text2) !important; }
    .home-nav-btn, #back-to-menu-btn, #auth-email-back { background: transparent !important; border: none !important; box-shadow: none !important; }
    #home-length-display, button.home-len-btn,
    button.home-len-btn:hover, button.home-len-btn:active,
    button.home-len-btn:focus, button.home-len-btn:focus-visible {
      background: transparent !important; border: none !important;
      box-shadow: none !important; outline: none !important; color: inherit !important;
    }

    /* ── Unified back arrow — identical style and hit-target on every screen ── */
    #back-to-menu-btn,
    #journey-back-btn,
    #sky-back-btn,
    #sky-hub-back-btn,
    #stub-back-btn,
    #const-detail-back-btn,
    #settings-back-btn,
    #profile-back-btn,
    #ach-back-btn {
      background: none !important;
      border: none !important;
      box-shadow: none !important;
      border-radius: 0 !important;
      backdrop-filter: none !important;
      min-width: 44px; min-height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; line-height: 1;
      color: var(--th-text2);
      padding: 0; cursor: pointer;
      transition: color 0.15s;
      flex-shrink: 0;
    }
    #back-to-menu-btn:active,
    #journey-back-btn:active,
    #sky-back-btn:active,
    #sky-hub-back-btn:active,
    #stub-back-btn:active,
    #const-detail-back-btn:active,
    #settings-back-btn:active,
    #profile-back-btn:active,
    #ach-back-btn:active {
      color: var(--th-text) !important;
    }
    #ui-toggle-btn { background: rgba(0,0,0,0.30) !important; border: 1px solid rgba(248,247,245,0.14) !important; color: rgba(248,247,245,0.50) !important; }

    /* Victory / rank text: clamp so it never touches edges */
    #victory-title, #victory-sub, #victory-rating, #rank-display {
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 92%;
    }
    #victory-content {
      padding-left: calc(env(safe-area-inset-left, 0px) + 20px);
      padding-right: calc(env(safe-area-inset-right, 0px) + 20px);
      box-sizing: border-box; width: 100%;
    }

    /* ── Minimal UI: hide non-essential elements ── */
    .start-step > p,
    .sub,
    #journey-btn,
    .hints-toggle,
    #vsHuman,
    #p1level, #p1-rank-stars,
    #p2level, #ai-level-stars,
    #bottom-panel,
    #victory-rating,
    #change-rank-btn,
    .theme-btn,
    .start-themes,
    #theme-switcher { display: none !important; }

    /* ── global vignette overlay ── */
    #vignette-overlay {
      position: absolute; inset: 0;
      pointer-events: none; z-index: 9998;
      background: radial-gradient(ellipse at center,
        transparent 35%,
        rgba(0,0,0,var(--th-vignette)) 100%);
    }

    /* ── auth screen ── */
    #auth-screen {
      position: absolute; inset: 0; z-index: 20;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      justify-content: center; align-items: center; gap: 16px;
      padding-top:    calc(env(safe-area-inset-top, 0px)    + 48px);
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 48px);
      padding-left:   calc(env(safe-area-inset-left, 0px)   + 32px);
      padding-right:  calc(env(safe-area-inset-right, 0px)  + 32px);
    }
    #auth-screen h2 {
      margin: 0 0 16px;
      font-size: 13px; font-weight: 200; letter-spacing: 10px;
      color: var(--th-text2); text-transform: uppercase;
    }
    .auth-btn {
      width: 280px; padding: 14px 20px; border-radius: 10px;
      font-size: 15px; font-weight: 400; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 10px;
      border: none; transition: filter 0.15s, box-shadow 0.15s;
    }
    #auth-apple {
      background: #FFFFFF; color: #000000;
    }
    #auth-apple:hover  { filter: brightness(0.92); }
    #auth-google {
      background: rgba(248,247,245,0.07); color: #F8F7F5;
      border: 1px solid rgba(248,247,245,0.15) !important;
    }
    #auth-google:hover { filter: brightness(1.2); box-shadow: 0 0 16px 2px rgba(248,247,245,0.06); }
    #auth-skip {
      margin-top: 12px;
      font-size: 12px; color: rgba(248,247,245,0.28);
      background: none; border: none; cursor: pointer; padding: 4px 0;
      text-decoration: underline; text-underline-offset: 3px;
    }
    #auth-skip:hover { color: rgba(248,247,245,0.50); }

    /* ── email auth form ── */
    #auth-main-btns { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    #auth-email-panel {
      width: 280px; display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    #auth-tab-row {
      display: flex; width: 100%; border-radius: 8px;
      border: 1px solid rgba(248,247,245,0.13); overflow: hidden; margin-bottom: 2px;
    }
    .auth-tab-btn {
      flex: 1; padding: 10px 0; font-size: 12px; letter-spacing: 1.5px;
      text-transform: lowercase; background: transparent; border: none;
      color: rgba(248,247,245,0.35); cursor: pointer; font-family: inherit;
      transition: background 0.15s, color 0.15s;
    }
    .auth-tab-btn.active {
      background: rgba(248,247,245,0.08); color: rgba(248,247,245,0.88);
    }
    .auth-field {
      width: 100%; padding: 13px 16px; border-radius: 8px; box-sizing: border-box;
      background: rgba(248,247,245,0.05); border: 1px solid rgba(248,247,245,0.13);
      color: var(--th-text); font-family: inherit; font-size: 15px; outline: none;
      transition: border-color 0.15s;
    }
    .auth-field::placeholder { color: rgba(248,247,245,0.25); font-weight: 300; }
    .auth-field:focus { border-color: rgba(248,247,245,0.30); }
    #auth-email-error {
      min-height: 15px; font-size: 11px; color: rgba(255,110,90,0.9);
      text-align: center; letter-spacing: 0.3px;
    }
    #auth-email-success {
      min-height: 15px; font-size: 11px; color: rgba(130,220,160,0.9);
      text-align: center; letter-spacing: 0.3px;
    }
    #auth-email-submit {
      width: 100%; padding: 14px; border-radius: 10px;
      background: rgba(248,247,245,0.09); border: 1px solid rgba(248,247,245,0.20) !important;
      color: rgba(248,247,245,0.88); font-family: inherit; font-size: 15px;
      letter-spacing: 1px; cursor: pointer;
      transition: filter 0.15s;
    }
    #auth-email-submit:hover { filter: brightness(1.3); }
    #auth-email-submit:disabled { opacity: 0.45; cursor: default; }
    #auth-email-back {
      position: absolute !important;
      top: calc(env(safe-area-inset-top, 0px) + 14px);
      left: calc(env(safe-area-inset-left, 0px) + 16px);
      background: none !important; border: none !important; box-shadow: none !important;
      min-width: 44px; min-height: 44px;
      display: flex !important; align-items: center; justify-content: center;
      font-size: 20px; line-height: 1; color: var(--th-text2);
      padding: 0; cursor: pointer; z-index: 2;
      font-family: inherit;
      opacity: 0.7; transition: opacity 0.15s;
    }
    #auth-email-back:hover, #auth-email-back:active { opacity: 1; color: var(--th-text) !important; }

    /* ── achievements screen ("Мой путь") ── */
    #achievements-screen {
      position: absolute; inset: 0; z-index: 20;
      background: var(--th-bg);
      display: flex; flex-direction: column;
    }
    #ach-topbar {
      display: flex; align-items: center; gap: 14px; flex-shrink: 0;
      padding: calc(env(safe-area-inset-top, 0px) + 12px)
               calc(env(safe-area-inset-right, 0px) + 16px)
               16px
               calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #ach-screen-title {
      font-size: 20px; font-weight: 300; color: var(--th-text); letter-spacing: 0.4px;
    }
    #ach-scroll {
      flex: 1; overflow-y: auto;
      padding: 4px calc(env(safe-area-inset-right, 0px) + 20px)
               calc(env(safe-area-inset-bottom, 0px) + 28px)
               calc(env(safe-area-inset-left, 0px) + 20px);
      display: flex; flex-direction: column; gap: 8px;
    }
    /* rank card */
    #ach-rank-card {
      display: flex; gap: 16px; align-items: center;
      background: var(--th-card-bg); border: 1px solid var(--th-card-border);
      border-radius: 16px; padding: 18px 20px; margin-bottom: 4px;
    }
    #ach-rank-emblem { flex-shrink: 0; }
    #ach-rank-info { flex: 1; display: flex; flex-direction: column; gap: 5px; }
    #ach-rank-name { font-size: 17px; font-weight: 400; color: var(--th-text); }
    #ach-rank-rating { font-size: 13px; color: var(--th-text2); }
    #ach-rank-bar-wrap {
      width: 100%; height: 4px; background: rgba(128,128,128,0.15);
      border-radius: 2px; overflow: hidden;
    }
    #ach-rank-bar-fill {
      height: 100%; background: var(--th-text); border-radius: 2px;
      transition: width 0.7s cubic-bezier(.4,0,.2,1);
    }
    #ach-rank-next { font-size: 11px; color: var(--th-text2); letter-spacing: 0.3px; }
    /* category label */
    .ach-cat-label {
      font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase;
      color: var(--th-text2); padding: 8px 2px 2px;
    }
    /* achievement constellation canvas */
    .ach-constellation-canvas {
      display: block; width: 100%; border-radius: 16px;
      background: var(--th-card-bg); border: 1px solid var(--th-card-border);
    }
    /* floating tooltip on star tap */
    #ach-tooltip {
      position: absolute; left: 20px; right: 20px;
      bottom: calc(env(safe-area-inset-bottom, 34px) + 20px);
      background: var(--th-card-bg); border: 1px solid var(--th-card-border);
      border-radius: 14px; padding: 12px 18px; z-index: 2;
      text-align: center; pointer-events: none;
    }
    #ach-tooltip-name { font-size: 14px; color: var(--th-text); font-weight: 400; margin-bottom: 4px; }
    #ach-tooltip-desc { font-size: 12px; color: var(--th-text2); line-height: 1.4; }

    /* ── home screen ── */
    #home-screen {
      position: absolute; inset: 0; z-index: 15;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      padding-top:    calc(env(safe-area-inset-top, 0px)    + 14px);
      padding-bottom: calc(env(safe-area-inset-bottom, 34px) + 16px);
      padding-left:   calc(env(safe-area-inset-left, 0px)   + 32px);
      padding-right:  calc(env(safe-area-inset-right, 0px)  + 32px);
      overflow: hidden;
    }
    #home-bg-canvas {
      position: absolute; inset: 0; width: 100%; height: 100%;
      z-index: 0; pointer-events: none; opacity: 0.78;
    }
    #home-screen > *:not(#home-bg-canvas):not(#home-settings-icon) { position: relative; z-index: 1; }
    #home-header { display: flex; flex-direction: column; gap: 6px; }
    #home-player-name-row {
      display: flex; align-items: center; gap: 6px; cursor: pointer;
    }
    #home-player-name-row:active { opacity: 0.6; }
    #home-player-name {
      font-size: 24px; font-weight: 300; letter-spacing: 0.3px;
      color: var(--th-text);
    }
    #home-player-arrow {
      font-size: 18px; color: var(--th-text2); line-height: 1;
      margin-top: 3px;
    }
    #home-rank-row { display: flex; align-items: center; gap: 12px; }
    #home-rating-pts { font-size: 13px; color: var(--th-text2); letter-spacing: 0.3px; }
    #home-center {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: flex-end; gap: 0;
      padding-bottom: 0;
    }
    /* ── home settings icon (top-right) ── */
    #home-settings-icon {
      position: absolute !important;
      top: calc(env(safe-area-inset-top, 0px) + 14px);
      right: calc(env(safe-area-inset-right, 0px) + 16px);
      z-index: 3;
      background: none !important; border: none !important; outline: none !important;
      -webkit-appearance: none; box-shadow: none !important;
      cursor: pointer; padding: 10px;
      color: var(--th-text2); font-size: 17px;
      line-height: 1; transition: color 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    #home-settings-icon:active { color: var(--th-text); }

    /* ── length picker ── */
    #home-length-picker {
      display: flex; flex-direction: row; align-items: center; gap: 28px;
    }
    .home-len-btn {
      background: none; border: none !important; outline: none; -webkit-appearance: none;
      box-shadow: none !important;
      font-family: inherit; cursor: pointer; padding: 8px 0;
      font-size: 12px; font-weight: 300; letter-spacing: 1.5px; text-transform: lowercase;
      color: var(--th-text2);
      transition: color 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .home-len-btn.active {
      color: var(--th-text);
      font-weight: 500;
      text-shadow: 0 0 6px var(--th-len-glow, transparent),
                   0 0 18px var(--th-len-glow, transparent);
    }
    .home-len-btn:active { opacity: 0.6; }

    /* ── Unified button style (Sky tile, ИГРАТЬ) ── */
    #home-sky-nav-btn,
    #home-play-btn {
      background: var(--th-card-bg);
      border: 1px solid var(--th-card-border) !important;
      border-radius: 20px;
      -webkit-appearance: none; outline: none; cursor: pointer;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
      font-family: inherit;
    }
    #home-sky-nav-btn:active,
    #home-play-btn:active { opacity: 0.5; }

    /* Sky: square tile under score, left-aligned */
    #home-sky-nav-btn {
      width: 80px; height: 80px;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
      margin-top: 10px; padding: 0;
    }
    .home-sky-icon { font-size: 14px; color: var(--th-text2); line-height: 1; }
    .home-sky-label {
      font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
      color: var(--th-text2);
    }

    /* ── bottom: ИГРАТЬ ── */
    #home-bottom {
      padding-top: 12px;
    }
    #home-play-btn {
      width: 100%;
      font-size: 17px; font-weight: 300; letter-spacing: 5px; text-transform: uppercase;
      color: var(--th-text);
      padding: 28px 28px;
    }
    /* keep nav icon class for other screens that may still use it */
    .home-nav-icon { display: block; width: 40px; height: 40px; opacity: 1; }

    /* ── sky hub screen ── */
    #sky-hub-screen {
      position: absolute; inset: 0; z-index: 16;
      background: var(--th-bg);
      display: flex; flex-direction: column;
    }
    #sky-hub-topbar {
      display: flex; align-items: center;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) 28px 20px calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #sky-hub-back-btn {}
    #sky-hub-body {
      flex: 1; display: flex; flex-direction: column;
      gap: 12px;
      padding: 8px calc(env(safe-area-inset-right, 0px) + 20px)
               calc(env(safe-area-inset-bottom, 0px) + 24px)
               calc(env(safe-area-inset-left, 0px) + 20px);
    }
    .sky-hub-btn {
      flex: 1; width: 100%;
      background: var(--th-card-bg);
      border: 1px solid var(--th-card-border);
      border-radius: 24px;
      -webkit-appearance: none; outline: none;
      font-family: inherit; cursor: pointer; text-align: left;
      display: flex; align-items: center; gap: 18px;
      padding: 0 28px;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .sky-hub-btn:last-child { border-bottom: none; }
    .sky-hub-btn:active { opacity: 0.45; }
    .sky-hub-btn-icon { font-size: 14px; color: var(--th-text2); flex-shrink: 0; }
    .sky-hub-btn-label {
      font-size: 24px; font-weight: 300; letter-spacing: 0.3px;
      color: var(--th-text);
    }

    /* ── stub screens (Мои созвездия / Общее небо / Настройки) ── */
    #stub-screen {
      position: absolute; inset: 0; z-index: 16;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 40px);
      padding-left:   calc(env(safe-area-inset-left, 0px)   + 28px);
      padding-right:  calc(env(safe-area-inset-right, 0px)  + 28px);
      gap: 20px;
    }
    #stub-topbar {
      display: flex; align-items: center; gap: 16px;
      padding-top: calc(env(safe-area-inset-top, 0px) + 12px);
      padding-left: 0; /* parent already handles left padding */
      padding-bottom: 16px;
    }
    #stub-back-btn {}
    #stub-title {
      font-size: 13px; font-weight: 200; letter-spacing: 6px; text-transform: uppercase;
      color: var(--th-text2);
    }
    #stub-body {
      flex: 1; display: flex; align-items: center; justify-content: center;
    }
    #stub-body p {
      font-size: 14px; color: var(--th-text2); text-align: center; line-height: 1.7;
    }

    /* ── constellation detail screen ── */
    #const-detail-screen {
      position: absolute; inset: 0; z-index: 19;
      background: var(--th-bg);
      display: flex; flex-direction: column;
    }
    #const-detail-topbar {
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) calc(env(safe-area-inset-right, 0px) + 4px) 0 calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #const-detail-back-btn {}
    #const-detail-delete-btn {
      background: none !important; border: none !important; box-shadow: none !important;
      min-width: 44px; min-height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-size: 19px; cursor: pointer;
      color: var(--th-text2); opacity: 0.55;
      transition: color 0.2s, opacity 0.2s;
    }
    #const-detail-delete-btn:active { color: #E8504A !important; opacity: 1 !important; }
    #const-detail-confirm-bar {
      display: none; gap: 12px; flex-shrink: 0;
      padding: 10px 20px calc(env(safe-area-inset-bottom, 0px) + 20px);
    }
    #const-detail-confirm-yes {
      flex: 1; padding: 13px 10px; border-radius: 8px;
      font-size: 14px; font-family: var(--th-font); cursor: pointer;
      border: 1px solid rgba(232,80,74,0.45);
      color: rgba(232,80,74,0.9); background: rgba(232,80,74,0.08);
      transition: background 0.15s;
    }
    #const-detail-confirm-yes:active { background: rgba(232,80,74,0.20); }
    #const-detail-confirm-no {
      flex: 1; padding: 13px 10px; border-radius: 8px;
      font-size: 14px; font-family: var(--th-font); cursor: pointer;
      border: 1px solid var(--th-btn-border);
      color: var(--th-btn-text); background: transparent;
      transition: background 0.15s;
    }
    #const-detail-confirm-no:active { background: var(--th-card-bg); }
    #const-detail-canvas-wrap {
      flex: 1; position: relative; overflow: hidden; min-height: 0;
    }
    #const-detail-canvas {
      position: absolute; inset: 0; width: 100%; height: 100%; display: block;
    }
    /* Name block — below canvas, centred */
    #const-detail-info {
      flex-shrink: 0; text-align: center; padding: 14px 28px 6px;
    }
    #const-detail-name-text {
      font-size: 20px; font-weight: 300; letter-spacing: 0.4px;
      color: var(--th-text); cursor: text;
    }
    #const-detail-name-input {
      font-size: 20px; font-weight: 300; text-align: center;
      color: var(--th-btn-text); width: 100%;
      background: transparent; border: none;
      border-bottom: 1px solid var(--th-btn-border);
      font-family: var(--th-font); outline: none; box-sizing: border-box; padding: 2px 0;
    }
    #const-detail-name-hint {
      margin-top: 7px;
      font-size: 11px; color: var(--th-text2); letter-spacing: 0.3px;
    }
    #const-detail-addr {
      margin-top: 5px;
      font-size: 10px; color: var(--th-text2); letter-spacing: 0.4px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    #const-detail-bottombar {
      display: flex; gap: 12px; flex-shrink: 0;
      padding: 10px 20px calc(env(safe-area-inset-bottom, 0px) + 20px);
    }
    #const-detail-share-btn, #const-detail-publish-btn {
      flex: 1; padding: 13px 10px; border-radius: 8px;
      font-size: 14px; font-family: var(--th-font); cursor: pointer;
      border: 1px solid var(--th-btn-border);
      color: var(--th-btn-text); background: transparent;
      transition: background 0.15s, opacity 0.15s;
    }
    #const-detail-share-btn:active, #const-detail-publish-btn:active {
      background: var(--th-card-bg);
    }
    #const-detail-publish-btn.published {
      color: var(--th-text2); border-color: var(--th-card-border);
    }

    /* ── settings screen ── */
    #settings-screen {
      position: absolute; inset: 0; z-index: 17;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 40px);
    }
    #settings-topbar {
      display: flex; align-items: center; gap: 16px;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) 28px 20px calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #settings-back-btn {}
    #settings-screen-title {
      font-size: 13px; font-weight: 200; letter-spacing: 6px; text-transform: uppercase;
      color: var(--th-text2);
    }
    .settings-section-title {
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--th-text2); padding: 0 28px; margin-bottom: 6px;
    }
    .settings-group {
      border-top: 1px solid var(--th-card-border);
      border-bottom: 1px solid var(--th-card-border);
      margin-bottom: 28px;
    }
    .settings-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 15px 28px;
      border-bottom: 1px solid var(--th-card-border);
    }
    .settings-row:last-child { border-bottom: none; }
    .settings-row-label { display: flex; flex-direction: column; gap: 3px; }
    .settings-row-title {
      font-size: 15px; font-weight: 300; color: var(--th-text);
    }
    .settings-row-sub {
      font-size: 12px; color: var(--th-text2);
    }
    /* Toggle switch */
    .s-toggle {
      position: relative; width: 48px; height: 28px;
      background: var(--th-card-bg);
      border: 1px solid var(--th-btn-border);
      border-radius: 14px;
      cursor: pointer; transition: background 0.2s, border-color 0.2s;
      flex-shrink: 0;
    }
    .s-toggle::after {
      content: '';
      position: absolute; top: 3px; left: 3px;
      width: 20px; height: 20px; border-radius: 50%;
      background: var(--th-text2);
      transition: transform 0.2s, background 0.2s;
    }
    .s-toggle.on {
      background: var(--th-card-bg);
      border-color: var(--th-btn-border);
    }
    .s-toggle.on::after {
      transform: translateX(20px);
      background: var(--th-btn-text);
    }
    /* Segment control for star glow */
    .s-segment {
      display: flex; border: 1px solid var(--th-btn-border);
      border-radius: 8px; overflow: hidden;
    }
    .s-seg-btn {
      padding: 6px 13px; font-size: 12px; font-weight: 300;
      color: var(--th-text2);
      background: transparent; border: none; cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .s-seg-btn + .s-seg-btn { border-left: 1px solid var(--th-card-border); }
    .s-seg-btn.active {
      background: var(--th-card-bg);
      color: var(--th-btn-text);
    }
    /* Theme selector */
    .s-theme-row {
      display: flex; flex-wrap: wrap; gap: 8px; padding: 15px 28px;
    }
    .s-theme-btn {
      flex: 1 1 calc(50% - 4px); padding: 10px 4px;
      font-size: 12px; font-weight: 300; letter-spacing: 0.5px;
      color: var(--th-text2);
      background: var(--th-card-bg);
      border: 1px solid var(--th-card-border);
      border-radius: 8px; cursor: pointer; font-family: inherit;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .s-theme-btn.active {
      background: var(--th-card-bg);
      border-color: var(--th-btn-border);
      color: var(--th-btn-text);
    }
    .s-theme-btn:active { opacity: 0.7; }
    /* Language selector */
    .s-lang-row {
      display: flex; gap: 8px; padding: 4px 0; flex-wrap: wrap;
    }
    .s-lang-btn {
      flex: 1; min-width: 48px; padding: 8px 6px; border-radius: 10px;
      background: var(--th-btn-bg); border: 1px solid var(--th-btn-border);
      color: var(--th-text2); font-size: 13px; font-weight: 400;
      cursor: pointer; transition: all 0.18s ease;
    }
    .s-lang-btn.active {
      background: var(--th-text); color: var(--th-bg);
      border-color: var(--th-text);
    }

    /* ── profile screen ── */
    #profile-screen {
      position: absolute; inset: 0; z-index: 18;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      overflow: hidden;
    }
    #profile-topbar {
      display: flex; align-items: center; gap: 16px;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) 28px 20px calc(env(safe-area-inset-left, 0px) + 4px);
      flex-shrink: 0;
    }
    #profile-screen-title {
      font-size: 13px; font-weight: 200; letter-spacing: 6px; text-transform: uppercase;
      color: var(--th-text2);
    }
    #profile-scroll {
      flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch;
      padding: 0 0 calc(env(safe-area-inset-bottom, 0px) + 40px);
    }
    /* ── avatar zone ── */
    #profile-avatar-zone {
      display: flex; flex-direction: column; align-items: center;
      padding: 8px 28px 28px; gap: 14px; cursor: pointer;
    }
    #profile-avatar-circle {
      width: 80px; height: 80px; border-radius: 50%;
      border: 1.5px solid var(--th-btn-border);
      background: var(--th-card-bg);
      display: flex; align-items: center; justify-content: center;
      font-size: 34px; line-height: 1; overflow: hidden;
      transition: opacity 0.15s;
    }
    #profile-avatar-circle:active { opacity: 0.7; }
    #profile-avatar-photo { width: 100%; height: 100%; object-fit: cover; display: none; }
    #profile-avatar-emoji { display: block; }
    .profile-avatar-hint {
      font-size: 11px; color: var(--th-text2); letter-spacing: 1px;
    }
    /* ── name edit in profile ── */
    #profile-name-wrap {
      display: flex; align-items: center; gap: 8px;
      padding: 0 28px 4px;
    }
    #profile-name-display {
      font-size: 22px; font-weight: 300; color: var(--th-text);
      cursor: pointer; flex: 1;
    }
    #profile-name-input {
      display: none; flex: 1;
      font-size: 22px; font-weight: 300; color: var(--th-text); font-family: inherit;
      background: none; border: none;
      border-bottom: 1px solid var(--th-btn-border);
      outline: none; padding: 0 0 2px;
    }
    #profile-rank-display {
      padding: 0 28px 24px;
      font-size: 13px; color: var(--th-text2); letter-spacing: 0.3px;
    }
    /* ── stats ── */
    .profile-section-title {
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--th-text2); padding: 0 28px; margin-bottom: 6px;
    }
    .profile-stats-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--th-card-border);
      border-left: 1px solid var(--th-card-border);
      margin: 0 0 4px;
    }
    .profile-stat-cell {
      padding: 18px 28px;
      border-right: 1px solid var(--th-card-border);
      border-bottom: 1px solid var(--th-card-border);
    }
    .profile-stat-value {
      font-size: 28px; font-weight: 200; color: var(--th-text);
      letter-spacing: -0.5px; line-height: 1;
    }
    .profile-stat-label {
      font-size: 11px; color: var(--th-text2); margin-top: 4px; letter-spacing: 0.3px;
    }
    .profile-outcomes-row {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      border-top: 1px solid var(--th-card-border);
      border-left: 1px solid var(--th-card-border);
      margin: 0 0 28px;
    }
    .profile-outcome-cell {
      padding: 14px 0 14px 20px;
      border-right: 1px solid var(--th-card-border);
      border-bottom: 1px solid var(--th-card-border);
    }
    .profile-outcome-value {
      font-size: 22px; font-weight: 200; color: var(--th-text); line-height: 1;
    }
    .profile-outcome-label {
      font-size: 10px; color: var(--th-text2); margin-top: 4px; letter-spacing: 0.3px;
    }
    /* ── leaderboard ── */
    #profile-leaderboard-card {
      margin: 0 0 28px;
      border-top: 1px solid var(--th-card-border);
      border-bottom: 1px solid var(--th-card-border);
      padding: 18px 28px;
      display: flex; align-items: center; justify-content: space-between;
    }
    #profile-lb-rank {
      font-size: 36px; font-weight: 200; color: var(--th-text); line-height: 1;
    }
    #profile-lb-info {
      font-size: 12px; color: var(--th-text2); text-align: right; line-height: 1.5;
    }
    /* ── action buttons ── */
    #profile-actions {
      display: flex; flex-direction: column; gap: 10px;
      padding: 0 28px;
    }
    .profile-action-btn {
      width: 100%; padding: 14px 20px;
      text-align: left;
      font-size: 15px; font-weight: 300;
      background: transparent !important;
      border: 1px solid var(--th-card-border) !important;
      color: var(--th-text) !important;
      border-radius: 12px;
      display: flex; align-items: center; gap: 12px;
    }
    .profile-action-btn:active { opacity: 0.6; }
    .profile-action-btn .btn-icon { font-size: 18px; }
    #profile-logout-btn {
      color: var(--th-text2) !important;
      border: none !important;
      padding: 14px 0;
    }
    #profile-logout-btn .btn-icon {
      font-size: 20px; opacity: 0.6;
    }

    /* ── avatar picker overlay ── */
    #avatar-picker {
      position: absolute; inset: 0; z-index: 19;
      display: flex; flex-direction: column; justify-content: flex-end;
    }
    #avatar-picker-backdrop {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.45);
    }
    #avatar-picker-panel {
      position: relative; z-index: 1;
      background: var(--th-bg);
      border-top: 1px solid var(--th-card-border);
      padding: 20px 20px calc(env(safe-area-inset-bottom, 0px) + 28px);
      display: flex; flex-direction: column; gap: 16px;
    }
    .avatar-picker-title {
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--th-text2); padding: 0 8px;
    }
    .avatar-emoji-grid {
      display: grid; grid-template-columns: repeat(8, 1fr); gap: 6px;
    }
    .avatar-emoji-btn {
      aspect-ratio: 1; font-size: 22px;
      background: var(--th-card-bg) !important;
      border: 1px solid var(--th-card-border) !important;
      color: inherit !important;
      display: flex; align-items: center; justify-content: center;
      border-radius: 10px; padding: 0;
    }
    .avatar-emoji-btn.active {
      border-color: var(--th-btn-border) !important;
      background: var(--th-btn-bg) !important;
    }
    .avatar-emoji-btn:active { opacity: 0.6; }
    .avatar-picker-divider {
      height: 1px; background: var(--th-card-border);
    }
    #avatar-upload-btn {
      width: 100%; padding: 13px;
      text-align: center; font-size: 14px; font-weight: 300;
    }
    #avatar-picker-close {
      width: 100%; padding: 13px;
      font-size: 14px; color: var(--th-text2) !important;
    }

    /* ── sky screen ("Общее небо") ── */
    #sky-screen {
      position: absolute; inset: 0; z-index: 16;
      display: none; background: var(--th-bg); overflow: hidden;
    }
    #sky-canvas {
      position: absolute; inset: 0; display: block; touch-action: none; cursor: grab;
    }
    #sky-canvas:active { cursor: grabbing; }
    #sky-ui {
      position: absolute; inset: 0; pointer-events: none;
      display: flex; flex-direction: column; justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 12px) calc(env(safe-area-inset-right, 0px) + 16px) calc(env(safe-area-inset-bottom, 0px) + 16px) calc(env(safe-area-inset-left, 0px) + 4px);
    }
    #sky-ui > * { pointer-events: all; }
    #sky-top-row { display: flex; align-items: center; gap: 12px; }
    #sky-back-btn {}
    #sky-screen-title {
      font-size: 18px; font-weight: 300; color: rgba(248,247,245,0.80); letter-spacing: 0.4px;
      pointer-events: none;
    }
    #sky-bottom-row { display: flex; justify-content: space-between; align-items: flex-end; }
    #sky-mine-nav   { display: flex; align-items: center; gap: 6px; }
    #sky-zoom-btns  { display: flex; flex-direction: column; gap: 8px; }
    .sky-ctrl-btn {
      min-height: 44px; min-width: 44px; display: flex; align-items: center; justify-content: center;
      background: rgba(6,6,18,0.75) !important; border: 1px solid rgba(225,223,220,0.25) !important;
      border-radius: 8px; color: rgba(248,247,245,0.70) !important; font-size: 22px;
      cursor: pointer; backdrop-filter: blur(8px);
    }
    #sky-find-mine {
      min-height: 44px; display: flex; align-items: center;
      background: rgba(6,6,18,0.75) !important; border: 1px solid rgba(225,223,220,0.5) !important;
      border-radius: 8px; color: rgba(248,247,245,0.85) !important; font-size: 14px;
      padding: 0 16px; cursor: pointer; backdrop-filter: blur(8px);
    }
    #sky-mode-toggle {
      display: flex; gap: 4px;
      background: rgba(6,6,18,0.75); border: 1px solid rgba(248,247,245,0.12);
      border-radius: 8px; padding: 3px; backdrop-filter: blur(8px);
    }
    .sky-mode-btn {
      padding: 6px 14px; border-radius: 10px; border: none !important; cursor: pointer;
      font-size: 13px; font-family: var(--th-font);
      background: transparent !important; color: rgba(248,247,245,0.45) !important;
      box-shadow: none !important;
      transition: background 0.15s, color 0.15s;
    }
    .sky-mode-btn.active {
      background: rgba(225,223,220,0.25) !important; color: rgba(248,247,245,0.95) !important;
    }
    #sky-status {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-size: 15px; color: var(--th-text2); pointer-events: none;
      display: none; text-align: center; line-height: 1.7;
    }
    #sky-retry-btn {
      display: inline-block; margin-top: 10px;
      background: none; border: 1px solid var(--th-card-border);
      border-radius: 20px; padding: 6px 20px;
      font-family: inherit; font-size: 12px; font-weight: 300;
      letter-spacing: 1.5px; color: var(--th-text2);
      cursor: pointer; -webkit-tap-highlight-color: transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    #sky-retry-btn:active { color: var(--th-text); border-color: var(--th-btn-border); }

    /* ── tutorial screen ── */
    #tutorial-screen {
      position: absolute; inset: 0; z-index: 19;
      background: var(--th-bg);
      display: flex; flex-direction: column;
      justify-content: center; align-items: center; gap: 20px;
      padding-top:    calc(env(safe-area-inset-top, 0px)    + 56px);
      padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 48px);
      padding-left:   calc(env(safe-area-inset-left, 0px)   + 28px);
      padding-right:  calc(env(safe-area-inset-right, 0px)  + 28px);
    }
    #tutorial-canvas {
      border-radius: 16px;
      background: var(--th-card-bg);
    }
    #tutorial-title {
      font-size: 19px; font-weight: 300; letter-spacing: 0.3px;
      color: var(--th-text); text-align: center; margin: 0;
      transition: opacity 0.35s ease;
    }
    #tutorial-desc {
      font-size: 14px; color: var(--th-text2); text-align: center;
      margin: 0; max-width: 280px; line-height: 1.65;
      transition: opacity 0.45s ease;
    }
    #tutorial-dots { display: flex; gap: 8px; align-items: center; }
    .tdot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--th-card-border); transition: background 0.25s;
    }
    .tdot.active { background: var(--th-text2); }
    #tutorial-next-btn {
      width: 220px; padding: 14px; border-radius: 10px;
      font-size: 15px; cursor: pointer;
      background: var(--th-card-bg) !important;
      border: 1px solid var(--th-btn-border) !important;
      color: var(--th-btn-text) !important;
      transition: filter 0.15s;
    }
    #tutorial-next-btn:hover { filter: brightness(1.25) !important; }
    #tutorial-content {
      display: flex; flex-direction: column; align-items: center; gap: 20px; width: 100%;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    #tutorial-next-btn.t-disabled { opacity: 0.35 !important; cursor: default !important; }

    /* ── offline banner ── */
    #offline-banner {
      position: fixed;
      top: env(safe-area-inset-top, 0px);
      left: 0; right: 0;
      z-index: 10000;
      display: none;
      justify-content: center;
      align-items: center;
      gap: 6px;
      padding: 7px 20px;
      background: rgba(20,14,8,0.94);
      color: rgba(248,247,245,0.5);
      font-size: 11px;
      letter-spacing: 0.9px;
      border-bottom: 1px solid rgba(248,247,245,0.08);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      transition: opacity 0.4s;
    }
    #offline-banner.visible { display: flex; }
    #offline-queue-badge {
      display: none;
      position: fixed;
      bottom: calc(env(safe-area-inset-bottom, 20px) + 56px);
      right: 18px;
      background: rgba(248,200,100,0.18);
      border: 1px solid rgba(248,200,100,0.35);
      border-radius: 20px;
      padding: 5px 12px;
      font-size: 11px;
      color: rgba(248,200,100,0.85);
      letter-spacing: 0.6px;
      z-index: 9990;
      pointer-events: none;
    }

    /* ── global grain overlay ── */
    #grain-overlay {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='300' height='300'><filter id='grain'><feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='300' height='300' filter='url(%23grain)'/></svg>");
      background-repeat: repeat;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
</head>
<body>

  <!-- Offline indicator banner (shown when navigator.onLine = false) -->
  <div id="offline-banner" aria-live="polite">✦ offline</div>
  <!-- Queue badge: shows count of saves pending sync -->
  <div id="offline-queue-badge"></div>

  <!-- Auth screen (shown on first launch if no userId in localStorage) -->
  <div id="auth-screen" style="display:none">
    <h2 data-i18n="app_title">CONSTELLATION</h2>

    <!-- main buttons (Apple / Google / Email / skip) -->
    <div id="auth-main-btns">
      <button class="auth-btn" id="auth-apple">
        <svg width="17" height="20" viewBox="0 0 17 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M13.544 10.521c-.02-2.126 1.738-3.155 1.817-3.205-1-1.45-2.543-1.648-3.086-1.664-1.308-.134-2.57.78-3.233.78-.676 0-1.706-.764-2.808-.743C4.66 5.71 3.1 6.63 2.248 8.084c-1.72 2.974-.44 7.367 1.23 9.776.82 1.179 1.79 2.5 3.065 2.453 1.236-.05 1.703-.795 3.2-.795 1.483 0 1.912.795 3.204.769 1.326-.022 2.162-1.193 2.97-2.378a11.1 11.1 0 001.341-2.756c-.03-.012-2.688-1.028-2.714-4.132zM11.3 3.768C11.99 2.93 12.46 1.77 12.326.58c-1.003.043-2.22.67-2.938 1.49-.647.73-1.21 1.906-1.055 3.028 1.118.086 2.268-.567 2.968-1.33z" fill="#000000"/>
        </svg>
        <span data-i18n="auth_apple">Sign in with Apple</span>
      </button>
      <button class="auth-btn" id="auth-google">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        <span data-i18n="auth_google">Sign in with Google</span>
      </button>
      <button class="auth-btn" id="auth-email-open"
        style="background:rgba(248,247,245,0.07);color:#F8F7F5;border:1px solid rgba(248,247,245,0.15)!important;">
        <span data-i18n="auth_email">✉ Sign in with Email</span>
      </button>
      <button id="auth-skip" data-i18n="auth_skip">Continue without signing in</button>
    </div>

    <!-- email / password form (hidden until auth-email-open clicked) -->
    <div id="auth-email-panel" style="display:none">
      <div id="auth-tab-row">
        <button class="auth-tab-btn active" data-auth-tab="login" data-i18n="auth_tab_login">sign in</button>
        <button class="auth-tab-btn"        data-auth-tab="signup" data-i18n="auth_tab_signup">register</button>
      </div>
      <input class="auth-field" id="auth-field-email" type="email"
        data-i18n-placeholder="auth_placeholder_email" placeholder="email" autocomplete="email" autocapitalize="none" spellcheck="false">
      <input class="auth-field" id="auth-field-pass" type="password"
        data-i18n-placeholder="auth_placeholder_pass" placeholder="password" autocomplete="current-password">
      <div id="auth-email-error"></div>
      <div id="auth-email-success"></div>
      <button id="auth-email-submit" data-i18n="auth_submit_login">Sign In</button>
      <button id="auth-email-back">←</button>
    </div>
  </div>

  <!-- Tutorial screen (shown after auth on first launch) -->
  <div id="tutorial-screen" style="display:none">
    <div id="tutorial-content">
      <canvas id="tutorial-canvas" width="280" height="200"></canvas>
      <div style="display:flex;flex-direction:column;align-items:center;gap:10px">
        <h3 id="tutorial-title"></h3>
        <p id="tutorial-desc"></p>
      </div>
      <div id="tutorial-dots">
        <span class="tdot"></span>
        <span class="tdot"></span>
        <span class="tdot"></span>
        <span class="tdot"></span>
      </div>
      <button id="tutorial-next-btn" data-i18n="tutorial_next">Next</button>
    </div>
  </div>

  <!-- Stub screen (shared placeholder for nav sections not yet implemented) -->
