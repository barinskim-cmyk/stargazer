    /** Return the localized constellation name (Russian if lang=ru, else original). */
    function _constName(n) {
      if (_lang === 'ru' && CONSTELLATION_RU[n]) return CONSTELLATION_RU[n];
      return n;
    }

    // ── Home screen background constellation animation ─────────────────────────
    let _homeBgRaf       = null;
    let _homeBgData      = null;
    let _homeBgConstName = '';
    let _homeBgTwinkle   = [];
    let _homeBgConstIdx  = 0;       // index in REAL_CONSTELLATIONS
    let _homeBgFade        = null;  // multi-phase transition: {phase:'out'|'gap'|'stars'|'lines'}
    let _homeBgIdleTwinkle = null;  // victory-style idle twinkle: {idx,startMs,duration,waitUntil}

    function _stopHomeBgAnim() {
      if (_homeBgRaf) { cancelAnimationFrame(_homeBgRaf); _homeBgRaf = null; }
    }

    /** Pick the next star to idle-twinkle (victory-screen style). */
    function _homePickTwinkle(now) {
      if (!_homeBgData || !_homeBgData.points.length) return;
      const idx      = Math.floor(Math.random() * _homeBgData.points.length);
      const duration = 900 + Math.random() * 500;
      _homeBgIdleTwinkle = { idx, startMs: now, duration,
                              waitUntil: now + duration + 1500 + Math.random() * 2500 };
    }

    /**
     * Draw one constellation scene onto ctx2.
     * alpha          — uniform opacity (fade-out phase).
     * starAlphas     — optional per-star opacity array (stars phase).
     * starFlashBoosts — optional per-star extra boost for end-of-fadein flash.
     * lineAlphas     — optional per-line opacity array (lines phase).
     *                  null = draw all lines at `alpha` with existing 3-pass style.
     */
    function _homeDrawConstScene(ctx2, data, twinkle, name, alpha, pw, ph, ts,
                                  starAlphas, starFlashBoosts, lineAlphas, lineProgress, starScales, lineAnchors) {
      if (!data || !data.points || !data.points.length) return;
      const pts = data.points;
      let mnx = 1, mxx = 0, mny = 1, mxy = 0;
      pts.forEach(p => {
        mnx = Math.min(mnx, p.x); mxx = Math.max(mxx, p.x);
        mny = Math.min(mny, p.y); mxy = Math.max(mxy, p.y);
      });
      const span    = Math.max(mxx - mnx, mxy - mny, 0.01);
      const scalePx = (Math.min(pw, ph) * 0.54) / span;
      const cx0     = pw * 0.5, cy0 = ph * 0.44;
      const mpx     = pt => cx0 + (pt.x - (mnx + mxx) / 2) * scalePx;
      const mpy     = pt => cy0 + (pt.y - (mny + mxy) / 2) * scalePx;

      const lns     = data.lines    || [];
      const plgs    = data.polygons || [];
      const _th     = THEMES[activeTheme] || THEMES.stargazer;
      const lineClr = _th.lines    || 'rgba(248,247,245,0.88)';
      const fillClr = _th.captured || 'rgba(255,235,200,0.04)';

      const sa = i => starAlphas ? Math.min(1, starAlphas[i]) : alpha;

      // polygon fills (uniform, fade-out phase only)
      if (!starAlphas && !lineAlphas) {
        plgs.forEach(poly => {
          if (!poly.path || poly.path.length < 3) return;
          ctx2.save(); ctx2.globalAlpha = alpha;
          ctx2.beginPath();
          poly.path.forEach((idx, i) => {
            const pt = pts[idx];
            if (i === 0) ctx2.moveTo(mpx(pt), mpy(pt));
            else         ctx2.lineTo(mpx(pt), mpy(pt));
          });
          ctx2.closePath(); ctx2.fillStyle = fillClr; ctx2.fill();
          ctx2.restore();
        });
      }

      // ── lines ──────────────────────────────────────────────────────────────
      const lw1 = Math.max(3, pw * 0.018);
      const lw2 = Math.max(1.0, pw * 0.007);
      const lw3 = Math.max(0.4, pw * 0.0025);

      if (lineAlphas) {
        // lines phase: each line with optional progress + anchor direction
        lns.forEach(([key], li) => {
          const ga = lineAlphas[li];
          if (ga < 0.005) return;
          const [a, b] = key.split('-').map(Number);
          if (a >= pts.length || b >= pts.length) return;
          const prog = (lineProgress && lineProgress[li] != null) ? lineProgress[li] : 1;
          if (prog < 0.005) return;
          // anchor=0: fixed at pts[a], tip moves toward pts[b]
          // anchor=1: fixed at pts[b], tip moves toward pts[a]
          const anch  = lineAnchors ? lineAnchors[li] : 0;
          const fixX  = anch === 0 ? mpx(pts[a]) : mpx(pts[b]);
          const fixY  = anch === 0 ? mpy(pts[a]) : mpy(pts[b]);
          const movX  = anch === 0 ? mpx(pts[b]) : mpx(pts[a]);
          const movY  = anch === 0 ? mpy(pts[b]) : mpy(pts[a]);
          const ex = fixX + (movX - fixX) * prog;
          const ey = fixY + (movY - fixY) * prog;
          ctx2.save();
          ctx2.globalAlpha = ga;
          ctx2.lineCap     = 'round';
          ctx2.shadowBlur  = 6 * ga;
          ctx2.shadowColor = 'rgba(248,247,245,0.8)';
          // outer glow
          ctx2.strokeStyle = 'rgba(248,247,245,0.07)'; ctx2.lineWidth = lw1;
          ctx2.beginPath(); ctx2.moveTo(fixX,fixY); ctx2.lineTo(ex,ey); ctx2.stroke();
          // mid glow
          ctx2.strokeStyle = 'rgba(248,247,245,0.18)'; ctx2.lineWidth = lw2;
          ctx2.beginPath(); ctx2.moveTo(fixX,fixY); ctx2.lineTo(ex,ey); ctx2.stroke();
          // bright core
          ctx2.strokeStyle = 'rgba(248,247,245,0.88)'; ctx2.lineWidth = lw3;
          ctx2.beginPath(); ctx2.moveTo(fixX,fixY); ctx2.lineTo(ex,ey); ctx2.stroke();
          ctx2.restore();
        });
      } else if (starAlphas) {
        // stars phase: skip lines entirely (they appear later)
      } else {
        // settled / fade-out: draw all lines at uniform alpha
        [[lw1, 0.05 * alpha], [lw2, 0.15 * alpha], [lw3, 0.75 * alpha]].forEach(([lw, ga]) => {
          ctx2.beginPath();
          lns.forEach(([key]) => {
            const [a, b] = key.split('-').map(Number);
            if (a < pts.length && b < pts.length) {
              ctx2.moveTo(mpx(pts[a]), mpy(pts[a]));
              ctx2.lineTo(mpx(pts[b]), mpy(pts[b]));
            }
          });
          ctx2.strokeStyle = lineClr; ctx2.lineWidth = lw;
          ctx2.globalAlpha = ga; ctx2.stroke(); ctx2.globalAlpha = 1;
        });
      }

      // ── stars ──────────────────────────────────────────────────────────────
      const deg = new Array(pts.length).fill(0);
      lns.forEach(([key]) => {
        const [a, b] = key.split('-').map(Number);
        if (a < pts.length && b < pts.length) { deg[a]++; deg[b]++; }
      });
      const prevR = RADIUS;
      RADIUS = Math.max(2, Math.round(pw * 0.014));

      // idle twinkle boost (victory-screen style)
      const idleTw = _homeBgIdleTwinkle;

      pts.forEach((pt, i) => {
        const a = sa(i);
        if (a < 0.005) return;
        const sc = starScales ? Math.max(0, starScales[i]) : 1;
        if (sc < 0.005) return;
        const tw   = twinkle[i];
        const base = tw ? 0.25 + 0.75 * (0.5 + 0.5 * Math.sin(ts * 0.001 * tw.speed + tw.phase)) : 0.4;

        // flash after star fully appeared
        const flashBoost = starFlashBoosts ? starFlashBoosts[i] : 0;

        // idle twinkle boost (one star at a time, victory screen style)
        let idleBoost = 0;
        if (idleTw && idleTw.idx === i) {
          const t   = Math.min((ts - idleTw.startMs) / idleTw.duration, 1);
          const env = t < 0.3 ? t / 0.3 : (1 - t) / 0.7;
          idleBoost = Math.sin(env * Math.PI * 0.5) * 0.9;
        }

        const sx = mpx(pt), sy = mpy(pt);
        ctx2.save();
        ctx2.globalAlpha = a;
        if (sc !== 1) {
          // scale around star centre so it grows/shrinks from its own point
          ctx2.translate(sx, sy);
          ctx2.scale(sc, sc);
          ctx2.translate(-sx, -sy);
        }
        drawStarPointTo(ctx2, sx, sy, Math.max(deg[i], 2), false, false, false,
                        (base + flashBoost + idleBoost) * 0.65);
        ctx2.restore();
      });
      RADIUS = prevR;

      // ── name label — appears after all stars settled ───────────────────────
      if (name) {
        const nameAlpha = starAlphas ? Math.min(...Array.from({length: pts.length}, (_, i) => sa(i)))
                                     : alpha;
        if (nameAlpha > 0.01) {
          const fs = Math.max(12, Math.round(pw * 0.038));
          ctx2.save();
          ctx2.globalAlpha   = 0.42 * nameAlpha;
          ctx2.textAlign     = 'center';
          ctx2.textBaseline  = 'top';
          ctx2.font          = `300 ${fs}px -apple-system, "SF Pro Text", sans-serif`;
          ctx2.fillStyle     = 'rgba(248,247,245,1)';
          ctx2.letterSpacing = '0.12em';
          ctx2.fillText(_constName(name).toUpperCase(), pw * 0.5, ph * 0.74);
          ctx2.restore();
        }
      }
    }

    /**
     * Switch to next (+1) or previous (-1) constellation.
     *
     * OUT: stars shrink & fade in groups of 1–2; their lines retract INTO them simultaneously.
     * GAP: 500 ms darkness.
     * IN:  stars grow from a point in groups of 1–2; their lines extend FROM them.
     */
    function _homeBgSwipeTo(dir) {
      if (_homeBgFade) return;
      _homeBgConstIdx = ((_homeBgConstIdx + dir + REAL_CONSTELLATIONS.length) % REAL_CONSTELLATIONS.length);
      const rc  = REAL_CONSTELLATIONS[_homeBgConstIdx];
      const n   = rc.pts.length;
      const nl  = rc.lns.length;
      const prevLnCount = _homeBgData?.lines?.length  || 0;
      const prevStCount = _homeBgData?.points?.length || 0;

      // ── Helper: Fisher-Yates shuffle ──────────────────────────────────────
      function _shuffle(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
      }

      // ── OUT: group prev-stars into 1–2 per group, stagger group starts ────
      const outStarData = new Array(prevStCount);
      if (prevStCount > 0) {
        const oShuf = _shuffle(Array.from({length: prevStCount}, (_, i) => i));
        let gStart = 0, idx = 0;
        while (idx < oShuf.length) {
          const sz = (idx + 1 < oShuf.length && Math.random() < 0.5) ? 2 : 1;
          for (let g = 0; g < sz; g++) {
            const si  = oShuf[idx + g];
            const jit = (Math.random() - 0.5) * 60;   // ±30 ms within-group jitter
            const dur = 2000 + Math.random() * 1000;   // 2000–3000 ms per star
            outStarData[si] = { delay: Math.max(0, gStart + jit), dur };
          }
          gStart += 400 + Math.random() * 350;         // 400–750 ms between groups
          idx += sz;
        }
      }

      // ── OUT: per-line data — each line retracts INTO the star that fades first
      const outLineData = new Array(prevLnCount);
      const prevLines   = _homeBgData?.lines || [];
      for (let li = 0; li < prevLnCount; li++) {
        const [a, b]  = prevLines[li][0].split('-').map(Number);
        const sdA     = outStarData[a] || { delay: 0, dur: 2500 };
        const sdB     = outStarData[b] || { delay: 0, dur: 2500 };
        const anchor  = sdA.delay <= sdB.delay ? 0 : 1; // 0 = fixed at a, 1 = fixed at b
        const sd      = anchor === 0 ? sdA : sdB;
        // line retracts in full sync with its absorbing star
        outLineData[li] = { anchor, lineDelay: sd.delay, lineDur: sd.dur };
      }

      // ── IN: group new-stars into 1–2 per group, stagger group starts ──────
      const inStarData = new Array(n);
      {
        const iShuf = _shuffle(Array.from({length: n}, (_, i) => i));
        let gStart = 0, idx = 0;
        while (idx < iShuf.length) {
          const sz = (idx + 1 < iShuf.length && Math.random() < 0.5) ? 2 : 1;
          for (let g = 0; g < sz; g++) {
            const si      = iShuf[idx + g];
            const jit     = (Math.random() - 0.5) * 60;
            const dur     = 2000 + Math.random() * 1000;
            const flashDur= 400  + Math.random() * 300;  // flash after fully visible
            inStarData[si] = { delay: Math.max(0, gStart + jit), dur, flashDur };
          }
          gStart += 400 + Math.random() * 350;
          idx += sz;
        }
      }

      // ── IN: per-line data — each line extends FROM the star that appears first
      const inLineData = new Array(nl);
      for (let li = 0; li < nl; li++) {
        const [a, b] = rc.lns[li];
        const sdA    = inStarData[a] || { delay: 0, dur: 2500 };
        const sdB    = inStarData[b] || { delay: 0, dur: 2500 };
        const anchor = sdA.delay <= sdB.delay ? 0 : 1;
        const sd     = anchor === 0 ? sdA : sdB;
        // line starts extending once the source star is ~35% visible
        const lineDelay = sd.delay + sd.dur * 0.35;
        const lineDur   = sd.dur   * 0.65;
        inLineData[li]  = { anchor, lineDelay, lineDur };
      }

      _homeBgFade = {
        phase:       'out',
        startTs:     performance.now(),
        // out (prev constellation stars + lines together)
        prevData:    _homeBgData,
        prevTwinkle: _homeBgTwinkle,
        prevName:    _homeBgConstName,
        outStarData,
        outLineData,
        // gap
        gapDur:      500,
        gapStart:    null,
        // in (new constellation stars + lines together)
        inStart:     null,
        inStarData,
        inLineData,
      };

      // Load incoming constellation
      _homeBgConstName   = rc.n;
      _homeBgData        = { points: rc.pts, lines: rc.lns.map(([a,b]) => [`${a}-${b}`,1]), polygons: [] };
      _homeBgTwinkle     = rc.pts.map(() => ({ phase: Math.random()*Math.PI*2, speed: 0.5+Math.random()*0.9 }));
      _homeBgIdleTwinkle = null;
    }

    /** Attach swipe-left / swipe-right listeners on the home screen (once). */
    function _homeInitSwipe() {
      const scr = document.getElementById('home-screen');
      if (!scr || scr._swipeInit) return;
      scr._swipeInit = true;
      let tx0 = 0, ty0 = 0;
      scr.addEventListener('touchstart', e => {
        // ignore touches that start on interactive children
        if (e.target.closest('button,a,input,select,[role="button"]')) return;
        const t = e.touches[0]; tx0 = t.clientX; ty0 = t.clientY;
      }, { passive: true });
      scr.addEventListener('touchend', e => {
        if (e.target.closest('button,a,input,select,[role="button"]')) return;
        const t  = e.changedTouches[0];
        const dx = t.clientX - tx0;
        const dy = t.clientY - ty0;
        // horizontal swipe: dx > 45px and more horizontal than vertical
        if (Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy) * 1.4) {
          _homeBgSwipeTo(dx > 0 ? -1 : 1);
        }
      }, { passive: true });
    }

    function _startHomeBgAnim() {
      _stopHomeBgAnim();
      // Pick a random real constellation from the 88 IAU constellations
      _homeBgConstIdx = Math.floor(Math.random() * REAL_CONSTELLATIONS.length);
      const rc = REAL_CONSTELLATIONS[_homeBgConstIdx];
      _homeBgConstName = rc.n;
      _homeBgData = {
        points:   rc.pts,
        lines:    rc.lns.map(([a, b]) => [`${a}-${b}`, 1]),
        polygons: []
      };
      _homeBgTwinkle = rc.pts.map(() => ({
        phase: Math.random() * Math.PI * 2,
        speed: 0.5 + Math.random() * 0.9
      }));
      _homeBgFade = null;
      _homeInitSwipe();

      const cv = document.getElementById('home-bg-canvas');
      if (!cv) return;

      function loop(ts) {
        const scr = document.getElementById('home-screen');
        if (!scr || scr.style.display === 'none') { _homeBgRaf = null; return; }
        const pw = scr.offsetWidth || window.innerWidth;
        const ph = scr.offsetHeight || window.innerHeight;
        if (cv.width !== pw * (window.devicePixelRatio||1) | 0) {
          cv.width  = Math.round(pw * (window.devicePixelRatio||1));
          cv.height = Math.round(ph * (window.devicePixelRatio||1));
          cv.style.width  = pw + 'px';
          cv.style.height = ph + 'px';
        }
        const ctx2 = cv.getContext('2d');
        const dpr  = window.devicePixelRatio || 1;
        ctx2.clearRect(0, 0, cv.width, cv.height);
        ctx2.save();
        ctx2.scale(dpr, dpr);

        if (_homeBgFade) {
          const f = _homeBgFade;

          if (f.phase === 'out') {
            // ── OUT: stars shrink+fade AND lines retract into them, simultaneously
            const elapsed = ts - f.startTs;
            const nPrev   = f.prevData?.points?.length || 0;
            const nlPrev  = f.prevData?.lines?.length  || 0;
            const starAlphas  = new Array(nPrev);
            const starScales  = new Array(nPrev);
            const lineAlphas  = new Array(nlPrev);
            const lineProgs   = new Array(nlPrev);
            const lineAnchors = new Array(nlPrev);
            let allDone = true;
            for (let i = 0; i < nPrev; i++) {
              const { delay, dur } = f.outStarData[i];
              const t      = Math.min(1, Math.max(0, (elapsed - delay) / dur));
              const smooth = t * t * (3 - 2 * t);
              starAlphas[i] = 1 - smooth;
              starScales[i] = 1 - smooth;
              if (t < 1) allDone = false;
            }
            for (let li = 0; li < nlPrev; li++) {
              const { anchor, lineDelay, lineDur } = f.outLineData[li];
              const t      = Math.min(1, Math.max(0, (elapsed - lineDelay) / lineDur));
              const smooth = t * t * (3 - 2 * t);
              lineAlphas[li]  = 1 - smooth;
              lineProgs[li]   = 1 - smooth; // shrinks toward anchor star
              lineAnchors[li] = anchor;
              if (t < 1) allDone = false;
            }
            _homeDrawConstScene(ctx2, f.prevData, f.prevTwinkle,
                                f.prevName, 1, pw, ph, ts,
                                starAlphas, null, lineAlphas, lineProgs, starScales, lineAnchors);
            if (allDone) { f.phase = 'gap'; f.gapStart = ts; }

          } else if (f.phase === 'gap') {
            // ── GAP: darkness ──────────────────────────────────────────────────
            if (ts - f.gapStart >= f.gapDur) { f.phase = 'in'; f.inStart = ts; }

          } else if (f.phase === 'in') {
            // ── IN: stars grow from a point AND lines extend from them
            const elapsed = ts - f.inStart;
            const n       = _homeBgData.points.length;
            const nl      = _homeBgData.lines.length;
            const starAlphas      = new Array(n);
            const starFlashBoosts = new Array(n);
            const starScales      = new Array(n);
            const lineAlphas      = new Array(nl);
            const lineProgs       = new Array(nl);
            const lineAnchors     = new Array(nl);
            let allDone = true;
            for (let i = 0; i < n; i++) {
              const { delay: inDelay, dur: inDur, flashDur } = f.inStarData[i];
              const raw    = Math.min(1, Math.max(0, (elapsed - inDelay) / inDur));
              const smooth = raw * raw * (3 - 2 * raw);
              starAlphas[i] = smooth;
              starScales[i] = smooth;
              const fp = Math.max(0, Math.min(1, (elapsed - (inDelay + inDur)) / flashDur));
              if (fp > 0) starScales[i] = 1; // fully grown once flash starts
              starFlashBoosts[i] = Math.sin(fp * Math.PI) * 1.0;
              if (raw < 1 || fp < 1) allDone = false;
            }
            for (let li = 0; li < nl; li++) {
              const { anchor, lineDelay, lineDur } = f.inLineData[li];
              const t      = Math.min(1, Math.max(0, (elapsed - lineDelay) / lineDur));
              const smooth = t * t * (3 - 2 * t);
              lineAlphas[li]  = smooth;
              lineProgs[li]   = smooth; // extends from anchor star outward
              lineAnchors[li] = anchor;
              if (t < 1) allDone = false;
            }
            _homeDrawConstScene(ctx2, _homeBgData, _homeBgTwinkle,
                                _homeBgConstName, 1, pw, ph, ts,
                                starAlphas, starFlashBoosts, lineAlphas, lineProgs, starScales, lineAnchors);
            if (allDone) { _homeBgFade = null; _homeBgIdleTwinkle = null; }
          }

        } else {
          // ── Idle: victory-style star twinkle ─────────────────────────────
          if (!_homeBgIdleTwinkle || ts >= _homeBgIdleTwinkle.waitUntil) {
            _homePickTwinkle(ts);
          }
          _homeDrawConstScene(ctx2, _homeBgData, _homeBgTwinkle,
                              _homeBgConstName, 1, pw, ph, ts, null, null, null, null);
        }

        ctx2.restore();
        _homeBgRaf = requestAnimationFrame(loop);
      }
      _homeBgRaf = requestAnimationFrame(loop);
    }

