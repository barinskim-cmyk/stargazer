    // Generate deterministic "nebula address" for a constellation name
    function _constellationAddress(name) {
      const ADJ  = ['Тёмная','Северная','Малая','Дальняя','Тихая','Древняя','Туманная','Холодная','Тонкая','Звёздная'];
      const NOUN = ['Зари','Крыла','Тени','Пути','Звезды','Вуали','Кольца','Завесы','Дуги','Паутины'];
      const h    = k => _skyHash(name + k);
      const adj  = ADJ [Math.floor(h('_na') * ADJ.length)];
      const noun = NOUN[Math.floor(h('_nn') * NOUN.length)];
      const margin = 200;
      const wx   = margin + h('_x') * (_SKY_WORLD - 2 * margin);
      const wy   = margin + h('_y') * (_SKY_WORLD - 2 * margin);
      const coord = (wx * 33.33 + 10000).toFixed(0) + '.' + (wy * 33.33).toFixed(2).replace('.','');
      return `${t('nebula')} ${adj} ${noun}  ${coord}`;
    }

